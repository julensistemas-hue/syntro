---
// CiudadConsultoria — plantilla GENÉRICA de las páginas de consultoría IA por ciudad.
// Diseño moderno (glass + gradientes azul→morado) alineado con la home.
// Cada página pasa solo sus DATOS (nombre, meta, intro, sectores, FAQ).
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Sector { icon: string; nombre: string; uso: string; }
interface Props {
  nombre: string;          // "Valencia"
  slug: string;            // "consultoria-ia-valencia" (sin barra inicial)
  title: string;
  description: string;
  heroIntro: string;
  sectoresIntro: string;
  sectores: Sector[];
  faq: { q: string; a: string }[];
  ciudadSchema?: string;   // schema City (def. = nombre)
  regionSchema?: string;   // área administrativa (def. "Comunitat Valenciana")
}

const {
  nombre, slug, title, description, heroIntro, sectoresIntro, sectores, faq,
  ciudadSchema = Astro.props.nombre,
  regionSchema = "Comunitat Valenciana",
} = Astro.props;

const canonical = `https://aisecurity.es/${slug}`;
const planSlug = "Consultoria-IA-" + nombre.normalize("NFD").replace(/[̀-ͯ]/g, "");

// ─── GENÉRICO: catálogo completo de servicios de IA ───
const servicios = [
  { icon: "💬", c: "#60a5fa", t: "Chatbot IA",              d: "Atiende a tus clientes 24/7, conectado a tu ERP o CRM en tiempo real.",     href: "/servicios/chatbot" },
  { icon: "📞", c: "#38bdf8", t: "Atención de llamadas IA", d: "Recepcionista virtual con voz natural que filtra, informa y agenda.",        href: "/servicios/atencion-llamadas" },
  { icon: "📄", c: "#818cf8", t: "Gestor documental IA",    d: "Encuentra cualquier documento en segundos con búsqueda semántica.",         href: "/servicios/gestor-documental" },
  { icon: "📅", c: "#a78bfa", t: "Gestor de citas IA",      d: "Programa, confirma y recuerda citas automáticamente, sin solapamientos.",   href: "/servicios/gestor-citas" },
  { icon: "💡", c: "#60a5fa", t: "Consultoría IA",          d: "Analizamos tu empresa y diseñamos tu plan de IA a medida.",                 href: "/consultoria-ia" },
  { icon: "🌐", c: "#a78bfa", t: "Desarrollo web",          d: "Webs rápidas y modernas que convierten. Sin WordPress.",                   href: "/servicios/desarrollo-web" },
  { icon: "📈", c: "#c084fc", t: "Posicionamiento SEO y GEO", d: "Aparece en Google y en las IA cuando tus clientes te buscan.",            href: "/servicios/geo-posicionamiento" },
];

// ─── GENÉRICO: ¿te suena esto? ───
const dolores = [
  { icon: "⏳", texto: "Tu equipo pierde horas en tareas repetitivas: facturas, emails, informes, copiar datos." },
  { icon: "📞", texto: "Se escapan llamadas y oportunidades fuera de horario porque no hay quien las atienda." },
  { icon: "🔎", texto: "La información está dispersa y encontrar un documento concreto lleva demasiado tiempo." },
  { icon: "💬", texto: "Respondes las mismas preguntas una y otra vez por email, teléfono y WhatsApp." },
  { icon: "📉", texto: "Tu web no aparece en Google y apenas te llegan clientes nuevos por internet." },
  { icon: "🚀", texto: "Sabes que la IA puede ayudar, pero no sabes por dónde empezar — y tu competencia ya la usa." },
];

// ─── GENÉRICO: resultados ───
const resultados = [
  { c: "#60a5fa", num: "+15 h", label: "ahorradas / semana", sub: "automatizando tareas repetitivas" },
  { c: "#818cf8", num: "24/7",  label: "atención sin descanso", sub: "chatbot y llamadas con IA" },
  { c: "#a78bfa", num: "2-3 meses", label: "para ver el retorno", sub: "con resultados medibles" },
  { c: "#c084fc", num: "0 €",   label: "primera consulta", sub: "y sin permanencia" },
];

// ─── GENÉRICO: departamentos (diagrama interactivo) ───
const departamentos = [
  { id: "comunicacion", nombre: "Comunicación", icon: "🎨", color: "#84cc16",
    resumen: "Contenido visual, vídeos y creatividades con IA generativa",
    objetivos: [ { icono: "⏱️", texto: "Reduce un 70% el tiempo de producción de contenido visual" }, { icono: "📈", texto: "Multiplica por 10 el volumen de publicaciones" } ],
    herramientas: [ { nombre: "Midjourney", uso: "Imágenes y creatividades por prompt" }, { nombre: "HeyGen", uso: "Avatares de vídeo con voz natural" }, { nombre: "Canva AI", uso: "Diseño asistido y redimensionado" } ] },
  { id: "comercial", nombre: "Comercial & SEO", icon: "📊", color: "#f59e0b",
    resumen: "Analítica automática, SEO con IA y seguimiento de oportunidades",
    objetivos: [ { icono: "📬", texto: "Informes semanales automáticos a tu email" }, { icono: "🎯", texto: "Detecta oportunidades antes que la competencia" } ],
    herramientas: [ { nombre: "Claude + Excel/Word", uso: "Propuestas y análisis de ventas por chat" }, { nombre: "GSC + GA4 Automation", uso: "Análisis web semanal con IA" }, { nombre: "n8n + LLM", uso: "Seguimiento de leads y CRM" } ] },
  { id: "callcenter", nombre: "Call Center & Soporte", icon: "📞", color: "#10b981",
    resumen: "Atención telefónica y chat con IA que nunca descansa",
    objetivos: [ { icono: "🤖", texto: "Resuelve el 80% de consultas sin intervención" }, { icono: "🕐", texto: "Disponible 24/7 sin coste de personal" } ],
    herramientas: [ { nombre: "Atención Llamadas IA", uso: "Recepcionista virtual 24/7" }, { nombre: "Chatbot Empresarial IA", uso: "Acceso a tu base de datos y ERP" }, { nombre: "ElevenLabs", uso: "Voces IA ultra-realistas en español" } ] },
  { id: "proyectos", nombre: "Gestión de Proyectos", icon: "📋", color: "#3b82f6",
    resumen: "IA integrada en tu herramienta de proyectos para acelerar entregas",
    objetivos: [ { icono: "⚡", texto: "Reduce un 50% el tiempo de planificación" }, { icono: "🔍", texto: "Detecta bloqueos antes de que impacten" } ],
    herramientas: [ { nombre: "Jira + Atlassian Intelligence", uso: "Subtareas y resumen de issues" }, { nombre: "Notion AI", uso: "Documentación que se actualiza sola" }, { nombre: "n8n", uso: "Notificaciones y reportes automáticos" } ] },
  { id: "administracion", nombre: "Administración", icon: "🧾", color: "#ef4444",
    resumen: "Facturas, presupuestos y contabilidad de forma automática",
    objetivos: [ { icono: "🧾", texto: "Procesa facturas en segundos" }, { icono: "✅", texto: "Elimina errores de introducción manual" } ],
    herramientas: [ { nombre: "Claude + Excel/Word", uso: "Presupuestos y análisis por chat" }, { nombre: "Mindee", uso: "OCR que extrae datos de facturas" }, { nombre: "n8n + ChatGPT", uso: "Clasifica y registra facturas" } ] },
  { id: "desarrollo", nombre: "Desarrollo", icon: "💻", color: "#06b6d4",
    resumen: "Acelera tu equipo de desarrollo con IA en cada paso",
    objetivos: [ { icono: "🚀", texto: "Multiplica por 2-3x la velocidad de entrega" }, { icono: "🛡️", texto: "Reduce un 60% los bugs en producción" } ],
    herramientas: [ { nombre: "Claude Code", uso: "Agente que lee tu repo y ejecuta tareas" }, { nombre: "GitHub Copilot", uso: "Autocompletado en el IDE" }, { nombre: "GitHub Actions + IA", uso: "Tests y detección de bugs" } ] },
  { id: "devops", nombre: "DevOps", icon: "⚙️", color: "#f97316",
    resumen: "Infraestructura como código y despliegues automáticos con IA",
    objetivos: [ { icono: "📡", texto: "Resuelve incidencias hasta 3x más rápido" }, { icono: "🔄", texto: "Despliegues continuos sin downtime" } ],
    herramientas: [ { nombre: "Ansible + IA", uso: "Playbooks generados automáticamente" }, { nombre: "Kubernetes + K8sGPT", uso: "Diagnóstico automático de clústeres" }, { nombre: "Datadog AI", uso: "Detección de anomalías y alertas" } ] },
  { id: "sistemas", nombre: "Sistemas", icon: "🖥️", color: "#8b5cf6",
    resumen: "Administración de sistemas con documentación y seguridad IA",
    objetivos: [ { icono: "🛡️", texto: "Detección de amenazas con cumplimiento ENS" }, { icono: "📝", texto: "Cada cambio genera documentación automática" } ],
    herramientas: [ { nombre: "Wazuh", uso: "SIEM: amenazas y cumplimiento ENS" }, { nombre: "Ansible + LLM", uso: "Tareas de administración por lenguaje natural" }, { nombre: "Netdata", uso: "Monitorización en tiempo real con IA" } ] },
];

// ─── Schemas ───
const sectoresLista = sectores.map((s) => s.nombre.toLowerCase()).join(", ");
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": faq.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};
const localBusinessSchema = {
  "@context": "https://schema.org", "@type": "ProfessionalService",
  "name": `AI Security — Consultoría IA ${nombre}`,
  "description": `Consultoría de inteligencia artificial para empresas en ${nombre}. Automatización de procesos, chatbots, ciberseguridad y más. ${sectoresLista}.`,
  "url": canonical,
  "areaServed": [ { "@type": "City", "name": ciudadSchema }, { "@type": "AdministrativeArea", "name": regionSchema } ],
  "serviceType": "Consultoría de Inteligencia Artificial",
  "provider": { "@type": "Organization", "name": "AI Security", "url": "https://aisecurity.es" },
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://aisecurity.es/" },
    { "@type": "ListItem", "position": 2, "name": "Consultoría IA", "item": "https://aisecurity.es/consultoria-ia" },
    { "@type": "ListItem", "position": 3, "name": `Consultoría IA ${nombre}`, "item": canonical },
  ],
};

const provincias = [
  { nombre: "Valencia", slug: "consultoria-ia-valencia" },
  { nombre: "Alicante", slug: "consultoria-ia-alicante" },
  { nombre: "Castellón", slug: "consultoria-ia-castellon" },
].filter((p) => p.slug !== slug);
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <main class="cc">

    <!-- ═══ HERO ═══ -->
    <section class="cc-hero">
      <div class="cc-grid-bg"></div>
      <div class="cc-orb cc-orb-1"></div>
      <div class="cc-orb cc-orb-2"></div>
      <div class="cc-hero-inner">
        <span class="cc-badge"><span class="cc-dot"></span>Consultoría IA · {nombre}</span>

        <h1 class="cc-h1">
          Automatiza procesos con IA<br/>
          en tu empresa de <span class="cc-grad">{nombre}</span>
        </h1>

        <p class="cc-lead">{heroIntro}</p>

        <div class="cc-cta-row">
          <a href={`/presupuesto?plan=${planSlug}`} class="cc-btn-primary">Consulta gratuita en {nombre} →</a>
          <a href="#servicios" class="cc-btn-ghost">Ver servicios de IA →</a>
        </div>
      </div>
    </section>

    <!-- ═══ SERVICIOS (todos) ═══ -->
    <section id="servicios" class="cc-sec" style="background:#070b14;">
      <div class="cc-wrap">
        <div class="cc-head">
          <span class="cc-eyebrow">Servicios de IA</span>
          <h2 class="cc-h2">Todo lo que podemos <span class="cc-grad">automatizar con IA</span> en {nombre}</h2>
          <p class="cc-sub">Un solo equipo para toda tu tecnología. Elige por dónde empezar — o pídenos que lo analicemos por ti.</p>
        </div>
        <div class="cc-svc-grid">
          {servicios.map((s) => (
            <a href={s.href} class="cc-svc" style={`--c:${s.c};`}>
              <span class="cc-svc-ic">{s.icon}</span>
              <h3 class="cc-svc-t">{s.t}</h3>
              <p class="cc-svc-d">{s.d}</p>
              <span class="cc-svc-link">Ver más →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ DIAGRAMA INTERACTIVO ═══ -->
    <section class="cc-sec" style="background:#070b14;border-top:1px solid rgba(255,255,255,0.06);">
      <div class="cc-wrap-wide">
        <div class="cc-head">
          <span class="cc-eyebrow">Por departamento</span>
          <h2 class="cc-h2">¿Qué IA puede usar <span class="cc-grad">cada departamento</span>?</h2>
          <p class="cc-sub">Pulsa un departamento para ver las herramientas concretas y el ahorro estimado.</p>
        </div>
        <div class="cc-diagram">
          <div id="diagram-container">
            <svg id="diagram-svg" width="560" height="560" viewBox="0 0 560 560">
              <g id="lines"></g>
              <g id="center-node">
                <circle cx="280" cy="280" r="62" fill="#0d1424" stroke="#4f7cff" stroke-width="2"/>
                <circle cx="280" cy="280" r="56" fill="#0a0f1c" stroke="#4f7cff" stroke-width="1" opacity="0.5"/>
                <text x="280" y="272" text-anchor="middle" fill="#e2e8f0" font-size="14" font-weight="700">Tu</text>
                <text x="280" y="290" text-anchor="middle" fill="#e2e8f0" font-size="14" font-weight="700">Empresa</text>
                <text x="280" y="308" text-anchor="middle" fill="#7da4ff" font-size="10">+ IA</text>
              </g>
              <g id="nodes"></g>
            </svg>
          </div>
          <div id="info-panel">
            <div id="panel-default" class="cc-panel">
              <div style="font-size:46px;margin-bottom:14px;opacity:0.4;">👆</div>
              <p style="color:#7e93a8;font-size:1rem;">Selecciona un departamento del diagrama para ver las herramientas de IA recomendadas y el ahorro.</p>
            </div>
            <div id="panel-active" class="cc-panel" style="display:none;overflow:hidden;min-height:520px;padding:0;">
              <div id="panel-header" style="padding:20px 24px;display:flex;align-items:center;gap:12px;">
                <span id="panel-icon" style="font-size:28px;"></span>
                <div>
                  <h3 id="panel-title" style="font-size:1.2rem;font-weight:700;color:#e2e8f0;margin-bottom:4px;"></h3>
                  <p id="panel-resumen" style="font-size:0.85rem;color:#94a3b8;"></p>
                </div>
              </div>
              <div style="padding:0 24px 4px;">
                <p style="font-size:0.72rem;font-weight:700;color:#a78bfa;letter-spacing:0.08em;text-transform:uppercase;margin:16px 0 8px;">Qué gana tu empresa</p>
                <div id="panel-objetivos" style="display:flex;flex-direction:column;gap:6px;"></div>
              </div>
              <div style="padding:0 24px;">
                <p style="font-size:0.72rem;font-weight:700;color:#4f7cff;letter-spacing:0.08em;text-transform:uppercase;margin:14px 0 10px;">Herramientas que utilizamos</p>
                <div id="panel-tools" style="display:flex;flex-direction:column;gap:8px;"></div>
              </div>
              <div style="padding:16px 24px 24px;">
                <a href={`/presupuesto?plan=${planSlug}`} class="cc-btn-primary" style="display:block;text-align:center;">Quiero implementar esto →</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ ¿TE SUENA ESTO? ═══ -->
    <section class="cc-sec" style="background:#0a0f1c;border-top:1px solid rgba(255,255,255,0.06);">
      <div class="cc-wrap">
        <div class="cc-head">
          <span class="cc-eyebrow">A quién ayudamos</span>
          <h2 class="cc-h2">¿Te suena esto en tu empresa de {nombre}?</h2>
          <p class="cc-sub">Si te identificas con alguno de estos puntos, la IA puede ayudarte. Empieza con una conversación, sin compromiso.</p>
        </div>
        <div class="cc-pain-grid">
          {dolores.map((d) => (
            <div class="cc-pain">
              <span class="cc-pain-ic">{d.icon}</span>
              <p>{d.texto}</p>
            </div>
          ))}
        </div>
        <div class="cc-center"><a href={`/presupuesto?plan=${planSlug}`} class="cc-btn-primary">Cuéntanos tu caso — gratis →</a></div>
      </div>
    </section>

    <!-- ═══ RESULTADOS ═══ -->
    <section class="cc-sec" style="background:#0a0f1c;border-top:1px solid rgba(255,255,255,0.06);">
      <div class="cc-wrap">
        <div class="cc-head">
          <span class="cc-eyebrow">Resultados reales</span>
          <h2 class="cc-h2">Lo que gana tu empresa al automatizar</h2>
          <p class="cc-sub">No vendemos tecnología por tecnología. Vendemos tiempo recuperado y procesos que funcionan solos.</p>
        </div>
        <div class="cc-metrics">
          {resultados.map((r) => (
            <div class="cc-metric" style={`--c:${r.c};`}>
              <div class="cc-metric-num">{r.num}</div>
              <div class="cc-metric-l">{r.label}</div>
              <div class="cc-metric-s">{r.sub}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ FAQ ═══ -->
    <section class="cc-sec" style="background:#0a0f1c;border-top:1px solid rgba(255,255,255,0.06);">
      <div class="cc-wrap-sm">
        <div class="cc-head">
          <span class="cc-eyebrow">Dudas</span>
          <h2 class="cc-h2">Preguntas frecuentes</h2>
        </div>
        <div class="cc-faq">
          {faq.map((item) => (
            <details class="cc-faq-item">
              <summary>{item.q}<span class="cc-faq-plus">+</span></summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
        {provincias.length > 0 && (
          <div class="cc-center" style="margin-top:40px;">
            <p style="color:#64748b;font-size:0.85rem;margin-bottom:12px;">También en otras provincias de la Comunitat Valenciana:</p>
            <div class="cc-chips" style="justify-content:center;">
              {provincias.map((p) => (<a href={`/${p.slug}`} class="cc-chip cc-chip-link">{p.nombre} →</a>))}
              <a href="/consultoria-ia" class="cc-chip cc-chip-link">Todos los servicios IA →</a>
            </div>
          </div>
        )}
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .cc { background:#070b14; color:#e2e8f0; }
  .cc-wrap { max-width:1080px; margin:0 auto; padding:0 24px; }
  .cc-wrap-wide { max-width:1200px; margin:0 auto; padding:0 24px; }
  .cc-wrap-sm { max-width:760px; margin:0 auto; padding:0 24px; }
  .cc-sec { padding:80px 0; }
  .cc-center { text-align:center; }
  .cc-grad { background:linear-gradient(90deg,#60a5fa,#a78bfa,#c084fc); -webkit-background-clip:text; background-clip:text; color:transparent; }

  /* HERO */
  .cc-hero { position:relative; overflow:hidden; padding:96px 0 80px; background:linear-gradient(160deg,#070b14 0%,#0c1226 55%,#070b14 100%); }
  .cc-grid-bg { position:absolute; inset:0; background-image:linear-gradient(rgba(99,102,241,0.07) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,0.07) 1px,transparent 1px); background-size:46px 46px; opacity:0.6; -webkit-mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,#000,transparent 80%); mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,#000,transparent 80%); }
  .cc-orb { position:absolute; border-radius:50%; filter:blur(70px); pointer-events:none; }
  .cc-orb-1 { width:380px; height:380px; background:rgba(79,124,255,0.22); top:-80px; left:-60px; animation:ccFloat 14s ease-in-out infinite; }
  .cc-orb-2 { width:420px; height:420px; background:rgba(167,139,250,0.18); bottom:-120px; right:-80px; animation:ccFloat 18s ease-in-out infinite reverse; }
  .cc-orb-3 { width:500px; height:500px; background:rgba(99,102,241,0.25); top:50%; left:50%; transform:translate(-50%,-50%); }
  @keyframes ccFloat { 0%,100%{ transform:translate(0,0); } 50%{ transform:translate(30px,-24px); } }
  .cc-hero-inner { position:relative; z-index:2; max-width:880px; margin:0 auto; padding:0 24px; text-align:center; }
  /* Animación de entrada escalonada del hero */
  @keyframes ccUp { from { opacity:0; transform:translateY(18px); } to { opacity:1; transform:translateY(0); } }
  .cc-hero-inner > * { animation:ccUp .65s cubic-bezier(0.22,1,0.36,1) both; }
  .cc-hero-inner > *:nth-child(1){ animation-delay:.05s; }
  .cc-hero-inner > *:nth-child(2){ animation-delay:.15s; }
  .cc-hero-inner > *:nth-child(3){ animation-delay:.25s; }
  .cc-hero-inner > *:nth-child(4){ animation-delay:.35s; }
  .cc-hero-inner > *:nth-child(5){ animation-delay:.45s; }
  @media (prefers-reduced-motion: reduce){ .cc-hero-inner > *{ animation:none; } }
  .cc-badge { display:inline-flex; align-items:center; gap:8px; padding:7px 16px; border-radius:9999px; font-size:0.8rem; font-weight:600; color:#a5b4fc; background:rgba(79,124,255,0.1); border:1px solid rgba(124,140,248,0.3); margin-bottom:24px; }
  .cc-dot { width:7px; height:7px; border-radius:50%; background:#818cf8; box-shadow:0 0 8px #818cf8; }
  .cc-h1 { font-size:clamp(2.1rem,5.5vw,3.7rem); font-weight:900; line-height:1.08; color:#f0f6ff; letter-spacing:-0.02em; margin-bottom:20px; }
  .cc-lead { font-size:clamp(1rem,2.2vw,1.2rem); line-height:1.65; color:rgba(240,246,255,0.66); max-width:42rem; margin:0 auto 28px; }
  .cc-cta-row { display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
  .cc-trust { margin-top:18px; font-size:0.8rem; color:#64748b; text-align:center; }

  /* Botones */
  .cc-btn-primary { display:inline-flex; align-items:center; gap:8px; padding:14px 28px; border-radius:12px; font-weight:700; font-size:0.95rem; text-decoration:none; color:#fff; background:linear-gradient(135deg,#2563eb 0%,#7c3aed 100%); box-shadow:0 12px 34px -10px rgba(99,102,241,0.7); transition:transform .2s ease,box-shadow .2s ease; }
  .cc-btn-primary:hover { transform:translateY(-2px); box-shadow:0 18px 46px -10px rgba(124,58,237,0.85); }
  .cc-btn-lg { padding:17px 36px; font-size:1.05rem; }
  .cc-btn-ghost { display:inline-flex; align-items:center; gap:8px; padding:14px 26px; border-radius:12px; font-weight:600; font-size:0.95rem; text-decoration:none; color:#cbd5e1; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.16); transition:all .2s ease; }
  .cc-btn-ghost:hover { color:#fff; border-color:rgba(255,255,255,0.32); background:rgba(255,255,255,0.1); transform:translateY(-2px); }

  /* Cabeceras de sección */
  .cc-head { text-align:center; max-width:620px; margin:0 auto 44px; }
  .cc-eyebrow { display:inline-block; font-size:0.72rem; font-weight:800; letter-spacing:0.16em; text-transform:uppercase; color:#7da4ff; margin-bottom:12px; }
  .cc-h2 { font-size:clamp(1.7rem,3.8vw,2.5rem); font-weight:800; line-height:1.15; color:#f0f6ff; letter-spacing:-0.01em; }
  .cc-sub { color:rgba(240,246,255,0.6); font-size:1.02rem; line-height:1.6; margin-top:12px; }

  /* Servicios grid */
  .cc-svc-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:16px; }
  .cc-svc { position:relative; display:flex; flex-direction:column; padding:22px; border-radius:16px; background:rgba(255,255,255,0.035); border:1px solid rgba(255,255,255,0.08); text-decoration:none; overflow:hidden; transition:transform .22s ease,border-color .22s ease,box-shadow .22s ease,background .22s ease; }
  .cc-svc::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,var(--c),transparent 85%); }
  .cc-svc:hover { transform:translateY(-6px); border-color:var(--c); background:rgba(255,255,255,0.05); box-shadow:0 18px 44px -18px var(--c); }
  .cc-svc-ic { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.55rem; margin-bottom:14px; background:color-mix(in srgb,var(--c) 14%,transparent); border:1px solid color-mix(in srgb,var(--c) 30%,transparent); transition:transform .22s ease; }
  .cc-svc:hover .cc-svc-ic { transform:scale(1.08) rotate(-5deg); }
  .cc-svc-t { font-size:1.02rem; font-weight:700; color:#f0f6ff; margin-bottom:6px; }
  .cc-svc-d { font-size:0.85rem; line-height:1.5; color:rgba(240,246,255,0.6); flex:1; margin-bottom:12px; }
  .cc-svc-link { font-size:0.82rem; font-weight:700; color:var(--c); }

  /* Pain */
  .cc-pain-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:16px; margin-bottom:36px; }
  .cc-pain { display:flex; align-items:flex-start; gap:14px; padding:20px; border-radius:14px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); }
  .cc-pain-ic { font-size:26px; line-height:1; flex-shrink:0; }
  .cc-pain p { color:#cbd5e1; font-size:0.92rem; line-height:1.6; margin:0; }

  /* Diagrama */
  .cc-diagram { display:flex; flex-direction:column; gap:24px; align-items:center; justify-content:center; }
  #diagram-svg { display:block; max-width:100%; height:auto; }
  #info-panel { width:100%; max-width:480px; }
  .cc-panel { background:rgba(255,255,255,0.035); border:1px solid rgba(255,255,255,0.1); border-radius:18px; padding:32px; text-align:center; }
  #node-svg g { transition:transform .15s ease; }
  @media (min-width:1024px) { .cc-diagram { flex-direction:row; align-items:flex-start; gap:40px; } #info-panel { position:sticky; top:24px; } }

  /* Métricas */
  .cc-metrics { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
  @media (min-width:900px) { .cc-metrics { grid-template-columns:repeat(4,1fr); } }
  .cc-metric { text-align:center; padding:26px 18px; border-radius:16px; background:rgba(255,255,255,0.035); border:1px solid rgba(255,255,255,0.08); border-top:3px solid var(--c); }
  .cc-metric-num { font-size:2rem; font-weight:900; line-height:1; color:var(--c); margin-bottom:8px; text-shadow:0 0 26px color-mix(in srgb,var(--c) 45%,transparent); }
  .cc-metric-l { font-size:0.92rem; font-weight:700; color:#e2e8f0; margin-bottom:4px; }
  .cc-metric-s { font-size:0.78rem; color:#64748b; line-height:1.4; }

  /* Chips */
  .cc-chips { display:flex; flex-wrap:wrap; gap:10px; justify-content:center; max-width:840px; margin:0 auto; }
  .cc-chip { display:inline-flex; align-items:center; gap:8px; padding:9px 16px; border-radius:9999px; font-size:0.9rem; font-weight:500; color:#cbd5e1; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); }
  .cc-chip-link { text-decoration:none; color:#a5b4fc; transition:all .2s ease; }
  .cc-chip-link:hover { border-color:#818cf8; background:rgba(129,140,248,0.12); }

  /* FAQ */
  .cc-faq { display:flex; flex-direction:column; gap:12px; }
  .cc-faq-item { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:12px; overflow:hidden; }
  .cc-faq-item summary { display:flex; align-items:center; justify-content:space-between; gap:12px; cursor:pointer; list-style:none; padding:18px 22px; font-size:0.98rem; font-weight:600; color:#e2e8f0; }
  .cc-faq-item summary::-webkit-details-marker { display:none; }
  .cc-faq-plus { font-size:1.4rem; font-weight:400; color:#7da4ff; transition:transform .2s ease; flex-shrink:0; }
  .cc-faq-item[open] .cc-faq-plus { transform:rotate(45deg); }
  .cc-faq-item p { padding:0 22px 20px; margin:0; color:#94a3b8; font-size:0.9rem; line-height:1.7; }

  /* CTA final */
  .cc-cta-final { position:relative; overflow:hidden; padding:90px 0; background:linear-gradient(135deg,#0c1226,#160a2e); border-top:1px solid rgba(255,255,255,0.06); }
  .cc-cta-final .cc-orb-3 { filter:blur(90px); opacity:0.5; }

  @media (max-width:640px){ .cc-sec{ padding:60px 0; } .cc-hero{ padding:72px 0 60px; } }
</style>

<script define:vars={{ departamentos }} is:inline>
  const SVG_SIZE = 560, CENTER = 280, ORBIT_RADIUS = 200, NODE_RADIUS = 46;
  const linesGroup = document.getElementById('lines');
  const nodesGroup = document.getElementById('nodes');
  const panelDefault = document.getElementById('panel-default');
  const panelActive = document.getElementById('panel-active');
  const panelHeader = document.getElementById('panel-header');
  const panelIcon = document.getElementById('panel-icon');
  const panelTitle = document.getElementById('panel-title');
  const panelResumen = document.getElementById('panel-resumen');
  const panelTools = document.getElementById('panel-tools');
  let activeId = null;
  if (!nodesGroup) { /* no diagram on page */ } else {

  function getPos(index, total) {
    const angle = (index / total) * 2 * Math.PI - Math.PI / 2;
    return { x: CENTER + ORBIT_RADIUS * Math.cos(angle), y: CENTER + ORBIT_RADIUS * Math.sin(angle) };
  }

  departamentos.forEach((dep, i) => {
    const pos = getPos(i, departamentos.length);
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', CENTER); line.setAttribute('y1', CENTER);
    line.setAttribute('x2', pos.x); line.setAttribute('y2', pos.y);
    line.setAttribute('stroke', dep.color); line.setAttribute('stroke-width', '1.5');
    line.setAttribute('opacity', '0.3'); line.id = `line-${dep.id}`;
    linesGroup.appendChild(line);
  });

  departamentos.forEach((dep, i) => {
    const pos = getPos(i, departamentos.length);
    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('cursor', 'pointer'); g.id = `node-${dep.id}`;
    const bg = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    bg.setAttribute('cx', pos.x); bg.setAttribute('cy', pos.y); bg.setAttribute('r', NODE_RADIUS);
    bg.setAttribute('fill', '#0d1424'); bg.setAttribute('stroke', dep.color);
    bg.setAttribute('stroke-width', '1.5'); bg.setAttribute('opacity', '0.85'); bg.id = `bg-${dep.id}`;
    const icon = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    icon.setAttribute('x', pos.x); icon.setAttribute('y', pos.y - 8);
    icon.setAttribute('text-anchor', 'middle'); icon.setAttribute('dominant-baseline', 'middle');
    icon.setAttribute('font-size', '20'); icon.textContent = dep.icon;
    g.appendChild(bg); g.appendChild(icon);
    const words = dep.nombre.split(' & ');
    if (words.length > 1) {
      const t1 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t1.setAttribute('x', pos.x); t1.setAttribute('y', pos.y + 10); t1.setAttribute('text-anchor', 'middle'); t1.setAttribute('fill', '#cbd5e1'); t1.setAttribute('font-size', '9'); t1.setAttribute('font-weight', '600'); t1.textContent = words[0];
      const t2 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t2.setAttribute('x', pos.x); t2.setAttribute('y', pos.y + 22); t2.setAttribute('text-anchor', 'middle'); t2.setAttribute('fill', '#7da4ff'); t2.setAttribute('font-size', '8'); t2.setAttribute('font-weight', '600'); t2.textContent = '& ' + words[1];
      g.appendChild(t1); g.appendChild(t2);
    } else {
      const nameWords = dep.nombre.split(' ');
      if (nameWords.length > 2) {
        const t1 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        t1.setAttribute('x', pos.x); t1.setAttribute('y', pos.y + 10); t1.setAttribute('text-anchor', 'middle'); t1.setAttribute('fill', '#cbd5e1'); t1.setAttribute('font-size', '9'); t1.setAttribute('font-weight', '600'); t1.textContent = nameWords.slice(0, 2).join(' ');
        const t2 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        t2.setAttribute('x', pos.x); t2.setAttribute('y', pos.y + 22); t2.setAttribute('text-anchor', 'middle'); t2.setAttribute('fill', '#cbd5e1'); t2.setAttribute('font-size', '9'); t2.setAttribute('font-weight', '600'); t2.textContent = nameWords.slice(2).join(' ');
        g.appendChild(t1); g.appendChild(t2);
      } else {
        const name = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        name.setAttribute('x', pos.x); name.setAttribute('y', pos.y + 16); name.setAttribute('text-anchor', 'middle'); name.setAttribute('fill', '#cbd5e1'); name.setAttribute('font-size', '9.5'); name.setAttribute('font-weight', '600'); name.textContent = dep.nombre;
        g.appendChild(name);
      }
    }
    g.addEventListener('click', () => selectDep(dep.id));
    g.addEventListener('mouseenter', () => { if (activeId !== dep.id) { bg.setAttribute('opacity', '1'); bg.setAttribute('stroke-width', '2'); } });
    g.addEventListener('mouseleave', () => { if (activeId !== dep.id) { bg.setAttribute('opacity', '0.85'); bg.setAttribute('stroke-width', '1.5'); } });
    nodesGroup.appendChild(g);
  });

  function selectDep(id) {
    activeId = id;
    const dep = departamentos.find(d => d.id === id);
    if (!dep) return;
    departamentos.forEach(d => {
      const bg = document.getElementById(`bg-${d.id}`); const line = document.getElementById(`line-${d.id}`);
      if (bg) { bg.setAttribute('opacity', '0.85'); bg.setAttribute('stroke-width', '1.5'); bg.setAttribute('fill', '#0d1424'); }
      if (line) { line.setAttribute('opacity', '0.3'); line.setAttribute('stroke-width', '1.5'); }
    });
    const activeBg = document.getElementById(`bg-${id}`); const activeLine = document.getElementById(`line-${id}`);
    if (activeBg) { activeBg.setAttribute('opacity', '1'); activeBg.setAttribute('stroke-width', '3'); activeBg.setAttribute('fill', dep.color + '22'); }
    if (activeLine) { activeLine.setAttribute('opacity', '0.85'); activeLine.setAttribute('stroke-width', '2.5'); }
    panelDefault.style.display = 'none';
    panelActive.style.display = 'block';
    panelActive.style.border = `1px solid ${dep.color}40`;
    panelHeader.style.background = `${dep.color}18`;
    panelHeader.style.borderBottom = `1px solid ${dep.color}30`;
    panelIcon.textContent = dep.icon;
    panelTitle.textContent = dep.nombre; panelTitle.style.color = dep.color;
    panelResumen.textContent = dep.resumen;
    const panelObjetivos = document.getElementById('panel-objetivos');
    if (panelObjetivos) {
      panelObjetivos.innerHTML = dep.objetivos.map(o => `
        <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:${dep.color}12;border:1px solid ${dep.color}28;border-radius:8px;">
          <span style="font-size:15px;flex-shrink:0;">${o.icono}</span>
          <span style="font-size:0.82rem;font-weight:600;color:#e2e8f0;line-height:1.4;">${o.texto}</span>
        </div>`).join('');
    }
    panelTools.innerHTML = '';
    dep.herramientas.forEach(h => {
      const item = document.createElement('div');
      item.style.cssText = `background:rgba(255,255,255,0.04);border-radius:8px;padding:10px 12px;border-left:3px solid ${dep.color};`;
      item.innerHTML = `<div style="font-size:0.85rem;font-weight:600;color:#e2e8f0;margin-bottom:2px;">${h.nombre}</div><div style="font-size:0.78rem;color:#64748b;">${h.uso}</div>`;
      panelTools.appendChild(item);
    });
  }

  document.addEventListener('DOMContentLoaded', () => selectDep('desarrollo'));
  if (document.readyState === 'complete' || document.readyState === 'interactive') { selectDep('desarrollo'); }
  }
</script>
