---
// Meeting request component (English) — dark theme (mismo estilo que /wazuh)
---

<section class="relative min-h-screen py-20 pb-24 overflow-hidden" style="background:#020817;">
  <!-- Grid de fondo -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(59,130,246,0.12) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,0.12) 1px,transparent 1px);background-size:40px 40px;opacity:0.6;"></div>
  <!-- Gradiente radial -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 60% at 50% 20%,rgba(37,99,235,0.15) 0%,transparent 65%);"></div>

  <div class="relative max-w-6xl mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold mb-6 border" style="background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.28);color:#60a5fa;">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Free consultation · No commitment
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight" style="color:#f0f6ff;">
        Book your meeting
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color:rgba(240,246,255,0.65);">
        We analyze your case, assess feasibility and propose tailored AI or cybersecurity solutions. 1 hour, free of charge.
      </p>
    </div>

    <!-- Alert Container -->
    <div id="alert-container" class="max-w-5xl mx-auto mb-6 hidden"></div>

    <!-- Grid principal -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- ═══ Calendario ═══ -->
      <div class="rounded-2xl overflow-hidden" style="background:rgba(255,255,255,0.03);border:1px solid rgba(59,130,246,0.2);backdrop-filter:blur(12px);">
        <!-- Header card -->
        <div class="px-6 py-4 flex items-center gap-3" style="background:rgba(37,99,235,0.15);border-bottom:1px solid rgba(59,130,246,0.2);">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(59,130,246,0.2);">
            <svg class="w-4 h-4" fill="none" stroke="#60a5fa" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-bold" style="color:#f0f6ff;">Select date and time</h3>
            <p class="text-xs" style="color:rgba(240,246,255,0.5);">Meetings last 1 hour</p>
          </div>
        </div>

        <div class="p-6">
          <!-- Calendar Header -->
          <div class="flex items-center justify-between mb-6">
            <button id="prev-month" class="p-2 rounded-lg transition-colors" style="color:rgba(240,246,255,0.6);" onmouseover="this.style.background='rgba(59,130,246,0.1)'" onmouseout="this.style.background='transparent'">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            <h4 id="calendar-month" class="text-base font-bold" style="color:#f0f6ff;">Loading...</h4>
            <button id="next-month" class="p-2 rounded-lg transition-colors" style="color:rgba(240,246,255,0.6);" onmouseover="this.style.background='rgba(59,130,246,0.1)'" onmouseout="this.style.background='transparent'">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>

          <!-- Day Headers -->
          <div class="grid grid-cols-7 gap-1 mb-3">
            {['M','T','W','T','F','S','S'].map(d => (
              <div class="text-center text-xs font-semibold" style="color:rgba(96,165,250,0.7);">{d}</div>
            ))}
          </div>

          <!-- Calendar Grid -->
          <div class="grid grid-cols-7 gap-1 mb-6" id="calendar-grid"></div>

          <!-- Time Slots -->
          <div class="pt-5" style="border-top:1px solid rgba(59,130,246,0.15);">
            <h5 class="text-xs font-bold uppercase tracking-wider mb-3" style="color:#60a5fa;">Available time slots</h5>

            <div id="time-slots-loading" class="text-center py-6">
              <p class="text-sm" style="color:rgba(240,246,255,0.4);">Select a day to see available times</p>
            </div>

            <div id="time-slots-container" class="hidden">
              <div id="time-slots-spinner" class="text-center py-4">
                <div class="inline-flex items-center gap-2" style="color:#60a5fa;">
                  <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  <span class="text-sm">Checking availability...</span>
                </div>
              </div>
              <div id="time-slots-grid" class="hidden grid grid-cols-2 gap-2"></div>
              <div id="time-slots-error" class="hidden text-sm rounded-lg p-3" style="color:#fca5a5;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);">
                No time slots available for this day
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ Formulario ═══ -->
      <div class="rounded-2xl overflow-hidden" style="background:rgba(255,255,255,0.03);border:1px solid rgba(59,130,246,0.2);backdrop-filter:blur(12px);">
        <!-- Header card -->
        <div class="px-6 py-4 flex items-center gap-3" style="background:rgba(129,140,248,0.12);border-bottom:1px solid rgba(129,140,248,0.2);">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(129,140,248,0.2);">
            <svg class="w-4 h-4" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-bold" style="color:#f0f6ff;">Your details</h3>
            <p class="text-xs" style="color:rgba(240,246,255,0.5);">Fill in the information to confirm</p>
          </div>
        </div>

        <div class="p-6">
          <!-- Selected slot indicator -->
          <div id="selected-slot-indicator" class="hidden mb-5 p-3 rounded-lg flex items-center gap-2" style="background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.2);">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#4ade80" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
            <span id="selected-slot-text" class="text-sm font-medium" style="color:#4ade80;"></span>
          </div>

          <form id="meeting-form" class="space-y-4" method="POST">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color:rgba(240,246,255,0.5);">Full name *</label>
              <input type="text" name="nombre" required
                class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none transition-all"
                style="background:rgba(255,255,255,0.05);border:1px solid rgba(59,130,246,0.2);color:#f0f6ff;"
                placeholder="e.g. John Smith"
                onfocus="this.style.borderColor='rgba(59,130,246,0.6)';this.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)'"
                onblur="this.style.borderColor='rgba(59,130,246,0.2)';this.style.boxShadow='none'"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color:rgba(240,246,255,0.5);">Email *</label>
              <input type="email" name="email" required
                class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none transition-all"
                style="background:rgba(255,255,255,0.05);border:1px solid rgba(59,130,246,0.2);color:#f0f6ff;"
                placeholder="you@company.com"
                onfocus="this.style.borderColor='rgba(59,130,246,0.6)';this.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)'"
                onblur="this.style.borderColor='rgba(59,130,246,0.2)';this.style.boxShadow='none'"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color:rgba(240,246,255,0.5);">Phone *</label>
              <input type="tel" name="telefono" required
                class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none transition-all"
                style="background:rgba(255,255,255,0.05);border:1px solid rgba(59,130,246,0.2);color:#f0f6ff;"
                placeholder="+1 555 000 0000"
                onfocus="this.style.borderColor='rgba(59,130,246,0.6)';this.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)'"
                onblur="this.style.borderColor='rgba(59,130,246,0.2)';this.style.boxShadow='none'"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color:rgba(240,246,255,0.5);">What do you need? *</label>
              <textarea name="mensaje" rows="4" required
                class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none transition-all resize-none"
                style="background:rgba(255,255,255,0.05);border:1px solid rgba(59,130,246,0.2);color:#f0f6ff;"
                placeholder="e.g. I need to implement a chatbot for my online store..."
                onfocus="this.style.borderColor='rgba(59,130,246,0.6)';this.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)'"
                onblur="this.style.borderColor='rgba(59,130,246,0.2)';this.style.boxShadow='none'"
              ></textarea>
            </div>

            <input type="hidden" name="selectedDate" id="selectedDateInput" value="" />
            <input type="hidden" name="selectedTime" id="selectedTimeInput" value="" />

            <button type="submit" id="submit-button"
              class="w-full px-6 py-4 rounded-xl font-bold text-sm transition-all"
              style="background:linear-gradient(135deg,#2563eb,#1d4ed8);color:white;box-shadow:0 6px 20px rgba(37,99,235,0.4);"
              onmouseover="this.style.opacity='0.92';this.style.transform='translateY(-1px)'"
              onmouseout="this.style.opacity='1';this.style.transform='translateY(0)'">
              <span id="button-text">Confirm meeting</span>
              <span id="button-loading" class="hidden">Booking...</span>
            </button>

            <p class="text-xs text-center" style="color:rgba(240,246,255,0.3);">
              By submitting, you authorize us to contact you about our services.
            </p>
          </form>

          <!-- Success message -->
          <div id="booking-success" class="hidden space-y-4">
            <div class="rounded-2xl p-6 text-center" style="background:linear-gradient(135deg,rgba(34,197,94,0.15),rgba(16,185,129,0.1));border:1px solid rgba(74,222,128,0.3);">
              <div class="text-5xl mb-3">✅</div>
              <h4 class="text-xl font-bold mb-2" style="color:#f0f6ff;">Meeting confirmed!</h4>
              <p id="confirmed-date-time" class="text-sm font-medium" style="color:#4ade80;"></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Info cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
      <div class="rounded-xl p-5 flex items-center gap-4" style="background:rgba(255,255,255,0.03);border:1px solid rgba(59,130,246,0.15);">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:rgba(74,222,128,0.12);border:1px solid rgba(74,222,128,0.22);">
          <svg class="w-5 h-5" fill="none" stroke="#4ade80" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold" style="color:#f0f6ff;">Instant confirmation</p>
          <p class="text-xs" style="color:rgba(240,246,255,0.5);">Email + calendar invite</p>
        </div>
      </div>

      <div class="rounded-xl p-5 flex items-center gap-4" style="background:rgba(255,255,255,0.03);border:1px solid rgba(59,130,246,0.15);">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:rgba(59,130,246,0.12);border:1px solid rgba(59,130,246,0.22);">
          <svg class="w-5 h-5" fill="none" stroke="#60a5fa" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold" style="color:#f0f6ff;">Online meeting</p>
          <p class="text-xs" style="color:rgba(240,246,255,0.5);">Video call from wherever you are</p>
        </div>
      </div>

      <div class="rounded-xl p-5 flex items-center gap-4" style="background:rgba(255,255,255,0.03);border:1px solid rgba(59,130,246,0.15);">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:rgba(129,140,248,0.12);border:1px solid rgba(129,140,248,0.22);">
          <svg class="w-5 h-5" fill="none" stroke="#a5b4fc" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold" style="color:#f0f6ff;">1-hour consultation</p>
          <p class="text-xs" style="color:rgba(240,246,255,0.5);">Detailed analysis of your project</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Placeholder color en inputs oscuros */
  input::placeholder, textarea::placeholder {
    color: rgba(240,246,255,0.25);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const calendarGrid = document.getElementById('calendar-grid') as HTMLDivElement;
    const calendarMonth = document.getElementById('calendar-month') as HTMLHeadingElement;
    const prevMonthBtn = document.getElementById('prev-month') as HTMLButtonElement;
    const nextMonthBtn = document.getElementById('next-month') as HTMLButtonElement;

    const timeSlotsLoading = document.getElementById('time-slots-loading') as HTMLDivElement;
    const timeSlotsContainer = document.getElementById('time-slots-container') as HTMLDivElement;
    const timeSlotsSpinner = document.getElementById('time-slots-spinner') as HTMLDivElement;
    const timeSlotsGrid = document.getElementById('time-slots-grid') as HTMLDivElement;
    const timeSlotsError = document.getElementById('time-slots-error') as HTMLDivElement;

    const selectedSlotIndicator = document.getElementById('selected-slot-indicator') as HTMLDivElement;
    const selectedSlotText = document.getElementById('selected-slot-text') as HTMLSpanElement;
    const selectedDateInput = document.getElementById('selectedDateInput') as HTMLInputElement;
    const selectedTimeInput = document.getElementById('selectedTimeInput') as HTMLInputElement;

    const meetingForm = document.getElementById('meeting-form') as HTMLFormElement;
    const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
    const buttonText = document.getElementById('button-text') as HTMLSpanElement;
    const buttonLoading = document.getElementById('button-loading') as HTMLSpanElement;
    const bookingSuccess = document.getElementById('booking-success') as HTMLDivElement;
    const alertContainer = document.getElementById('alert-container') as HTMLDivElement;
    const confirmedDateTime = document.getElementById('confirmed-date-time') as HTMLParagraphElement;

    let currentMonth = new Date().getMonth();
    let currentYear = new Date().getFullYear();
    let selectedDate: Date | null = null;
    let selectedTime: string | null = null;

    const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                        'July', 'August', 'September', 'October', 'November', 'December'];

    function generateCalendar() {
      calendarGrid.innerHTML = '';
      calendarMonth.textContent = `${monthNames[currentMonth]} ${currentYear}`;

      const firstDay = new Date(currentYear, currentMonth, 1).getDay();
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      // No se permite reservar el mismo día: el mínimo es mañana
      const minDate = new Date(today);
      minDate.setDate(minDate.getDate() + 1);

      const offset = firstDay === 0 ? 6 : firstDay - 1;
      for (let i = 0; i < offset; i++) {
        calendarGrid.appendChild(document.createElement('div'));
      }

      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(currentYear, currentMonth, day);
        date.setHours(0, 0, 0, 0);

        const dayButton = document.createElement('button');
        dayButton.type = 'button';
        dayButton.textContent = day.toString();

        const isPast = date < minDate; // hoy y días anteriores quedan deshabilitados
        const isToday = date.getTime() === today.getTime();
        const isSelected = selectedDate && date.getTime() === selectedDate.getTime();

        dayButton.style.cssText = `
          aspect-ratio:1;padding:6px 2px;border-radius:8px;font-size:0.8rem;
          font-weight:600;transition:all 0.15s;width:100%;
        `;

        if (isPast) {
          dayButton.style.color = 'rgba(240,246,255,0.2)';
          dayButton.style.cursor = 'not-allowed';
          dayButton.disabled = true;
        } else if (isSelected) {
          dayButton.style.background = '#2563eb';
          dayButton.style.color = 'white';
          dayButton.style.boxShadow = '0 0 12px rgba(37,99,235,0.5)';
        } else if (isToday) {
          dayButton.style.background = 'rgba(59,130,246,0.18)';
          dayButton.style.color = '#60a5fa';
          dayButton.style.border = '1px solid rgba(59,130,246,0.4)';
        } else {
          dayButton.style.color = 'rgba(240,246,255,0.75)';
          dayButton.addEventListener('mouseover', () => {
            dayButton.style.background = 'rgba(59,130,246,0.1)';
            dayButton.style.color = '#93c5fd';
          });
          dayButton.addEventListener('mouseout', () => {
            if (!isSelected) {
              dayButton.style.background = 'transparent';
              dayButton.style.color = 'rgba(240,246,255,0.75)';
            }
          });
        }

        if (!isPast) {
          dayButton.addEventListener('click', () => selectDay(date));
        }

        calendarGrid.appendChild(dayButton);
      }
    }

    async function selectDay(date: Date) {
      selectedDate = date;
      selectedTime = null;
      selectedTimeInput.value = '';
      selectedDateInput.value = date.toISOString().split('T')[0];

      generateCalendar();

      timeSlotsLoading.classList.add('hidden');
      timeSlotsContainer.classList.remove('hidden');
      timeSlotsSpinner.classList.remove('hidden');
      timeSlotsGrid.classList.add('hidden');
      timeSlotsError.classList.add('hidden');
      selectedSlotIndicator.classList.add('hidden');

      try {
        const response = await fetch('/api/check-availability', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ date: date.toISOString().split('T')[0] }),
        });

        const data = await response.json();
        timeSlotsSpinner.classList.add('hidden');

        if (!response.ok || data.availableSlots.length === 0) {
          timeSlotsError.classList.remove('hidden');
          return;
        }

        timeSlotsGrid.innerHTML = '';
        data.availableSlots.forEach((slot: string) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.textContent = slot;
          button.style.cssText = `
            padding:10px 8px;border-radius:10px;font-size:0.8rem;font-weight:600;
            transition:all 0.15s;
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(59,130,246,0.2);
            color:rgba(240,246,255,0.75);
          `;
          button.addEventListener('mouseover', () => {
            button.style.borderColor = 'rgba(59,130,246,0.6)';
            button.style.background = 'rgba(59,130,246,0.1)';
            button.style.color = '#93c5fd';
          });
          button.addEventListener('mouseout', () => {
            if (selectedTime !== slot) {
              button.style.borderColor = 'rgba(59,130,246,0.2)';
              button.style.background = 'rgba(255,255,255,0.04)';
              button.style.color = 'rgba(240,246,255,0.75)';
            }
          });
          button.addEventListener('click', () => selectTimeSlot(slot, button));
          timeSlotsGrid.appendChild(button);
        });

        timeSlotsGrid.classList.remove('hidden');
      } catch (error) {
        console.error('Error fetching slots:', error);
        timeSlotsSpinner.classList.add('hidden');
        timeSlotsError.classList.remove('hidden');
        timeSlotsError.textContent = 'Error checking availability. Please try again.';
      }
    }

    function selectTimeSlot(time: string, button: HTMLButtonElement) {
      timeSlotsGrid.querySelectorAll('button').forEach((btn: Element) => {
        const b = btn as HTMLButtonElement;
        b.style.borderColor = 'rgba(59,130,246,0.2)';
        b.style.background = 'rgba(255,255,255,0.04)';
        b.style.color = 'rgba(240,246,255,0.75)';
        b.style.boxShadow = 'none';
      });

      button.style.borderColor = '#2563eb';
      button.style.background = 'rgba(37,99,235,0.2)';
      button.style.color = '#93c5fd';
      button.style.boxShadow = '0 0 10px rgba(37,99,235,0.3)';

      selectedTime = time;
      selectedTimeInput.value = time;

      if (selectedDate) {
        const dateStr = `${monthNames[selectedDate.getMonth()]} ${selectedDate.getDate()}`;
        selectedSlotText.textContent = `Meeting: ${dateStr} at ${time}h`;
        selectedSlotIndicator.classList.remove('hidden');
      }
    }

    prevMonthBtn.addEventListener('click', () => {
      currentMonth--;
      if (currentMonth < 0) { currentMonth = 11; currentYear--; }
      generateCalendar();
    });

    nextMonthBtn.addEventListener('click', () => {
      currentMonth++;
      if (currentMonth > 11) { currentMonth = 0; currentYear++; }
      generateCalendar();
    });

    function showAlert(message: string, type: 'success' | 'error') {
      alertContainer.style.cssText = type === 'success'
        ? 'background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.25);color:#4ade80;padding:12px 16px;border-radius:12px;'
        : 'background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);color:#fca5a5;padding:12px 16px;border-radius:12px;';
      alertContainer.innerHTML = message;
      alertContainer.classList.remove('hidden');
      alertContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function setLoading(loading: boolean) {
      submitButton.disabled = loading;
      submitButton.style.opacity = loading ? '0.6' : '1';
      if (loading) {
        buttonText.classList.add('hidden');
        buttonLoading.classList.remove('hidden');
      } else {
        buttonText.classList.remove('hidden');
        buttonLoading.classList.add('hidden');
      }
    }

    meetingForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!selectedDate || !selectedTime) {
        showAlert('⚠️ Please select a date and time for the meeting', 'error');
        return;
      }

      setLoading(true);
      alertContainer.classList.add('hidden');

      try {
        const formData = new FormData(meetingForm);
        formData.append('lang', 'en');
        const response = await fetch('/api/send-meeting-request', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (response.ok) {
          meetingForm.classList.add('hidden');
          bookingSuccess.classList.remove('hidden');

          if (selectedDate && selectedTime) {
            const dateStr = `${monthNames[selectedDate.getMonth()]} ${selectedDate.getDate()}, ${selectedDate.getFullYear()}`;
            confirmedDateTime.textContent = `${dateStr} at ${selectedTime}h (1 hour)`;
          }

          bookingSuccess.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          showAlert(data.error || 'An error occurred. Please try again.', 'error');
        }
      } catch (error) {
        console.error('Error:', error);
        showAlert('Connection error. Please check your connection and try again.', 'error');
      } finally {
        setLoading(false);
      }
    });

    generateCalendar();
  });
</script>
