---
import OptimizedImage from "../../layouts/utilities/OptimizedImage.astro";

const sections = [
  {
    title: "Servicios",
    links: [
      { name: "Chatbot Inteligente", href: "/servicios/chatbot" },
      { name: "Gestor Documental IA", href: "/servicios/gestor-documental" },
      { name: "Gestor de Citas IA", href: "/servicios/gestor-citas" },
      { name: "Atención de Llamadas", href: "/servicios/atencion-llamadas" },
      { name: "Automatización", href: "/servicios/automatizacion" },
      { name: "Consultoría IA", href: "/consultoria-ia" },
    ],
  },
  {
    title: "Empresa",
    links: [
      { name: "Solicitar Reunión", href: "/reunion" },
      { name: "FAQ", href: "/faq" },
      { name: "Términos de Servicio", href: "/terms" },
      { name: "Política de Privacidad", href: "/privacy" },
    ],
  },
  {
    title: "Seguridad",
    links: [
      { name: "Wazuh & ENS", href: "/wazuh" },
      { name: "Consultoría IA", href: "/consultoria-ia" },
    ],
  },
  {
    title: "Contacto",
    links: [
      { name: "Email", href: "mailto:info@aisecurity.es" },
      { name: "Agendar Consulta", href: "/reunion" },
    ],
  },
];
---

<footer class="relative overflow-hidden" style="background:#04060c;">
  <!-- Línea de acento superior -->
  <div style="height:1px;background:linear-gradient(90deg,transparent,rgba(96,165,250,0.55),rgba(167,139,250,0.55),transparent);"></div>
  <!-- Grid + glow sutil -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(99,102,241,0.06) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,0.06) 1px,transparent 1px);background-size:46px 46px;opacity:0.5;"></div>
  <div class="absolute inset-x-0 top-0 pointer-events-none" style="height:260px;background:radial-gradient(ellipse 60% 100% at 50% 0,rgba(99,102,241,0.13),transparent 72%);"></div>

  <div class="relative px-6 md:px-12 lg:px-20 py-16 max-w-7xl mx-auto">

    <!-- Marca + CTA -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mb-14">
      <!-- Marca -->
      <div>
        <a href="/" class="inline-flex items-center gap-3 hover:opacity-80 transition-opacity">
          <OptimizedImage width={40} src="/logo.svg" alt="AI SECURITY logo" />
          <span class="text-lg font-bold text-white">AI SECURITY</span>
        </a>
        <p class="mt-5 text-sm leading-relaxed" style="color:#94a3b8;max-width:34ch;">
          Tu partner tecnológico: IA, ciberseguridad y sistemas bajo un mismo equipo. Todo conectado, todo bajo control.
        </p>
        <a href="mailto:info@aisecurity.es" class="mt-6 inline-flex items-center gap-2 text-sm transition-colors ft-mail" style="color:#cbd5e1;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          info@aisecurity.es
        </a>
        <div class="mt-5 flex items-center gap-3">
          <a href="https://www.youtube.com/@Systems_Boy" target="_blank" rel="noopener" aria-label="Canal de YouTube" class="ft-social">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.5 15.5v-7l6.5 3.5-6.5 3.5z"/></svg>
          </a>
        </div>
      </div>

      <!-- Tarjeta CTA -->
      <div class="lg:col-span-2">
        <div class="ft-cta-card">
          <div>
            <h3 class="text-xl font-bold text-white mb-2">¿Hablamos?</h3>
            <p class="text-sm leading-relaxed" style="color:#94a3b8;max-width:48ch;">
              Cuéntanos tu proyecto y te ayudamos a automatizar tu negocio con IA a medida. La primera consulta es gratis.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 mt-6">
            <button id="te-llamamos-btn" type="button" class="ft-btn-primary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Te llamamos
            </button>
            <a href="/reunion" class="ft-btn-ghost">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Agendar reunión
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Columnas de enlaces -->
    <div class="ft-links grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
      {
        sections.map(({ title, links }) => (
          <div>
            <h4 class="ft-col-title">{title}</h4>
            <ul class="space-y-3">
              {links.map(({ name, href }) => (
                <li>
                  <a href={href}>{name}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Barra inferior -->
    <div class="pt-8 mt-12 flex flex-col md:flex-row justify-between items-center gap-4 text-sm" style="border-top:1px solid rgba(255,255,255,0.07);color:#64748b;">
      <p>&copy; {new Date().getFullYear()} AI SECURITY · Todos los derechos reservados.</p>
      <div class="flex items-center gap-5">
        <a href="/terms" class="ft-legal">Términos</a>
        <a href="/privacy" class="ft-legal">Privacidad</a>
        <span class="flex items-center gap-1.5" style="color:#94a3b8;">Hecho en España <span aria-hidden="true">🇪🇸</span></span>
      </div>
    </div>
  </div>
</footer>

<style>
  .ft-mail:hover { color: #a5b4fc; }
  .ft-social {
    display:inline-flex; align-items:center; justify-content:center;
    width:40px; height:40px; border-radius:11px;
    color:#94a3b8;
    background:rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.1);
    transition:all .2s ease;
  }
  .ft-social:hover { color:#fff; border-color:#818cf8; background:rgba(129,140,248,0.14); transform:translateY(-2px); }

  .ft-cta-card {
    position:relative; height:100%;
    display:flex; flex-direction:column; justify-content:center;
    padding:1.85rem;
    border-radius:1.1rem;
    background:rgba(255,255,255,0.035);
    border:1px solid rgba(129,140,248,0.28);
    box-shadow:0 0 0 1px rgba(129,140,248,0.05), 0 24px 60px -30px rgba(99,102,241,0.6);
    overflow:hidden;
  }
  .ft-cta-card::before {
    content:''; position:absolute; top:0; left:0; right:0; height:3px;
    background:linear-gradient(90deg,#60a5fa,#818cf8,#a78bfa);
  }

  .ft-btn-primary {
    display:inline-flex; align-items:center; justify-content:center; gap:0.5rem;
    padding:0.8rem 1.5rem; border-radius:0.7rem;
    font-weight:700; font-size:0.9rem; color:#fff; cursor:pointer;
    background:linear-gradient(135deg,#2563eb 0%,#7c3aed 100%);
    box-shadow:0 10px 30px -10px rgba(99,102,241,0.7);
    transition:transform .2s ease, box-shadow .2s ease;
  }
  .ft-btn-primary:hover { transform:translateY(-2px); box-shadow:0 14px 40px -10px rgba(124,58,237,0.8); }

  .ft-btn-ghost {
    display:inline-flex; align-items:center; justify-content:center; gap:0.5rem;
    padding:0.8rem 1.5rem; border-radius:0.7rem;
    font-weight:600; font-size:0.9rem; color:#e2e8f0; text-decoration:none;
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.16);
    transition:all .2s ease;
  }
  .ft-btn-ghost:hover { color:#fff; border-color:rgba(255,255,255,0.32); background:rgba(255,255,255,0.1); transform:translateY(-2px); }

  .ft-col-title {
    position:relative; display:inline-block;
    font-size:0.95rem; font-weight:700; color:#fff;
    margin-bottom:1.3rem; padding-bottom:0.5rem;
  }
  .ft-col-title::after {
    content:''; position:absolute; left:0; bottom:0;
    width:22px; height:2px; border-radius:2px;
    background:linear-gradient(90deg,#60a5fa,#a78bfa);
  }
  .ft-links a {
    color:#94a3b8;
    transition:color .2s ease, padding-left .2s ease;
    display:inline-block;
  }
  .ft-links a:hover { color:#a5b4fc; padding-left:4px; }

  .ft-legal { color:#64748b; transition:color .2s ease; }
  .ft-legal:hover { color:#a5b4fc; }
</style>

<!-- Popup "Te llamamos" -->
<div id="te-llamamos-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background-color: rgba(0,0,0,0.7);">
  <div class="rounded-2xl shadow-2xl w-full max-w-md p-8 relative" style="background-color: #111827;">
    <button id="te-llamamos-close" type="button" class="absolute top-4 right-4 transition-colors" style="color: #9ca3af;" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-full mb-4" style="background-color: #1e3a5f;">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #60a5fa;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
      </div>
      <h3 class="text-2xl font-bold" style="color: #f9fafb;">Te llamamos nosotros</h3>
      <p class="mt-2 text-sm" style="color: #9ca3af;">Déjanos tu teléfono y te contactamos para resolver cualquier duda.</p>
    </div>
    <div id="te-llamamos-alert" class="hidden mb-4"></div>
    <form id="te-llamamos-form">
      <div class="mb-5">
        <label for="llamamos-telefono" class="block text-sm font-semibold mb-2" style="color: #d1d5db;">Tu teléfono</label>
        <input
          type="tel"
          id="llamamos-telefono"
          name="telefono"
          required
          placeholder="612 345 678"
          class="w-full px-4 py-3 rounded-lg focus:outline-none transition-all text-base"
          style="background-color: #1f2937; border: 2px solid #374151; color: #f9fafb;"
          onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#374151'"
        />
      </div>
      <button
        type="submit"
        id="llamamos-submit"
        class="w-full py-3 px-6 rounded-lg font-semibold transition-all shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
        style="background-color: #2563eb; color: #ffffff;"
        onmouseover="this.style.backgroundColor='#1d4ed8'" onmouseout="this.style.backgroundColor='#2563eb'"
      >
        <span id="llamamos-btn-text">Solicitar llamada</span>
        <span id="llamamos-btn-loading" class="hidden">Enviando...</span>
      </button>
    </form>
  </div>
</div>

<script>
  const modal = document.getElementById('te-llamamos-modal') as HTMLDivElement;
  const openBtn = document.getElementById('te-llamamos-btn') as HTMLButtonElement;
  const closeBtn = document.getElementById('te-llamamos-close') as HTMLButtonElement;
  const form = document.getElementById('te-llamamos-form') as HTMLFormElement;
  const alert = document.getElementById('te-llamamos-alert') as HTMLDivElement;
  const submitBtn = document.getElementById('llamamos-submit') as HTMLButtonElement;
  const btnText = document.getElementById('llamamos-btn-text') as HTMLSpanElement;
  const btnLoading = document.getElementById('llamamos-btn-loading') as HTMLSpanElement;

  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);

  // Cerrar al hacer click fuera
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const telefono = (document.getElementById('llamamos-telefono') as HTMLInputElement).value.trim();

    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    alert.classList.add('hidden');

    try {
      const formData = new FormData();
      formData.append('telefono', telefono);

      const response = await fetch('/api/te-llamamos', { method: 'POST', body: formData });
      const data = await response.json();

      if (response.ok) {
        alert.className = 'mb-4 p-3 rounded-lg text-sm bg-green-50 border border-green-200 text-green-800';
        alert.textContent = '¡Recibido! Te contactaremos lo antes posible.';
        alert.classList.remove('hidden');
        form.reset();
        setTimeout(closeModal, 3000);
      } else {
        alert.className = 'mb-4 p-3 rounded-lg text-sm bg-red-50 border border-red-200 text-red-800';
        alert.textContent = data.error || 'Error al enviar. Inténtalo de nuevo.';
        alert.classList.remove('hidden');
      }
    } catch {
      alert.className = 'mb-4 p-3 rounded-lg text-sm bg-red-50 border border-red-200 text-red-800';
      alert.textContent = 'Error de conexión. Verifica tu internet e inténtalo de nuevo.';
      alert.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
    }
  });
</script>

