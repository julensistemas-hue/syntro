---
import OptimizedImage from "../../layouts/utilities/OptimizedImage.astro";

const sections = [
  {
    title: "Servicios",
    links: [
      { name: "Chatbot Inteligente", href: "/servicios/chatbot" },
      { name: "Gestor Documental IA", href: "/servicios/gestor-documental" },
      { name: "Gestor de Citas IA", href: "/servicios/gestor-citas" },
      { name: "Atención de Llamadas", href: "/servicios/atencion-llamadas" },
      { name: "Automatización", href: "/servicios/automatizacion" },
    ],
  },
  {
    title: "Empresa",
    links: [
      { name: "Solicitar Reunión", href: "/reunion" },
      { name: "FAQ", href: "/faq" },
      { name: "Términos de Servicio", href: "/terms" },
      { name: "Política de Privacidad", href: "/privacy" },
    ],
  },
  {
    title: "Seguridad",
    links: [
      { name: "Wazuh & ENS", href: "/wazuh" },
      { name: "Ciberseguridad", href: "/reunion" },
      { name: "Consultoría", href: "/reunion" },
    ],
  },
  {
    title: "Contacto",
    links: [
      { name: "Email", href: "mailto:info@aisecurity.es" },
      { name: "Agendar Consulta", href: "/reunion" },
    ],
  },
];
---

<footer
  class="relative border-t border-base-200 mt-0" style="background-color: black;">
  <div class="px-6 md:px-12 lg:px-20 py-20 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div class="md:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 hover:opacity-80 transition-opacity">
          <OptimizedImage width={40} src="/logo.svg" alt="AI SECURITY logo" />
          <span class="text-lg font-bold text-white">AI SECURITY</span>
        </a>
        <p class="mt-5 text-sm text-base-300 leading-relaxed">
          Soluciones de inteligencia artificial para empresas. Automatiza procesos,
          mejora la atención al cliente y optimiza tu operativa con tecnología de vanguardia.
        </p>
      </div>

      <div class="md:col-span-2">
        <h3 class="text-lg font-bold text-white mb-3">
          ¿Hablamos?
        </h3>
        <p class="text-sm text-base-300 mb-5 leading-relaxed">
          Cuéntanos tu proyecto y te ayudamos a automatizar tu negocio con soluciones de IA a medida.
        </p>
        <div class="flex flex-col sm:flex-row items-stretch gap-3 w-full">
          <button
            id="te-llamamos-btn"
            type="button"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-accent-600 font-semibold hover:bg-accent-700 transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5"
            style="color: #ffffff;"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Te llamamos
          </button>
          <a
            href="/reunion"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-white/10 text-white font-semibold hover:bg-white/20 border border-white/20 transition-all hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Agendar Reunión
          </a>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
      {
        sections.map(({ title, links }) => (
          <div>
            <h4 class="text-base font-bold text-white mb-5">{title}</h4>
            <ul class="space-y-3">
              {links.map(({ name, href }) => (
                <li>
                  <a
                    href={href}
                    class="text-base-300 hover:text-accent-400 inline-block transition-colors">
                    {name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="pt-10 mt-12 border-t border-base-700 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-base-400">
      <p>
        &copy; {new Date().getFullYear()} AI SECURITY. Todos los derechos reservados.
      </p>
      <p class="font-medium">Soluciones de inteligencia artificial para empresas</p>
    </div>
  </div>
</footer>

<!-- Popup "Te llamamos" -->
<div id="te-llamamos-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background-color: rgba(0,0,0,0.7);">
  <div class="rounded-2xl shadow-2xl w-full max-w-md p-8 relative" style="background-color: #111827;">
    <button id="te-llamamos-close" type="button" class="absolute top-4 right-4 transition-colors" style="color: #9ca3af;" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-full mb-4" style="background-color: #1e3a5f;">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #60a5fa;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
      </div>
      <h3 class="text-2xl font-bold" style="color: #f9fafb;">Te llamamos nosotros</h3>
      <p class="mt-2 text-sm" style="color: #9ca3af;">Déjanos tu teléfono y te contactamos para resolver cualquier duda.</p>
    </div>
    <div id="te-llamamos-alert" class="hidden mb-4"></div>
    <form id="te-llamamos-form">
      <div class="mb-5">
        <label for="llamamos-telefono" class="block text-sm font-semibold mb-2" style="color: #d1d5db;">Tu teléfono</label>
        <input
          type="tel"
          id="llamamos-telefono"
          name="telefono"
          required
          placeholder="612 345 678"
          class="w-full px-4 py-3 rounded-lg focus:outline-none transition-all text-base"
          style="background-color: #1f2937; border: 2px solid #374151; color: #f9fafb;"
          onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#374151'"
        />
      </div>
      <button
        type="submit"
        id="llamamos-submit"
        class="w-full py-3 px-6 rounded-lg font-semibold transition-all shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
        style="background-color: #2563eb; color: #ffffff;"
        onmouseover="this.style.backgroundColor='#1d4ed8'" onmouseout="this.style.backgroundColor='#2563eb'"
      >
        <span id="llamamos-btn-text">Solicitar llamada</span>
        <span id="llamamos-btn-loading" class="hidden">Enviando...</span>
      </button>
    </form>
  </div>
</div>

<script>
  const modal = document.getElementById('te-llamamos-modal') as HTMLDivElement;
  const openBtn = document.getElementById('te-llamamos-btn') as HTMLButtonElement;
  const closeBtn = document.getElementById('te-llamamos-close') as HTMLButtonElement;
  const form = document.getElementById('te-llamamos-form') as HTMLFormElement;
  const alert = document.getElementById('te-llamamos-alert') as HTMLDivElement;
  const submitBtn = document.getElementById('llamamos-submit') as HTMLButtonElement;
  const btnText = document.getElementById('llamamos-btn-text') as HTMLSpanElement;
  const btnLoading = document.getElementById('llamamos-btn-loading') as HTMLSpanElement;

  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);

  // Cerrar al hacer click fuera
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const telefono = (document.getElementById('llamamos-telefono') as HTMLInputElement).value.trim();

    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    alert.classList.add('hidden');

    try {
      const formData = new FormData();
      formData.append('telefono', telefono);

      const response = await fetch('/api/te-llamamos', { method: 'POST', body: formData });
      const data = await response.json();

      if (response.ok) {
        alert.className = 'mb-4 p-3 rounded-lg text-sm bg-green-50 border border-green-200 text-green-800';
        alert.textContent = '¡Recibido! Te contactaremos lo antes posible.';
        alert.classList.remove('hidden');
        form.reset();
        setTimeout(closeModal, 3000);
      } else {
        alert.className = 'mb-4 p-3 rounded-lg text-sm bg-red-50 border border-red-200 text-red-800';
        alert.textContent = data.error || 'Error al enviar. Inténtalo de nuevo.';
        alert.classList.remove('hidden');
      }
    } catch {
      alert.className = 'mb-4 p-3 rounded-lg text-sm bg-red-50 border border-red-200 text-red-800';
      alert.textContent = 'Error de conexión. Verifica tu internet e inténtalo de nuevo.';
      alert.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
    }
  });
</script>

