---
// Cabecera de la experiencia inglesa: simplificada a Wazuh + Blog.
// (Los servicios de IA y el curso solo existen en español, así que no se enlazan.)
import OptimizedImage from "../../layouts/utilities/OptimizedImage.astro";
import { stripLocale } from "../../i18n/config";

const currentPath = Astro.url.pathname;
const esUrl = stripLocale(currentPath); // equivalente en español de esta página
---

<header
  id="main-header"
  class="sticky top-0 z-50 transition-all duration-300"
  style="background: linear-gradient(135deg, #0a0d14 0%, #0f1117 50%, #0a0d14 100%); border-bottom: 1px solid rgba(255,255,255,0.07);"
  data-scrolled="false">
  <div class="w-full mx-auto px-6 max-w-7xl">
    <div
      x-data="{ open: false }"
      class="relative flex flex-col w-full py-4 mx-auto lg:items-center lg:justify-between lg:flex-row">

      <!-- Logo -->
      <div class="flex flex-row items-center justify-between lg:justify-start">
        <a href="/en" class="inline-flex items-center gap-2.5 hover:opacity-80 transition-opacity" style="color: #ffffff;">
          <OptimizedImage width={40} src="/logo.svg" alt="AI SECURITY logo" />
          <span class="font-bold text-xl tracking-tight text-white">AI SECURITY</span>
        </a>

        <!-- Mobile Menu Button -->
        <button
          @click="open = !open"
          :aria-expanded="open.toString()"
          aria-controls="main-navigation"
          aria-label="Toggle navigation menu"
          class="inline-flex items-center justify-center p-2.5 rounded-lg focus:outline-none lg:hidden transition-colors"
          style="color: rgba(255,255,255,0.7);">
          <svg
            :class="{'rotate-90': open}"
            class="w-6 h-6 transition-transform duration-300 ease-in-out"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            <path x-show="open"  stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Navigation -->
      <nav
        :class="{'flex': open, 'hidden': !open}"
        id="main-navigation"
        class="flex-col items-start gap-1 lg:flex lg:flex-row lg:items-center lg:gap-1 lg:ml-auto mt-4 lg:mt-0"
        role="navigation"
        aria-label="Main navigation">

        <a
          href="/en/wazuh"
          class={`nav-link nav-link--highlight w-full lg:w-auto text-[11px] font-semibold tracking-wider uppercase transition-all duration-200 px-3 py-3 ${currentPath === '/en/wazuh' ? 'nav-link--active' : ''}`}>
          Wazuh
        </a>

        <a
          href="/en/blog"
          class={`nav-link w-full lg:w-auto text-[11px] font-semibold tracking-wider uppercase transition-all duration-200 px-3 py-3 ${currentPath.startsWith('/en/blog') ? 'nav-link--active' : ''}`}>
          Blog
        </a>

        <!-- Language switcher -->
        <a
          href={esUrl}
          hreflang="es"
          class="nav-link w-full lg:w-auto text-[11px] font-semibold tracking-wider uppercase transition-all duration-200 px-3 py-3 inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
          </svg>
          Español
        </a>

        <!-- CTA Button -->
        <a
          href="/reunion"
          class="w-full lg:w-auto inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-bold rounded-lg transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5 mt-2 lg:mt-0 lg:ml-2"
          style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: #ffffff;">
          Book a Meeting
          <span class="bg-green-500 text-white text-[10px] px-2 py-0.5 rounded-full font-bold shadow-sm">FREE</span>
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
    color: rgba(255, 255, 255, 0.80);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 12px;
    right: 12px;
    height: 1.5px;
    background: linear-gradient(90deg, #6366f1, #60a5fa);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease, opacity 0.22s ease;
    opacity: 0;
  }
  .nav-link:hover { color: rgba(255, 255, 255, 0.95); }
  .nav-link:hover::after { transform: scaleX(1); opacity: 1; }
  .nav-link--highlight { color: #818cf8; }
  .nav-link--highlight:hover { color: #a5b4fc; }
  .nav-link--active { color: #ffffff !important; }
  .nav-link--active::after { transform: scaleX(1) !important; opacity: 0.5 !important; }

  @media (max-width: 1023px) {
    #main-navigation {
      overflow-y: auto;
      max-height: calc(100vh - 72px);
      padding-bottom: 12px;
      -webkit-overflow-scrolling: touch;
    }
  }
</style>

<script>
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.style.setProperty('background', 'linear-gradient(135deg, #060810 0%, #0a0d14 100%)');
    } else {
      header?.style.setProperty('background', 'linear-gradient(135deg, #0a0d14 0%, #0f1117 50%, #0a0d14 100%)');
    }
  });
</script>
