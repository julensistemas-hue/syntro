---
// CTA para promocionar el test/curso de concienciación y captar leads empresariales
interface Props {
  source?: string;
}

const { source = "blog" } = Astro.props;
---

<div class="test-concienciacion-cta my-8 rounded-xl overflow-hidden" style="background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4c1d95 100%); border: 1px solid rgba(139, 92, 246, 0.3);">
  <!-- Header con badge -->
  <div class="px-6 pt-6 pb-4">
    <div class="flex items-center gap-2 mb-3">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold" style="background: rgba(34, 197, 94, 0.2); color: #4ade80;">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
        </svg>
        GRATIS
      </span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold" style="background: rgba(139, 92, 246, 0.2); color: #a78bfa;">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"></path>
        </svg>
        Mini-curso interactivo
      </span>
    </div>

    <h3 class="text-xl md:text-2xl font-bold text-white mb-2">
      🧪 Pon a prueba la seguridad de tu equipo
    </h3>

    <p class="text-gray-300 text-sm md:text-base">
      ¿Quieres saber cómo de preparados están tus empleados frente a ataques? Empieza con nuestro <strong class="text-white">test de concienciación gratuito</strong> sobre contraseñas seguras.
    </p>
  </div>

  <!-- Preview del curso - MÁS VISIBLE -->
  <div class="px-6 py-5" style="background: rgba(0, 0, 0, 0.2);">
    <p class="text-purple-300 text-xs uppercase tracking-wider font-semibold mb-3">👇 Prueba el test de ejemplo:</p>

    <a href="/blog/contrasenas-seguras-empleados-guia-completa" class="group block p-4 rounded-xl transition-all hover:scale-[1.02]" style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(99, 102, 241, 0.15) 100%); border: 2px solid rgba(139, 92, 246, 0.4);">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-white font-bold text-base md:text-lg group-hover:text-purple-300 transition-colors">Contraseñas Seguras para Empleados</p>
          <p class="text-gray-400 text-sm mt-1">8 secciones · 10 min · Progreso guardado</p>
        </div>
        <div class="shrink-0 flex items-center gap-2 px-4 py-2 rounded-lg font-semibold text-white text-sm" style="background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);">
          <span class="hidden sm:inline">Empezar test</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </div>
      </div>
    </a>
  </div>

  <!-- CTA para empresas - TABULADO -->
  <div class="px-6 py-5" style="background: rgba(0, 0, 0, 0.3);">
    <div class="md:pl-6 md:border-l-2 border-purple-500/30">
      <p class="text-white font-semibold mb-1">¿Quieres más tests para tu empresa?</p>
      <p class="text-gray-400 text-sm mb-4">Recibe acceso a más cursos de concienciación + métricas de resultados de tu equipo.</p>

      <button
        type="button"
        onclick="document.getElementById('cta-email-form').classList.toggle('hidden')"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-white transition-all hover:scale-105"
        style="background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        Quiero más información
      </button>
    </div>

    <!-- Formulario de email (oculto por defecto) -->
    <form id="cta-email-form" class="hidden mt-4 pt-4 border-t border-purple-500/30">
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          name="email"
          required
          placeholder="tu@empresa.com"
          class="flex-1 px-4 py-3 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500"
          style="background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(139, 92, 246, 0.3);"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold text-white transition-all hover:opacity-90"
          style="background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);"
        >
          <span>Solicitar acceso</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </button>
      </div>
      <p class="text-gray-500 text-xs mt-2">Te contactamos en menos de 24h con información sobre los planes de concienciación para empresas.</p>
      <div id="cta-form-status" class="hidden mt-2 text-sm"></div>
    </form>
  </div>

  <!-- Footer con beneficios -->
  <div class="px-6 py-4 flex flex-wrap gap-4 text-xs text-gray-400" style="background: rgba(0, 0, 0, 0.2); border-top: 1px solid rgba(139, 92, 246, 0.2);">
    <span class="flex items-center gap-1.5">
      <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
      </svg>
      Tests de phishing simulados
    </span>
    <span class="flex items-center gap-1.5">
      <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
      </svg>
      Gráficas y métricas por empleado
    </span>
    <span class="flex items-center gap-1.5">
      <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
      </svg>
      Cumplimiento ISO 27001 / ENS
    </span>
    <span class="flex items-center gap-1.5">
      <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
      </svg>
      Informes para auditorías
    </span>
  </div>
</div>

<script define:vars={{ source }}>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('cta-email-form');
    const statusDiv = document.getElementById('cta-form-status');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = form.querySelector('input[name="email"]');
      const submitBtn = form.querySelector('button[type="submit"]');
      const email = emailInput?.value;

      if (!email) return;

      // Loading state
      if (submitBtn) {
        submitBtn.innerHTML = '<svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Enviando...</span>';
        submitBtn.disabled = true;
      }

      try {
        const response = await fetch('/api/lead-concienciacion', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            source: `test-cta-${source}`,
            interest: 'plataforma-concienciacion'
          })
        });

        if (response.ok) {
          if (statusDiv) {
            statusDiv.className = 'mt-2 text-sm text-green-400';
            statusDiv.textContent = '✅ ¡Recibido! Te contactamos pronto con más información.';
            statusDiv.classList.remove('hidden');
          }
          form.reset();
          // Ocultar form después de éxito
          setTimeout(() => {
            form.classList.add('hidden');
          }, 3000);
        } else {
          throw new Error('Error');
        }
      } catch (error) {
        if (statusDiv) {
          statusDiv.className = 'mt-2 text-sm text-red-400';
          statusDiv.textContent = '❌ Error al enviar. Inténtalo de nuevo.';
          statusDiv.classList.remove('hidden');
        }
      } finally {
        if (submitBtn) {
          submitBtn.innerHTML = '<span>Solicitar acceso</span><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>';
          submitBtn.disabled = false;
        }
      }
    });
  });
</script>