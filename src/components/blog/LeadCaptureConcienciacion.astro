---
interface Props {
  source?: string;
}

const { source = "blog-concienciacion" } = Astro.props;
---

<div class="my-12 rounded-2xl overflow-hidden" style="background: linear-gradient(135deg, #7c3aed 0%, #2563eb 100%); border: 1px solid rgba(255,255,255,0.2);">
  <div class="p-8 md:p-10">
    <!-- Header -->
    <div class="flex items-start gap-4 mb-6">
      <div class="w-14 h-14 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(255,255,255,0.2);">
        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <div>
        <h3 class="text-2xl md:text-3xl font-bold text-white m-0">
          Evalua la concienciacion de tu equipo
        </h3>
        <p class="text-white/80 mt-2 text-lg">
          Herramienta gratuita para cumplir <strong class="text-white">ISO 27001</strong> y <strong class="text-white">ENS</strong>
        </p>
      </div>
    </div>

    <!-- Benefits -->
    <ul class="space-y-3 mb-8">
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-green-300 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-white/90">Test de concienciacion para tus empleados</span>
      </li>
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-green-300 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-white/90">Graficos de resultados por departamento</span>
      </li>
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-green-300 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-white/90">Informe descargable para auditorias</span>
      </li>
    </ul>

    <!-- Form -->
    <form id="lead-form" class="space-y-4" data-source={source}>
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          id="lead-email"
          name="email"
          placeholder="tu@empresa.com"
          required
          class="flex-1 px-5 py-4 rounded-xl text-base-900 placeholder-base-500 focus:outline-none focus:ring-2 focus:ring-white/50"
          style="background-color: #ffffff;"
        />
        <button
          type="submit"
          id="lead-submit"
          class="px-8 py-4 rounded-xl font-semibold text-purple-900 transition-all hover:scale-105 whitespace-nowrap"
          style="background-color: #fbbf24;"
        >
          Acceder gratis
        </button>
      </div>

      <!-- Messages -->
      <div id="lead-error" class="hidden p-4 rounded-lg" style="background-color: rgba(239, 68, 68, 0.2); border: 1px solid rgba(239, 68, 68, 0.4);">
        <p class="text-red-200 text-sm m-0"></p>
      </div>
      <div id="lead-success" class="hidden p-4 rounded-lg" style="background-color: rgba(34, 197, 94, 0.2); border: 1px solid rgba(34, 197, 94, 0.4);">
        <p class="text-green-200 text-sm m-0"></p>
      </div>
    </form>

    <!-- Footer text -->
    <p class="text-white/60 text-sm mt-4 text-center">
      Sin compromiso · Configuracion en 5 minutos · Datos 100% seguros
    </p>
  </div>
</div>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const emailInput = document.getElementById('lead-email') as HTMLInputElement;
  const submitBtn = document.getElementById('lead-submit') as HTMLButtonElement;
  const errorDiv = document.getElementById('lead-error') as HTMLDivElement;
  const errorText = errorDiv?.querySelector('p') as HTMLParagraphElement;
  const successDiv = document.getElementById('lead-success') as HTMLDivElement;
  const successText = successDiv?.querySelector('p') as HTMLParagraphElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = emailInput.value.trim();
      const source = form.dataset.source || 'blog-concienciacion';

      if (!email) {
        errorText.textContent = 'Por favor, introduce tu email';
        errorDiv.classList.remove('hidden');
        successDiv.classList.add('hidden');
        return;
      }

      // Disable form
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      try {
        const response = await fetch('/api/lead-concienciacion', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source }),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Error al enviar');
        }

        // Success
        successText.textContent = 'Te hemos enviado un email con los detalles de acceso. Revisa tu bandeja de entrada.';
        successDiv.classList.remove('hidden');
        form.reset();

      } catch (error: any) {
        errorText.textContent = error.message || 'Error al procesar la solicitud';
        errorDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Acceder gratis';
      }
    });
  }
</script>