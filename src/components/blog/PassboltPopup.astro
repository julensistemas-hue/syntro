---
// Popup para solicitar ayuda con implementación de Passbolt
---

<!-- Overlay del popup -->
<div id="passbolt-popup-overlay" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
  <div class="bg-[#1a1a1a] border border-gray-700 rounded-xl max-w-md w-full p-6 relative animate-fadeIn">
    <!-- Botón cerrar -->
    <button id="passbolt-popup-close" class="absolute top-4 right-4 text-gray-400 hover:text-white transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Logo Passbolt -->
    <div class="flex items-center gap-3 mb-4">
      <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-green-500 to-green-700 flex items-center justify-center">
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
        </svg>
      </div>
      <div>
        <h3 class="text-xl font-bold text-white">Passbolt para empresas</h3>
        <p class="text-green-400 text-sm">Gestor de contraseñas open source</p>
      </div>
    </div>

    <p class="text-gray-300 mb-4">Passbolt es ideal para equipos que necesitan compartir credenciales de forma segura. Te ayudamos a implementarlo en tu empresa.</p>

    <ul class="text-gray-400 text-sm space-y-2 mb-6">
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        Instalación y configuración completa
      </li>
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        Integración con LDAP/Active Directory
      </li>
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        Formación al equipo
      </li>
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        Soporte y mantenimiento
      </li>
    </ul>

    <!-- Formulario -->
    <form id="passbolt-form" class="space-y-4">
      <div>
        <label for="passbolt-email" class="block text-sm font-medium text-gray-300 mb-1">Tu email corporativo</label>
        <input
          type="email"
          id="passbolt-email"
          name="email"
          required
          placeholder="tu@empresa.com"
          class="w-full px-4 py-3 bg-[#0d0d0d] border border-gray-600 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
        />
      </div>

      <button
        type="submit"
        id="passbolt-submit"
        class="w-full py-3 px-4 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-500 hover:to-green-600 text-white font-semibold rounded-lg transition-all duration-200 flex items-center justify-center gap-2"
      >
        <span>Te ayudamos a implementarlo</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </button>

      <!-- Estado de envío -->
      <div id="passbolt-status" class="hidden text-center py-2"></div>
    </form>

    <p class="text-gray-500 text-xs text-center mt-4">Sin compromiso. Te contactamos en menos de 24h.</p>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.2s ease-out;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('passbolt-popup-overlay');
    const closeBtn = document.getElementById('passbolt-popup-close');
    const form = document.getElementById('passbolt-form') as HTMLFormElement;
    const submitBtn = document.getElementById('passbolt-submit');
    const statusDiv = document.getElementById('passbolt-status');

    // Función para abrir el popup (se llama desde el link de Passbolt)
    (window as any).openPassboltPopup = () => {
      overlay?.classList.remove('hidden');
      overlay?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };

    // Cerrar popup
    const closePopup = () => {
      overlay?.classList.add('hidden');
      overlay?.classList.remove('flex');
      document.body.style.overflow = '';
    };

    closeBtn?.addEventListener('click', closePopup);

    // Cerrar al hacer clic fuera
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) closePopup();
    });

    // Cerrar con ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) {
        closePopup();
      }
    });

    // Enviar formulario
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = (document.getElementById('passbolt-email') as HTMLInputElement)?.value;

      if (!email) return;

      // Mostrar loading
      if (submitBtn) {
        submitBtn.innerHTML = '<svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Enviando...</span>';
        (submitBtn as HTMLButtonElement).disabled = true;
      }

      try {
        const response = await fetch('/api/passbolt-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await response.json();

        if (response.ok) {
          if (statusDiv) {
            statusDiv.className = 'text-center py-2 text-green-400';
            statusDiv.textContent = '✅ ¡Recibido! Te contactamos pronto.';
            statusDiv.classList.remove('hidden');
          }
          form.reset();

          // Cerrar popup después de 2 segundos
          setTimeout(closePopup, 2000);
        } else {
          throw new Error(data.error || 'Error al enviar');
        }
      } catch (error) {
        if (statusDiv) {
          statusDiv.className = 'text-center py-2 text-red-400';
          statusDiv.textContent = '❌ Error al enviar. Inténtalo de nuevo.';
          statusDiv.classList.remove('hidden');
        }
      } finally {
        if (submitBtn) {
          submitBtn.innerHTML = '<span>Te ayudamos a implementarlo</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>';
          (submitBtn as HTMLButtonElement).disabled = false;
        }
      }
    });
  });
</script>
