---
interface Props {
  title: string;
  description: string;
  icon: string;
  features: string[];
  href: string;
  featured?: boolean;
}

const { title, description, icon, features, href, featured = false } = Astro.props;

// Texto del botón según el tipo de servicio
const buttonMap: Record<string, string> = {
  "Chatbot Inteligente":       "Ver demo interactiva",
  "Gestor Documental IA":      "Ver demo interactiva",
  "Gestor de Citas IA":        "Ver demo interactiva",
  "Atención de Llamadas IA":   "Ver demo interactiva",
  "Wazuh & Ciberseguridad":    "Ver Wazuh",
  "Consultoría IA":            "Ver consultoría",
  "Diseño Web Profesional":    "Ver diseño web",
  "Posicionamiento SEO y GEO": "Ver SEO y GEO",
  "Soporte Técnico IT":        "Ver soporte IT",
};
const buttonText = buttonMap[title] ?? "Ver servicio";
const isConsultoria = !["Chatbot Inteligente","Gestor Documental IA","Gestor de Citas IA","Atención de Llamadas IA"].includes(title);

// Plan para el botón de presupuesto
const planMap: Record<string, string> = {
  "Chatbot Inteligente":       "Chatbot-IA",
  "Gestor Documental IA":      "Gestor-Documental-IA",
  "Gestor de Citas IA":        "Gestor-Citas-IA",
  "Atención de Llamadas IA":   "Atencion-Llamadas-IA",
  "Wazuh & Ciberseguridad":    "Wazuh-Ciberseguridad",
  "Consultoría IA":            "Consultoria-IA",
  "Diseño Web Profesional":    "Diseno-Web",
  "Posicionamiento SEO y GEO": "SEO-GEO",
  "Soporte Técnico IT":        "Soporte-IT",
};
const presupuestoPlan = planMap[title] ?? title.replace(/\s+/g, '-');
---

<div
  class={`
    relative p-6 rounded-2xl border-2 transition-all duration-300 bg-base-50 group flex flex-col h-full
    ${featured
      ? 'border-accent-300 shadow-lg hover:shadow-2xl hover:border-accent-400 hover:-translate-y-2'
      : 'border-base-200 hover:border-accent-300 hover:shadow-xl hover:-translate-y-1'
    }
  `}
>
  {featured && (
    <div class="absolute -top-4 left-8">
      <span class="bg-gradient-to-r from-accent-600 to-blue-600 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-md">
        Más Popular
      </span>
    </div>
  )}

  <div class="flex items-center gap-3 mb-4">
    <div class="flex-1 min-w-0">
      <h3 class="text-lg font-bold text-base-900">{title}</h3>
    </div>
  </div>

  <!-- Icono grande reemplaza al texto descriptivo -->
  <div class="flex justify-center items-center mb-6">
    <div class={`service-icon-big transition-transform duration-300 group-hover:scale-105 ${featured ? 'service-icon-featured' : 'service-icon-default'}`}>
      <span class="service-icon-emoji">{icon}</span>
      <div class="service-icon-ring"></div>
    </div>
  </div>

  <ul class="space-y-2 mb-6 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        <span class="text-base-700 text-sm leading-relaxed">{feature}</span>
      </li>
    ))}
  </ul>

  <a
    href={href}
    class={`
      inline-flex items-center justify-center w-full px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-200
      ${featured
        ? 'bg-gradient-to-r from-accent-600 to-blue-600 text-white shadow-lg hover:shadow-xl hover:-translate-y-0.5 hover:from-accent-700 hover:to-blue-700'
        : 'bg-base-100 text-base-900 hover:bg-accent-600 border-2 border-base-200 hover:border-accent-600 shadow-sm hover:shadow-md service-card-button'
      }
    `}
    style="color: #FFFFFF;"
  >
    {buttonText}
    <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      {isConsultoria ? (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      ) : (
        <>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
        </>
      )}
    </svg>
  </a>

  <a
    href={`/presupuesto?plan=${presupuestoPlan}`}
    class="inline-flex items-center justify-center w-full px-5 py-2.5 rounded-xl font-semibold text-sm transition-all duration-200 mt-2 border-2 border-accent-200 hover:border-accent-400 hover:bg-accent-50"
    style="color: #1d4ed8;"
  >
    Solicitar presupuesto
    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
  </a>
</div>

<style>
  .service-card-button:hover {
    color: #000000 !important;
  }

  .service-icon-big {
    position: relative;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-icon-default {
    background: radial-gradient(circle at 35% 35%, rgba(59,130,246,0.18), rgba(15,23,42,0.9));
    border: 1.5px solid rgba(59,130,246,0.3);
    box-shadow:
      0 0 24px rgba(59,130,246,0.15),
      inset 0 1px 0 rgba(255,255,255,0.07);
  }

  .service-icon-featured {
    background: radial-gradient(circle at 35% 35%, rgba(96,165,250,0.35), rgba(29,78,216,0.85));
    border: 1.5px solid rgba(96,165,250,0.5);
    box-shadow:
      0 0 32px rgba(59,130,246,0.3),
      0 8px 24px rgba(29,78,216,0.25),
      inset 0 1px 0 rgba(255,255,255,0.1);
  }

  .service-icon-emoji {
    font-size: 2.4rem;
    line-height: 1;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
    position: relative;
    z-index: 1;
  }

  .service-icon-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(59,130,246,0.15);
    animation: icon-ring-pulse 3s ease-in-out infinite;
  }

  @keyframes icon-ring-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%       { opacity: 0.8; transform: scale(1.04); }
  }

  .group:hover .service-icon-ring {
    border-color: rgba(59,130,246,0.35);
    animation: none;
    opacity: 1;
  }
</style>
