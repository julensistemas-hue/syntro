---
interface Props {
  title: string;
  description: string;
  icon: string;
  features: string[];
  href: string;
  accent?: string;
  featured?: boolean;
}

const { title, description, icon, features, href, accent = "#60a5fa", featured = false } = Astro.props;

// rgb del acento para usar en rgba()
const hx = accent.replace('#', '');
const aR = parseInt(hx.slice(0, 2), 16);
const aG = parseInt(hx.slice(2, 4), 16);
const aB = parseInt(hx.slice(4, 6), 16);
const accentRgb = `${aR},${aG},${aB}`;

// Texto del botón según el tipo de servicio
const buttonMap: Record<string, string> = {
  "Chatbot Inteligente":       "Ver demo interactiva",
  "Gestor Documental IA":      "Ver demo interactiva",
  "Gestor de Citas IA":        "Ver demo interactiva",
  "Atención de Llamadas IA":   "Ver demo interactiva",
  "Wazuh & Ciberseguridad":    "Ver Wazuh",
  "Consultoría IA":            "Ver consultoría",
  "Diseño Web Profesional":    "Ver diseño web",
  "Posicionamiento SEO y GEO": "Ver SEO y GEO",
  "Soporte Técnico IT":        "Ver soporte IT",
};
const buttonText = buttonMap[title] ?? "Ver servicio";

// Plan para el botón de presupuesto
const planMap: Record<string, string> = {
  "Chatbot Inteligente":       "Chatbot-IA",
  "Gestor Documental IA":      "Gestor-Documental-IA",
  "Gestor de Citas IA":        "Gestor-Citas-IA",
  "Atención de Llamadas IA":   "Atencion-Llamadas-IA",
  "Wazuh & Ciberseguridad":    "Wazuh-Ciberseguridad",
  "Consultoría IA":            "Consultoria-IA",
  "Diseño Web Profesional":    "Diseno-Web",
  "Posicionamiento SEO y GEO": "SEO-GEO",
  "Soporte Técnico IT":        "Soporte-IT",
};
const presupuestoPlan = planMap[title] ?? title.replace(/\s+/g, '-');
---

<div class={`svc-card group${featured ? ' svc-featured' : ''}`} style={`--a:${accent};--argb:${accentRgb};`}>

  {featured && (
    <span class="svc-badge">★ Más popular</span>
  )}

  <!-- Cabecera: icono + título -->
  <div class="flex items-center gap-3.5 mb-3">
    <div class="svc-icon">{icon}</div>
    <h3 class="svc-title">{title}</h3>
  </div>

  <p class="svc-desc">{description}</p>

  <ul class="svc-feat">
    {features.map((feature) => (
      <li>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <a href={href} class="svc-cta">
    {buttonText}
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
    </svg>
  </a>

  <a href={`/presupuesto?plan=${presupuestoPlan}`} class="svc-cta2">
    Solicitar presupuesto
  </a>
</div>

<style>
  .svc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    border-radius: 1rem;
    background: rgba(255,255,255,0.035);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(8px);
    overflow: hidden;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease, background .25s ease;
  }
  /* línea de acento superior */
  .svc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--a), transparent 80%);
    opacity: .8;
  }
  .svc-card:hover {
    transform: translateY(-6px);
    border-color: var(--a);
    background: rgba(var(--argb), 0.06);
    box-shadow: 0 18px 50px -16px rgba(var(--argb), 0.55);
  }
  .svc-featured {
    border-color: rgba(var(--argb), 0.5);
    box-shadow: 0 0 0 1px rgba(var(--argb), 0.18), 0 14px 44px -18px rgba(var(--argb), 0.5);
  }

  .svc-badge {
    position: absolute;
    top: 0.9rem; right: 0.9rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    color: #0a0f1a;
    background: var(--a);
    box-shadow: 0 4px 14px -4px rgba(var(--argb), 0.8);
  }

  .svc-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.7rem; line-height: 1;
    flex-shrink: 0;
    background: rgba(var(--argb), 0.13);
    border: 1px solid rgba(var(--argb), 0.3);
    transition: transform .25s ease;
  }
  .svc-card:hover .svc-icon { transform: scale(1.08) rotate(-5deg); }

  .svc-title {
    font-size: 1.08rem;
    font-weight: 700;
    color: #f0f6ff;
    line-height: 1.2;
  }

  .svc-desc {
    font-size: 0.85rem;
    line-height: 1.55;
    color: rgba(240,246,255,0.62);
    margin: 0 0 1.1rem;
  }

  .svc-feat {
    list-style: none;
    padding: 0;
    margin: 0 0 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }
  .svc-feat li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.83rem;
    line-height: 1.4;
    color: rgba(240,246,255,0.8);
  }
  .svc-feat svg {
    width: 1rem; height: 1rem;
    color: var(--a);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .svc-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.45rem;
    width: 100%;
    padding: 0.72rem 1rem;
    border-radius: 0.7rem;
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
    color: #0a0f1a;
    background: var(--a);
    transition: filter .2s ease, transform .2s ease;
  }
  .svc-cta:hover { filter: brightness(1.12); transform: translateY(-1px); }

  .svc-cta2 {
    display: inline-flex; align-items: center; justify-content: center;
    width: 100%;
    padding: 0.6rem 1rem;
    margin-top: 0.55rem;
    border-radius: 0.7rem;
    font-weight: 600;
    font-size: 0.8rem;
    text-decoration: none;
    color: #cbd5e1;
    border: 1px solid rgba(255,255,255,0.14);
    background: transparent;
    transition: all .2s ease;
  }
  .svc-cta2:hover {
    border-color: var(--a);
    color: #fff;
    background: rgba(var(--argb), 0.08);
  }
</style>
