---
// HeroMagnetic — "Orden del caos"
// Los nodos de las 4 áreas flotan dispersos y desconectados (caos). El cursor es
// un campo organizador: a su alrededor los nodos se atraen, se alinean en una
// constelación y se conectan. Metáfora: ponemos orden donde había caos.
---

<section id="mag-hero" class="relative overflow-hidden" style="background:#06080f;height:100vh;min-height:640px;">

  <canvas id="mag-canvas" class="absolute inset-0" style="width:100%;height:100%;display:block;z-index:1;"></canvas>

  <!-- Contenido -->
  <div class="relative h-full flex flex-col items-center justify-center text-center px-6" style="z-index:10;pointer-events:none;">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6 border" style="background:rgba(0,0,0,0.35);border-color:rgba(148,163,184,0.25);color:#cbd5e1;letter-spacing:0.12em;text-transform:uppercase;backdrop-filter:blur(2px);">
      Tu partner tecnológico de confianza
    </div>

    <h1 class="font-black tracking-tight" style="font-size:clamp(2.2rem,6.5vw,4.4rem);line-height:1.04;color:#f4f8ff;text-shadow:0 2px 50px rgba(0,0,0,0.85);">
      Tu tecnología,<br>sin el caos.
    </h1>

    <p class="mt-5" style="max-width:36rem;font-size:clamp(1rem,2.4vw,1.3rem);line-height:1.55;color:rgba(220,232,255,0.7);text-shadow:0 2px 30px rgba(0,0,0,0.9);">
      IA, ciberseguridad y sistemas dispersos en mil proveedores es caos. Bajo un mismo equipo, todo se ordena, se conecta y se optimiza.
    </p>

    <div id="mag-hint" class="mt-7 flex items-center gap-2" style="color:rgba(148,163,184,0.85);font-size:0.85rem;transition:opacity .5s;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
      Mueve el ratón y pon orden
    </div>

    <div class="mt-9" style="pointer-events:auto;">
      <a href="/reunion" id="mag-cta" style="display:inline-flex;align-items:center;gap:0.6rem;background:#f4f8ff;color:#06080f;font-weight:800;padding:0.95rem 2rem;border-radius:0.8rem;text-decoration:none;font-size:1rem;box-shadow:0 10px 40px rgba(255,255,255,0.15);transition:transform .2s,box-shadow .2s;">
        Pon orden en tu tecnología
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- leyenda de áreas -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-5 gap-y-2" style="font-size:0.78rem;color:#94a3b8;">
      <span class="flex items-center gap-1.5"><span style="width:8px;height:8px;border-radius:50%;background:#60a5fa;display:inline-block;"></span>IA</span>
      <span class="flex items-center gap-1.5"><span style="width:8px;height:8px;border-radius:50%;background:#34d399;display:inline-block;"></span>Ciberseguridad</span>
      <span class="flex items-center gap-1.5"><span style="width:8px;height:8px;border-radius:50%;background:#a78bfa;display:inline-block;"></span>Sistemas</span>
      <span class="flex items-center gap-1.5"><span style="width:8px;height:8px;border-radius:50%;background:#fbbf24;display:inline-block;"></span>Automatización</span>
    </div>
  </div>
</section>

<style>
  #mag-cta:hover { transform:translateY(-2px);box-shadow:0 14px 50px rgba(255,255,255,0.28); }
</style>

<script>
(function () {
  const section = document.getElementById('mag-hero') as HTMLElement;
  const canvas  = document.getElementById('mag-canvas') as HTMLCanvasElement;
  const hint    = document.getElementById('mag-hint') as HTMLElement;
  if (!section || !canvas) return;
  const ctx = canvas.getContext('2d')!;

  let W=0,H=0,DPR=Math.min(window.devicePixelRatio||1,2);
  const COLORS = ['#60a5fa','#34d399','#a78bfa','#fbbf24'];

  interface P { x:number;y:number;vx:number;vy:number;r:number;ci:number;phase:number; }
  let parts: P[] = [];

  function build(){
    const COUNT = Math.round((W*H)/14000);
    parts = [];
    for (let i=0;i<COUNT;i++){
      parts.push({
        x:Math.random()*W, y:Math.random()*H,
        vx:(Math.random()-0.5)*0.5, vy:(Math.random()-0.5)*0.5,
        r:Math.random()*1.8+1.6,
        ci:i%4,
        phase:Math.random()*6.28,
      });
    }
  }
  function resize(){
    W=section.clientWidth; H=section.clientHeight;
    canvas.width=W*DPR; canvas.height=H*DPR;
    canvas.style.width=W+'px'; canvas.style.height=H+'px';
    ctx.setTransform(DPR,0,0,DPR,0,0);
    build();
  }

  let mx=-9999,my=-9999,hasPointer=false,t=0;
  const R=210;     // radio de influencia
  const RING=70;   // radio del "halo" ordenado
  const K=0.020;   // rigidez del muelle

  function hexA(hex:string,a:number){ const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); return `rgba(${r},${g},${b},${a})`; }

  function frame(){
    t++;
    if(!hasPointer){ mx=W*(0.5+0.3*Math.sin(t*0.011)); my=H*(0.52+0.28*Math.sin(t*0.017+2)); }

    ctx.clearRect(0,0,W,H);

    // actualizar física
    const near:number[]=[];
    for (let i=0;i<parts.length;i++){
      const p=parts[i];
      const dx=mx-p.x, dy=my-p.y;
      const d=Math.hypot(dx,dy)||0.001;
      if (d<R){
        // muelle hacia el anillo RING (atrae si fuera, repele si dentro) → forma halo ordenado
        const force=(d-RING)*K;
        const ux=dx/d, uy=dy/d;
        p.vx += ux*force; p.vy += uy*force;
        // componente tangencial → rotación suave (vida)
        p.vx += -uy*0.06; p.vy += ux*0.06;
        // amortiguación fuerte dentro = se "asienta" ordenado
        p.vx*=0.86; p.vy*=0.86;
        near.push(i);
      } else {
        // caos: deriva libre
        p.vx*=0.995; p.vy*=0.995;
      }
      p.x+=p.vx; p.y+=p.vy;
      // rebote bordes
      if(p.x<0){p.x=0;p.vx*=-1;} if(p.x>W){p.x=W;p.vx*=-1;}
      if(p.y<0){p.y=0;p.vy*=-1;} if(p.y>H){p.y=H;p.vy*=-1;}
    }

    // enlaces SOLO entre nodos ordenados (cerca del cursor) → constelación
    for (let a=0;a<near.length;a++){
      for (let b=a+1;b<near.length;b++){
        const p=parts[near[a]], q=parts[near[b]];
        const dx=p.x-q.x, dy=p.y-q.y; const dd=dx*dx+dy*dy;
        if (dd<86*86){
          const al=(1-Math.sqrt(dd)/86)*0.5;
          ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(q.x,q.y);
          ctx.strokeStyle=hexA(COLORS[p.ci],al); ctx.lineWidth=1; ctx.stroke();
        }
      }
    }

    // dibujar nodos
    const nearSet = new Set(near);
    for (let i=0;i<parts.length;i++){
      const p=parts[i]; const ordered=nearSet.has(i);
      const col=COLORS[p.ci];
      const pulse=0.5+0.5*Math.sin(t*0.06+p.phase);
      if (ordered){
        const g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*5);
        g.addColorStop(0,hexA(col,0.45)); g.addColorStop(1,hexA(col,0));
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(p.x,p.y,p.r*5,0,6.28); ctx.fill();
        ctx.beginPath(); ctx.arc(p.x,p.y,p.r+0.6,0,6.28); ctx.fillStyle=col; ctx.fill();
      } else {
        // caos: gris tenue, apenas color
        ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,6.28);
        ctx.fillStyle=hexA(col,0.18+pulse*0.10); ctx.fill();
      }
    }

    // halo del cursor
    if (hasPointer || t>0){
      const gg=ctx.createRadialGradient(mx,my,0,mx,my,R);
      gg.addColorStop(0,'rgba(255,255,255,0.05)');
      gg.addColorStop(0.6,'rgba(148,163,184,0.03)');
      gg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=gg; ctx.beginPath(); ctx.arc(mx,my,R,0,6.28); ctx.fill();
      ctx.beginPath(); ctx.arc(mx,my,RING,0,6.28); ctx.strokeStyle='rgba(255,255,255,0.10)'; ctx.lineWidth=1; ctx.stroke();
    }

    requestAnimationFrame(frame);
  }

  function onMove(x:number,y:number){
    const rect=section.getBoundingClientRect();
    mx=x-rect.left; my=y-rect.top;
    if(!hasPointer){ hasPointer=true; if(hint) hint.style.opacity='0'; }
  }
  section.addEventListener('mousemove', e=>onMove(e.clientX,e.clientY));
  section.addEventListener('mouseleave', ()=>{ hasPointer=false; });
  section.addEventListener('touchmove', e=>{ if(e.touches[0]) onMove(e.touches[0].clientX,e.touches[0].clientY); }, {passive:true});

  resize();
  window.addEventListener('resize', resize);
  requestAnimationFrame(frame);
})();
</script>
