---
// HeroGlobe — "Núcleo orbital 3D"
// Esfera wireframe con 3D real (rotación + proyección perspectiva) en canvas.
// Se gira arrastrando el ratón (con inercia). Las 4 áreas son nodos luminosos
// que orbitan y se atenúan en la cara trasera. Drag-to-rotate.
---

<section id="glb-hero" class="relative overflow-hidden flex flex-col items-center justify-center px-6" style="background:#04060e;min-height:100vh;">

  <div class="absolute pointer-events-none" style="top:50%;left:50%;transform:translate(-50%,-50%);width:70vw;height:70vh;background:radial-gradient(circle,rgba(59,130,246,0.10),transparent 65%);z-index:0;"></div>

  <!-- Cabecera -->
  <div class="relative text-center mb-2" style="z-index:20;pointer-events:none;">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-5 border" style="background:rgba(0,0,0,0.4);border-color:rgba(148,163,184,0.25);color:#cbd5e1;letter-spacing:0.12em;text-transform:uppercase;backdrop-filter:blur(2px);">
      Tu partner tecnológico de confianza
    </div>
    <h1 class="font-black tracking-tight" style="font-size:clamp(1.9rem,5vw,3.4rem);line-height:1.06;color:#f4f8ff;text-shadow:0 2px 40px rgba(0,0,0,0.7);">
      Toda tu tecnología,<br>en una sola órbita.
    </h1>
  </div>

  <!-- Canvas 3D -->
  <canvas id="glb-canvas" class="relative" style="z-index:10;width:min(620px,92vw);height:min(440px,48vh);cursor:grab;touch-action:none;"></canvas>
  <!-- Etiquetas de dominio -->
  <div id="glb-labels" class="absolute inset-0 pointer-events-none" style="z-index:15;"></div>

  <div class="relative mt-2 flex flex-col items-center" style="z-index:20;">
    <p id="glb-hint" style="color:rgba(148,163,184,0.8);font-size:0.85rem;margin-bottom:1rem;transition:opacity .4s;">
      Arrastra para girar tu infraestructura
    </p>
    <a href="/reunion" id="glb-cta" style="display:inline-flex;align-items:center;gap:0.6rem;background:#7cc0ff;color:#04060e;font-weight:800;padding:0.95rem 2rem;border-radius:0.8rem;text-decoration:none;font-size:1rem;box-shadow:0 12px 40px -8px rgba(124,192,255,0.55);transition:transform .2s,box-shadow .2s;">
      Habla con nosotros · Consulta gratuita
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<style>
  #glb-cta:hover { transform:translateY(-2px);box-shadow:0 16px 50px -8px rgba(124,192,255,0.8); }
  #glb-canvas:active { cursor:grabbing; }
  .glb-label {
    position:absolute;transform:translate(-50%,-50%);
    font-size:0.74rem;font-weight:800;white-space:nowrap;
    padding:3px 9px;border-radius:9px;
    background:rgba(4,6,14,0.7);backdrop-filter:blur(3px);
    transition:opacity .15s;text-shadow:0 1px 6px rgba(0,0,0,0.8);
    pointer-events:auto;text-decoration:none;
  }
</style>

<script>
(function () {
  const section = document.getElementById('glb-hero') as HTMLElement;
  const canvas  = document.getElementById('glb-canvas') as HTMLCanvasElement;
  const labelsBox = document.getElementById('glb-labels') as HTMLElement;
  const hint    = document.getElementById('glb-hint') as HTMLElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  const DOMAINS = [
    { label:'IA',             col:'#60a5fa', href:'/consultoria-ia' },
    { label:'Ciberseguridad', col:'#34d399', href:'/wazuh' },
    { label:'Sistemas',       col:'#a78bfa', href:'/soporte-tecnico' },
    { label:'Automatización', col:'#fbbf24', href:'/servicios/automatizacion' },
  ];

  let W=0,H=0,cx=0,cy=0,scale=0,offX=0,offY=0,DPR=Math.min(window.devicePixelRatio||1,2);
  let stars:{x:number;y:number;r:number;p:number}[]=[];

  interface V { x:number;y:number;z:number;dom:number; }   // dom: -1 normal, 0-3 dominio
  let pts: V[] = [];
  let edges: [number,number][] = [];

  const N = 150;
  function buildSphere(){
    pts=[]; edges=[];
    const GA = Math.PI*(3-Math.sqrt(5));
    for (let i=0;i<N;i++){
      const y = 1 - (i/(N-1))*2;
      const r = Math.sqrt(1-y*y);
      const th = i*GA;
      pts.push({ x:Math.cos(th)*r, y, z:Math.sin(th)*r, dom:-1 });
    }
    // marcar 4 dominios repartidos
    [Math.floor(N*0.18), Math.floor(N*0.40), Math.floor(N*0.60), Math.floor(N*0.82)]
      .forEach((idx,k)=> pts[idx].dom=k);
    // aristas entre nodos angularmente cercanos
    for (let i=0;i<N;i++){
      for (let j=i+1;j<N;j++){
        const dot = pts[i].x*pts[j].x + pts[i].y*pts[j].y + pts[i].z*pts[j].z;
        if (dot>0.86) edges.push([i,j]);
      }
    }
  }

  // etiquetas DOM
  const labelEls: HTMLAnchorElement[] = DOMAINS.map(d=>{
    const a=document.createElement('a'); a.className='glb-label'; a.textContent=d.label;
    a.href=d.href; a.style.color=d.col; a.style.border=`1px solid ${d.col}55`;
    labelsBox.appendChild(a); return a;
  });

  function resize(){
    W=canvas.clientWidth; H=canvas.clientHeight;
    canvas.width=W*DPR; canvas.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0);
    cx=W/2; cy=H/2; scale=Math.min(W,H)*0.34;
    const cr=canvas.getBoundingClientRect(), sr=section.getBoundingClientRect();
    offX=cr.left-sr.left; offY=cr.top-sr.top;
    // campo de estrellas de fondo
    const SN=Math.round((W*H)/9000);
    stars=[]; for(let i=0;i<SN;i++){ stars.push({x:Math.random()*W, y:Math.random()*H, r:Math.random()*1.2+0.3, p:Math.random()*6.28}); }
  }

  // rotación
  let ax=0.3, ay=0, vax=0, vay=0.004;   // ángulos + velocidades
  let dragging=false, lastX=0, lastY=0, idle=true, t=0;

  const PERSP=2.6;
  function project(v:V){
    // rotar Y
    let cosY=Math.cos(ay), sinY=Math.sin(ay);
    let x1=v.x*cosY + v.z*sinY;
    let z1=-v.x*sinY + v.z*cosY;
    let y1=v.y;
    // rotar X
    let cosX=Math.cos(ax), sinX=Math.sin(ax);
    let y2=y1*cosX - z1*sinX;
    let z2=y1*sinX + z1*cosX;
    let x2=x1;
    const p = PERSP/(PERSP - z2);
    return { sx:cx + x2*scale*p, sy:cy + y2*scale*p, z:z2, p };
  }
  function hexA(hex:string,a:number){ const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); return `rgba(${r},${g},${b},${a})`; }

  function frame(){
    t++;
    if (!dragging){
      if (idle){ vay += (0.004-vay)*0.02; }       // vuelve a giro suave
      ax += vax; ay += vay;
      vax*=0.94; vay = idle ? vay : vay*0.94;
    }
    ctx.clearRect(0,0,W,H);

    // estrellas de fondo (parpadeo suave)
    for (const st of stars){
      const tw=0.4+0.4*Math.sin(t*0.03+st.p);
      ctx.beginPath(); ctx.arc(st.x,st.y,st.r,0,6.28);
      ctx.fillStyle=`rgba(200,220,255,${0.12+tw*0.25})`; ctx.fill();
    }
    // atmósfera del globo
    const atm=ctx.createRadialGradient(cx,cy,scale*0.6,cx,cy,scale*1.45);
    atm.addColorStop(0,'rgba(59,130,246,0.10)'); atm.addColorStop(0.7,'rgba(96,165,250,0.05)'); atm.addColorStop(1,'rgba(59,130,246,0)');
    ctx.fillStyle=atm; ctx.beginPath(); ctx.arc(cx,cy,scale*1.45,0,6.28); ctx.fill();

    const pr = pts.map(project);

    // aristas (alpha por profundidad media)
    for (const [i,j] of edges){
      const a=pr[i], b=pr[j];
      const depth=(a.z+b.z)/2;                      // -1..1
      const al=(depth+1)/2*0.5+0.05;
      ctx.strokeStyle=`rgba(96,165,250,${al})`;
      ctx.lineWidth=0.6;
      ctx.beginPath(); ctx.moveTo(a.sx,a.sy); ctx.lineTo(b.sx,b.sy); ctx.stroke();
    }
    // nodos
    for (let i=0;i<N;i++){
      const v=pts[i], s=pr[i];
      const depth=(s.z+1)/2;          // 0 atrás .. 1 delante
      if (v.dom>=0){
        const col=DOMAINS[v.dom].col;
        const rad=(3+depth*4);
        const g=ctx.createRadialGradient(s.sx,s.sy,0,s.sx,s.sy,rad*3);
        g.addColorStop(0,hexA(col,0.5*depth+0.2)); g.addColorStop(1,hexA(col,0));
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(s.sx,s.sy,rad*3,0,6.28); ctx.fill();
        ctx.beginPath(); ctx.arc(s.sx,s.sy,rad,0,6.28); ctx.fillStyle=col; ctx.fill();
      } else {
        ctx.beginPath(); ctx.arc(s.sx,s.sy,1+depth*1.6,0,6.28);
        ctx.fillStyle=`rgba(150,180,220,${0.2+depth*0.6})`; ctx.fill();
      }
    }

    // posicionar etiquetas en sus nodos
    let di=0;
    for (let i=0;i<N;i++){
      if (pts[i].dom<0) continue;
      const s=pr[i]; const k=pts[i].dom;
      labelEls[k].style.left=(offX+s.sx)+'px';
      labelEls[k].style.top=(offY+s.sy-16)+'px';
      const front=(s.z+1)/2;
      labelEls[k].style.opacity=String(front<0.45?0:(front-0.45)/0.55);
      labelEls[k].style.pointerEvents = front<0.55 ? 'none':'auto';
      di++;
    }

    requestAnimationFrame(frame);
  }

  // drag
  function down(x:number,y:number){ dragging=true; idle=false; lastX=x; lastY=y; if(hint)hint.style.opacity='0'; }
  function move(x:number,y:number){ if(!dragging)return; const dx=x-lastX, dy=y-lastY; ay+=dx*0.006; ax+=dy*0.006; ax=Math.max(-1.3,Math.min(1.3,ax)); vay=dx*0.006; vax=dy*0.006; lastX=x; lastY=y; }
  function up(){ dragging=false; setTimeout(()=>{ idle=true; }, 1800); }

  canvas.addEventListener('mousedown', e=>down(e.clientX,e.clientY));
  window.addEventListener('mousemove', e=>move(e.clientX,e.clientY));
  window.addEventListener('mouseup', up);
  canvas.addEventListener('touchstart', e=>{ if(e.touches[0]) down(e.touches[0].clientX,e.touches[0].clientY); }, {passive:true});
  window.addEventListener('touchmove', e=>{ if(e.touches[0]) move(e.touches[0].clientX,e.touches[0].clientY); }, {passive:true});
  window.addEventListener('touchend', up);

  buildSphere();
  resize();
  window.addEventListener('resize', resize);

  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce){ vay=0; // dibujar estático una vez
    ctx.clearRect(0,0,W,H); const pr=pts.map(project);
    for(const [i,j] of edges){ const a=pr[i],b=pr[j]; ctx.strokeStyle='rgba(96,165,250,0.3)'; ctx.lineWidth=0.6; ctx.beginPath(); ctx.moveTo(a.sx,a.sy); ctx.lineTo(b.sx,b.sy); ctx.stroke(); }
    for(let i=0;i<N;i++){ const s=pr[i],v=pts[i]; if(v.dom>=0){ctx.fillStyle=DOMAINS[v.dom].col; ctx.beginPath(); ctx.arc(s.sx,s.sy,4,0,6.28); ctx.fill();} else {ctx.fillStyle='rgba(150,180,220,0.5)'; ctx.beginPath(); ctx.arc(s.sx,s.sy,1.5,0,6.28); ctx.fill();} }
    for(let i=0;i<N;i++){ if(pts[i].dom<0)continue; const s=pr[i],k=pts[i].dom; labelEls[k].style.left=(offX+s.sx)+'px'; labelEls[k].style.top=(offY+s.sy-16)+'px'; labelEls[k].style.opacity='1'; }
  } else {
    requestAnimationFrame(frame);
  }
})();
</script>
