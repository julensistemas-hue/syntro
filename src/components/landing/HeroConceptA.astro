---
// HeroConceptA — "Núcleo conectado"
// Nodo central AI Security con los 4 dominios orbitando y conexiones animadas.
// Visualiza la tesis: todo conectado a un mismo centro = todo optimizado.

const domains = [
  { key: 'ia',     label: 'Inteligencia Artificial', short: 'IA',             color: '#60a5fa', href: '/consultoria-ia',           pos: 'top',    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  { key: 'ciber',  label: 'Ciberseguridad',          short: 'Ciberseguridad', color: '#34d399', href: '/wazuh',                    pos: 'right',  icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { key: 'auto',   label: 'Automatización',          short: 'Automatización', color: '#fbbf24', href: '/servicios/automatizacion', pos: 'bottom', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { key: 'sist',   label: 'Sistemas IT',             short: 'Sistemas',       color: '#a78bfa', href: '/soporte-tecnico',          pos: 'left',   icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z' },
];
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 py-20" style="background:#020817;">

  <!-- Grid de fondo -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(59,130,246,0.10) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,0.10) 1px,transparent 1px);background-size:48px 48px;opacity:0.5;"></div>
  <!-- Viñeta -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 75% 60% at 50% 45%,transparent 30%,rgba(2,8,23,0.9) 100%);"></div>

  <div class="relative w-full max-w-5xl mx-auto text-center" style="z-index:10;">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6 border" style="background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.3);color:#7cc0ff;letter-spacing:0.08em;text-transform:uppercase;">
      <span style="width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 8px #4ade80;display:inline-block;"></span>
      Tu partner tecnológico de confianza
    </div>

    <!-- H1 -->
    <h1 class="font-extrabold tracking-tight mb-5" style="font-size:clamp(2rem,5.5vw,3.6rem);line-height:1.08;color:#f0f6ff;">
      IA, ciberseguridad y sistemas.<br>
      <span style="background:linear-gradient(90deg,#60a5fa,#a78bfa,#34d399);-webkit-background-clip:text;background-clip:text;color:transparent;">Todo conectado, todo optimizado.</span>
    </h1>

    <p class="mx-auto mb-2" style="max-width:42rem;font-size:clamp(1rem,2.2vw,1.2rem);line-height:1.6;color:rgba(240,246,255,0.72);">
      En vez de cinco proveedores que no se hablan entre sí, <strong style="color:#f0f6ff;font-weight:600;">un solo equipo</strong> que controla toda tu tecnología. Cuanto más conectado está todo, más se optimiza y automatiza solo.
    </p>

    <!-- ═══ HUB VISUALIZATION ═══ -->
    <div class="hub-wrap mx-auto my-8" style="position:relative;width:min(560px,90vw);aspect-ratio:1;">

      <!-- SVG líneas de conexión (flujo hacia el centro) -->
      <svg viewBox="0 0 560 560" class="absolute inset-0 w-full h-full" style="overflow:visible;" aria-hidden="true">
        <defs>
          <radialGradient id="hubCoreGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="rgba(59,130,246,0.45)"/>
            <stop offset="100%" stop-color="rgba(59,130,246,0)"/>
          </radialGradient>
        </defs>

        <!-- Anillo orbital -->
        <circle cx="280" cy="280" r="200" fill="none" stroke="rgba(96,165,250,0.12)" stroke-width="1" stroke-dasharray="4 8"/>
        <circle cx="280" cy="280" r="140" fill="none" stroke="rgba(96,165,250,0.08)" stroke-width="1"/>

        <!-- Glow central -->
        <circle cx="280" cy="280" r="120" fill="url(#hubCoreGlow)"/>

        <!-- Líneas centro ↔ nodos (top,right,bottom,left) -->
        <line class="hub-line" x1="280" y1="280" x2="280" y2="72"  stroke="#60a5fa" stroke-width="2"/>
        <line class="hub-line" x1="280" y1="280" x2="488" y2="280" stroke="#34d399" stroke-width="2"/>
        <line class="hub-line" x1="280" y1="280" x2="280" y2="488" stroke="#fbbf24" stroke-width="2"/>
        <line class="hub-line" x1="280" y1="280" x2="72"  y2="280" stroke="#a78bfa" stroke-width="2"/>

        <!-- Pulsos viajando hacia el centro -->
        <circle r="4" fill="#60a5fa"><animateMotion dur="2.4s" repeatCount="indefinite" path="M280,72 L280,280"/></circle>
        <circle r="4" fill="#34d399"><animateMotion dur="2.4s" begin="0.6s" repeatCount="indefinite" path="M488,280 L280,280"/></circle>
        <circle r="4" fill="#fbbf24"><animateMotion dur="2.4s" begin="1.2s" repeatCount="indefinite" path="M280,488 L280,280"/></circle>
        <circle r="4" fill="#a78bfa"><animateMotion dur="2.4s" begin="1.8s" repeatCount="indefinite" path="M72,280 L280,280"/></circle>
      </svg>

      <!-- Nodo central -->
      <div class="hub-core" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:clamp(96px,20vw,128px);height:clamp(96px,20vw,128px);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:radial-gradient(circle at 50% 35%,#0d1f44,#050d22);border:1.5px solid rgba(96,165,250,0.5);box-shadow:0 0 40px rgba(59,130,246,0.35),inset 0 1px 0 rgba(255,255,255,0.08);z-index:5;">
        <svg class="w-7 h-7 mb-0.5" fill="none" stroke="#7cc0ff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span style="font-size:0.6rem;font-weight:800;letter-spacing:0.1em;color:#f0f6ff;line-height:1;">AI SECURITY</span>
        <span style="font-size:0.5rem;color:rgba(124,192,255,0.7);margin-top:2px;">el centro</span>
      </div>

      <!-- Nodos satélite -->
      {domains.map(d => (
        <a href={d.href} class={`hub-node hub-node-${d.pos}`} style={`--c:${d.color};`}>
          <div class="hub-node-inner">
            <div class="hub-node-icon" style={`background:rgba(${d.color === '#60a5fa' ? '96,165,250' : d.color === '#34d399' ? '52,211,153' : d.color === '#fbbf24' ? '251,191,36' : '167,139,250'},0.14);`}>
              <svg class="w-5 h-5" fill="none" stroke={d.color} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={d.icon}/></svg>
            </div>
            <span class="hub-node-label">{d.short}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10">
      <a href="/reunion" class="cta-primary">
        Consulta gratuita
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="#servicios" class="cta-ghost">Ver todos los servicios</a>
    </div>

    <!-- Stats -->
    <div class="flex items-center justify-center gap-6">
      <div class="text-center"><div class="text-base font-bold" style="color:#60a5fa;">4 áreas</div><div class="text-xs" style="color:#94a3b8;">Un solo proveedor</div></div>
      <div style="width:1px;height:24px;background:rgba(255,255,255,0.08);"></div>
      <div class="text-center"><div class="text-base font-bold" style="color:#34d399;">Wazuh/ENS</div><div class="text-xs" style="color:#94a3b8;">Cumplimiento</div></div>
      <div style="width:1px;height:24px;background:rgba(255,255,255,0.08);"></div>
      <div class="text-center"><div class="text-base font-bold" style="color:#fbbf24;">24/7</div><div class="text-xs" style="color:#94a3b8;">Monitorización</div></div>
    </div>

  </div>
</section>

<style>
  /* Pulso de las líneas */
  .hub-line { opacity:0.4; }

  /* Posicionamiento de nodos satélite */
  .hub-node {
    position:absolute;
    text-decoration:none;
    z-index:6;
    transform:translate(-50%,-50%);
  }
  .hub-node-top    { top:0;    left:50%; }
  .hub-node-right  { top:50%;  left:100%; }
  .hub-node-bottom { top:100%; left:50%; }
  .hub-node-left   { top:50%;  left:0; }

  .hub-node-inner {
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:6px;
    padding:10px 14px;
    border-radius:16px;
    background:rgba(7,15,32,0.85);
    border:1px solid color-mix(in srgb, var(--c) 35%, transparent);
    backdrop-filter:blur(6px);
    transition:transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    animation:nodeFloat 5s ease-in-out infinite;
  }
  .hub-node-right .hub-node-inner  { animation-delay:-1.2s; }
  .hub-node-bottom .hub-node-inner { animation-delay:-2.4s; }
  .hub-node-left .hub-node-inner   { animation-delay:-3.6s; }

  .hub-node:hover .hub-node-inner {
    transform:translateY(-4px) scale(1.05);
    border-color:var(--c);
    box-shadow:0 8px 28px -8px var(--c);
  }
  .hub-node-icon {
    width:40px;height:40px;border-radius:11px;
    display:flex;align-items:center;justify-content:center;
  }
  .hub-node-label {
    font-size:0.72rem;font-weight:700;color:#e2e8f0;white-space:nowrap;
  }

  @keyframes nodeFloat {
    0%,100% { transform:translateY(0); }
    50%     { transform:translateY(-7px); }
  }

  /* CTAs */
  .cta-primary {
    display:inline-flex;align-items:center;gap:0.5rem;
    background:#2563eb;color:#fff;font-weight:700;
    padding:0.8rem 1.6rem;border-radius:0.75rem;text-decoration:none;
    box-shadow:0 8px 24px rgba(37,99,235,0.4);
    transition:all 0.2s ease;
  }
  .cta-primary:hover { background:#1d4ed8;transform:translateY(-2px);box-shadow:0 12px 32px rgba(37,99,235,0.55); }
  .cta-ghost {
    display:inline-flex;align-items:center;
    color:#cbd5e1;font-weight:600;
    padding:0.8rem 1.4rem;border-radius:0.75rem;text-decoration:none;
    border:1px solid rgba(255,255,255,0.14);
    transition:all 0.2s ease;
  }
  .cta-ghost:hover { color:#fff;border-color:rgba(255,255,255,0.3);background:rgba(255,255,255,0.04); }

  /* ── Móvil: el hub se reduce y los nodos se acercan ── */
  @media (max-width: 520px) {
    .hub-node-icon { width:34px;height:34px; }
    .hub-node-label { font-size:0.65rem; }
    .hub-node-inner { padding:7px 10px; }
  }
</style>
