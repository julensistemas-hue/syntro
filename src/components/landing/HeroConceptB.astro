---
// HeroConceptB — "Los 4 pilares"
// Hero tipo panel de control: headline + 4 tarjetas-pilar conectadas.
// Cada pilar = keyword fuerte para SEO.

const pillars = [
  { label: 'Inteligencia Artificial', desc: 'Chatbots, gestor documental, atención de llamadas y citas con IA.', color: '#60a5fa', rgb: '96,165,250',  href: '/consultoria-ia',           icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  { label: 'Ciberseguridad',          desc: 'Wazuh SIEM, cumplimiento ENS y monitorización de amenazas 24/7.',     color: '#34d399', rgb: '52,211,153',  href: '/wazuh',                    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { label: 'Sistemas IT',             desc: 'Administración de servidores, copias de seguridad y soporte técnico.', color: '#a78bfa', rgb: '167,139,250', href: '/soporte-tecnico',          icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { label: 'Automatización',          desc: 'Procesos repetitivos automatizados que ahorran horas cada semana.',   color: '#fbbf24', rgb: '251,191,36',  href: '/servicios/automatizacion', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
];
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 py-20" style="background:#020817;">

  <!-- Grid de fondo -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(59,130,246,0.10) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,0.10) 1px,transparent 1px);background-size:48px 48px;opacity:0.5;"></div>
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 85% 65% at 50% 40%,rgba(37,99,235,0.16) 0%,transparent 70%);"></div>

  <div class="relative w-full max-w-6xl mx-auto" style="z-index:10;">

    <!-- Cabecera -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6 border" style="background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.3);color:#7cc0ff;letter-spacing:0.08em;text-transform:uppercase;">
        <span style="width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 8px #4ade80;display:inline-block;"></span>
        Tu partner tecnológico de confianza
      </div>

      <h1 class="font-extrabold tracking-tight mb-5" style="font-size:clamp(2rem,5.5vw,3.6rem);line-height:1.08;color:#f0f6ff;">
        IA, ciberseguridad y sistemas.<br>
        <span style="background:linear-gradient(90deg,#60a5fa,#a78bfa,#34d399);-webkit-background-clip:text;background-clip:text;color:transparent;">Todo conectado, todo optimizado.</span>
      </h1>

      <p class="mx-auto" style="max-width:44rem;font-size:clamp(1rem,2.2vw,1.2rem);line-height:1.6;color:rgba(240,246,255,0.72);">
        Un solo proveedor para toda tu tecnología. Cuando un mismo equipo controla tus sistemas, todo se integra mejor, se optimiza y se automatiza solo.
      </p>
    </div>

    <!-- 4 Pilares -->
    <div class="pillars-grid">
      {pillars.map((p, i) => (
        <a href={p.href} class="pillar-card" style={`--c:${p.color};--rgb:${p.rgb};animation-delay:${i * 0.1}s;`}>
          <div class="pillar-icon" style={`background:rgba(${p.rgb},0.12);border:1px solid rgba(${p.rgb},0.25);`}>
            <svg class="w-6 h-6" fill="none" stroke={p.color} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={p.icon}/></svg>
          </div>
          <h3 class="pillar-title">{p.label}</h3>
          <p class="pillar-desc">{p.desc}</p>
          <span class="pillar-link" style={`color:${p.color};`}>
            Ver más
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>

    <!-- Línea de integración -->
    <div class="flex items-center justify-center gap-3 mt-8 mb-10">
      <div style="flex:1;max-width:120px;height:1px;background:linear-gradient(to right,transparent,rgba(96,165,250,0.4));"></div>
      <span style="font-size:0.72rem;font-weight:600;color:#94a3b8;letter-spacing:0.12em;text-transform:uppercase;white-space:nowrap;">Integrado bajo un mismo equipo</span>
      <div style="flex:1;max-width:120px;height:1px;background:linear-gradient(to left,transparent,rgba(52,211,153,0.4));"></div>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/reunion" class="cta-primary">
        Consulta gratuita
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="#servicios" class="cta-ghost">Ver todos los servicios</a>
    </div>

  </div>
</section>

<style>
  .pillars-grid {
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:1rem;
  }
  .pillar-card {
    display:flex;flex-direction:column;
    padding:1.5rem;border-radius:1rem;
    background:rgba(255,255,255,0.035);
    border:1px solid color-mix(in srgb, var(--c) 18%, transparent);
    backdrop-filter:blur(8px);
    text-decoration:none;
    transition:transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
    animation:pillarIn 0.6s ease-out both;
  }
  .pillar-card:hover {
    transform:translateY(-6px);
    border-color:var(--c);
    background:rgba(var(--rgb),0.06);
    box-shadow:0 16px 40px -12px rgba(var(--rgb),0.45);
  }
  .pillar-icon {
    width:52px;height:52px;border-radius:14px;
    display:flex;align-items:center;justify-content:center;
    margin-bottom:1rem;
    transition:transform 0.25s ease;
  }
  .pillar-card:hover .pillar-icon { transform:scale(1.1) rotate(-4deg); }
  .pillar-title { font-size:1.05rem;font-weight:700;color:#f0f6ff;margin-bottom:0.5rem; }
  .pillar-desc { font-size:0.85rem;line-height:1.5;color:rgba(240,246,255,0.6);flex:1;margin-bottom:1rem; }
  .pillar-link { display:inline-flex;align-items:center;gap:0.35rem;font-size:0.8rem;font-weight:700; }

  @keyframes pillarIn {
    from { opacity:0;transform:translateY(24px); }
    to   { opacity:1;transform:translateY(0); }
  }

  /* CTAs */
  .cta-primary {
    display:inline-flex;align-items:center;gap:0.5rem;
    background:#2563eb;color:#fff;font-weight:700;
    padding:0.8rem 1.6rem;border-radius:0.75rem;text-decoration:none;
    box-shadow:0 8px 24px rgba(37,99,235,0.4);
    transition:all 0.2s ease;
  }
  .cta-primary:hover { background:#1d4ed8;transform:translateY(-2px);box-shadow:0 12px 32px rgba(37,99,235,0.55); }
  .cta-ghost {
    display:inline-flex;align-items:center;
    color:#cbd5e1;font-weight:600;
    padding:0.8rem 1.4rem;border-radius:0.75rem;text-decoration:none;
    border:1px solid rgba(255,255,255,0.14);
    transition:all 0.2s ease;
  }
  .cta-ghost:hover { color:#fff;border-color:rgba(255,255,255,0.3);background:rgba(255,255,255,0.04); }

  /* Responsive grid */
  @media (max-width: 900px) { .pillars-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width: 480px) { .pillars-grid { grid-template-columns:1fr; } }
</style>
