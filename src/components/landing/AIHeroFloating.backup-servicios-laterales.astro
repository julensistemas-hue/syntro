// ─── Lógica del panel ─────────────────────────────────────────────────────
const panel       = document.getElementById('service-panel')!;
const panelInner  = document.getElementById('service-panel-inner')!;
const panelClose  = document.getElementById('service-panel-close')!;
const overlay     = document.getElementById('panel-overlay')!;
let activeBtn: HTMLElement | null = null;

function openPanel(btn: HTMLElement) {
  const id   = btn.dataset.card!;
  const data = PANEL_CONTENT[id];
  if (!data) return;

  // Posición horizontal según lado
  const isLeft = data.side === 'left';
  panel.style.left  = isLeft ? 'auto' : '';
  panel.style.right = isLeft ? '' : 'auto';

  // Posicionar junto al botón pulsado
  const rect = btn.getBoundingClientRect();
  const margin = 12;

  if (isLeft) {
    panel.style.left = (rect.right + margin) + 'px';
    panel.style.right = 'auto';
  } else {
    panel.style.right = (window.innerWidth - rect.left + margin) + 'px';
    panel.style.left = 'auto';
  }

  // Inyectar contenido + botón de navegación al servicio
  const href = btn.dataset.href || '/';
  panelInner.innerHTML = data.html + `
    <a href="${href}" style="display:flex;align-items:center;justify-content:center;gap:6px;width:100%;padding:9px;font-size:12px;font-weight:600;color:#60a5fa;text-decoration:none;background:rgba(96,165,250,0.07);border-top:1px solid rgba(255,255,255,0.06);transition:background 0.2s;"
       onmouseover="this.style.background='rgba(96,165,250,0.14)'" onmouseout="this.style.background='rgba(96,165,250,0.07)'">
      Ver servicio completo
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>`;
  panel.classList.remove('hidden');
  panel.classList.remove('panel-enter');
  void panel.offsetWidth; // reflow
  panel.classList.add('panel-enter');

  overlay.classList.remove('hidden');

  // Marcar activo
  activeBtn?.classList.remove('active');
  btn.classList.add('active');
  activeBtn = btn;
}

function closePanel() {
  panel.classList.add('hidden');
  overlay.classList.add('hidden');
  activeBtn?.classList.remove('active');
  activeBtn = null;
}

document.querySelectorAll<HTMLElement>('.service-btn').forEach(btn => {
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (btn === activeBtn) { closePanel(); return; }
    openPanel(btn);
  });
});

panelClose.addEventListener('click', closePanel);
overlay.addEventListener('click', closePanel);

// ─── Canvas partículas ────────────────────────────────────────────────────
(function () {
  const canvas = document.getElementById('neural-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  const isMobile = window.innerWidth < 768;
  const COUNT    = isMobile ? 35 : 70;
  const MAX_DIST = isMobile ? 110 : 150;
  const SPEED    = 0.3;

  function resize() { canvas.width=canvas.offsetWidth; canvas.height=canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize, { passive:true });

  interface P { x:number;y:number;vx:number;vy:number;r:number;alpha:number; }
  const pts: P[] = Array.from({length:COUNT}, ()=>({
    x:Math.random()*canvas.width, y:Math.random()*canvas.height,
    vx:(Math.random()-0.5)*SPEED, vy:(Math.random()-0.5)*SPEED,
    r:Math.random()*1.8+0.8,     alpha:Math.random()*0.45+0.25,
  }));
  const COLORS=['59,130,246','99,102,241','167,139,250','52,211,153'];
  let raf:number, running=false;

  function draw() {
    ctx.clearRect(0,0,canvas.width,canvas.height);
    for(const p of pts){
      p.x+=p.vx; p.y+=p.vy;
      if(p.x<0||p.x>canvas.width) p.vx*=-1;
      if(p.y<0||p.y>canvas.height) p.vy*=-1;
    }
    for(let i=0;i<pts.length;i++) for(let j=i+1;j<pts.length;j++){
      const a=pts[i],b=pts[j],dx=a.x-b.x,dy=a.y-b.y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<MAX_DIST){ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.strokeStyle=`rgba(99,102,241,${(1-d/MAX_DIST)*0.2})`;ctx.lineWidth=0.7;ctx.stroke();}
    }
    pts.forEach((p,i)=>{ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=`rgba(${COLORS[i%COLORS.length]},${p.alpha})`;ctx.fill();});
    raf=requestAnimationFrame(draw);
  }
  window.addEventListener('load',()=>{setTimeout(()=>{running=true;draw();},400);});
  document.addEventListener('visibilitychange',()=>{
    if(document.hidden){cancelAnimationFrame(raf);running=false;}
    else if(!running){running=true;draw();}
  });
})();

