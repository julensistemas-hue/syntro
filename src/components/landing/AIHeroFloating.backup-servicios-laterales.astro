---
// AIHeroFloating — Red neuronal + servicios laterales clicables
// Izquierda: títulos Ciberseguridad | Centro: Chat | Derecha: títulos IA
---

<section class="relative min-h-screen overflow-hidden" style="background:#05070f;">

  <canvas id="neural-canvas" class="absolute inset-0 w-full h-full" aria-hidden="true"></canvas>

  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(59,130,246,0.07) 0%,transparent 70%)"></div>
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 40% at 50% 100%,rgba(99,102,241,0.05) 0%,transparent 70%)"></div>
  <div class="scan-line absolute w-full pointer-events-none" aria-hidden="true"></div>

  <!-- Layout: Izq | Centro | Der -->
  <div class="relative min-h-screen flex items-center justify-center gap-4 xl:gap-8 px-4 lg:px-6" style="z-index:10;">

    <!-- ═══════════════════════════
         IZQUIERDA — Ciberseguridad
    ═══════════════════════════ -->
    <div class="side-list hidden lg:flex flex-col gap-1" style="width:220px;flex-shrink:0;">
      <div class="side-list-label flex items-center gap-2 mb-3">
        <div class="pulse-dot" style="background:#f85149;box-shadow:0 0 6px #f85149;"></div>
        <span style="color:#8b949e;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;">Ciberseguridad</span>
      </div>

      {[
        { id:'wazuh-alerts',   label:'Wazuh — Alertas SIEM',        color:'#f85149', rgb:'248,81,73',    href:'/wazuh',  featured: false },
        { id:'ens-compliance', label:'ENS · Cumplimiento Normativo', color:'#3fb950', rgb:'63,185,80',    href:'/wazuh',  featured: false },
        { id:'net-monitor',    label:'Monitor de Red',               color:'#58a6ff', rgb:'88,166,255',   href:'/wazuh',  featured: false },
        { id:'seo-ranking',    label:'Posicionamiento Web',          color:'#f0883e', rgb:'240,136,62',   href:'/blog',   featured: true  },
      ].map(s => (
        <button
          class={`service-btn service-btn-left group flex items-center gap-3 px-3 rounded-xl text-left transition-all w-full ${s.featured ? 'py-3' : 'py-2.5'}`}
          data-card={s.id}
          data-href={s.href}
          style={s.featured
            ? `--btn-color:rgba(240,136,62,0.7);--btn-border:rgba(240,136,62,0.35);background:rgba(240,136,62,0.07);`
            : `--btn-color:rgba(${s.rgb},0.7);--btn-border:rgba(${s.rgb},0.35);`}
        >
          <div class="service-dot flex-shrink-0" style={`width:7px;height:7px;border-radius:50%;background:${s.color};box-shadow:0 0 0px ${s.color};transition:box-shadow 0.3s;`}></div>
          <div class="flex-1 min-w-0">
            <span class="service-label font-medium transition-colors block" style={`color:${s.featured ? '#f0883e' : '#4b5563'};font-size:${s.featured ? '13px' : '13px'};`}>{s.label}</span>
            {s.featured && <span style="color:#6e7681;font-size:10px;">SEO · Analytics · SEM</span>}
          </div>
          {s.featured
            ? <span style="background:rgba(240,136,62,0.15);color:#f0883e;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;flex-shrink:0;">TOP</span>
            : <svg class="service-arrow ml-auto w-3.5 h-3.5 flex-shrink-0 opacity-0 transition-all -translate-x-1" style="color:#4b5563;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
          }
        </button>
      ))}
    </div>

    <!-- ═══════════════════════════
         CENTRO — Chat hero
    ═══════════════════════════ -->
    <div class="hero-box w-full max-w-2xl mx-auto rounded-3xl p-8 md:p-12 flex-shrink-0"
      style="z-index:10;background:rgba(5,7,15,0.85);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border:1px solid rgba(59,130,246,0.18);box-shadow:0 0 0 1px rgba(59,130,246,0.05),0 32px 80px -16px rgba(0,0,0,0.8),0 0 60px rgba(59,130,246,0.06),inset 0 1px 0 rgba(255,255,255,0.05);">

      <div class="flex justify-center mb-5">
        <span class="hero-badge inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold" style="background:rgba(59,130,246,0.12);border:1px solid rgba(59,130,246,0.25);color:#93c5fd;letter-spacing:0.05em;">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background:#3b82f6;"></span>
            <span class="relative inline-flex rounded-full h-2 w-2" style="background:#60a5fa;"></span>
          </span>
          IA + CIBERSEGURIDAD PARA PYMES
        </span>
      </div>

      <h1 class="hero-title text-3xl sm:text-4xl font-bold leading-tight tracking-tight mb-4 text-center" style="color:#f0f6ff;">
        Automatiza lo que se repite.
        <span class="block mt-1" style="background:linear-gradient(90deg,#60a5fa 0%,#818cf8 50%,#a78bfa 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
          Protege lo que importa.
        </span>
      </h1>

      <p class="hero-subtitle text-base mb-7 max-w-md mx-auto text-center" style="color:#94a3b8;">
        IA para ahorrar tiempo en lo que se repite. Wazuh y sistemas para blindar lo que no puedes permitirte perder.
      </p>

      <div class="hero-input-container">
        <form id="chat-form">
          <div class="chat-input-wrapper rounded-2xl px-2 py-1.5 transition-all" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);">
            <div id="chat-response" class="hidden px-3 py-3">
              <div id="chat-response-text" class="text-sm leading-relaxed" style="color:#e2e8f0;"></div>
              <div id="email-contact" class="mt-3 pt-3" style="border-top:1px solid rgba(255,255,255,0.08);">
                <p class="text-xs mb-2" style="color:#94a3b8;">¿Quieres que te respondamos con más detalle?</p>
                <div id="email-input-row" class="flex items-center gap-2">
                  <input type="email" id="email-input" placeholder="Tu email..." class="flex-1 bg-transparent px-3 py-1.5 text-sm focus:outline-none rounded-lg" style="color:#f0f6ff;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);" />
                  <button type="button" id="email-send" class="px-3 py-1.5 text-xs font-medium text-white rounded-lg" style="background:#2563eb;">Enviar</button>
                </div>
                <p id="email-success" class="hidden text-xs mt-2" style="color:#4ade80;">Recibido. Te contestaremos lo antes posible.</p>
                <p id="email-error" class="hidden text-xs mt-2" style="color:#f87171;">Error. Prueba en info@aisecurity.es</p>
              </div>
              <button type="button" id="chat-back" class="mt-3 flex items-center gap-1.5 text-xs" style="color:#60a5fa;">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Nueva pregunta
              </button>
            </div>
            <div id="chat-input-row" class="flex items-center">
              <input type="text" id="chat-input" placeholder="Pregunta sobre nuestros servicios..." class="flex-1 bg-transparent px-3 py-2.5 focus:outline-none text-sm" style="color:#f0f6ff;" />
              <button type="submit" class="p-2.5 rounded-xl flex items-center justify-center" style="background:#2563eb;color:white;">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
              </button>
            </div>
            <div id="chat-typing" class="hidden px-3 py-3">
              <div class="flex gap-1.5 items-center">
                <div class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#60a5fa;animation-delay:0ms"></div>
                <div class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#60a5fa;animation-delay:150ms"></div>
                <div class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#60a5fa;animation-delay:300ms"></div>
                <span class="text-xs ml-2" style="color:#64748b;">Pensando...</span>
              </div>
            </div>
          </div>
        </form>

        <div id="quick-buttons" class="flex flex-wrap gap-2 mt-4 justify-center">
          <button class="quick-question flex items-center gap-1.5 px-3 py-1.5 text-xs rounded-full transition-all" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);color:#94a3b8;">
            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#60a5fa;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            ¿Cuánto cuesta una web?
          </button>
          <button class="quick-question flex items-center gap-1.5 px-3 py-1.5 text-xs rounded-full transition-all" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);color:#94a3b8;">
            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#4ade80;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            ¿Qué puedo automatizar?
          </button>
          <button class="quick-question flex items-center gap-1.5 px-3 py-1.5 text-xs rounded-full transition-all" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);color:#94a3b8;">
            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#a78bfa;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            ¿Qué es Wazuh?
          </button>
        </div>
      </div>

      <div class="hero-stats flex items-center justify-center gap-5 mt-7 pt-6" style="border-top:1px solid rgba(255,255,255,0.06);">
        <div class="text-center">
          <div class="text-base font-bold" style="color:#60a5fa;">24/7</div>
          <div class="text-xs" style="color:#475569;">Disponibilidad</div>
        </div>
        <div style="width:1px;height:24px;background:rgba(255,255,255,0.07);"></div>
        <div class="text-center">
          <div class="text-base font-bold" style="color:#a78bfa;">Wazuh/ENS</div>
          <div class="text-xs" style="color:#475569;">Ciberseguridad</div>
        </div>
        <div style="width:1px;height:24px;background:rgba(255,255,255,0.07);"></div>
        <div class="text-center">
          <div class="text-base font-bold" style="color:#4ade80;">PyMEs ES</div>
          <div class="text-xs" style="color:#475569;">Nuestro foco</div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════
         DERECHA — Automatización IA
    ═══════════════════════════ -->
    <div class="side-list hidden lg:flex flex-col gap-1" style="width:220px;flex-shrink:0;">
      <div class="side-list-label flex items-center gap-2 mb-3 justify-end">
        <span style="color:#8b949e;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;">Automatización IA</span>
        <div class="pulse-dot" style="background:#818cf8;box-shadow:0 0 6px #818cf8;"></div>
      </div>

      {[
        { id:'chatbot',      label:'Chatbot Inteligente 24/7',   color:'#818cf8', rgb:'129,140,248', href:'/servicios/chatbot' },
        { id:'automation',   label:'Automatización de Procesos', color:'#34d399', rgb:'52,211,153',  href:'/servicios/automatizacion' },
        { id:'receptionist', label:'Recepcionista IA',           color:'#a78bfa', rgb:'167,139,250', href:'/servicios/atencion-llamadas' },
        { id:'calendar',     label:'Gestor de Citas IA',         color:'#60a5fa', rgb:'96,165,250',  href:'/servicios/gestor-citas' },
        { id:'docmanager',   label:'Gestor Documental IA',       color:'#f0883e', rgb:'240,136,62',  href:'/servicios/gestor-documental' },
        { id:'webdev',       label:'Desarrollo Web',             color:'#38bdf8', rgb:'56,189,248',  href:'/servicios/desarrollo-web' },
      ].map(s => (
        <button
          class="service-btn service-btn-right group flex items-center gap-3 px-3 py-2.5 rounded-xl text-left transition-all w-full"
          data-card={s.id}
          data-href={s.href}
          style={`--btn-color:rgba(${s.rgb},0.7);--btn-border:rgba(${s.rgb},0.35);`}
        >
          <svg class="service-arrow mr-auto w-3.5 h-3.5 flex-shrink-0 opacity-0 transition-all translate-x-1" style="color:#4b5563;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span class="service-label text-sm font-medium transition-colors flex-1" style="color:#4b5563;">{s.label}</span>
          <div class="service-dot flex-shrink-0" style={`width:7px;height:7px;border-radius:50%;background:${s.color};box-shadow:0 0 0px ${s.color};transition:box-shadow 0.3s;`}></div>
        </button>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════
       PANEL FLOTANTE de detalle (se muestra al hacer clic)
  ═══════════════════════════ -->
  <div id="service-panel" class="hidden fixed pointer-events-auto" style="z-index:50;top:50%;transform:translateY(-50%);">
    <div id="service-panel-inner" style="width:280px;border-radius:16px;overflow:hidden;box-shadow:0 25px 60px -12px rgba(0,0,0,0.8),0 0 40px rgba(59,130,246,0.12);">
      <!-- El contenido se inyecta por JS -->
    </div>
    <button id="service-panel-close" class="absolute flex items-center justify-center w-7 h-7 rounded-full" style="top:-10px;right:-10px;background:rgba(30,30,50,0.95);border:1px solid rgba(255,255,255,0.12);color:#9ca3af;">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Overlay para cerrar el panel -->
  <div id="panel-overlay" class="hidden fixed inset-0" style="z-index:40;"></div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" style="z-index:20;">
    <div class="flex flex-col items-center gap-2 animate-bounce" style="color:#475569;">
      <span class="text-xs font-medium">Descubre más</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </div>
</section>

<style>
  @keyframes scanLine {
    0%   { top:-2px;opacity:0; }
    5%   { opacity:0.4; }
    95%  { opacity:0.1; }
    100% { top:100%;opacity:0; }
  }
  .scan-line {
    height:1px;
    background:linear-gradient(90deg,transparent 0%,rgba(59,130,246,0.6) 30%,rgba(99,102,241,0.8) 50%,rgba(59,130,246,0.6) 70%,transparent 100%);
    animation:scanLine 8s linear infinite 2s;
    z-index:3;opacity:0;
  }

  .pulse-dot {
    width:6px;height:6px;border-radius:50%;flex-shrink:0;
    animation:pulseDot 2.5s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%,100% { opacity:1;transform:scale(1); }
    50%     { opacity:0.6;transform:scale(1.3); }
  }

  /* Botones de servicio — border controlado siempre por CSS, no inline */
  .service-btn {
    border: 1px solid var(--btn-border, transparent) !important;
    background: transparent;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .service-btn:hover {
    background: rgba(255,255,255,0.04) !important;
    --btn-border: var(--btn-color);
  }
  .service-btn:hover .service-label { color:#c9d1d9 !important; }
  .service-btn:hover .service-dot   { box-shadow:0 0 8px var(--btn-color,#fff) !important; }
  .service-btn:hover .service-arrow { opacity:1 !important;transform:translateX(0) !important; }

  .service-btn.active {
    background:rgba(255,255,255,0.06) !important;
    --btn-border: var(--btn-color);
  }
  .service-btn.active .service-label { color:#f0f6ff !important; font-weight:600; }
  .service-btn.active .service-arrow { opacity:1 !important;transform:translateX(0) !important; }

  /* Panel flotante */
  #service-panel {
    transition:opacity 0.2s ease,transform 0.2s ease;
  }
  #service-panel.panel-enter {
    animation:panelIn 0.25s ease-out both;
  }
  @keyframes panelIn {
    from { opacity:0;transform:translateY(-50%) scale(0.95); }
    to   { opacity:1;transform:translateY(-50%) scale(1); }
  }

  /* Hero fade in */
  .hero-badge          { animation:fadeInUp 0.6s ease-out both; }
  .hero-title          { animation:fadeInUp 0.7s ease-out 0.1s both; }
  .hero-subtitle       { animation:fadeInUp 0.7s ease-out 0.2s both; }
  .hero-input-container { animation:fadeInUp 0.7s ease-out 0.3s both; }
  .hero-stats          { animation:fadeInUp 0.7s ease-out 0.45s both; }
  .side-list           { animation:fadeInUp 0.8s ease-out 0.2s both; }

  @keyframes fadeInUp {
    from { opacity:0;transform:translateY(16px); }
    to   { opacity:1;transform:translateY(0); }
  }

  .chat-input-wrapper:focus-within {
    background:rgba(255,255,255,0.06) !important;
    border-color:rgba(59,130,246,0.4) !important;
    box-shadow:0 0 24px rgba(59,130,246,0.1);
  }
  .quick-question:hover {
    background:rgba(255,255,255,0.08) !important;
    border-color:rgba(255,255,255,0.15) !important;
    color:#e2e8f0 !important;
  }
</style>

<script>
// ─── Contenido de los paneles ─────────────────────────────────────────────
const PANEL_CONTENT: Record<string, { html: string; side: 'left'|'right' }> = {
  'wazuh-alerts': {
    side: 'left',
    html: `<div style="background:#0d1117;padding:16px;font-family:system-ui,sans-serif;">
      <div style="display:flex;align-items:center;gap:7px;margin-bottom:10px;">
        <div style="width:7px;height:7px;background:#f85149;border-radius:50%;box-shadow:0 0 5px #f85149;flex-shrink:0;"></div>
        <span style="color:#e6edf3;font-size:12px;font-weight:600;">Wazuh — Alertas en vivo</span>
        <span style="margin-left:auto;background:rgba(248,81,73,0.15);color:#f85149;font-size:10px;padding:1px 7px;border-radius:4px;font-weight:700;">3 críticas</span>
      </div>
      <div style="background:rgba(248,81,73,0.07);border-left:3px solid #f85149;padding:7px 9px;margin-bottom:5px;border-radius:0 4px 4px 0;">
        <div style="color:#f85149;font-size:10px;font-weight:700;">CRÍTICO · Nivel 15</div>
        <div style="color:#c9d1d9;font-size:11px;margin-top:1px;">Brute force SSH — 192.168.1.45</div>
        <div style="color:#6e7681;font-size:10px;margin-top:1px;">hace 2 min · agent-prod-01</div>
      </div>
      <div style="background:rgba(240,136,62,0.07);border-left:3px solid #f0883e;padding:7px 9px;margin-bottom:5px;border-radius:0 4px 4px 0;">
        <div style="color:#f0883e;font-size:10px;font-weight:700;">ALTO · Nivel 12</div>
        <div style="color:#c9d1d9;font-size:11px;margin-top:1px;">Modificación en /etc/passwd</div>
        <div style="color:#6e7681;font-size:10px;margin-top:1px;">hace 8 min · agent-web-02</div>
      </div>
      <div style="display:flex;gap:6px;margin-top:10px;">
        <div style="flex:1;background:rgba(255,255,255,0.04);border-radius:6px;padding:6px;text-align:center;"><div style="color:#f85149;font-size:15px;font-weight:700;">247</div><div style="color:#6e7681;font-size:9px;">alertas hoy</div></div>
        <div style="flex:1;background:rgba(255,255,255,0.04);border-radius:6px;padding:6px;text-align:center;"><div style="color:#3fb950;font-size:15px;font-weight:700;">12</div><div style="color:#6e7681;font-size:9px;">agentes</div></div>
        <div style="flex:1;background:rgba(255,255,255,0.04);border-radius:6px;padding:6px;text-align:center;"><div style="color:#58a6ff;font-size:15px;font-weight:700;">99.8%</div><div style="color:#6e7681;font-size:9px;">uptime</div></div>
      </div>
    </div>`
  },
  'ens-compliance': {
    side: 'left',
    html: `<div style="background:#0d1117;padding:16px;font-family:system-ui,sans-serif;">
      <div style="display:flex;align-items:center;gap:7px;margin-bottom:12px;">
        <div style="width:7px;height:7px;background:#3fb950;border-radius:50%;box-shadow:0 0 5px #3fb950;flex-shrink:0;"></div>
        <span style="color:#e6edf3;font-size:12px;font-weight:600;">ENS · Nivel MEDIO</span>
        <span style="margin-left:auto;background:rgba(63,185,80,0.15);color:#3fb950;font-size:10px;padding:1px 7px;border-radius:4px;font-weight:700;">89%</span>
      </div>
      ${[['Control de Acceso',94],['Gestión de Logs',88],['Cifrado de Datos',100],['Detección Intrus.',91]].map(([l,p])=>`
