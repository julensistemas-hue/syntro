---
// "Lo que tu empresa gana" — sección de resultados con cifras + garantías.
// Sustituye al antiguo "Proceso de Implementación" por algo de más valor.

const metrics = [
  { accent:'#60a5fa', rgb:'96,165,250',  count:15, prefix:'hasta ', value:'15', unit:'h', title:'ahorradas cada semana', desc:'Automatizamos las tareas repetitivas que hoy consumen a tu equipo.' },
  { accent:'#818cf8', rgb:'129,140,248', value:'24/7', unit:'', title:'atención sin descanso', desc:'Chatbot y llamadas con IA que responden de día, de noche y en festivos.' },
  { accent:'#c084fc', rgb:'192,132,252', count:0, value:'0', unit:'', title:'llamadas y clientes perdidos', desc:'La recepción IA contesta siempre, aunque estés ocupado o cerrado.' },
  { accent:'#a78bfa', rgb:'167,139,250', value:'<1', unit:'sem', title:'para verlo funcionando', desc:'Implantación rápida sin frenar tu operativa ni cambiar lo que ya usas.' },
];

const guarantees = [
  'Primera consulta gratis',
  'Sin permanencia',
  'Formación del equipo incluida',
  'Resultados medibles',
];
---

<section class="py-24 lg:py-32 relative overflow-hidden" style="background: linear-gradient(180deg, #0d1120 0%, #111827 100%);">
  <!-- Glow ambiental -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 55% at 50% 0%, rgba(99,102,241,0.14), transparent 70%);"></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold mb-6 border" style="background: rgba(129,140,248,0.1); border-color: rgba(129,140,248,0.3); color: #a5b4fc;">
        <span aria-hidden="true">📈</span>
        Resultados reales
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold mb-6 tracking-tight" style="color: #f0f6ff;">
        Lo que tu empresa gana con <span style="background:linear-gradient(90deg,#60a5fa,#a78bfa,#c084fc);-webkit-background-clip:text;background-clip:text;color:transparent;">AI Security</span>
      </h2>
      <p class="text-lg md:text-xl max-w-3xl mx-auto leading-relaxed" style="color: rgba(240,246,255,0.65);">
        No vendemos tecnología por tecnología. Vendemos tiempo recuperado, clientes que no se escapan y procesos que funcionan solos — desde la primera semana.
      </p>
    </div>

    <!-- Métricas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
      {metrics.map((m, i) => (
        <div class="val-card" style={`--a:${m.accent};--argb:${m.rgb};animation-delay:${i*0.09}s;`}>
          <div class="val-num">
            {m.prefix && <span class="val-prefix">{m.prefix}</span>}
            <span class="val-figure" data-count={m.count ?? ''} data-value={m.value}>{m.value}</span>{m.unit && <span class="val-unit">{m.unit}</span>}
          </div>
          <div class="val-title">{m.title}</div>
          <div class="val-desc">{m.desc}</div>
        </div>
      ))}
    </div>

    <!-- Garantías -->
    <div class="guarantee-bar">
      {guarantees.map(g => (
        <div class="guarantee-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          <span>{g}</span>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="/reunion" class="hiw-cta">
        Reserva tu consulta gratuita
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .val-card {
    position: relative;
    padding: 1.75rem 1.5rem;
    border-radius: 1rem;
    background: rgba(255,255,255,0.035);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(8px);
    overflow: hidden;
    opacity: 0;
    animation: valIn 0.6s ease-out forwards;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease, background .25s ease;
  }
  .val-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--a), transparent 85%);
  }
  .val-card:hover {
    transform: translateY(-6px);
    border-color: var(--a);
    background: rgba(var(--argb), 0.06);
    box-shadow: 0 18px 50px -18px rgba(var(--argb), 0.55);
  }
  .val-num {
    display: flex; align-items: baseline; gap: 0.15rem;
    font-weight: 900; line-height: 1;
    color: #f0f6ff;
    margin-bottom: 0.85rem;
  }
  .val-prefix { font-size: 0.85rem; font-weight: 600; color: rgba(240,246,255,0.5); margin-right: 0.3rem; align-self: center; }
  .val-figure { font-size: clamp(2.4rem, 5vw, 3.2rem); color: var(--a); text-shadow: 0 0 28px rgba(var(--argb), 0.4); }
  .val-unit { font-size: 1.4rem; font-weight: 800; color: var(--a); }
  .val-title { font-size: 1rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.4rem; }
  .val-desc { font-size: 0.85rem; line-height: 1.5; color: rgba(240,246,255,0.6); }

  @keyframes valIn { from { opacity: 0; transform: translateY(26px); } to { opacity: 1; transform: translateY(0); } }

  .guarantee-bar {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem 2rem;
    padding: 1.25rem 1.5rem;
    border-radius: 1rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .guarantee-item { display: flex; align-items: center; gap: 0.55rem; font-size: 0.92rem; font-weight: 600; color: #e2e8f0; }
  .guarantee-item svg { width: 1.15rem; height: 1.15rem; color: #60a5fa; flex-shrink: 0; }

  .hiw-cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.95rem 2rem; border-radius: 0.8rem;
    font-weight: 800; font-size: 1rem; text-decoration: none;
    color: #fff;
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
    box-shadow: 0 10px 36px -8px rgba(99,102,241,0.6);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .hiw-cta:hover { transform: translateY(-2px); box-shadow: 0 14px 46px -8px rgba(124,58,237,0.7); }

  @media (prefers-reduced-motion: reduce) {
    .val-card { opacity: 1; animation: none; }
  }
</style>

<script>
  // Conteo animado de las cifras numéricas al entrar en pantalla
  (function () {
    const figs = Array.from(document.querySelectorAll('.val-figure')) as HTMLElement[];
    if (!figs.length) return;
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function run(el: HTMLElement) {
      const target = parseInt(el.getAttribute('data-count') || '', 10);
      const finalText = el.getAttribute('data-value') || el.textContent || '';
      if (reduce || isNaN(target) || target <= 0) { el.textContent = finalText; return; }
      const dur = 1100; const start = performance.now();
      function tick(now: number) {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = String(Math.round(target * eased));
        if (p < 1) requestAnimationFrame(tick); else el.textContent = finalText;
      }
      requestAnimationFrame(tick);
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { run(e.target as HTMLElement); io.unobserve(e.target); } });
      }, { threshold: 0.5 });
      figs.forEach(f => io.observe(f));
    } else {
      figs.forEach(f => { f.textContent = f.getAttribute('data-value') || f.textContent; });
    }
  })();
</script>
