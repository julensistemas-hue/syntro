---
// HeroFusion — Linterna reveladora (fondo) + titular desencriptado (palabras)
// Fondo: red de infraestructura oculta con las 4 áreas y amenazas, revelada por
// el foco del cursor. Texto: se descifra al cargar y hace glitch siguiendo el ratón.
// Contexto real AI Security: IA · Ciberseguridad · Sistemas · Automatización.
---

<section id="fus-hero" class="relative overflow-hidden flex items-center justify-center px-6" style="background:#03060d;min-height:100vh;cursor:none;">

  <!-- Capa linterna -->
  <canvas id="fus-canvas" class="absolute inset-0" style="width:100%;height:100%;display:block;z-index:1;"></canvas>

  <!-- Viñeta central: atenúa nodos y líneas detrás del texto para que destaque -->
  <div class="absolute inset-0 pointer-events-none" style="z-index:2;background:radial-gradient(ellipse 44% 40% at 50% 47%, rgba(3,6,13,0.92) 0%, rgba(3,6,13,0.78) 38%, rgba(3,6,13,0.4) 60%, transparent 75%);"></div>

  <!-- Foco visual que sigue al cursor -->
  <div id="fus-cursor" style="position:absolute;width:16px;height:16px;border-radius:50%;pointer-events:none;z-index:30;transform:translate(-50%,-50%);background:radial-gradient(circle,#fff,rgba(255,255,255,0.2));box-shadow:0 0 24px 6px rgba(124,192,255,0.6);opacity:0;transition:opacity .3s;"></div>

  <!-- Línea de escaneo -->
  <div id="fus-scan" class="absolute left-0 right-0 pointer-events-none" style="height:2px;background:linear-gradient(90deg,transparent,rgba(129,140,248,0.5),transparent);z-index:6;top:0;"></div>

  <!-- Contenido -->
  <div class="relative w-full max-w-4xl mx-auto text-center" style="z-index:20;pointer-events:none;">

    <h1 class="sr-only">AI Security — IA, ciberseguridad y sistemas para empresas. Todo conectado, todo bajo control.</h1>

    <!-- Enlaces accesibles a los servicios (teclado y buscadores) — los nodos del canvas replican estos destinos -->
    <nav class="sr-only" aria-label="Servicios">
      <a href="/servicios/chatbot">Chatbot IA</a>
      <a href="/servicios/gestor-documental">Gestor documental</a>
      <a href="/servicios/atencion-llamadas">Atención de llamadas con IA</a>
      <a href="/servicios/gestor-citas">Gestor de citas</a>
      <a href="/consultoria-ia">Consultoría IA</a>
      <a href="/wazuh">Ciberseguridad Wazuh y cumplimiento ENS</a>
      <a href="/servicios/desarrollo-web">Desarrollo web</a>
      <a href="/servicios/geo-posicionamiento">Posicionamiento SEO y GEO</a>
      <a href="/servicios/automatizacion">Automatización de procesos</a>
    </nav>

    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-8 border" style="background:rgba(0,0,0,0.45);border-color:rgba(129,140,248,0.3);color:#a5b4fc;letter-spacing:0.16em;text-transform:uppercase;font-family:ui-monospace,monospace;backdrop-filter:blur(2px);">
      <span style="width:7px;height:7px;border-radius:50%;background:#818cf8;box-shadow:0 0 8px #818cf8;display:inline-block;"></span>
      AI Security · partner tecnológico
    </div>

    <!-- Titular desencriptable -->
    <div id="fus-h1" aria-hidden="true" class="font-black tracking-tight" style="font-size:clamp(2.1rem,7vw,4.6rem);line-height:1.04;color:#eaf2ff;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;text-shadow:0 2px 40px rgba(3,6,13,0.95),0 0 70px rgba(3,6,13,0.9);">
      <span class="fus-line" data-text="TODO"></span>
      <span class="fus-line" data-text="BAJO CONTROL"></span>
    </div>

    <!-- Rotor -->
    <p class="mt-6 font-bold" style="font-size:clamp(1.05rem,3vw,1.7rem);font-family:ui-monospace,monospace;color:#94a3b8;text-shadow:0 2px 24px rgba(3,6,13,0.95);">
      <span style="color:#60a5fa;">&gt;</span> todo
      <span id="fus-rotor" style="color:#a78bfa;"></span><span id="fus-caret" style="display:inline-block;width:0.55ch;height:1.05em;background:#818cf8;vertical-align:text-bottom;margin-left:2px;animation:fusBlink 1s step-end infinite;"></span>
    </p>

    <p class="mx-auto mt-7" style="max-width:40rem;font-size:clamp(0.98rem,2.2vw,1.18rem);line-height:1.6;color:rgba(220,232,255,0.66);text-shadow:0 1px 20px rgba(3,6,13,0.95);">
      IA, ciberseguridad y sistemas bajo un mismo equipo. Lo que no se ve no se controla — y lo que no se controla, no se optimiza. Nosotros lo iluminamos todo.
    </p>

    <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3" style="pointer-events:auto;">
      <a href="/reunion" id="fus-cta" style="display:inline-flex;align-items:center;gap:0.6rem;background:linear-gradient(135deg,#2563eb 0%,#7c3aed 100%);color:#fff;font-weight:800;padding:0.95rem 2rem;border-radius:0.7rem;text-decoration:none;font-family:ui-monospace,monospace;font-size:0.95rem;cursor:pointer;box-shadow:0 10px 36px -8px rgba(99,102,241,0.6);transition:transform .2s,box-shadow .2s;">
        Solicitar consulta gratuita
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="#servicios" id="fus-ghost" style="display:inline-flex;align-items:center;color:#cbd5e1;font-weight:600;font-family:ui-monospace,monospace;font-size:0.9rem;padding:0.85rem 1.3rem;border-radius:0.7rem;border:1px solid rgba(255,255,255,0.14);text-decoration:none;cursor:pointer;transition:all .2s;">Ver servicios</a>
    </div>

    <div id="fus-hint" class="mt-7 flex items-center justify-center gap-2" style="color:rgba(159,198,255,0.8);font-size:0.84rem;transition:opacity .5s;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
      Mueve el ratón para iluminar tu infraestructura
    </div>
  </div>

  <!-- Scroll -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2" style="z-index:20;pointer-events:none;">
    <div class="flex flex-col items-center gap-1 animate-bounce" style="color:rgba(159,198,255,0.6);">
      <span class="text-xs">Descubre más</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </div>
</section>

<style>
  @keyframes fusBlink { 0%,100%{opacity:1;} 50%{opacity:0;} }
  @keyframes fusScan { 0%{top:0;opacity:0;} 8%{opacity:1;} 92%{opacity:1;} 100%{top:100%;opacity:0;} }
  #fus-scan { animation:fusScan 8s linear infinite 1.5s; }
  #fus-h1 .fus-line { display:block; }
  #fus-h1 .fus-char { display:inline-block; transition:color .12s; }
  #fus-h1 .fus-char.scrambling { color:#a78bfa; text-shadow:0 0 14px rgba(167,139,250,0.7); }
  #fus-cta:hover { transform:translateY(-2px);box-shadow:0 14px 46px -8px rgba(124,58,237,0.7); }
  #fus-ghost:hover { color:#fff;border-color:rgba(255,255,255,0.3);background:rgba(255,255,255,0.04); }
  @media (max-width:640px){ #fus-hero{ cursor:auto; } #fus-cursor{ display:none; } }
</style>

<script>
(function () {
  const section = document.getElementById('fus-hero') as HTMLElement;
  const canvas  = document.getElementById('fus-canvas') as HTMLCanvasElement;
  const cursorEl = document.getElementById('fus-cursor') as HTMLElement;
  const hint    = document.getElementById('fus-hint') as HTMLElement;
  if (!section || !canvas) return;
  const ctx = canvas.getContext('2d')!;
  const lit = document.createElement('canvas');
  const lctx = lit.getContext('2d')!;
  // Máscara acumulativa: guarda TODO lo ya descubierto por la linterna
  const mask = document.createElement('canvas');
  const mctx = mask.getContext('2d')!;

  let W=0,H=0,DPR=Math.min(window.devicePixelRatio||1,2);
  let mx=-9999,my=-9999,hasPointer=false,t=0;

  type Kind='ia'|'cyber'|'system'|'auto'|'node'|'event';
  const COLORS:Record<Kind,string>={ ia:'#60a5fa', cyber:'#818cf8', system:'#a78bfa', auto:'#c084fc', node:'#5b7290', event:'#7cc0ff' };
  interface N{ x:number;y:number;r:number;kind:Kind;label?:string;href?:string;color?:string;phase:number;vx:number;vy:number; }
  let nodes:N[]=[]; let links:[number,number][]=[];

  function build(){
    nodes=[]; links=[];
    // Servicios reales — cada nodo enlaza a su página
    const SERVICES:{kind:Kind;label:string;href:string;fx:number;fy:number}[]=[
      // IA — izquierda
      { kind:'ia',     label:'Chatbot IA',          href:'/servicios/chatbot',           fx:0.12, fy:0.22 },
      { kind:'ia',     label:'Gestor documental',   href:'/servicios/gestor-documental', fx:0.27, fy:0.33 },
      { kind:'ia',     label:'Llamadas IA · ATC',   href:'/servicios/atencion-llamadas', fx:0.09, fy:0.42 },
      { kind:'ia',     label:'Gestor de citas',     href:'/servicios/gestor-citas',      fx:0.30, fy:0.14 },
      { kind:'ia',     label:'Consultoría IA',      href:'/consultoria-ia',              fx:0.18, fy:0.60 },
      // Ciberseguridad — arriba derecha
      { kind:'cyber',  label:'Wazuh · SIEM',        href:'/wazuh',                       fx:0.87, fy:0.20 },
      { kind:'cyber',  label:'Cumplimiento ENS',    href:'/wazuh',                       fx:0.72, fy:0.30 },
      // Web y posicionamiento — abajo izquierda
      { kind:'system', label:'Desarrollo web',      href:'/servicios/desarrollo-web',    fx:0.12, fy:0.76 },
      { kind:'system', label:'Posicionamiento SEO', href:'/servicios/geo-posicionamiento', fx:0.31, fy:0.84 },
      // Automatización — abajo derecha
      { kind:'auto',   label:'Automatización',      href:'/servicios/automatizacion',    fx:0.87, fy:0.80 },
      { kind:'auto',   label:'Integraciones',       href:'/servicios/automatizacion',    fx:0.73, fy:0.67 },
    ];
    SERVICES.forEach(s=>nodes.push({ x:s.fx*W, y:s.fy*H, r:9, kind:s.kind, label:s.label, href:s.href, phase:Math.random()*6.28, vx:0, vy:0 }));
    const NLAB=nodes.length;
    const SMALL=Math.round((W*H)/34000);
    for(let i=0;i<SMALL;i++) nodes.push({ x:Math.random()*W, y:Math.random()*H, r:Math.random()*2.2+2.2, kind:'node', phase:Math.random()*6.28, vx:(Math.random()-0.5)*0.18, vy:(Math.random()-0.5)*0.18 });
    const NSMALL=nodes.length;
    // los nodos pequeños forman la red de fondo: se unen al servicio más cercano + vecinos
    for(let i=NLAB;i<NSMALL;i++){ let best=-1,bd=1e9; for(let h=0;h<NLAB;h++){ const dx=nodes[i].x-nodes[h].x,dy=nodes[i].y-nodes[h].y; const d=dx*dx+dy*dy; if(d<bd){bd=d;best=h;} } if(best>=0&&bd<(W*0.32)*(W*0.32)) links.push([i,best]); }
    for(let i=NLAB;i<NSMALL;i++) for(let j=i+1;j<NSMALL;j++){ const dx=nodes[i].x-nodes[j].x,dy=nodes[i].y-nodes[j].y; if(dx*dx+dy*dy<120*120&&Math.random()<0.5) links.push([i,j]); }
    // Nodos-evento: ejemplos reales ATADOS a su servicio (si = índice del servicio). Mismo color + conexión directa.
    const EVENTS:{si:number;label:string}[]=[
      { si:0,  label:'✓ Consulta resuelta 24/7' },        // Chatbot
      { si:1,  label:'✓ Contrato hallado en 0,3 s' },     // Gestor documental
      { si:2,  label:'✓ Cita reservada con el cliente' }, // Llamadas IA · ATC
      { si:2,  label:'✓ Llamada atendida sin esperas' },  // Llamadas IA · ATC
      { si:3,  label:'✓ Recordatorio enviado' },          // Gestor de citas
      { si:4,  label:'✓ Plan de IA a medida' },           // Consultoría IA
      { si:5,  label:'✓ Amenaza bloqueada' },             // Wazuh
      { si:6,  label:'✓ Cumple el ENS' },                 // Cumplimiento ENS
      { si:7,  label:'✓ Web publicada en días' },         // Desarrollo web
      { si:8,  label:'✓ Top 3 en Google' },               // Posicionamiento SEO
      { si:9,  label:'✓ Factura enviada sola' },          // Automatización
      { si:10, label:'✓ CRM y email conectados' },        // Integraciones
    ];
    EVENTS.forEach(e=>{ const sv=nodes[e.si]; const ang=Math.random()*6.28; const dist=66+Math.random()*36;
      const ex=Math.max(34,Math.min(W-34, sv.x+Math.cos(ang)*dist));
      const ey=Math.max(34,Math.min(H-34, sv.y+Math.sin(ang)*dist));
      const ei=nodes.length;
      nodes.push({ x:ex, y:ey, r:4, kind:'event', label:e.label, color:COLORS[sv.kind], phase:Math.random()*6.28, vx:0, vy:0 });
      links.push([ei, e.si]); // línea directa evento → su servicio
    });
  }
  function resize(){ W=section.clientWidth; H=section.clientHeight; canvas.width=lit.width=mask.width=W*DPR; canvas.height=lit.height=mask.height=H*DPR; canvas.style.width=lit.style.width=W+'px'; canvas.style.height=lit.style.height=H+'px'; ctx.setTransform(DPR,0,0,DPR,0,0); lctx.setTransform(DPR,0,0,DPR,0,0); mctx.setTransform(DPR,0,0,DPR,0,0); mctx.clearRect(0,0,W,H); build(); }
  function hexA(hex:string,a:number){ const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); return `rgba(${r},${g},${b},${a})`; }

  function drawNetwork(c:CanvasRenderingContext2D, on:boolean){
    for(const [a,b] of links){ const na=nodes[a],nb=nodes[b]; c.beginPath(); c.moveTo(na.x,na.y); c.lineTo(nb.x,nb.y); const ca=na.kind!=='node'?(na.color||COLORS[na.kind]):null; const cb=nb.kind!=='node'?(nb.color||COLORS[nb.kind]):null; const col=ca||cb||'#3a4d68'; c.strokeStyle=on?hexA(col,0.55):hexA('#2a3a52',1); c.lineWidth=on?1.1:0.8; c.stroke(); }
    if(on){ for(let k=0;k<links.length;k+=3){ const [a,b]=links[k]; const na=nodes[a],nb=nodes[b]; const p=((t*0.4+k*40)%100)/100; const px=na.x+(nb.x-na.x)*p,py=na.y+(nb.y-na.y)*p; const col=na.kind!=='node'?COLORS[na.kind]:'#7cc0ff'; c.beginPath(); c.arc(px,py,1.8,0,6.28); c.fillStyle=col; c.fill(); } }
    for(const n of nodes){ const pulse=0.5+0.5*Math.sin(t*0.05+n.phase); const col=n.color||COLORS[n.kind];
      if(n.kind==='event'){ if(on){ const g=c.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*4); g.addColorStop(0,hexA(col,0.55)); g.addColorStop(1,hexA(col,0)); c.fillStyle=g; c.beginPath(); c.arc(n.x,n.y,n.r*4,0,6.28); c.fill(); } c.beginPath(); c.arc(n.x,n.y,n.r,0,6.28); c.fillStyle=on?col:hexA(col,0.7); c.fill(); }
      else { if(on){ const g=c.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*5); g.addColorStop(0,hexA(col,0.5*pulse+0.2)); g.addColorStop(1,hexA(col,0)); c.fillStyle=g; c.beginPath(); c.arc(n.x,n.y,n.r*5,0,6.28); c.fill(); } c.beginPath(); c.arc(n.x,n.y,n.r,0,6.28); c.fillStyle=on?col:hexA(col,0.9); c.fill(); if(n.kind!=='node'){ c.lineWidth=2; c.strokeStyle=on?'#eaf2ff':hexA(col,0.6); c.stroke(); } }
      if(on&&n.label){ c.font=n.kind==='event'?'600 11px Inter,sans-serif':'700 12px Inter,sans-serif'; c.fillStyle=n.kind==='event'?col:'#eaf2ff'; c.textAlign='center'; c.fillText(n.label,n.x,n.y-n.r-8); } }
  }

  const R=185;
  // ── Detección de servicio bajo el cursor (clicable) ──
  let hoverNode:N|null=null;
  function hitTest(){ hoverNode=null; let best=32*32; for(const n of nodes){ if(!n.href) continue; const dx=n.x-mx,dy=n.y-my; const d=dx*dx+dy*dy; if(d<best){ best=d; hoverNode=n; } } }

  function frame(){
    t++;
    for(const n of nodes){ if(n.kind==='node'||n.kind==='event'){ n.x+=n.vx; n.y+=n.vy; if(n.x<0||n.x>W)n.vx*=-1; if(n.y<0||n.y>H)n.vy*=-1; } }
    // En modo automático (antes de interactuar) la luz es transitoria: limpiamos la máscara.
    // Cuando el usuario mueve el ratón, la máscara se acumula y lo descubierto se queda visible.
    if(!hasPointer){ mx=W*(0.5+0.32*Math.sin(t*0.011)); my=H*(0.55+0.24*Math.sin(t*0.019+1.5)); mctx.clearRect(0,0,W,H); }
    // pintar el foco actual en la máscara acumulativa (el disco interior revela al 100%)
    const mg=mctx.createRadialGradient(mx,my,0,mx,my,R); mg.addColorStop(0,'rgba(0,0,0,1)'); mg.addColorStop(0.62,'rgba(0,0,0,1)'); mg.addColorStop(1,'rgba(0,0,0,0)');
    mctx.fillStyle=mg; mctx.beginPath(); mctx.arc(mx,my,R,0,6.28); mctx.fill();

    ctx.clearRect(0,0,W,H); ctx.globalAlpha=0.16; drawNetwork(ctx,false); ctx.globalAlpha=1;
    lctx.clearRect(0,0,W,H); drawNetwork(lctx,true);
    lctx.globalCompositeOperation='destination-in';
    lctx.drawImage(mask,0,0,W,H); lctx.globalCompositeOperation='source-over';
    ctx.drawImage(lit,0,0,W,H);
    const glow=ctx.createRadialGradient(mx,my,0,mx,my,R*1.1); glow.addColorStop(0,'rgba(124,192,255,0.09)'); glow.addColorStop(1,'rgba(124,192,255,0)'); ctx.fillStyle=glow; ctx.beginPath(); ctx.arc(mx,my,R*1.1,0,6.28); ctx.fill();
    // resaltado del servicio bajo el cursor + pista "abrir →"
    if(hoverNode){ const col=COLORS[hoverNode.kind]; const pr=hoverNode.r+7+Math.sin(t*0.15)*1.5;
      ctx.beginPath(); ctx.arc(hoverNode.x,hoverNode.y,pr,0,6.28); ctx.strokeStyle=col; ctx.lineWidth=2; ctx.shadowColor=col; ctx.shadowBlur=14; ctx.stroke(); ctx.shadowBlur=0;
      ctx.font='800 11px Inter,sans-serif'; ctx.fillStyle=col; ctx.textAlign='center'; ctx.fillText('abrir →', hoverNode.x, hoverNode.y+hoverNode.r+18); }
    requestAnimationFrame(frame);
  }

  function setCursorHover(on:boolean){
    if(on && hoverNode){ const col=COLORS[hoverNode.kind]; cursorEl.style.width=cursorEl.style.height='34px'; cursorEl.style.background='transparent'; cursorEl.style.border='2px solid '+col; cursorEl.style.boxShadow='0 0 22px '+col; }
    else { cursorEl.style.width=cursorEl.style.height='16px'; cursorEl.style.background='radial-gradient(circle,#fff,rgba(255,255,255,0.2))'; cursorEl.style.border='none'; cursorEl.style.boxShadow='0 0 24px 6px rgba(124,192,255,0.6)'; }
  }
  function onMove(x:number,y:number){ const r=section.getBoundingClientRect(); mx=x-r.left; my=y-r.top; if(!hasPointer){ hasPointer=true; cursorEl.style.opacity='1'; if(hint)hint.style.opacity='0'; mctx.clearRect(0,0,W,H); } cursorEl.style.left=mx+'px'; cursorEl.style.top=my+'px'; hitTest(); setCursorHover(!!hoverNode); }
  section.addEventListener('mousemove', e=>onMove(e.clientX,e.clientY));
  section.addEventListener('mouseleave', ()=>{ hasPointer=false; cursorEl.style.opacity='0'; });
  section.addEventListener('touchmove', e=>{ if(e.touches[0]) onMove(e.touches[0].clientX,e.touches[0].clientY); }, {passive:true});
  // clic en un nodo de servicio → su página
  section.addEventListener('click', (e)=>{ if((e.target as HTMLElement)?.closest('a,button')) return; const r=section.getBoundingClientRect(); mx=e.clientX-r.left; my=e.clientY-r.top; hitTest(); if(hoverNode&&hoverNode.href) window.location.href=hoverNode.href; });

  resize();
  window.addEventListener('resize', resize);

  // ───────────── Texto desencriptado ─────────────
  const GLYPHS='ABCDEF0123456789#%&$/<>*+=!?@';
  const rnd=()=>GLYPHS[Math.floor(Math.random()*GLYPHS.length)];
  const wait=(ms:number)=>new Promise(r=>setTimeout(r,ms));
  const h1=document.getElementById('fus-h1') as HTMLElement;
  const rotor=document.getElementById('fus-rotor') as HTMLElement;
  const allChars:{el:HTMLElement;final:string}[]=[];
  (Array.from(h1.querySelectorAll('.fus-line')) as HTMLElement[]).forEach(line=>{ const text=line.getAttribute('data-text')||''; line.textContent=''; for(const ch of text){ const s=document.createElement('span'); s.className='fus-char'; if(ch===' '){ s.innerHTML='&nbsp;'; line.appendChild(s); continue; } s.textContent=rnd(); s.dataset.final=ch; line.appendChild(s); allChars.push({el:s,final:ch}); } });

  // Descifrado rápido: revela varios caracteres a la vez para poder leer enseguida
  async function decryptIn(){ const STEP=3; for(let i=0;i<allChars.length;i+=STEP){ for(let g=0;g<STEP&&i+g<allChars.length;g++) allChars[i+g].el.classList.add('scrambling'); for(let c=0;c<4;c++){ for(let g=0;g<STEP&&i+g<allChars.length;g++) allChars[i+g].el.textContent=rnd(); await wait(12); } for(let g=0;g<STEP&&i+g<allChars.length;g++){ const {el,final}=allChars[i+g]; el.textContent=final; el.classList.remove('scrambling'); } } }

  let lastGlitch=0;
  h1.addEventListener('mousemove',(e)=>{ const now=t; if(now-lastGlitch<1) return; lastGlitch=now;
    for(const {el,final} of allChars){ const r=el.getBoundingClientRect(); const cxp=r.left+r.width/2, cyp=r.top+r.height/2; const d=Math.hypot(e.clientX-cxp,e.clientY-cyp); if(d<46&&!el.dataset.busy){ el.dataset.busy='1'; el.classList.add('scrambling'); let n=0; const iv=setInterval(()=>{ el.textContent=rnd(); n++; if(n>4){ clearInterval(iv); el.textContent=final; el.classList.remove('scrambling'); delete el.dataset.busy; } },32); } } });

  const WORDS=['conectado','protegido','automatizado','optimizado'];
  let wi=0;
  async function scrambleTo(word:string){ const max=Math.max(word.length, rotor.textContent?.length||0); for(let step=0;step<=max;step++){ let out=''; for(let i=0;i<word.length;i++){ out+= i<step ? word[i] : (Math.random()<0.6?rnd().toLowerCase():(word[i]||'')); } rotor.textContent=out; await wait(45); } rotor.textContent=word; }
  async function rotorLoop(){ await wait(1600); while(true){ wi=(wi+1)%WORDS.length; await scrambleTo(WORDS[wi]); await wait(1900); } }

  const reduce=window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(reduce){
    section.style.cursor='auto'; cursorEl.style.display='none'; if(hint)hint.style.display='none';
    const scan=document.getElementById('fus-scan'); if(scan)scan.style.display='none';
    const caret=document.getElementById('fus-caret'); if(caret)caret.style.animation='none';
    allChars.forEach(c=>{ c.el.textContent=c.final; }); rotor.textContent='conectado';
    // red estática revelada
    ctx.clearRect(0,0,W,H); ctx.globalAlpha=0.5; drawNetwork(ctx,true); ctx.globalAlpha=1;
  } else {
    requestAnimationFrame(frame);
    (async()=>{ rotor.textContent='conectado'; await decryptIn(); rotorLoop(); })();
  }
})();
</script>
