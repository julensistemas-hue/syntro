---
// HeroSpotlight — "Lo que no ves"
// La pantalla está a oscuras. El ratón es un foco que revela la infraestructura
// digital oculta: nodos de IA, escudos, servidores, flujos y AMENAZAS rojas que
// solo se ven al iluminarlas. Metáfora: lo que no monitorizas, no lo controlas.
---

<section id="spot-hero" class="relative overflow-hidden" style="background:#03060d;height:100vh;min-height:640px;cursor:none;">

  <!-- Canvas red oculta + linterna -->
  <canvas id="spot-canvas" class="absolute inset-0" style="width:100%;height:100%;display:block;"></canvas>

  <!-- Foco visual (sigue al cursor) -->
  <div id="spot-cursor" style="position:absolute;width:18px;height:18px;border-radius:50%;pointer-events:none;z-index:30;transform:translate(-50%,-50%);background:radial-gradient(circle,#fff,rgba(255,255,255,0.2));box-shadow:0 0 24px 6px rgba(124,192,255,0.6);transition:opacity .3s;opacity:0;"></div>

  <!-- Contenido -->
  <div class="relative h-full flex flex-col items-center justify-center text-center px-6" style="z-index:20;pointer-events:none;">

    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-7 border" style="background:rgba(0,0,0,0.4);border-color:rgba(124,192,255,0.25);color:#9fc6ff;letter-spacing:0.14em;text-transform:uppercase;backdrop-filter:blur(2px);">
      AI Security · Partner tecnológico
    </div>

    <h1 class="font-black tracking-tight" style="font-size:clamp(2.1rem,6vw,4.2rem);line-height:1.02;color:#eaf2ff;text-shadow:0 2px 40px rgba(0,0,0,0.9),0 0 80px rgba(0,0,0,0.9);max-width:18ch;">
      Tu empresa ya tiene una<br>infraestructura digital.
    </h1>

    <p class="mt-5 font-medium" style="font-size:clamp(1.05rem,2.6vw,1.6rem);color:#9fc6ff;text-shadow:0 2px 30px rgba(0,0,0,0.95);">
      <span id="spot-sub-glow">Nosotros la vemos entera.</span>
    </p>

    <p class="mt-6" style="max-width:34rem;font-size:0.98rem;line-height:1.6;color:rgba(220,232,255,0.6);text-shadow:0 1px 20px rgba(0,0,0,0.9);">
      IA, ciberseguridad y sistemas bajo un mismo equipo. Lo que no se monitoriza, no se controla — y lo que no se controla, no se optimiza.
    </p>

    <!-- Pista de interacción -->
    <div id="spot-hint" class="mt-7 flex items-center gap-2" style="color:rgba(159,198,255,0.85);font-size:0.85rem;transition:opacity .5s;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/></svg>
      Mueve el ratón para iluminar lo que hay debajo
    </div>

    <div class="mt-9" style="pointer-events:auto;">
      <a href="/reunion" id="spot-cta" style="display:inline-flex;align-items:center;gap:0.6rem;background:#7cc0ff;color:#03060d;font-weight:800;padding:0.95rem 2rem;border-radius:0.8rem;text-decoration:none;font-size:1rem;box-shadow:0 0 0 1px rgba(255,255,255,0.1),0 10px 40px rgba(124,192,255,0.4);transition:transform .2s,box-shadow .2s;">
        Enciende la luz · Consulta gratuita
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  #spot-cta:hover { transform:translateY(-2px); box-shadow:0 0 0 1px rgba(255,255,255,0.2),0 14px 50px rgba(124,192,255,0.6); }
  @keyframes subGlow { 0%,100%{ opacity:0.85; } 50%{ opacity:1; text-shadow:0 0 24px rgba(159,198,255,0.7); } }
  #spot-sub-glow { animation:subGlow 3s ease-in-out infinite; }
  @media (max-width:640px){ #spot-hero{ cursor:auto; } }
</style>

<script>
(function () {
  const section = document.getElementById('spot-hero') as HTMLElement;
  const canvas  = document.getElementById('spot-canvas') as HTMLCanvasElement;
  const cursorEl = document.getElementById('spot-cursor') as HTMLElement;
  const hint    = document.getElementById('spot-hint') as HTMLElement;
  if (!section || !canvas) return;
  const ctx = canvas.getContext('2d')!;

  // Offscreen para la capa "iluminada"
  const lit = document.createElement('canvas');
  const lctx = lit.getContext('2d')!;

  let W = 0, H = 0, DPR = Math.min(window.devicePixelRatio || 1, 2);

  type Kind = 'ai' | 'cyber' | 'system' | 'auto' | 'node' | 'alert';
  const COLORS: Record<Kind, string> = {
    ai:     '#60a5fa',
    cyber:  '#34d399',
    system: '#a78bfa',
    auto:   '#fbbf24',
    node:   '#5b7290',
    alert:  '#ff5564',
  };

  interface N { x:number; y:number; r:number; kind:Kind; label?:string; phase:number; vx:number; vy:number; }
  let nodes: N[] = [];
  let links: [number,number][] = [];

  function build() {
    nodes = [];
    links = [];
    // 4 hubs de dominio en posiciones relativas
    const hubs: {kind:Kind; label:string; fx:number; fy:number}[] = [
      { kind:'ai',     label:'IA',             fx:0.20, fy:0.30 },
      { kind:'cyber',  label:'Ciberseguridad', fx:0.80, fy:0.28 },
      { kind:'system', label:'Sistemas',       fx:0.16, fy:0.74 },
      { kind:'auto',   label:'Automatización', fx:0.84, fy:0.76 },
    ];
    hubs.forEach(h => nodes.push({ x:h.fx*W, y:h.fy*H, r:13, kind:h.kind, label:h.label, phase:Math.random()*6.28, vx:0, vy:0 }));

    // nodos pequeños (endpoints/servidores) distribuidos
    const SMALL = Math.round((W*H) / 42000); // densidad adaptativa
    for (let i=0;i<SMALL;i++) {
      nodes.push({
        x: Math.random()*W,
        y: Math.random()*H,
        r: Math.random()*2.2+2.2,
        kind:'node',
        phase: Math.random()*6.28,
        vx:(Math.random()-0.5)*0.18,
        vy:(Math.random()-0.5)*0.18,
      });
    }
    // amenazas ocultas (solo visibles con la luz)
    const ALERTS = 5;
    for (let i=0;i<ALERTS;i++) {
      nodes.push({ x:Math.random()*W, y:(0.15+Math.random()*0.7)*H, r:6, kind:'alert', label:'⚠ amenaza', phase:Math.random()*6.28, vx:0, vy:0 });
    }
    // enlaces: cada nodo pequeño se une al hub más cercano + vecinos
    for (let i=4;i<nodes.length;i++) {
      // hub más cercano
      let best=-1, bd=1e9;
      for (let h=0; h<4; h++){ const dx=nodes[i].x-nodes[h].x, dy=nodes[i].y-nodes[h].y; const d=dx*dx+dy*dy; if(d<bd){bd=d;best=h;} }
      if (best>=0 && bd < (W*0.42)*(W*0.42)) links.push([i,best]);
    }
    // vecinos cercanos
    for (let i=4;i<nodes.length;i++){
      for (let j=i+1;j<nodes.length;j++){
        const dx=nodes[i].x-nodes[j].x, dy=nodes[i].y-nodes[j].y;
        if (dx*dx+dy*dy < 130*130 && Math.random()<0.5) links.push([i,j]);
      }
    }
  }

  function resize() {
    W = section.clientWidth; H = section.clientHeight;
    canvas.width = lit.width = W*DPR;
    canvas.height= lit.height= H*DPR;
    canvas.style.width = lit.style.width = W+'px';
    canvas.style.height= lit.style.height= H+'px';
    ctx.setTransform(DPR,0,0,DPR,0,0);
    lctx.setTransform(DPR,0,0,DPR,0,0);
    build();
  }

  // Posición de la luz (auto hasta que el usuario mueva el ratón)
  let mx = -9999, my = -9999, hasPointer = false;
  let t = 0;

  function drawNetwork(c: CanvasRenderingContext2D, lit:boolean) {
    // enlaces
    for (const [a,b] of links) {
      const na=nodes[a], nb=nodes[b];
      c.beginPath(); c.moveTo(na.x,na.y); c.lineTo(nb.x,nb.y);
      const col = na.kind!=='node' ? COLORS[na.kind] : (nb.kind!=='node'?COLORS[nb.kind]:'#3a4d68');
      c.strokeStyle = lit ? hexA(col,0.55) : hexA('#2a3a52',1);
      c.lineWidth = lit ? 1.1 : 0.8;
      c.stroke();
    }
    // pulsos de datos (solo capa lit)
    if (lit) {
      for (let k=0;k<links.length;k+=3){
        const [a,b]=links[k]; const na=nodes[a], nb=nodes[b];
        const p=( (t*0.4 + k*40) % 100)/100;
        const px=na.x+(nb.x-na.x)*p, py=na.y+(nb.y-na.y)*p;
        const col = na.kind!=='node'?COLORS[na.kind]:'#7cc0ff';
        c.beginPath(); c.arc(px,py,1.8,0,6.28); c.fillStyle=col; c.fill();
      }
    }
    // nodos
    for (const n of nodes){
      const pulse = 0.5+0.5*Math.sin(t*0.05+n.phase);
      const col = COLORS[n.kind];
      if (n.kind==='alert'){
        // triángulo de alerta
        const s = n.r + (lit? pulse*2:0);
        c.beginPath(); c.moveTo(n.x,n.y-s); c.lineTo(n.x+s,n.y+s); c.lineTo(n.x-s,n.y+s); c.closePath();
        c.fillStyle = lit ? hexA(col, 0.9) : hexA(col,0.9);
        c.strokeStyle = lit ? '#ffd2d6' : col;
        if(lit){ c.shadowColor=col; c.shadowBlur=16; }
        c.fill(); c.shadowBlur=0;
      } else {
        if (lit){ const g=c.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*5); g.addColorStop(0,hexA(col,0.5*pulse+0.2)); g.addColorStop(1,hexA(col,0)); c.fillStyle=g; c.beginPath(); c.arc(n.x,n.y,n.r*5,0,6.28); c.fill(); }
        c.beginPath(); c.arc(n.x,n.y,n.r,0,6.28);
        c.fillStyle = lit ? col : hexA(col,0.9);
        c.fill();
        if (n.kind!=='node'){ c.lineWidth=2; c.strokeStyle=lit?'#eaf2ff':hexA(col,0.6); c.stroke(); }
      }
      // etiquetas (solo lit y para hubs/alertas)
      if (lit && n.label){
        c.font = n.kind==='alert' ? '600 11px Inter, sans-serif' : '700 13px Inter, sans-serif';
        c.fillStyle = n.kind==='alert' ? '#ff8d97' : '#eaf2ff';
        c.textAlign='center';
        c.fillText(n.label, n.x, n.y - n.r - 9);
      }
    }
  }

  function hexA(hex:string,a:number){
    const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${a})`;
  }

  const R = 175; // radio de la linterna

  function frame(){
    t++;
    // mover nodos pequeños suavemente
    for (let i=4;i<nodes.length;i++){
      const n=nodes[i];
      if(n.kind==='node'){ n.x+=n.vx; n.y+=n.vy; if(n.x<0||n.x>W)n.vx*=-1; if(n.y<0||n.y>H)n.vy*=-1; }
    }

    // luz automática si no hay puntero
    if (!hasPointer){
      mx = W*(0.5 + 0.32*Math.sin(t*0.012));
      my = H*(0.55 + 0.26*Math.sin(t*0.019+1.5));
    }

    // 1) capa base (oscura, casi invisible)
    ctx.clearRect(0,0,W,H);
    ctx.globalAlpha = 0.16;
    drawNetwork(ctx, false);
    ctx.globalAlpha = 1;

    // 2) capa iluminada recortada por la linterna
    lctx.clearRect(0,0,W,H);
    drawNetwork(lctx, true);
    // máscara radial
    lctx.globalCompositeOperation = 'destination-in';
    const grad = lctx.createRadialGradient(mx,my,0, mx,my,R);
    grad.addColorStop(0,'rgba(0,0,0,1)');
    grad.addColorStop(0.7,'rgba(0,0,0,0.85)');
    grad.addColorStop(1,'rgba(0,0,0,0)');
    lctx.fillStyle = grad;
    lctx.beginPath(); lctx.arc(mx,my,R,0,6.28); lctx.fill();
    lctx.globalCompositeOperation = 'source-over';
    // halo de luz cálido
    ctx.drawImage(lit,0,0,W,H);
    // resplandor del foco
    const glow = ctx.createRadialGradient(mx,my,0,mx,my,R*1.1);
    glow.addColorStop(0,'rgba(124,192,255,0.10)');
    glow.addColorStop(1,'rgba(124,192,255,0)');
    ctx.fillStyle=glow; ctx.beginPath(); ctx.arc(mx,my,R*1.1,0,6.28); ctx.fill();

    requestAnimationFrame(frame);
  }

  function onMove(x:number,y:number){
    const rect = section.getBoundingClientRect();
    mx = x-rect.left; my = y-rect.top;
    if(!hasPointer){ hasPointer=true; cursorEl.style.opacity='1'; if(hint) hint.style.opacity='0'; }
    cursorEl.style.left = mx+'px'; cursorEl.style.top = my+'px';
  }
  section.addEventListener('mousemove', e=> onMove(e.clientX,e.clientY));
  section.addEventListener('mouseleave', ()=>{ hasPointer=false; cursorEl.style.opacity='0'; });
  section.addEventListener('touchmove', e=>{ if(e.touches[0]) onMove(e.touches[0].clientX,e.touches[0].clientY); }, {passive:true});

  resize();
  window.addEventListener('resize', resize);

  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce){
    // accesibilidad: mostrar la red revelada de forma estática, sin foco animado
    ctx.clearRect(0,0,W,H);
    ctx.globalAlpha=0.5; drawNetwork(ctx,true); ctx.globalAlpha=1;
    cursorEl.style.display='none';
    if (hint) hint.style.display='none';
    section.style.cursor='auto';
  } else {
    requestAnimationFrame(frame);
  }
})();
</script>
