---
// HeroParticleText — "Texto vivo de partículas"
// El titular está formado por miles de partículas con los colores de las 4 áreas.
// El ratón las dispersa y se recomponen solas. El texto está HECHO de tus servicios.
---

<section id="pt-hero" class="relative overflow-hidden flex items-center justify-center" style="background:#05070e;height:100vh;min-height:640px;">

  <canvas id="pt-canvas" class="absolute inset-0" style="width:100%;height:100%;display:block;z-index:1;"></canvas>

  <!-- Texto accesible real (oculto visualmente, lo dibuja el canvas) -->
  <h1 class="sr-only">Todo conectado — IA, ciberseguridad y sistemas con AI Security</h1>

  <!-- Subtítulo + CTA bajo el texto de partículas -->
  <div id="pt-overlay" class="absolute left-0 right-0 flex flex-col items-center text-center px-6" style="z-index:10;bottom:14%;pointer-events:none;">
    <p style="max-width:36rem;font-size:clamp(1rem,2.3vw,1.3rem);line-height:1.55;color:rgba(220,232,255,0.72);text-shadow:0 2px 24px rgba(0,0,0,0.8);">
      IA, ciberseguridad y sistemas bajo un mismo equipo. Un titular hecho, literalmente, de tus cuatro áreas — igual que tu tecnología cuando la unificas.
    </p>
    <div id="pt-hint" class="mt-5 flex items-center gap-2" style="color:rgba(148,163,184,0.8);font-size:0.85rem;transition:opacity .5s;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
      Pasa el ratón por encima del texto
    </div>
    <div class="mt-7" style="pointer-events:auto;">
      <a href="/reunion" id="pt-cta" style="display:inline-flex;align-items:center;gap:0.6rem;background:#fff;color:#05070e;font-weight:800;padding:0.95rem 2rem;border-radius:0.8rem;text-decoration:none;font-size:1rem;box-shadow:0 10px 40px rgba(255,255,255,0.16);transition:transform .2s,box-shadow .2s;">
        Unifica tu tecnología
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Badge superior -->
  <div class="absolute left-0 right-0 flex justify-center px-6" style="top:7%;z-index:10;pointer-events:none;">
    <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold border" style="background:rgba(0,0,0,0.4);border-color:rgba(148,163,184,0.25);color:#cbd5e1;letter-spacing:0.12em;text-transform:uppercase;backdrop-filter:blur(2px);">
      Tu partner tecnológico de confianza
    </span>
  </div>
</section>

<style>
  #pt-cta:hover { transform:translateY(-2px);box-shadow:0 14px 50px rgba(255,255,255,0.3); }
</style>

<script>
(function () {
  const section = document.getElementById('pt-hero') as HTMLElement;
  const canvas  = document.getElementById('pt-canvas') as HTMLCanvasElement;
  const hint    = document.getElementById('pt-hint') as HTMLElement;
  if (!section || !canvas) return;
  const ctx = canvas.getContext('2d')!;

  const COLORS = ['#60a5fa','#34d399','#a78bfa','#fbbf24']; // IA, ciber, sistemas, auto
  let W=0,H=0,DPR=Math.min(window.devicePixelRatio||1,2);

  interface P { x:number;y:number;hx:number;hy:number;vx:number;vy:number;col:string; }
  let parts: P[] = [];

  function sampleText(){
    // Canvas offscreen para muestrear los píxeles del texto
    const off = document.createElement('canvas');
    const o = off.getContext('2d')!;
    off.width = W; off.height = H;
    o.clearRect(0,0,W,H);
    o.fillStyle = '#fff';
    o.textAlign = 'center';
    o.textBaseline = 'middle';

    const big = Math.min(W*0.16, 190);
    const small = big*0.62;
    const cx = W/2, cy = H*0.42;
    o.font = `900 ${big}px Inter, system-ui, sans-serif`;
    o.fillText('TODO', cx, cy - big*0.42);
    o.font = `900 ${small*1.18}px Inter, system-ui, sans-serif`;
    o.fillText('CONECTADO', cx, cy + small*0.62);

    const img = o.getImageData(0,0,W,H).data;
    const step = W < 600 ? 5 : 4;
    const targets:{x:number;y:number}[] = [];
    for (let y=0;y<H;y+=step){
      for (let x=0;x<W;x+=step){
        const a = img[(y*W + x)*4 + 3];
        if (a > 128) targets.push({x,y});
      }
    }
    return targets;
  }

  function build(){
    const targets = sampleText();
    parts = targets.map((t,i)=>({
      x: Math.random()*W,
      y: Math.random()*H,
      hx: t.x, hy: t.y,
      vx:0, vy:0,
      col: COLORS[i % 4],
    }));
  }

  function resize(){
    W=section.clientWidth; H=section.clientHeight;
    canvas.width=W*DPR; canvas.height=H*DPR;
    canvas.style.width=W+'px'; canvas.style.height=H+'px';
    ctx.setTransform(DPR,0,0,DPR,0,0);
    build();
  }

  let mx=-9999,my=-9999,hasPointer=false,t=0;
  const R=78, R2=R*R, SPRING=0.045, FRICTION=0.85, PUSH=5.5;

  function hexA(hex:string,a:number){ const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); return `rgba(${r},${g},${b},${a})`; }

  function frame(){
    t++;
    ctx.clearRect(0,0,W,H);

    let px=mx, py=my;
    if(!hasPointer){ px=-9999; py=-9999; }

    const active:number[]=[]; // partículas cerca del cursor o en movimiento
    const ACT_R = R*1.4, ACT_R2 = ACT_R*ACT_R;

    for (let i=0;i<parts.length;i++){
      const p=parts[i];
      // muelle a casa
      let ax=(p.hx-p.x)*SPRING;
      let ay=(p.hy-p.y)*SPRING;
      // repulsión del ratón
      const dx=p.x-px, dy=p.y-py; const d2=dx*dx+dy*dy;
      if (d2<R2 && d2>0.01){
        const d=Math.sqrt(d2);
        const f=(R-d)/R*PUSH;
        ax+=(dx/d)*f; ay+=(dy/d)*f;
      }
      p.vx=(p.vx+ax)*FRICTION;
      p.vy=(p.vy+ay)*FRICTION;
      p.x+=p.vx; p.y+=p.vy;

      const speed=Math.abs(p.vx)+Math.abs(p.vy);
      if (d2<ACT_R2 || speed>1.2) active.push(i);

      ctx.fillStyle=p.col;
      const s = speed>2 ? 2.6 : 1.8;
      ctx.globalAlpha = speed>1 ? 1 : 0.82;
      ctx.fillRect(p.x-s/2, p.y-s/2, s, s);
    }
    ctx.globalAlpha=1;

    // conexiones vivas: la red se ilumina donde interactúas (subconjunto acotado)
    if (active.length>1 && active.length<700){
      const LIM=26, LIM2=LIM*LIM;
      ctx.lineWidth=0.6;
      for (let a=0;a<active.length;a++){
        const pa=parts[active[a]];
        for (let b=a+1;b<active.length;b++){
          const pb=parts[active[b]];
          const dx=pa.x-pb.x, dy=pa.y-pb.y; const dd=dx*dx+dy*dy;
          if (dd<LIM2){
            const al=(1-Math.sqrt(dd)/LIM)*0.45;
            ctx.strokeStyle=hexA(pa.col,al);
            ctx.beginPath(); ctx.moveTo(pa.x,pa.y); ctx.lineTo(pb.x,pb.y); ctx.stroke();
          }
        }
      }
    }

    // glow del cursor
    if (hasPointer){
      const g=ctx.createRadialGradient(px,py,0,px,py,R);
      g.addColorStop(0,'rgba(255,255,255,0.05)'); g.addColorStop(1,'rgba(255,255,255,0)');
      ctx.fillStyle=g; ctx.beginPath(); ctx.arc(px,py,R,0,6.28); ctx.fill();
    }

    requestAnimationFrame(frame);
  }

  function drawStatic(){
    // fallback sin animación (prefers-reduced-motion)
    for (const p of parts){ p.x=p.hx; p.y=p.hy; }
    ctx.clearRect(0,0,W,H);
    for (const p of parts){ ctx.fillStyle=p.col; ctx.globalAlpha=0.9; ctx.fillRect(p.x-0.9,p.y-0.9,1.8,1.8); }
    ctx.globalAlpha=1;
  }

  function onMove(x:number,y:number){
    const r=section.getBoundingClientRect();
    mx=x-r.left; my=y-r.top;
    if(!hasPointer){ hasPointer=true; if(hint) hint.style.opacity='0'; }
  }
  section.addEventListener('mousemove', e=>onMove(e.clientX,e.clientY));
  section.addEventListener('mouseleave', ()=>{ hasPointer=false; mx=my=-9999; });
  section.addEventListener('touchmove', e=>{ if(e.touches[0]) onMove(e.touches[0].clientX,e.touches[0].clientY); }, {passive:true});
  // click = onda expansiva
  section.addEventListener('click', e=>{
    const r=section.getBoundingClientRect(); const cx=e.clientX-r.left, cy=e.clientY-r.top;
    for(const p of parts){ const dx=p.x-cx,dy=p.y-cy; const d=Math.hypot(dx,dy)||1; if(d<260){ const f=(260-d)/260*14; p.vx+=dx/d*f; p.vy+=dy/d*f; } }
  });

  resize();
  let rzTimer:any; window.addEventListener('resize', ()=>{ clearTimeout(rzTimer); rzTimer=setTimeout(resize,180); });

  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce){ drawStatic(); }
  else { requestAnimationFrame(frame); }   // intro: las partículas vuelan al texto
})();
</script>
