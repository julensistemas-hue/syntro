<section class="city-hero relative overflow-hidden" style="background:linear-gradient(180deg,#04080f 0%,#07111f 55%,#0a1628 100%); width:100vw; margin-left:calc(-50vw + 50%); display:flex; flex-direction:column;">

  <div class="star-field absolute inset-0" style="z-index:0;pointer-events:none;"></div>

  <!-- TOP TEXT -->
  <div class="relative text-center px-6 pt-14 pb-2" style="z-index:20;">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium mb-4" style="background:rgba(124,58,237,.18);border:1px solid rgba(124,58,237,.35);color:#c4b5fd;">
      <span class="w-2 h-2 rounded-full bg-purple-400 animate-pulse"></span>
      El camino completo para tu empresa
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3 leading-tight">
      Más segura. Más eficiente.
      <span style="background:linear-gradient(90deg,#38bdf8,#a78bfa,#34d399,#fb923c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"> Más rentable.</span>
    </h1>
    <p class="text-gray-400 text-sm max-w-lg mx-auto">Sigue el camino de tu empresa — desde la base hasta crecer online. Haz clic en cada fase.</p>
  </div>

  <!-- CITY WRAPPER — contains chart (behind), SVG, panels above buildings, canvas -->
  <div class="relative w-full city-wrapper" style="z-index:10; isolation:isolate;">

    <!-- METRICS CHART — z-index:2, behind the SVG (DOM order: first = behind) -->
    <div id="metrics-panel" class="metrics-panel">
      <div class="metrics-header">
        <span class="metrics-title">📈 Evolución</span>
        <span id="metrics-phase-label" class="metrics-phase-tag">Inicio</span>
      </div>
      <div class="chart-wrap">
        <svg id="chart-svg" viewBox="0 0 260 110" xmlns="http://www.w3.org/2000/svg" style="width:100%;display:block;">
          <line x1="36" y1="10" x2="36" y2="90"  stroke="#1e2a3a" stroke-width="1"/>
          <line x1="36" y1="10" x2="252" y2="10" stroke="#1e2a3a" stroke-width="0.8" stroke-dasharray="3,4"/>
          <line x1="36" y1="34" x2="252" y2="34" stroke="#1e2a3a" stroke-width="0.8" stroke-dasharray="3,4"/>
          <line x1="36" y1="57" x2="252" y2="57" stroke="#1e2a3a" stroke-width="0.8" stroke-dasharray="3,4"/>
          <line x1="36" y1="80" x2="252" y2="80" stroke="#1e2a3a" stroke-width="0.8" stroke-dasharray="3,4"/>
          <line x1="36" y1="90" x2="252" y2="90" stroke="#1e2a3a" stroke-width="1"/>
          <text x="30" y="13"  text-anchor="end" fill="#3d5068" font-size="7" font-family="Inter,sans-serif">100%</text>
          <text x="30" y="37"  text-anchor="end" fill="#3d5068" font-size="7" font-family="Inter,sans-serif">75%</text>
          <text x="30" y="60"  text-anchor="end" fill="#3d5068" font-size="7" font-family="Inter,sans-serif">50%</text>
          <text x="30" y="83"  text-anchor="end" fill="#3d5068" font-size="7" font-family="Inter,sans-serif">25%</text>
          <text x="72"  y="102" text-anchor="middle" fill="#3d5068" font-size="6.5" font-family="Inter,sans-serif">F0</text>
          <text x="116" y="102" text-anchor="middle" fill="#3d5068" font-size="6.5" font-family="Inter,sans-serif">F1</text>
          <text x="184" y="102" text-anchor="middle" fill="#3d5068" font-size="6.5" font-family="Inter,sans-serif">F2</text>
          <text x="244" y="102" text-anchor="middle" fill="#3d5068" font-size="6.5" font-family="Inter,sans-serif">F3</text>
          <line x1="72"  y1="88" x2="72"  y2="93" stroke="#3d5068" stroke-width="1"/>
          <line x1="116" y1="88" x2="116" y2="93" stroke="#3d5068" stroke-width="1"/>
          <line x1="184" y1="88" x2="184" y2="93" stroke="#3d5068" stroke-width="1"/>
          <line x1="244" y1="88" x2="244" y2="93" stroke="#3d5068" stroke-width="1"/>
          <path id="area-seg"  d="" fill="#7c3aed" opacity="0.08"/>
          <path id="area-prod" d="" fill="#34d399" opacity="0.08"/>
          <path id="area-ing"  d="" fill="#fbbf24" opacity="0.08"/>
          <polyline id="line-seg"  points="" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <polyline id="line-prod" points="" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <polyline id="line-ing"  points="" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle id="dot-seg"  cx="0" cy="0" r="3.5" fill="#a78bfa" stroke="#1a0a2e" stroke-width="1.5"/>
          <circle id="dot-prod" cx="0" cy="0" r="3.5" fill="#34d399" stroke="#041a10" stroke-width="1.5"/>
          <circle id="dot-ing"  cx="0" cy="0" r="3.5" fill="#fbbf24" stroke="#1c1200" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="metrics-legend">
        <div class="legend-item"><span style="background:#a78bfa;"></span>Seguridad</div>
        <div class="legend-item"><span style="background:#34d399;"></span>Productividad</div>
        <div class="legend-item"><span style="background:#fbbf24;"></span>Ingresos</div>
      </div>
      <div class="kpi-row">
        <div class="kpi-item" id="kpi-seg"><div class="kpi-val" style="color:#a78bfa;" id="kpi-seg-val">10%</div><div class="kpi-lbl">Seg.</div></div>
        <div class="kpi-item" id="kpi-prod"><div class="kpi-val" style="color:#34d399;" id="kpi-prod-val">15%</div><div class="kpi-lbl">Prod.</div></div>
        <div class="kpi-item" id="kpi-ing"><div class="kpi-val" style="color:#fbbf24;" id="kpi-ing-val">10%</div><div class="kpi-lbl">Ingresos</div></div>
      </div>
    </div>

    <!-- Flying icon canvas — above SVG, below panels -->
    <canvas id="fly-canvas" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:15;"></canvas>

    <!-- SERVICE PANELS — always visible above buildings, animated when active -->
    <!-- Positioned by % matching SVG building centers (x/1440*100) -->
    <!-- IT: 200/1440=13.9%, Ciber: 570/1440=39.6%, IA: 970/1440=67.4%, SEO: 1280/1440=88.9% -->
    <div id="panel-ciber" class="svc-panel" data-dept="ciber" style="left:28%; --pc:#a78bfa;">
      <div class="svc-phase" style="--pc:#a78bfa;">F1 · Ciberseguridad</div>
      <div class="svc-links">
        <a href="/wazuh">🛡️ Wazuh SIEM</a>
        <a href="/curso-wazuh">🎓 Curso Wazuh</a>
        <a href="/wazuh">📋 Cumplimiento ENS</a>
        <a href="/wazuh">📡 Monitoreo 24/7</a>
      </div>
    </div>

    <div id="panel-ia" class="svc-panel" data-dept="ia" style="left:57%; --pc:#34d399;">
      <div class="svc-phase" style="--pc:#34d399;">F2 · IA Productividad</div>
      <div class="svc-links">
        <a href="/servicios/chatbot">💬 Chatbot IA 24/7</a>
        <a href="/servicios/automatizacion">⚙️ Automatización</a>
        <a href="/servicios/gestor-documental">📄 Gestor documental</a>
        <a href="/servicios/atencion-llamadas">📞 Recepcionista virtual</a>
      </div>
    </div>

    <div id="panel-seo" class="svc-panel" data-dept="seo" style="left:84%; --pc:#fb923c;">
      <div class="svc-phase" style="--pc:#fb923c;">F3 · SEO &amp; Publicidad</div>
      <div class="svc-links">
        <a href="/blog">🔍 SEO en Google</a>
        <a href="/blog">📍 SEO local &amp; GEO</a>
        <a href="/servicios/automatizacion">✉️ Email marketing</a>
        <a href="/blog">📊 Analítica GA4</a>
      </div>
    </div>

    <!-- CITY SVG -->
    <svg id="city-svg" viewBox="0 0 1440 490" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMax meet" style="width:100%;display:block;position:relative;z-index:10;">
      <defs>
        <filter id="glow"><feGaussianBlur stdDeviation="4" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        <filter id="glow-sm"><feGaussianBlur stdDeviation="2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        <linearGradient id="road-g" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#0d1520"/><stop offset="50%" stop-color="#141e2e"/><stop offset="100%" stop-color="#0d1520"/>
        </linearGradient>
        <!-- Milestone glow gradients -->
        <radialGradient id="glow-blue" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.15"/>
          <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="glow-purple" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#a78bfa" stop-opacity="0.18"/>
          <stop offset="100%" stop-color="#a78bfa" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="glow-green" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#34d399" stop-opacity="0.15"/>
          <stop offset="100%" stop-color="#34d399" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="glow-orange" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#fb923c" stop-opacity="0.18"/>
          <stop offset="100%" stop-color="#fb923c" stop-opacity="0"/>
        </radialGradient>
      </defs>

      <!-- Horizon glow -->
      <rect x="0" y="360" width="1440" height="60" fill="url(#road-g)" opacity="0.4"/>

      <!-- GROUND -->
      <rect x="0" y="400" width="1440" height="90" fill="#080f1a"/>

      <!-- ROAD -->
      <rect x="0" y="408" width="1440" height="54" fill="url(#road-g)"/>
