}
.svc-panel:hover {
  opacity: 1;
  border-color: color-mix(in srgb, var(--pc, white) 50%, transparent);
  box-shadow: 0 0 22px color-mix(in srgb, var(--pc, transparent) 22%, transparent), 0 6px 24px rgba(0,0,0,0.5);
  transform: translateX(-50%) translateY(-2px);
}
/* Active state: máximo brillo + pulso de glow sincronizado con el muñeco */
.svc-panel.active {
  opacity: 1 !important;
  border-color: var(--pc, rgba(255,255,255,0.5)) !important;
  transform: translateX(-50%) translateY(-5px) scale(1.04) !important;
  animation: panelPulse 2s ease-in-out infinite;
