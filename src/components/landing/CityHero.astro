/* ===== SERVICE PANELS (always visible, above buildings) ===== */
.svc-panel {
  position: absolute;
  top: 4px;
  transform: translateX(-50%);
  width: 190px;
  background: rgba(6,10,22,0.72);
  border: 1px solid color-mix(in srgb, var(--pc, #94a3b8) 28%, transparent);
