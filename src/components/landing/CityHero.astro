  50% {
    box-shadow: 0 0 42px color-mix(in srgb, var(--pc, white) 55%, transparent),
                0 0 80px color-mix(in srgb, var(--pc, white) 15%, transparent),
                0 8px 32px rgba(0,0,0,0.55);
