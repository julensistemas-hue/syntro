}

/* Blinks */
.blink       { animation: blk  1.6s ease-in-out infinite; }
.blink-slow  { animation: blk  2.8s ease-in-out infinite; animation-delay:.9s; }
.blink-green { animation: blkG 2s   ease-in-out infinite; }
@keyframes blk  { 0%,44%,100%{opacity:1}48%,96%{opacity:.04} }
@keyframes blkG { 0%,40%,100%{opacity:1}44%,90%{opacity:.1}  }

/* Flame */
.flame-anim { animation: flame .4s ease-in-out infinite alternate; }
@keyframes flame { from{opacity:.5;transform:scaleY(.8)} to{opacity:1;transform:scaleY(1.2)} }

/* Buildings */
.iso-building { transition: filter .2s ease; }
.iso-building:hover { filter: drop-shadow(0 0 22px rgba(255,255,255,.22)) brightness(1.16) !important; }
.iso-building.active { filter: drop-shadow(0 0 32px rgba(99,102,241,.55)) brightness(1.28) !important; }
.bld-label { pointer-events:none; }

/* ===== WALKER JOURNEY — 36s cycle =====
   Starts at Fase 1 (Ciber). F0 skipped unless clicked.
    Fase 1 (Ciber, x≈570):  0%–  → stops 10%–20%  = 3.6s–7.2s
    Fase 2 (IA,    x≈970): 20%   → stops 38%–48%  = 13.7s–17.3s
    Fase 3 (SEO,   x≈1280):48%   → stops 62%–72%  = 22.3s–25.9s
    Walk off + reset: 72%–100%
*/
#walker { animation: wJourney 36s linear infinite; }
@keyframes wJourney {
  0%   { transform: translate(-30px,  428px); }   /* entra desde fuera */
  6%   { transform: translate(440px,  428px); }
  10%  { transform: translate(570px,  428px); }
  20%  { transform: translate(570px,  428px); }   /* stop Ciber */
  35%  { transform: translate(940px,  428px); }
  38%  { transform: translate(970px,  428px); }
  48%  { transform: translate(970px,  428px); }   /* stop IA */
  60%  { transform: translate(1250px, 428px); }
  62%  { transform: translate(1280px, 428px); }
  72%  { transform: translate(1280px, 428px); }   /* stop SEO */
  88%  { transform: translate(1490px, 428px); }
  89%  { transform: translate(330px,  428px); }   /* instant reset */
  100% { transform: translate(330px,  428px); }
}

/* Leg walk */
#leg-l { animation: legW .38s ease-in-out infinite alternate; transform-origin: top center; }
#leg-r { animation: legW .38s ease-in-out infinite alternate reverse; transform-origin: top center; }
@keyframes legW { from{transform:rotate(-24deg)} to{transform:rotate(24deg)} }

/* Think bubble — synced to 36s */
#think-bubble { animation: thinkSync 36s linear infinite; }
@keyframes thinkSync {
  0%,9%    { opacity:0; }
  11%,19%  { opacity:1; }
  21%,37%  { opacity:0; }
  39%,47%  { opacity:1; }
  49%,61%  { opacity:0; }
  63%,71%  { opacity:1; }
  73%,100% { opacity:0; }
}

/* Badges — appear when walker leaves each building
   shield after Ciber stop (20%), gear after IA stop (48%), rocket after SEO (72%) */
#badge-shield  { animation: bdgShield 36s linear infinite; }
@keyframes bdgShield {
  0%,19%  { opacity:0; transform:translate(16px,-20px) scale(.2); }
  22%     { opacity:1; transform:translate(16px,-20px) scale(1.3); }
  25%     { transform:translate(16px,-20px) scale(1); }
  88%     { opacity:1; transform:translate(16px,-20px) scale(1); }
  89%     { opacity:0; transform:translate(16px,-20px) scale(.2); }
  100%    { opacity:0; }
}
#badge-gear   { animation: bdgGear 36s linear infinite; }
@keyframes bdgGear {
  0%,47%  { opacity:0; transform:translate(16px,-8px) scale(.2); }
  50%     { opacity:1; transform:translate(16px,-8px) scale(1.3); }
  53%     { transform:translate(16px,-8px) scale(1); }
  88%     { opacity:1; transform:translate(16px,-8px) scale(1); }
  89%     { opacity:0; transform:translate(16px,-8px) scale(.2); }
  100%    { opacity:0; }
}
#badge-rocket { animation: bdgRocket 36s linear infinite; }
@keyframes bdgRocket {
  0%,71%  { opacity:0; transform:translate(28px,-16px) scale(.2); }
  74%     { opacity:1; transform:translate(28px,-16px) scale(1.3); }
  77%     { transform:translate(28px,-16px) scale(1); }
  88%     { opacity:1; transform:translate(28px,-16px) scale(1); }
  89%     { opacity:0; transform:translate(28px,-16px) scale(.2); }
  100%    { opacity:0; }
}

/* Success aura */
#aura-success { animation: auraAppear 36s linear infinite; }
@keyframes auraAppear {
  0%,74%  { opacity:0; }
  78%,86% { opacity:1; }
  89%     { opacity:0; }
  100%    { opacity:0; }
}

/* Background walkers */
#walker2 { animation: w2 26s linear infinite; animation-delay:-10s; }
@keyframes w2 { 0%{transform:translate(-40px,433px) scale(.58);opacity:0} 5%{opacity:.4} 92%{opacity:.4} 100%{transform:translate(1490px,433px) scale(.58);opacity:0} }
