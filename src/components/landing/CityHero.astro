    margin: 0 16px 12px;
  }
}
</style>

<script>
// =====================================================================
// CITY HERO — full controller
// =====================================================================

const CYCLE = 36000;
const stops = [
  { dept: 'ciber', from: 0.10, to: 0.20, icon: '🛡️', chartPhase: 2 },
  { dept: 'ia',    from: 0.38, to: 0.48, icon: '🤖', chartPhase: 3 },
  { dept: 'seo',   from: 0.62, to: 0.72, icon: '🚀', chartPhase: 4 },
];
const bldIcons: Record<string, string> = { ciber: '🛡️', ia: '🤖', seo: '🚀' };

// ======================
// PANELS (always visible, highlight active)
// ======================
const svcs = document.querySelectorAll<HTMLElement>('.svc-panel');
let activePanel: string | null = null;

function activatePanel(id: string) {
  svcs.forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.iso-building').forEach(b => b.classList.remove('active'));
  const el = document.getElementById(`panel-${id}`);
  el?.classList.add('active');
  document.getElementById(`bld-${id}`)?.classList.add('active');
  activePanel = id;
  // Set --pc on panel so border glow matches dept color
  const colors: Record<string,string> = { ciber:'#a78bfa', ia:'#34d399', seo:'#fb923c' };
  if (el && colors[id]) el.style.setProperty('--pc', colors[id]);
}

function deactivateAll() {
  svcs.forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.iso-building').forEach(b => b.classList.remove('active'));
  activePanel = null;
}

document.querySelectorAll('.iso-building').forEach(b => {
  b.addEventListener('click', (e) => {
    e.stopPropagation();
    const dept = (b as HTMLElement).dataset.dept!;
    autoMode = false;
    activatePanel(dept);
    const phase = deptToPhase[dept];
    if (phase) updateChart(phase);
    fireFlyIcon(dept);
  });
});
document.addEventListener('click', (e) => {
  if (!(e.target as Element).closest('.iso-building') && !(e.target as Element).closest('.svc-panel')) {
    deactivateAll();
  }
});

// ======================
// AUTO WALKER SYNC
// ======================
let autoMode = true;
let lastStop: string | null = null;
const thinkIconEl = document.getElementById('think-icon');
const loadTime = Date.now();

function walkerTick() {
  if (!autoMode) { requestAnimationFrame(walkerTick); return; }
  const pct = ((Date.now() - loadTime) % CYCLE) / CYCLE;
  const current = stops.find(s => pct >= s.from && pct < s.to) ?? null;

  if (current) {
    if (thinkIconEl) thinkIconEl.textContent = current.icon;
    if (lastStop !== current.dept) {
      activatePanel(current.dept);
      updateChart(current.chartPhase);
      fireFlyIcon(current.dept);
      lastStop = current.dept;
    }
  } else {
    if (lastStop !== null) { deactivateAll(); lastStop = null; }
  }
  requestAnimationFrame(walkerTick);
}
requestAnimationFrame(walkerTick);

// ======================
// FLYING ICON ANIMATION
// ======================
const canvas = document.getElementById('fly-canvas') as HTMLCanvasElement;
const ctx = canvas?.getContext('2d');

interface FlyParticle {
  emoji: string;
  x: number; y: number;       // current pos (canvas px)
  tx: number; ty: number;     // target (walker pos)
  t: number;                  // 0→1 progress
  size: number;
  done: boolean;
  trail: Array<{x:number;y:number;a:number}>;
  // control point for arc
  cx: number; cy: number;
}

const flyParticles: FlyParticle[] = [];
const svg = document.getElementById('city-svg') as SVGSVGElement;

function getWalkerCanvasPos(): { x: number; y: number } {
  const svgRect  = svg.getBoundingClientRect();
  const canRect  = canvas.getBoundingClientRect();
  const pct = ((Date.now() - loadTime) % CYCLE) / CYCLE;

  // Interpolate walker SVG x based on CSS keyframes
  // Rough linear approximation of walker position
  let svgX = -30;
  if (pct < 0.06)       svgX = -30 + (pct / 0.06) * (440 - (-30));
  else if (pct < 0.10)  svgX = 440 + ((pct - 0.06) / 0.04) * (570 - 440);
  else if (pct < 0.20)  svgX = 570;
  else if (pct < 0.38)  svgX = 570 + ((pct - 0.20) / 0.18) * (940 - 570);
  else if (pct < 0.48)  svgX = 970;
  else if (pct < 0.62)  svgX = 970 + ((pct - 0.48) / 0.14) * (1250 - 970);
  else if (pct < 0.72)  svgX = 1280;
  else                  svgX = 1280 + ((pct - 0.72) / 0.17) * (1490 - 1280);

  const scaleX = svgRect.width / 1440;
  const scaleY = svgRect.height / 490;
  const svgY   = 428; // walker road y

  return {
    x: svgRect.left - canRect.left + svgX * scaleX,
    y: svgRect.top  - canRect.top  + svgY * scaleY - 30,
  };
}

function getBuildingCanvasPos(dept: string): { x: number; y: number } {
  const svgRect = svg.getBoundingClientRect();
  const canRect = canvas.getBoundingClientRect();
  const scaleX  = svgRect.width / 1440;
  const scaleY  = svgRect.height / 490;

  // Approximate top-center of each building
  const tops: Record<string, { x: number; y: number }> = {
    it:    { x: 200,  y: 265 },
    ciber: { x: 570,  y: 213 },
    ia:    { x: 970,  y: 177 },
    seo:   { x: 1280, y: 142 },
  };
  const p = tops[dept] || { x: 570, y: 250 };
  return {
    x: svgRect.left - canRect.left + p.x * scaleX,
    y: svgRect.top  - canRect.top  + p.y * scaleY,
  };
}

function fireFlyIcon(dept: string) {
  if (!ctx || !canvas) return;
  const icon  = bldIcons[dept];
  if (!icon) return;

  const from = getBuildingCanvasPos(dept);
  const to   = getWalkerCanvasPos();

  // Arc control point: goes up and toward target
  const cpx = (from.x + to.x) / 2;
  const cpy = Math.min(from.y, to.y) - 80;

  flyParticles.push({
    emoji: icon,
    x: from.x, y: from.y,
    tx: to.x,  ty: to.y,
    cx: cpx,   cy: cpy,
    t: 0,
    size: 28,
    done: false,
    trail: [],
  });
}

function resizeCanvas() {
  if (!canvas) return;
  const rect = canvas.parentElement!.getBoundingClientRect();
  canvas.width  = rect.width;
  canvas.height = rect.height;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
function easeInOut(t: number) { return t < .5 ? 2*t*t : -1+(4-2*t)*t; }

function flyTick() {
  if (!ctx || !canvas) { requestAnimationFrame(flyTick); return; }
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  for (const p of flyParticles) {
    if (p.done) continue;
    p.t = Math.min(p.t + 0.010, 1);
    const e = easeInOut(p.t);

    // Quadratic bezier
    const bx = (1-e)*(1-e)*p.x + 2*(1-e)*e*p.cx + e*e*p.tx;
    const by = (1-e)*(1-e)*p.y + 2*(1-e)*e*p.cy + e*e*p.ty;

    // Trail
    p.trail.push({ x: bx, y: by, a: 1 - e });
    if (p.trail.length > 12) p.trail.shift();

    // Draw trail
    for (let i = 0; i < p.trail.length; i++) {
      const pt = p.trail[i];
      const alpha = (i / p.trail.length) * pt.a * 0.5;
      ctx.globalAlpha = alpha;
      ctx.font = `${p.size * 0.6}px serif`;
      ctx.fillText(p.emoji, pt.x - 8, pt.y + 8);
    }

    // Draw icon
    const scale = p.t < 0.8 ? 1 : 1 + (1 - p.t) * 2; // small pop at end
    ctx.globalAlpha = p.t < 0.85 ? 1 : 1 - (p.t - 0.85) / 0.15;
    ctx.font = `${p.size * scale}px serif`;
    ctx.fillText(p.emoji, bx - p.size * scale / 2, by + p.size * scale / 2);

    // Sparkle ring at arrival
    if (p.t > 0.92) {
      ctx.globalAlpha = (1 - p.t) * 4;
      ctx.strokeStyle = '#fbbf24';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(p.tx, p.ty, (p.t - 0.92) * 200, 0, Math.PI * 2);
      ctx.stroke();
    }

    ctx.globalAlpha = 1;
    if (p.t >= 1) p.done = true;
  }

  // Remove done
  for (let i = flyParticles.length - 1; i >= 0; i--) {
    if (flyParticles[i].done) flyParticles.splice(i, 1);
  }

  requestAnimationFrame(flyTick);
}
requestAnimationFrame(flyTick);

// ======================
// METRICS CHART
// ======================
const metricData = {
  // [phase0_start, after_it, after_ciber, after_ia, after_seo]
  seg:  [10, 22, 82, 88, 92],
  prod: [15, 28, 40, 78, 88],
  ing:  [10, 18, 32, 58, 94],
};
const chartX    = [36, 72, 116, 184, 244];
const toY       = (v: number) => 90 - (v / 100) * 80;
const deptToPhase: Record<string, number> = { ciber: 2, ia: 3, seo: 4 };

const phaseLabels  = ['Inicio', 'IT', 'Ciberseguridad', 'IA', 'SEO'];
const phaseColors  = ['#38bdf8','#38bdf8','#a78bfa','#34d399','#fb923c'];
const phaseBgs     = ['rgba(56,189,248,.12)','rgba(56,189,248,.12)','rgba(167,139,250,.14)','rgba(52,211,153,.12)','rgba(251,146,60,.14)'];
const phaseBorders = ['rgba(56,189,248,.25)','rgba(56,189,248,.25)','rgba(167,139,250,.3)','rgba(52,211,153,.25)','rgba(251,146,60,.3)'];

const lineSeg  = document.getElementById('line-seg')  as SVGPolylineElement;
const lineProd = document.getElementById('line-prod') as SVGPolylineElement;
const lineIng  = document.getElementById('line-ing')  as SVGPolylineElement;
const areaSeg  = document.getElementById('area-seg')  as SVGPathElement;
const areaProd = document.getElementById('area-prod') as SVGPathElement;
const areaIng  = document.getElementById('area-ing')  as SVGPathElement;
const dotSeg   = document.getElementById('dot-seg')   as SVGCircleElement;
const dotProd  = document.getElementById('dot-prod')  as SVGCircleElement;
const dotIng   = document.getElementById('dot-ing')   as SVGCircleElement;
const phaseTagEl = document.getElementById('metrics-phase-label')!;
const kpiSegVal  = document.getElementById('kpi-seg-val')!;
const kpiProdVal = document.getElementById('kpi-prod-val')!;
const kpiIngVal  = document.getElementById('kpi-ing-val')!;

let currentChartPhase = 0;

function buildPts(data: number[], n: number) {
  return chartX.slice(0,n+1).map((x,i) => `${x},${toY(data[i]).toFixed(1)}`).join(' ');
}
function buildArea(data: number[], n: number) {
  const pts = chartX.slice(0,n+1).map((x,i) => `${x},${toY(data[i]).toFixed(1)}`);
  return `M${pts.join(' L')} L${chartX[n]},90 L36,90 Z`;
}
function animKpi(el: HTMLElement, from: number, to: number) {
  const t0 = performance.now();
  const fn = (now: number) => {
    const e = 1 - Math.pow(1 - Math.min((now-t0)/900,1), 3);
    el.textContent = Math.round(from+(to-from)*e)+'%';
    if (e < 1) requestAnimationFrame(fn);
  };
  requestAnimationFrame(fn);
}

function updateChart(phase: number) {
  if (phase === currentChartPhase) return;
  const prev = currentChartPhase;
  currentChartPhase = phase;

  lineSeg.setAttribute('points', buildPts(metricData.seg, phase));
  lineProd.setAttribute('points',buildPts(metricData.prod,phase));
  lineIng.setAttribute('points', buildPts(metricData.ing, phase));
  areaSeg.setAttribute('d',  buildArea(metricData.seg,  phase));
  areaProd.setAttribute('d', buildArea(metricData.prod, phase));
  areaIng.setAttribute('d',  buildArea(metricData.ing,  phase));
  dotSeg.setAttribute('cx',  String(chartX[phase])); dotSeg.setAttribute('cy',  toY(metricData.seg[phase]).toFixed(1));
  dotProd.setAttribute('cx', String(chartX[phase])); dotProd.setAttribute('cy', toY(metricData.prod[phase]).toFixed(1));
  dotIng.setAttribute('cx',  String(chartX[phase])); dotIng.setAttribute('cy',  toY(metricData.ing[phase]).toFixed(1));

  phaseTagEl.textContent     = phaseLabels[phase];
  phaseTagEl.style.color     = phaseColors[phase];
  phaseTagEl.style.background= phaseBgs[phase];
  phaseTagEl.style.borderColor=phaseBorders[phase];

  animKpi(kpiSegVal,  metricData.seg[prev],  metricData.seg[phase]);
  animKpi(kpiProdVal, metricData.prod[prev], metricData.prod[phase]);
  animKpi(kpiIngVal,  metricData.ing[prev],  metricData.ing[phase]);

  document.querySelectorAll('.kpi-item').forEach(k=>k.classList.remove('highlight'));
  const diffs = [
    Math.abs(metricData.seg[phase]-metricData.seg[prev]),
    Math.abs(metricData.prod[phase]-metricData.prod[prev]),
    Math.abs(metricData.ing[phase]-metricData.ing[prev]),
  ];
  const ids = ['kpi-seg','kpi-prod','kpi-ing'];
  document.getElementById(ids[diffs.indexOf(Math.max(...diffs))])?.classList.add('highlight');
}

// Init
updateChart(0);
</script>
