---
// HeroConceptC — "Fragmentación vs Unificación"
// Contraste visual: el caos de 5 proveedores frente a un solo partner integrado.

const antes = [
  'Una empresa para la IA',
  'Otra para la ciberseguridad',
  'Otra para los sistemas',
  'Otra para el soporte técnico',
  'Ninguna se habla con las demás',
];
const despues = [
  { t: 'Inteligencia Artificial', c: '#60a5fa' },
  { t: 'Ciberseguridad',          c: '#34d399' },
  { t: 'Sistemas IT',             c: '#a78bfa' },
  { t: 'Automatización',          c: '#fbbf24' },
  { t: 'Todo integrado y optimizado', c: '#7cc0ff' },
];
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 py-20" style="background:#020817;">

  <!-- Grid de fondo -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(59,130,246,0.10) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,0.10) 1px,transparent 1px);background-size:48px 48px;opacity:0.5;"></div>
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 85% 65% at 70% 45%,rgba(37,99,235,0.16) 0%,transparent 70%);"></div>

  <div class="relative w-full max-w-6xl mx-auto" style="z-index:10;">

    <!-- Cabecera -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6 border" style="background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.3);color:#7cc0ff;letter-spacing:0.08em;text-transform:uppercase;">
        <span style="width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 8px #4ade80;display:inline-block;"></span>
        Tu partner tecnológico de confianza
      </div>

      <h1 class="font-extrabold tracking-tight mb-5" style="font-size:clamp(2rem,5.5vw,3.6rem);line-height:1.08;color:#f0f6ff;">
        IA, ciberseguridad y sistemas.<br>
        <span style="background:linear-gradient(90deg,#60a5fa,#a78bfa,#34d399);-webkit-background-clip:text;background-clip:text;color:transparent;">Todo conectado, todo optimizado.</span>
      </h1>

      <p class="mx-auto" style="max-width:44rem;font-size:clamp(1rem,2.2vw,1.2rem);line-height:1.6;color:rgba(240,246,255,0.72);">
        La mayoría de empresas reparten su tecnología entre varios proveedores que no se coordinan. Nosotros lo unificamos todo bajo un mismo equipo.
      </p>
    </div>

    <!-- Comparativa -->
    <div class="compare-grid mb-10">

      <!-- ANTES -->
      <div class="compare-col compare-antes">
        <div class="compare-head">
          <span class="compare-tag" style="background:rgba(248,113,113,0.12);border:1px solid rgba(248,113,113,0.3);color:#fca5a5;">Lo habitual</span>
          <h2 style="font-size:1.25rem;font-weight:700;color:#cbd5e1;margin-top:0.75rem;">Tecnología fragmentada</h2>
        </div>
        <ul class="compare-list">
          {antes.map(item => (
            <li>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#f87171" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <div class="compare-foot" style="color:#fca5a5;">= caos, sobrecostes y sistemas que no se integran</div>
      </div>

      <!-- Flecha / VS -->
      <div class="compare-vs" aria-hidden="true">
        <div class="compare-vs-circle">
          <svg class="w-6 h-6" fill="none" stroke="#7cc0ff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>
        </div>
      </div>

      <!-- DESPUÉS -->
      <div class="compare-col compare-despues">
        <div class="compare-head">
          <span class="compare-tag" style="background:rgba(52,211,153,0.12);border:1px solid rgba(52,211,153,0.3);color:#6ee7b7;">Con AI Security</span>
          <h2 style="font-size:1.25rem;font-weight:700;color:#f0f6ff;margin-top:0.75rem;">Un solo partner integrado</h2>
        </div>
        <ul class="compare-list">
          {despues.map(item => (
            <li>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="#34d399" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span style={`color:${item.c};font-weight:600;`}>{item.t}</span>
            </li>
          ))}
        </ul>
        <div class="compare-foot" style="color:#6ee7b7;">= más eficiencia, menos coste y todo automatizado</div>
      </div>

    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/reunion" class="cta-primary">
        Consulta gratuita
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="#servicios" class="cta-ghost">Ver todos los servicios</a>
    </div>

  </div>
</section>

<style>
  .compare-grid {
    display:grid;
    grid-template-columns:1fr auto 1fr;
    align-items:stretch;
    gap:1.25rem;
  }
  .compare-col {
    display:flex;flex-direction:column;
    padding:1.75rem;border-radius:1rem;
    backdrop-filter:blur(8px);
  }
  .compare-antes {
    background:rgba(255,255,255,0.02);
    border:1px solid rgba(248,113,113,0.15);
    opacity:0.85;
  }
  .compare-despues {
    background:rgba(52,211,153,0.05);
    border:1px solid rgba(52,211,153,0.3);
    box-shadow:0 16px 50px -20px rgba(52,211,153,0.4);
  }
  .compare-tag {
    display:inline-block;font-size:0.7rem;font-weight:700;
    padding:0.25rem 0.7rem;border-radius:9999px;
    letter-spacing:0.06em;text-transform:uppercase;
  }
  .compare-list { list-style:none;padding:0;margin:1.5rem 0;display:flex;flex-direction:column;gap:0.85rem;flex:1; }
  .compare-list li { display:flex;align-items:center;gap:0.7rem;font-size:0.92rem; }
  .compare-antes .compare-list li span { color:rgba(203,213,225,0.75); }
  .compare-foot { font-size:0.8rem;font-weight:600;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.08); }

  .compare-vs { display:flex;align-items:center;justify-content:center; }
  .compare-vs-circle {
    width:52px;height:52px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    background:rgba(7,15,32,0.9);
    border:1px solid rgba(124,192,255,0.4);
    box-shadow:0 0 24px rgba(59,130,246,0.3);
    animation:vsPulse 2.5s ease-in-out infinite;
  }
  @keyframes vsPulse {
    0%,100% { box-shadow:0 0 24px rgba(59,130,246,0.25); }
    50%     { box-shadow:0 0 36px rgba(59,130,246,0.5); }
  }

  /* CTAs */
  .cta-primary {
    display:inline-flex;align-items:center;gap:0.5rem;
    background:#2563eb;color:#fff;font-weight:700;
    padding:0.8rem 1.6rem;border-radius:0.75rem;text-decoration:none;
    box-shadow:0 8px 24px rgba(37,99,235,0.4);
    transition:all 0.2s ease;
  }
  .cta-primary:hover { background:#1d4ed8;transform:translateY(-2px);box-shadow:0 12px 32px rgba(37,99,235,0.55); }
  .cta-ghost {
    display:inline-flex;align-items:center;
    color:#cbd5e1;font-weight:600;
    padding:0.8rem 1.4rem;border-radius:0.75rem;text-decoration:none;
    border:1px solid rgba(255,255,255,0.14);
    transition:all 0.2s ease;
  }
  .cta-ghost:hover { color:#fff;border-color:rgba(255,255,255,0.3);background:rgba(255,255,255,0.04); }

  /* Responsive: apila en móvil, la flecha gira */
  @media (max-width: 820px) {
    .compare-grid { grid-template-columns:1fr;gap:0.75rem; }
    .compare-vs-circle { transform:rotate(90deg); }
    .compare-antes { opacity:0.8; }
  }
</style>
