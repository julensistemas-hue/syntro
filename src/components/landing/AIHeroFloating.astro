---
// AIHeroFloating — Typewriter de problemas reales
// Frase grande que cambia sola con el dolor del cliente, chat pequeño debajo
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 pb-16" style="background:#020817;">

  <!-- Canvas red neuronal animada -->
  <canvas id="hero-net-canvas" class="absolute inset-0 pointer-events-none" style="width:100%;height:100%;opacity:0.85;display:block;"></canvas>

  <!-- Viñeta perimetral — mantiene focus en el centro -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 65% at 50% 50%,transparent 25%,rgba(2,8,23,0.82) 100%);"></div>

  <!-- Bolita animada (position:fixed para salir desde el nav) -->
  <div id="sol-ball"></div>

  <!-- ═══════════════════════════
       BLOQUE PRINCIPAL
  ═══════════════════════════ -->
  <div class="relative w-full max-w-5xl mx-auto text-center" style="z-index:10;">

    <!-- H1 SEO oculto visualmente — Google lo indexa, el usuario no lo ve -->
    <h1 class="sr-only">Automatización con Inteligencia Artificial y Consultoría IT para PyMEs en España — Chatbot IA, Gestor Documental, Atención de Llamadas y Gestión de Citas con IA</h1>

    <!-- ¿Te suena esto? — separador -->
    <div class="w-full max-w-3xl mx-auto flex items-center gap-3" style="margin-bottom:1rem;">
      <div style="flex:1;height:1px;background:linear-gradient(to right,transparent,rgba(59,130,246,0.3));"></div>
      <p id="tw-label" class="font-bold" style="font-size:clamp(1.05rem,2.2vw,1.35rem);letter-spacing:0.06em;color:#e2e8f0;white-space:nowrap;">¿Te suena esto?</p>
      <div style="flex:1;height:1px;background:linear-gradient(to left,transparent,rgba(59,130,246,0.3));"></div>
    </div>

    <!-- ╔═ CAJA PRINCIPAL ═══════════════════════════════════════════════════╗ -->
    <div class="hero-main-card w-full max-w-3xl mx-auto rounded-2xl px-4 py-4 sm:px-7 sm:py-6 mb-2" style="background:rgba(5,12,30,0.75);border:1px solid rgba(59,130,246,0.18);backdrop-filter:blur(8px);">

      <!-- Frase typewriter — altura fija para no mover layout -->
      <div class="tw-height-wrap" style="min-height:120px;display:flex;flex-direction:column;align-items:center;justify-content:center;margin-bottom:10px;overflow:hidden;">
        <p id="typewriter-text" class="font-bold leading-tight text-center" aria-hidden="true" style="color:#f0f6ff;font-size:clamp(1.4rem,3.2vw,2.2rem);max-width:100%;white-space:pre-line;"></p>
        <span id="tw-cursor" class="tw-cursor" aria-hidden="true"></span>
      </div>

      <!-- Separador interno -->
      <div style="height:1px;background:linear-gradient(to right,transparent,rgba(59,130,246,0.3),transparent);margin-bottom:16px;"></div>

      <!-- Solución — altura flexible -->
      <div class="sol-height-wrap" style="min-height:64px;display:flex;align-items:center;justify-content:center;overflow:hidden;">
        <div id="solution-box" class="solution-card w-full rounded-xl px-4 py-3 sm:px-5 sm:py-4 flex flex-col sm:flex-row items-start sm:items-center gap-3 text-left" style="position:relative;overflow:hidden;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);opacity:0;transform:translateY(24px) scale(0.85);filter:blur(4px);">
          <div id="solution-glow" style="position:absolute;inset:0;border-radius:0.75rem;opacity:0;pointer-events:none;background:radial-gradient(ellipse at center,rgba(96,165,250,0.25),transparent 70%);"></div>
          <!-- Fila icono + texto (siempre en fila) -->
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <div id="solution-icon-wrap" class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-xl flex items-center justify-center" style="background:rgba(96,165,250,0.12);">
              <svg id="solution-icon" class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:#60a5fa;"></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold mb-1 flex items-center gap-1.5" style="color:#4ade80;text-transform:uppercase;letter-spacing:0.1em;">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span id="solution-label"></span>
              </p>
              <p id="solution-text" class="font-semibold leading-snug" style="color:#f1f5f9;font-size:clamp(0.82rem,2.2vw,1rem);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"></p>
            </div>
          </div>
          <!-- Botón CTA -->
          <a id="solution-link" href="/" class="sol-cta-btn flex-shrink-0 flex items-center gap-1.5 sm:gap-2 rounded-xl font-bold transition-all self-end sm:self-auto" style="position:relative;overflow:hidden;background:#2563eb;color:white;text-decoration:none;white-space:nowrap;font-size:0.8rem;padding:0.5rem 0.875rem;">
            <span id="solution-cta-text" class="sol-cta-text">Ver servicio</span>
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <div id="btn-shine" style="position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.35),transparent);transform:skewX(-20deg);pointer-events:none;"></div>
          </a>
        </div>
      </div>

    </div>
    <!-- ╚═══════════════════════════════════════════════════════════════════╝ -->

    <!-- "o pregunta directamente a nuestra IA" — separador -->
    <div class="w-full max-w-3xl mx-auto flex items-center gap-3" style="margin-top:1.5rem;margin-bottom:0.75rem;">
      <div style="flex:1;height:1px;background:linear-gradient(to right,transparent,rgba(59,130,246,0.3));"></div>
      <span style="font-size:0.72rem;font-weight:600;color:#94a3b8;letter-spacing:0.14em;text-transform:uppercase;white-space:nowrap;">o pregunta directamente a nuestra IA</span>
      <div style="flex:1;height:1px;background:linear-gradient(to left,transparent,rgba(59,130,246,0.3));"></div>
    </div>

    <!-- ╔═ CAJA CHAT ═══════════════════════════════════════════════════════╗ -->
    <div class="w-full max-w-3xl mx-auto rounded-2xl" style="background:rgba(5,12,30,0.75);border:1px solid rgba(59,130,246,0.18);backdrop-filter:blur(8px);padding:0.75rem;">
      <!-- Sin overflow-hidden aquí para que los quick buttons puedan hacer scroll -->
      <div class="rounded-xl" style="background:rgba(10,12,28,0.85);border:1px solid rgba(59,130,246,0.15);">

        <!-- Respuesta inline -->
        <div id="chat-response" class="hidden px-4 py-4 overflow-y-auto" style="max-height:200px;">
          <div id="chat-response-text" class="text-sm leading-relaxed mb-3" style="color:#e2e8f0;"></div>
          <div id="email-contact" style="border-top:1px solid rgba(255,255,255,0.07);padding-top:12px;">
            <p class="text-xs mb-2" style="color:#94a3b8;">¿Quieres que te respondamos con más detalle?</p>
            <div id="email-input-row" class="flex items-center gap-2">
              <input type="email" id="email-input" placeholder="Tu email..." class="flex-1 bg-transparent px-3 py-1.5 text-sm focus:outline-none rounded-lg" style="color:#f0f6ff;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);min-width:0;" />
              <button type="button" id="email-send" class="px-3 py-1.5 text-xs font-medium text-white rounded-lg flex-shrink-0" style="background:#2563eb;">Enviar</button>
            </div>
            <p id="email-success" class="hidden text-xs mt-2" style="color:#4ade80;">Recibido. Te contestaremos pronto.</p>
            <p id="email-error" class="hidden text-xs mt-2" style="color:#f87171;">Error. Escríbenos a info@aisecurity.es</p>
          </div>
          <button type="button" id="chat-back" class="mt-3 flex items-center gap-1.5 text-xs" style="color:#60a5fa;">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Nueva pregunta
          </button>
        </div>

        <!-- Input -->
        <form id="chat-form">
          <div id="chat-input-row" style="display:flex;align-items:center;padding:0.625rem 0.75rem;gap:0.5rem;overflow:hidden;">
            <svg class="w-4 h-4 flex-shrink-0" style="color:#a0aec0;min-width:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            <input type="text" id="chat-input" placeholder="Pregunta sobre IA o ciberseguridad..." class="focus:outline-none bg-transparent" style="flex:1;min-width:0;color:#f0f6ff;font-size:0.875rem;padding:0.5rem 0;" />
            <button type="submit" style="flex-shrink:0;background:#2563eb;color:white;border-radius:0.625rem;padding:0.5rem 0.75rem;font-size:0.8rem;font-weight:600;display:flex;align-items:center;gap:0.375rem;white-space:nowrap;">
              <span style="display:none;" class="sm-inline">Enviar</span>
              <svg style="width:1rem;height:1rem;min-width:1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
            </button>
          </div>
        </form>

        <!-- Typing -->
        <div id="chat-typing" class="hidden px-4 py-3">
          <div class="flex gap-1.5 items-center">
            <div class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#60a5fa;animation-delay:0ms"></div>
            <div class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#60a5fa;animation-delay:150ms"></div>
            <div class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#60a5fa;animation-delay:300ms"></div>
            <span class="text-xs ml-2" style="color:#c4b5fd;">Pensando...</span>
          </div>
        </div>

        <!-- Quick buttons — scroll horizontal en móvil -->
        <div id="quick-buttons" style="display:flex;flex-wrap:wrap;gap:0.375rem;padding:0 0.75rem 0.75rem;">
          <button class="quick-question" style="background:rgba(255,255,255,0.08);border:1px solid rgba(167,139,250,0.25);color:#e2d9f3;display:flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border-radius:9999px;font-size:0.72rem;white-space:nowrap;flex-shrink:0;transition:all 0.15s;">
            <svg style="width:0.625rem;height:0.625rem;flex-shrink:0;color:#60a5fa;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            ¿Qué servicios ofrecéis?
          </button>
          <button class="quick-question" style="background:rgba(255,255,255,0.08);border:1px solid rgba(167,139,250,0.25);color:#e2d9f3;display:flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border-radius:9999px;font-size:0.72rem;white-space:nowrap;flex-shrink:0;transition:all 0.15s;">
            <svg style="width:0.625rem;height:0.625rem;flex-shrink:0;color:#4ade80;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            ¿Cómo puedo vender más?
          </button>
          <button class="quick-question" style="background:rgba(255,255,255,0.08);border:1px solid rgba(167,139,250,0.25);color:#e2d9f3;display:flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border-radius:9999px;font-size:0.72rem;white-space:nowrap;flex-shrink:0;transition:all 0.15s;">
            <svg style="width:0.625rem;height:0.625rem;flex-shrink:0;color:#f87171;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            ¿Cómo protegerme?
          </button>
          <button class="quick-question" style="background:rgba(255,255,255,0.08);border:1px solid rgba(167,139,250,0.25);color:#e2d9f3;display:flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border-radius:9999px;font-size:0.72rem;white-space:nowrap;flex-shrink:0;transition:all 0.15s;">
            <svg style="width:0.625rem;height:0.625rem;flex-shrink:0;color:#4ade80;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            ¿Qué puedo automatizar?
          </button>
          <button class="quick-question" style="background:rgba(255,255,255,0.08);border:1px solid rgba(167,139,250,0.25);color:#e2d9f3;display:flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border-radius:9999px;font-size:0.72rem;white-space:nowrap;flex-shrink:0;transition:all 0.15s;">
            <svg style="width:0.625rem;height:0.625rem;flex-shrink:0;color:#fbbf24;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            ¿Cuánto cuesta?
          </button>
          <button class="quick-question" style="background:rgba(255,255,255,0.08);border:1px solid rgba(167,139,250,0.25);color:#e2d9f3;display:flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border-radius:9999px;font-size:0.72rem;white-space:nowrap;flex-shrink:0;transition:all 0.15s;">
            <svg style="width:0.625rem;height:0.625rem;flex-shrink:0;color:#a78bfa;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            ¿Necesito equipo técnico?
          </button>
        </div>

      </div>
    </div><!-- /caja chat -->

    <!-- Stats -->
    <div class="flex items-center justify-center gap-6 mt-10">
      <div class="text-center">
        <div class="text-base font-bold" style="color:#60a5fa;">24/7</div>
        <div class="text-xs" style="color:#a0aec0;">Disponibilidad</div>
      </div>
      <div style="width:1px;height:24px;background:rgba(255,255,255,0.07);"></div>
      <div class="text-center">
        <div class="text-base font-bold" style="color:#a78bfa;">Wazuh/ENS</div>
        <div class="text-xs" style="color:#a0aec0;">Ciberseguridad</div>
      </div>
      <div style="width:1px;height:24px;background:rgba(255,255,255,0.07);"></div>
      <div class="text-center">
        <div class="text-base font-bold" style="color:#4ade80;">PyMEs ES</div>
        <div class="text-xs" style="color:#a0aec0;">Nuestro foco</div>
      </div>
    </div>

  </div><!-- /BLOQUE PRINCIPAL -->

  <!-- Scroll -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2" style="z-index:20;">
    <div class="flex flex-col items-center gap-1 animate-bounce" style="color:#a0aec0;">
      <span class="text-xs">Descubre más</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </div>

</section>

<style>
  @keyframes scanLine {
    0%   { top:-2px;opacity:0; }
    5%   { opacity:0.3; }
    95%  { opacity:0.05; }
    100% { top:100%;opacity:0; }
  }
  .scan-line {
    height:1px;
    background:linear-gradient(90deg,transparent 0%,rgba(59,130,246,0.5) 30%,rgba(99,102,241,0.7) 50%,rgba(59,130,246,0.5) 70%,transparent 100%);
    animation:scanLine 10s linear infinite 3s;
    z-index:3;opacity:0;
  }

  /* Cursor typewriter */
  .tw-cursor {
    display:inline-block;
    width:3px;
    height:1.1em;
    background:#60a5fa;
    border-radius:2px;
    vertical-align:middle;
    margin-left:4px;
    animation:twBlink 0.9s step-end infinite;
  }
  @keyframes twBlink {
    0%,100% { opacity:1; }
    50%     { opacity:0; }
  }


  /* Bolita de servicio */
  #sol-ball {
    position: fixed;
    display: none; /* oculta por defecto — fiable al 100% */
    width: 13px;
    height: 13px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
  }

  #typewriter-text {
    transition: color 0.4s ease;
  }

  /* ── Solución reveal ── */
  @keyframes solReveal {
    0%   { opacity:0; transform:translateY(24px) scale(0.85); filter:blur(6px); }
    40%  { opacity:1; filter:blur(0px); transform:translateY(-8px) scale(1.04); }
    65%  { transform:translateY(3px) scale(0.988); }
    100% { opacity:1; transform:translateY(0) scale(1); filter:blur(0); }
  }
  @keyframes solHide {
    0%   { opacity:1; transform:translateY(0) scale(1); filter:blur(0); }
    100% { opacity:0; transform:translateY(10px) scale(0.93); filter:blur(3px); }
  }
  @keyframes iconSpin {
    0%   { opacity:0; transform: scale(0) rotate(-60deg); }
    60%  { opacity:1; transform: scale(1.3) rotate(8deg); }
    100% { opacity:1; transform: scale(1) rotate(0deg); }
  }
  @keyframes glowBurst {
    0%   { opacity:0.8; }
    100% { opacity:0; }
  }
  @keyframes btnShine {
    0%   { left:-100%; }
    100% { left:150%; }
  }

  #solution-box {
    border-color: rgba(255,255,255,0.08);
    transition: border-color 0.4s ease;
  }
  #solution-box.visible {
    animation: solReveal 0.65s cubic-bezier(0.22,1,0.36,1) both;
  }
  #solution-box.hiding {
    animation: solHide 0.35s ease both;
  }
  #solution-icon-wrap.spin {
    animation: iconSpin 0.55s cubic-bezier(0.34,1.56,0.64,1) 0.15s both;
  }
  #solution-glow.burst {
    animation: glowBurst 0.7s ease-out both;
  }
  #btn-shine.shine {
    animation: btnShine 0.65s ease 0.35s both;
  }

  #solution-link:hover {
    background: #1d4ed8 !important;
  }

  /* Chat */
  #chat-form input:focus { outline: none; }

  .quick-question:hover {
    background:rgba(255,255,255,0.08) !important;
    border-color:rgba(255,255,255,0.15) !important;
    color:#e2e8f0 !important;
  }

  /* Animaciones entrada */
  section > div { animation: fadeUp 0.7s ease-out both; }

  @keyframes fadeUp {
    from { opacity:0; transform:translateY(20px); }
    to   { opacity:1; transform:translateY(0); }
  }

  /* Globo hero */
  @keyframes hero-continent-pulse {
    0%, 100% { opacity: 0.75; }
    50%       { opacity: 1; }
  }
  .hero-continents { animation: hero-continent-pulse 4s ease-in-out infinite; }

  @keyframes hero-spin {
    0%   { rx: 1px; }
    25%  { rx: 95px; }
    50%  { rx: 1px; }
    75%  { rx: 95px; }
    100% { rx: 1px; }
  }
  .hero-m1 { animation: hero-spin 12s linear infinite; }
  .hero-m2 { animation: hero-spin 12s linear infinite -3s; }
  .hero-m3 { animation: hero-spin 12s linear infinite -6s; }
  .hero-m4 { animation: hero-spin 12s linear infinite -9s; }

  /* ── Alturas auto en mobile ── */
  @media (max-width: 639px) {
    .tw-height-wrap  { height: auto !important; }
    .sol-height-wrap { height: auto !important; }
    /* Botón CTA de la solution card: ocultar texto en móvil */
    .sol-cta-text { display: none; }
  }

  /* ── Botón enviar: mostrar texto en sm+ ── */
  @media (min-width: 640px) {
    .sm-inline { display: inline !important; }
  }

  /* ── Quick buttons: 2 filas en móvil con wrap, sin cortar texto ── */
  #quick-buttons { row-gap: 0.375rem; }
  #quick-buttons .quick-question:hover {
    background: rgba(255,255,255,0.13) !important;
    border-color: rgba(255,255,255,0.2) !important;
  }
</style>

<script>
// ─── Red neuronal de fondo ────────────────────────────────────────────────────
(function () {
  const canvas = document.getElementById('hero-net-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  const NODE_COUNT   = 55;
  const MAX_DIST     = 160;
  const PULSE_SPEED  = 1.8;
  const PULSE_SIZE   = 3.5;

  // Paleta: azul #3b82f6, violeta #818cf8, cian #22d3ee
  const NODE_COLORS  = ['rgba(96,165,250,', 'rgba(129,140,248,', 'rgba(34,211,238,'];

  interface Node {
    x: number; y: number;
    vx: number; vy: number;
    r: number;
    colorIdx: number;
    phase: number;
  }

  interface Pulse {
    ax: number; ay: number;
    bx: number; by: number;
    t: number; // 0→1
    colorIdx: number;
  }

  let W = 0, H = 0;
  let nodes: Node[] = [];
  let pulses: Pulse[] = [];

  function resize() {
    const section = canvas.closest('section') as HTMLElement;
    W = canvas.width  = section ? section.offsetWidth  : window.innerWidth;
    H = canvas.height = section ? section.offsetHeight : window.innerHeight;
  }

  function init() {
    nodes = [];
    for (let i = 0; i < NODE_COUNT; i++) {
      nodes.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
        r: Math.random() * 2.5 + 1.5,
        colorIdx: Math.floor(Math.random() * NODE_COLORS.length),
        phase: Math.random() * Math.PI * 2,
      });
    }
  }

  function spawnPulse() {
    // Elige dos nodos cercanos al azar para lanzar un pulso
    const a = nodes[Math.floor(Math.random() * nodes.length)];
    const b = nodes[Math.floor(Math.random() * nodes.length)];
    const dx = b.x - a.x, dy = b.y - a.y;
    if (Math.sqrt(dx*dx + dy*dy) < MAX_DIST) {
      pulses.push({ ax: a.x, ay: a.y, bx: b.x, by: b.y, t: 0, colorIdx: a.colorIdx });
    }
  }

  let frameCount = 0;

  function draw() {
    ctx.clearRect(0, 0, W, H);
    frameCount++;

    // Mover nodos
    for (const n of nodes) {
      n.x += n.vx;
      n.y += n.vy;
      if (n.x < 0 || n.x > W) n.vx *= -1;
      if (n.y < 0 || n.y > H) n.vy *= -1;
    }

    // Dibujar conexiones
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        const dx = b.x - a.x, dy = b.y - a.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < MAX_DIST) {
          const alpha = (1 - dist / MAX_DIST) * 0.55;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(96,165,250,${alpha})`;
          ctx.lineWidth = 1.4;
          ctx.stroke();
        }
      }
    }

    // Dibujar pulsos
    pulses = pulses.filter(p => p.t <= 1);
    for (const p of pulses) {
      p.t += PULSE_SPEED / 100;
      const px = p.ax + (p.bx - p.ax) * p.t;
      const py = p.ay + (p.by - p.ay) * p.t;
      const alpha = Math.sin(p.t * Math.PI) * 0.9;
      const col = NODE_COLORS[p.colorIdx];
      // Glow
      const grd = ctx.createRadialGradient(px, py, 0, px, py, PULSE_SIZE * 3);
      grd.addColorStop(0, col + alpha + ')');
      grd.addColorStop(1, col + '0)');
      ctx.beginPath();
      ctx.arc(px, py, PULSE_SIZE * 3, 0, Math.PI * 2);
      ctx.fillStyle = grd;
      ctx.fill();
      // Núcleo
      ctx.beginPath();
      ctx.arc(px, py, PULSE_SIZE * 0.6, 0, Math.PI * 2);
      ctx.fillStyle = col + '1)';
      ctx.fill();
    }

    // Dibujar nodos
    const t = Date.now() / 1000;
    for (const n of nodes) {
      const pulse = 0.45 + 0.25 * Math.sin(t * 1.2 + n.phase);
      const col = NODE_COLORS[n.colorIdx];
      // Aura
      const grd = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 4);
      grd.addColorStop(0, col + (pulse * 0.5) + ')');
      grd.addColorStop(1, col + '0)');
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r * 4, 0, Math.PI * 2);
      ctx.fillStyle = grd;
      ctx.fill();
      // Core
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = col + pulse + ')';
      ctx.fill();
    }

    // Lanzar pulso cada ~40 frames
    if (frameCount % 40 === 0) spawnPulse();

    requestAnimationFrame(draw);
  }

  resize();
  init();
  draw();

  window.addEventListener('resize', () => { resize(); init(); });
})();
</script>

<script>
// ─── Typewriter ───────────────────────────────────────────────────────────
(function () {
  const el          = document.getElementById('typewriter-text')!;
  const solBox      = document.getElementById('solution-box')!;
  const solText     = document.getElementById('solution-text')!;
  const solLabel    = document.getElementById('solution-label')!;
  const solCtaText  = document.getElementById('solution-cta-text')!;
  const solIcon     = document.getElementById('solution-icon')!;
  const solIconWrap = document.getElementById('solution-icon-wrap')!;
  const solLink     = document.getElementById('solution-link') as HTMLAnchorElement;

  // Busca el botón "Servicios" del nav para origen de la bolita
  function getServiciosPos(): { x: number; y: number } {
    const btn = Array.from(document.querySelectorAll('button, a')).find(
      el => el.textContent?.trim().toLowerCase().startsWith('servicio')
    );
    if (btn) {
      const r = btn.getBoundingClientRect();
      return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
    }
    // fallback: top-center si no se encuentra
    return { x: window.innerWidth / 2, y: 30 };
  }

  interface Slide {
    problem:  string;
    color:    string;
    solution: string;
    label:    string;
    ctaText:  string;
    icon:     string;
    href:     string;
  }

  const SLIDES: Slide[] = [
    // 1ª — llamadas
    {
      problem:  'Recibes 80 llamadas al día\ny se pierden fuera de horario...',
      color:    '#818cf8',
      label:    'Llamada IA',
      ctaText:  'Ver Atención de Llamadas',
      solution: 'La recepcionista IA atiende, filtra y agenda sin descanso.',
      icon:     'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
      href:     '/servicios/atencion-llamadas',
    },
    // 2ª — contrato/carpetas
    {
      problem:  'Buscas ese contrato entre 200 carpetas\ny 3 años de archivos...',
      color:    '#a78bfa',
      label:    'Gestor Documental',
      ctaText:  'Ver Gestor Documental',
      solution: 'El gestor documental IA lo encuentra en 0.3 segundos.',
      icon:     'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
      href:     '/servicios/gestor-documental',
    },
    // 3ª — servidor/brecha
    {
      problem:  'Tu servidor tiene una brecha\nque nadie ha detectado...',
      color:    '#f85149',
      label:    'Wazuh',
      ctaText:  'Ver Wazuh SIEM',
      solution: 'Wazuh monitoriza 24/7 y alerta en tiempo real de cualquier amenaza.',
      icon:     'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
      href:     '/wazuh',
    },
    // 4ª — emails
    {
      problem:  'Llevas 3h al día\nrespondiendo los mismos emails...',
      color:    '#f0883e',
      label:    'Chatbot IA',
      ctaText:  'Ver Chatbot IA',
      solution: 'Un chatbot IA los responde automáticamente al instante.',
      icon:     'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
      href:     '/servicios/chatbot',
    },
    // 5ª — Consultoría IA
    {
      problem:  'Tu competencia ya usa IA\ny tú no sabes por dónde empezar...',
      color:    '#3fb950',
      label:    'Consultoría IA',
      ctaText:  'Ver Consultoría IA',
      solution: 'Analizamos tu negocio y diseñamos un plan de IA a tu medida.',
      icon:     'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
      href:     '/servicios/consultoria-ia',
    },
    // 6ª — citas
    {
      problem:  'Tu equipo pierde horas\ngestionando citas y confirmaciones...',
      color:    '#60a5fa',
      label:    'Gestor de Citas',
      ctaText:  'Ver Gestor de Citas',
      solution: 'La IA gestiona tu agenda, confirma y recuerda automáticamente.',
      icon:     'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
      href:     '/servicios/gestor-citas',
    },
  ];

  let current = 0;

  const SPEED_TYPE   = 32;
  const SPEED_DELETE = 18;
  const PAUSE_READ   = 1200; // pausa corta antes de mostrar solución
  const PAUSE_SOL    = 2600; // tiempo mostrando la solución

  function hexToRgb(hex: string): string {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `${r},${g},${b}`;
  }

  function setIcon(path: string, color: string) {
    solIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${path}"/>`;
    (solIcon as HTMLElement).style.color = color;
    solIconWrap.style.background = `rgba(${hexToRgb(color)},0.15)`;
    solBox.style.borderColor = `rgba(${hexToRgb(color)},0.25)`;
  }

  async function wait(ms: number) {
    return new Promise(r => setTimeout(r, ms));
  }

  async function typeText(text: string, color: string) {
    el.style.color = color;
    for (let i = 0; i <= text.length; i++) {
      el.textContent = text.slice(0, i);
      await wait(SPEED_TYPE + Math.random() * 15);
    }
  }

  async function deleteText() {
    const len = el.textContent?.length || 0;
    for (let i = len; i >= 0; i--) {
      el.textContent = el.textContent!.slice(0, i);
      await wait(SPEED_DELETE);
    }
  }

  async function showSolution(slide: Slide) {
    const glow       = document.getElementById('solution-glow')!;
    const iconWrap   = document.getElementById('solution-icon-wrap')!;
    const btnShineEl = document.getElementById('btn-shine')!;
    const ball       = document.getElementById('sol-ball')!;

    // Preparar contenido y colores
    setIcon(slide.icon, slide.color);
    solLabel.textContent   = slide.label;
    solCtaText.textContent = slide.ctaText;
    solText.textContent    = slide.solution;
    solLink.href           = slide.href;
    glow.style.background = `radial-gradient(ellipse at center,rgba(${hexToRgb(slide.color)},0.35),transparent 70%)`;

    // ── 1. Bolita desde el botón "Servicios" del nav ─────────────
    const origin = getServiciosPos();
    const startX = origin.x;
    const navY   = origin.y;

    const rect = solBox.getBoundingClientRect();
    const endX = rect.left + rect.width  / 2;
    const endY = rect.top  + rect.height / 2;

    const dx = endX - startX;
    const dy = endY - navY;
    const r  = 6; // radio (13px / 2 ≈ 6)

    // Mostrar y posicionar la bolita
    ball.style.display    = 'block';
    ball.style.left       = `${startX}px`;
    ball.style.top        = `${navY}px`;
    ball.style.background = slide.color;
    ball.style.boxShadow  = `0 0 18px 5px ${slide.color}99, 0 0 36px 10px ${slide.color}44`;

    // Animar (fill:'none' — sin estado residual al terminar)
    const ballAnim = ball.animate([
      { transform: `translate(${-r}px,${-r}px) scale(0)`,          opacity: 0            },
      { transform: `translate(${-r}px,${-r}px) scale(1.4)`,         opacity: 1, offset: 0.06 },
      { transform: `translate(${dx-r}px,${dy-r}px) scale(0.8)`,     opacity: 1, offset: 0.80 },
      { transform: `translate(${dx-r}px,${dy-r}px) scale(4)`,       opacity: 0.5, offset: 0.90 },
      { transform: `translate(${dx-r}px,${dy-r}px) scale(0)`,       opacity: 0            },
    ], { duration: 800, easing: 'cubic-bezier(0.35,0.05,0.6,1)', fill: 'none' });

    // Al terminar la animación, ocultar con display:none
    ballAnim.finished.catch(() => {}).finally(() => { ball.style.display = 'none'; });

    await wait(640); // bolita llega a la card

    // ── 2. Card explota hacia fuera ───────────────────────────────
    solBox.classList.remove('hiding');
    void solBox.offsetWidth;
    solBox.classList.add('visible');

    glow.classList.remove('burst'); iconWrap.classList.remove('spin'); btnShineEl.classList.remove('shine');
    void glow.offsetWidth;
    glow.classList.add('burst');
    iconWrap.classList.add('spin');
    btnShineEl.classList.add('shine');

    await wait(PAUSE_SOL);

    // ── 3. Ocultar ───────────────────────────────────────────────
    solBox.classList.remove('visible');
    solBox.classList.add('hiding');
    ball.style.display = 'none'; // ocultar ya (el finally del finished también lo hará)
    ballAnim.cancel();
    await wait(400);
    solBox.classList.remove('hiding');
  }

  async function loop() {
    while (true) {
      const slide = SLIDES[current];
      await typeText(slide.problem, slide.color);
      await wait(PAUSE_READ);
      await showSolution(slide);
      await deleteText();
      await wait(300);
      current = (current + 1) % SLIDES.length;
    }
  }

  window.addEventListener('load', () => {
    setTimeout(loop, 700);
  });
})();

// ─── Chat ─────────────────────────────────────────────────────────────────
const chatForm         = document.getElementById('chat-form');
const chatInput        = document.getElementById('chat-input')    as HTMLInputElement;
const chatInputRow     = document.getElementById('chat-input-row');
const chatResponse     = document.getElementById('chat-response');
const chatTyping       = document.getElementById('chat-typing');
const chatBack         = document.getElementById('chat-back');
const quickButtons     = document.getElementById('quick-buttons');
const quickQuestions   = document.querySelectorAll('.quick-question');
const emailInput       = document.getElementById('email-input')   as HTMLInputElement;
const emailSend        = document.getElementById('email-send');
const emailSuccess     = document.getElementById('email-success');
const emailError       = document.getElementById('email-error');
const emailInputRow    = document.getElementById('email-input-row');

let lastQuestion = '', lastReply = '';

function showInput() {
  chatInputRow!.classList.remove('hidden');
  (chatInputRow as HTMLElement).style.borderTop = 'none';
  chatTyping!.classList.add('hidden');
  chatResponse!.classList.add('hidden');
  quickButtons!.classList.remove('hidden');
  chatInput.value = '';
  chatInput.focus();
  emailInput.value = '';
  emailInputRow!.classList.remove('hidden');
  emailSuccess!.classList.add('hidden');
  emailError!.classList.add('hidden');
  (document.querySelector('#email-contact p:first-child') as HTMLElement)?.classList.remove('hidden');
}

function showInputAfterResponse() {
  (chatInputRow as HTMLElement).style.borderTop = '1px solid rgba(255,255,255,0.06)';
  showInput();
}

function openMascotWithQuestion(question: string) {
  // Abrir popup del mascot
  const popup  = document.getElementById('mascot-popup');
  const input  = document.getElementById('popup-input') as HTMLInputElement | null;
  const sendBtn = document.getElementById('popup-send');
  if (!popup) return;
  popup.classList.add('open');
  popup.setAttribute('aria-hidden', 'false');
  popup.removeAttribute('inert');
  // Scroll suave hacia abajo donde está el mascot
  setTimeout(() => {
    if (input) { input.value = question; }
    sendBtn?.click();
    input?.focus();
  }, 150);
}

chatForm?.addEventListener('submit', e => {
  e.preventDefault();
  const m = chatInput?.value.trim();
  if (!m) return;
  openMascotWithQuestion(m);
  chatInput.value = '';
});
quickQuestions.forEach(btn => btn.addEventListener('click', () => {
  const q = btn.textContent?.trim();
  if (q) openMascotWithQuestion(q);
}));
chatBack?.addEventListener('click', () => showInputAfterResponse());

emailSend?.addEventListener('click', async () => {
  const email = emailInput.value.trim();
  if (!email || !email.includes('@')) {
    emailInput.style.borderColor = 'rgba(239,68,68,0.5)';
    setTimeout(() => { emailInput.style.borderColor = 'rgba(255,255,255,0.1)'; }, 2000);
    return;
  }
  emailSend.textContent = '...'; (emailSend as HTMLButtonElement).disabled = true;
  try {
    const res = await fetch('/api/chat-email', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ email, question:lastQuestion, reply:lastReply }) });
    if (res.ok) {
      emailInputRow!.classList.add('hidden');
      (document.querySelector('#email-contact p:first-child') as HTMLElement)?.classList.add('hidden');
      emailSuccess!.classList.remove('hidden');
    } else emailError!.classList.remove('hidden');
  } catch { emailError!.classList.remove('hidden'); }
  finally { emailSend.textContent = 'Enviar'; (emailSend as HTMLButtonElement).disabled = false; }
});
emailInput?.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); emailSend?.click(); } });
</script>
