---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Soporte IT y Administración de Sistemas - Linux, Windows, Cloud";
const description = "Administración profesional de sistemas Linux/Windows. Copias de seguridad, microinformática, desarrollo web, consultoría cloud. Soporte técnico para PyMEs.";
const canonical = "https://aisecurity.es/soporte-tecnico";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- BANNER PROMOCIONAL - PRIMERA HORA GRATIS -->
  <section class="relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover opacity-40" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, #0065ff, #4f46e5, #0b8aff); opacity: 0.85;"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 py-6 md:py-8">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
        <!-- Contenido principal -->
        <div class="flex items-center gap-4 md:gap-6">
          <div class="hidden sm:flex w-16 h-16 md:w-20 md:h-20 bg-white/20 backdrop-blur-sm rounded-2xl items-center justify-center border-2 border-white/30 shadow-lg animate-pulse">
            <span class="text-3xl md:text-4xl">🎁</span>
          </div>
          <div class="text-center lg:text-left">
            <div class="flex items-center justify-center lg:justify-start gap-2 mb-1">
              <span class="sm:hidden text-2xl">🎁</span>
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-white/20 text-white rounded-full text-xs font-bold uppercase tracking-wider shadow-md border border-white/30">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path></svg>
                Oferta Especial
              </span>
            </div>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-black text-white tracking-tight">
              Primera Hora de Soporte <span class="text-white">GRATIS</span>
            </h2>
            <p class="text-sm md:text-base mt-1" style="color: rgba(255,255,255,0.92); max-width: 36rem;">
              ¿Problema técnico urgente? <strong>Abre un ticket ahora</strong> y te ayudamos sin compromiso.
              Horario: <span class="font-semibold" style="color: white;">08:00-14:00</span> y <span class="font-semibold" style="color: white;">16:00-19:00</span>
            </p>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="flex flex-col items-center gap-2">
          <a
            href="/abrir-ticket"
            class="group inline-flex items-center gap-3 px-8 py-4 bg-white hover:bg-base-50 font-bold text-lg rounded-xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105"
            style="color: #0065ff;"
          >
            <svg class="w-6 h-6 transition-transform group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
            </svg>
            Abrir Ticket Gratis
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <span class="text-xs" style="color: rgba(255,255,255,0.75);">Sin tarjeta · Sin compromiso</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero Section -->
  <section class="py-20 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover opacity-40" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/60 via-blue-600/70 to-accent-500/60"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/20 backdrop-blur-sm border border-white/40 text-white rounded-full text-sm font-semibold mb-6">
            <span class="text-xl">🎁</span>
            Primera Incidencia GRATIS
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
            Soporte Técnico <br>
            <span class="text-white/90">Cuando lo Necesites</span>
          </h1>
          <p class="text-xl mb-8 leading-relaxed" style="color: rgba(255,255,255,0.92); max-width: none;">
            Tu departamento IT bajo demanda. Ideal para empresas que no pueden contratar un informático pero necesitan soporte técnico profesional de forma periódica.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/abrir-ticket"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 text-lg font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200"
              style="background-color: #0b8aff; color: white;"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
              </svg>
              Abrir Ticket Gratis
            </a>
            <a
              href="mailto:info@aisecurity.es"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 text-lg font-semibold bg-white rounded-xl transition-all duration-200"
              style="color: #0065ff;"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              info@aisecurity.es
            </a>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-6 mt-12 pt-8 border-t border-white/30">
            <div>
              <div class="text-3xl font-bold text-white mb-1">&lt; 2h</div>
              <div class="text-sm text-white/80">Tiempo respuesta</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white mb-1">100%</div>
              <div class="text-sm text-white/80">Remoto o presencial</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white mb-1">0€</div>
              <div class="text-sm text-white/80">Primera incidencia</div>
            </div>
          </div>
        </div>

        <!-- Dashboard Preview -->
        <div class="relative">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 shadow-2xl border border-white/20">
            <h3 class="text-2xl font-bold text-white mb-6">Casos Resueltos Recientemente</h3>

            <!-- Success Case 1 -->
            <div class="bg-white/20 backdrop-blur-sm rounded-xl p-6 shadow-lg mb-4 border border-white/30">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white text-2xl border-2 border-white/30 shadow-lg">
                  ✓
                </div>
                <div class="flex-1">
                  <div class="font-semibold text-white text-lg">💾 Configuración de Backups</div>
                  <div class="text-sm text-white/80">Plan de contingencia empresarial</div>
                </div>
              </div>
              <div class="flex items-center gap-2 text-xs mt-3">
                <span class="px-3 py-1 bg-green-500/30 text-green-100 rounded-full font-medium">Resuelta en 2h</span>
                <span class="px-3 py-1 bg-blue-500/30 text-blue-100 rounded-full font-medium">Presencial</span>
              </div>
            </div>

            <!-- Success Case 2 -->
            <div class="bg-white/20 backdrop-blur-sm rounded-xl p-6 shadow-lg mb-4 border border-white/30">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-12 h-12 bg-red-500 rounded-full flex items-center justify-center text-white text-2xl border-2 border-white/30 shadow-lg">
                  🔥
                </div>
                <div class="flex-1">
                  <div class="font-semibold text-white text-lg">🛡️ Configuración Firewall</div>
                  <div class="text-sm text-white/80">Seguridad perimetral empresarial</div>
                </div>
              </div>
              <div class="flex items-center gap-2 text-xs mt-3">
                <span class="px-3 py-1 bg-red-500/30 text-red-100 rounded-full font-medium">Resuelta en 3h</span>
                <span class="px-3 py-1 bg-purple-500/30 text-purple-100 rounded-full font-medium">Remoto</span>
              </div>
            </div>

            <!-- Success Case 3 -->
            <div class="bg-white/20 backdrop-blur-sm rounded-xl p-6 shadow-lg mb-4 border border-white/30">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-12 h-12 bg-blue-500 rounded-full flex items-center justify-center text-white text-2xl border-2 border-white/30 shadow-lg">
                  ⚡
                </div>
                <div class="flex-1">
                  <div class="font-semibold text-white text-lg">📧 Migración Office 365</div>
                  <div class="text-sm text-white/80">15 cuentas + sincronización completa</div>
                </div>
              </div>
              <div class="flex items-center gap-2 text-xs mt-3">
                <span class="px-3 py-1 bg-blue-500/30 text-blue-100 rounded-full font-medium">Resuelta en 1.5h</span>
                <span class="px-3 py-1 bg-green-500/30 text-green-100 rounded-full font-medium">Presencial</span>
              </div>
            </div>

            <!-- Info Banner -->
            <div class="bg-gradient-to-r from-green-500/20 to-blue-500/20 backdrop-blur-sm rounded-xl p-4 border border-white/30">
              <p class="text-white font-semibold text-center">
                ⏱️ Tiempo medio de resolución: <span class="text-green-300">2.5 horas</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- Value Proposition for SMBs -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block px-4 py-2 bg-blue-100 text-blue-800 rounded-full text-sm font-semibold mb-4">
            Para empresas de 5 a 50 empleados
          </span>
          <h2 class="text-3xl md:text-4xl font-bold text-base-900 mb-6">
            Tu departamento IT <span class="text-blue-600">sin contratar</span> un informático
          </h2>
          <p class="text-lg text-base-600 mb-6 leading-relaxed">
            Muchas PyMEs no pueden justificar un técnico a tiempo completo, pero sí necesitan
            <strong>soporte profesional de forma periódica</strong>: resolver incidencias,
            automatizar tareas, consultoría para decisiones técnicas...
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-200">
              <span class="text-2xl">🆘</span>
              <div>
                <h4 class="font-bold text-base-900">Soporte de emergencia</h4>
                <p class="text-sm text-base-600">PC que no arranca, virus, email caído... Incidencias que bloquean tu trabajo.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-4 bg-purple-50 rounded-xl border border-purple-200">
              <span class="text-2xl">⚙️</span>
              <div>
                <h4 class="font-bold text-base-900">Automatización de tareas</h4>
                <p class="text-sm text-base-600">Backups automáticos, informes, actualizaciones... Libera tiempo de tu equipo.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-200">
              <span class="text-2xl">🧠</span>
              <div>
                <h4 class="font-bold text-base-900">Consultoría IT</h4>
                <p class="text-sm text-base-600">Problemas técnicos complejos que tu técnico habitual no puede resolver.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-base-100 to-base-50 rounded-2xl p-8 border border-base-200">
          <h3 class="text-xl font-bold text-base-900 mb-6 text-center">¿Te identificas con esto?</h3>
          <ul class="space-y-4">
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center text-red-600 text-sm">✗</span>
              <span class="text-base-700">"No tenemos presupuesto para un informático fijo"</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center text-red-600 text-sm">✗</span>
              <span class="text-base-700">"El sobrino del jefe ya no nos puede ayudar"</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center text-red-600 text-sm">✗</span>
              <span class="text-base-700">"Perdemos horas con problemas técnicos tontos"</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center text-red-600 text-sm">✗</span>
              <span class="text-base-700">"Nuestro técnico no sabe de servidores/redes"</span>
            </li>
          </ul>
          <div class="mt-8 p-4 bg-accent-100 rounded-xl border-2 border-accent-300">
            <p class="text-center text-accent-800 font-semibold">
              <span class="text-2xl">✓</span> Nosotros somos tu solución
            </p>
          </div>
          <a
            href="/abrir-ticket"
            class="block w-full mt-6 py-4 px-6 bg-accent-600 hover:bg-accent-700 text-white font-bold text-center rounded-xl shadow-lg hover:shadow-xl transition-all duration-300"
          >
            Prueba gratis (1ª hora sin coste)
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20" style="background-color: #0a0c0e;">
    <div class="max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4" style="color: white;">
          ¿En qué te podemos ayudar?
        </h2>
        <p class="text-xl max-w-3xl mx-auto" style="color: rgba(255,255,255,0.75); max-width: 48rem;">
          Soporte técnico integral para todas las necesidades informáticas de tu empresa
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Service Cards -->
        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            💻
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Reparación de PCs</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Diagnóstico y reparación de ordenadores lentos, virus, problemas de arranque y hardware.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            📧
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Configuración Email</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de correo corporativo (Outlook, Gmail, Office 365) en todos tus dispositivos.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🛒
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Compra de Equipos</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Asesoramiento y compra de equipos informáticos adaptados a tus necesidades y presupuesto.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-yellow-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🔧
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Instalación Software</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Instalación y configuración de programas, licencias, actualizaciones y migraciones.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-red-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🌐
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Redes y WiFi</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de redes, routers, WiFi empresarial, VPN y conexiones remotas.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🖨️
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Impresoras y Periféricos</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de impresoras, escáneres, cámaras y otros dispositivos en red.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-pink-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            💾
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Copias de Seguridad</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Implementación de sistemas de backup automáticos para proteger tus datos.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-teal-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            📱
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Dispositivos Móviles</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de smartphones y tablets para uso empresarial (email, apps, VPN).
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🎓
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Formación Básica</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Formación para tu equipo en herramientas ofimáticas y buenas prácticas de seguridad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 bg-base-50 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 opacity-40">
      <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Dark overlay to maintain visibility -->
    <div class="absolute inset-0 bg-base-50/60"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Precios Transparentes
        </h2>
        <p class="text-xl text-white/90 mx-auto">
          Paga solo por las horas que necesites o ahorra con bolsas de horas
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- 5 hours pack -->
        <div class="bg-base-50 rounded-xl p-6 border-1 flex flex-col">
          <h4 class="text-xl font-bold mb-2 text-white">Bolsa 5h</h4>
          <p class="text-sm text-gray-300 mb-4">€37/hora</p>

          <div class="text-3xl font-bold mb-4 text-white">€185</div>
          <p class="text-sm text-gray-300 mb-4">Ahorra €15 - Ideal para uso ocasional</p>

          <ul class="space-y-2 text-sm text-gray-300 mb-6 flex-grow">
            <li><span class="text-blue-400">✅</span> 5 horas prepagadas</li>
            <li><span class="text-blue-400">✅</span> Válido 6 meses</li>
            <li><span class="text-blue-400">✅</span> Soporte remoto o presencial</li>
            <li><span class="text-blue-400">✅</span> Descuento 7.5%</li>
            <li><span class="text-blue-400">✅</span> Primera incidencia gratis</li>
          </ul>
          <a
            href="/reunion"
                        style="color: white;"

            class="block w-full px-4 py-3 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors mt-auto"
          >
            Contratar
          </a>
        </div>

