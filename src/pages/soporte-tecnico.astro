---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Soporte Técnico IT para Empresas — Primera Hora Gratis | AI Security";
const description = "Soporte técnico remoto para PyMEs: incidencias, redes, backups, email corporativo y administración de sistemas Windows/Linux. Primera hora gratuita. Respuesta en menos de 2 horas.";
const canonical = "https://aisecurity.es/soporte-tecnico";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Schema JSON-LD -->
  <script type="application/ld+json" is:inline>
  [
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Soporte Técnico IT para Empresas",
      "description": "Soporte técnico remoto para PyMEs de 5 a 50 empleados. Incidencias, redes, backups, email corporativo, administración de sistemas Windows y Linux. Primera hora gratuita sin compromiso.",
      "provider": {
        "@type": "Organization",
        "name": "AI Security",
        "url": "https://aisecurity.es",
        "areaServed": "ES"
      },
      "serviceType": "Soporte técnico informático para empresas",
      "areaServed": "España",
      "offers": [
        { "@type": "Offer", "name": "Bolsa 5 horas", "price": "185", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Bolsa 10 horas", "price": "350", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Bolsa 20 horas", "price": "600", "priceCurrency": "EUR" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿El soporte es presencial o podéis ayudarme si estoy en otra ciudad?",
          "acceptedAnswer": { "@type": "Answer", "text": "El soporte es 100% remoto. Trabajamos con empresas de toda España usando herramientas de acceso remoto seguras (TeamViewer, AnyDesk) para resolver incidencias como si estuviéramos en tu oficina." }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tardáis en responder cuando hay una urgencia?",
          "acceptedAnswer": { "@type": "Answer", "text": "Garantizamos respuesta en menos de 2 horas en horario laboral (L-V 9:00-18:00) para clientes con bolsa de horas activa. Si la incidencia bloquea completamente el trabajo del equipo, lo tratamos como urgencia máxima." }
        },
        {
          "@type": "Question",
          "name": "¿Qué incluye exactamente la primera hora gratuita?",
          "acceptedAnswer": { "@type": "Answer", "text": "La primera hora incluye diagnóstico completo y resolución si el problema se puede solucionar en ese tiempo. No es una demo ni una consultoría de ventas. Sin tarjeta, sin contrato previo." }
        },
        {
          "@type": "Question",
          "name": "¿Puedo contratar horas sueltas sin comprar una bolsa?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. La tarifa por hora suelta es €40/hora. Las bolsas de horas salen más económicas (desde €30/h) y tienen ventajas adicionales como atención prioritaria." }
        },
        {
          "@type": "Question",
          "name": "¿Con qué sistemas operativos y software trabajáis?",
          "acceptedAnswer": { "@type": "Answer", "text": "Trabajamos con Windows (10/11/Server), Linux y macOS. Cubrimos Microsoft 365, Google Workspace, Outlook, Teams, OneDrive, impresoras en red, VPNs, NAS, backups con Veeam/Restic y más." }
        },
        {
          "@type": "Question",
          "name": "¿Las horas de la bolsa caducan?",
          "acceptedAnswer": { "@type": "Answer", "text": "Las horas prepagadas tienen validez de 12 meses desde la compra. Para la mayoría de PyMEs de 10-50 empleados, una bolsa de 10h se consume en 3-6 meses." }
        }
      ]
    }
  ]
  </script>


  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 50%, #0a0d1a 100%); padding: 80px 0 60px; position: relative; overflow: hidden;">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, #2563eb 0%, transparent 50%), radial-gradient(circle at 80% 70%, #0ea5e9 0%, transparent 50%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium mb-6" style="background: rgba(37,99,235,0.15); border: 1px solid rgba(37,99,235,0.3); color: #7da4ff;">
          <span>🖥️</span> Para empresas de 5 a 50 empleados
        </div>
        <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight" style="color: #fff;">
          Tu departamento IT<br/>
          <span style="background: linear-gradient(90deg, #60a5fa, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">sin contratar un fijo</span>
        </h1>
        <p class="text-xl max-w-3xl mx-auto mb-10" style="color: #94a3b8; line-height: 1.7;">
          Soporte técnico profesional cuando lo necesitas: incidencias, redes, backups, email, servidores.
          <strong style="color: #e2e8f0;">Primera hora gratuita</strong> y sin compromiso.
        </p>

        <!-- Stats -->
        <div class="flex flex-wrap justify-center gap-6 mb-10">
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">&lt;2h</div>
            <div class="text-xs mt-1" style="color: #64748b;">Tiempo de respuesta</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #22d3ee;">1ª hora</div>
            <div class="text-xs mt-1" style="color: #64748b;">Gratis sin compromiso</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">100%</div>
            <div class="text-xs mt-1" style="color: #64748b;">Remoto · Toda España</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #22d3ee;">3 OS</div>
            <div class="text-xs mt-1" style="color: #64748b;">Windows · Linux · macOS</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/abrir-ticket"
            style="display:inline-flex;align-items:center;gap:8px;padding:14px 32px;background:linear-gradient(135deg,#2563eb,#0ea5e9);color:#fff;font-weight:700;font-size:1rem;border-radius:12px;text-decoration:none;box-shadow:0 16px 36px -8px rgba(37,99,235,0.4);">
            Abrir ticket gratis →
          </a>
          <a href="#precios"
            style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:#cbd5e1;font-weight:600;font-size:0.95rem;border-radius:12px;text-decoration:none;">
            Ver precios
          </a>
        </div>
      </div>

      <!-- Pain points + propuesta -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:900px;margin:0 auto;">
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:28px;">
          <h3 style="color:#e2e8f0;font-weight:700;font-size:1rem;margin:0 0 16px;">¿Te identificas con esto?</h3>
          <div style="display:flex;flex-direction:column;gap:10px;">
            {[
              '"No tenemos presupuesto para un informático fijo"',
              '"El sobrino del jefe ya no nos puede ayudar"',
              '"Perdemos horas con problemas técnicos tontos"',
              '"Nuestro técnico no sabe de servidores ni redes"',
            ].map(t => (
              <div style="display:flex;align-items:flex-start;gap:10px;">
                <span style="width:20px;height:20px;background:rgba(239,68,68,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#f87171;font-size:0.7rem;flex-shrink:0;margin-top:1px;">✗</span>
                <span style="color:#94a3b8;font-size:0.875rem;line-height:1.5;">{t}</span>
              </div>
            ))}
          </div>
        </div>
        <div style="background:rgba(37,99,235,0.08);border:1px solid rgba(37,99,235,0.25);border-radius:1.25rem;padding:28px;display:flex;flex-direction:column;gap:14px;">
          <h3 style="color:#e2e8f0;font-weight:700;font-size:1rem;margin:0;">Nosotros somos tu solución</h3>
          {[
            { icon: "🆘", t: "Soporte de emergencia", d: "PC que no arranca, virus, email caído. Incidencias que bloquean tu trabajo." },
            { icon: "⚙️", t: "Automatización de tareas", d: "Backups automáticos, informes, actualizaciones. Libera tiempo de tu equipo." },
            { icon: "🧠", t: "Consultoría IT", d: "Problemas complejos que tu técnico habitual no puede resolver." },
          ].map(item => (
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <span style="font-size:1.25rem;flex-shrink:0;">{item.icon}</span>
              <div>
                <div style="color:#e2e8f0;font-weight:600;font-size:0.875rem;margin-bottom:2px;">{item.t}</div>
                <div style="color:#64748b;font-size:0.8rem;line-height:1.4;">{item.d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       SERVICIOS
  ══════════════════════════════════════════════ -->
  <section style="background: #0f1628; padding: 80px 0;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #e2e8f0;">¿En qué te podemos ayudar?</h2>
        <p style="color: #94a3b8; font-size: 1.05rem; max-width: 560px; margin: 0 auto;">Soporte técnico integral para todas las necesidades informáticas de tu empresa.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;">
        {[
          { icon: "💻", titulo: "Reparación de PCs", desc: "Diagnóstico y reparación de ordenadores lentos, virus, problemas de arranque y hardware." },
          { icon: "📧", titulo: "Configuración Email", desc: "Correo corporativo (Outlook, Gmail, Office 365) configurado en todos tus dispositivos." },
          { icon: "🛒", titulo: "Compra de Equipos", desc: "Asesoramiento y compra de equipos informáticos adaptados a tus necesidades y presupuesto." },
          { icon: "🔧", titulo: "Instalación Software", desc: "Instalación y configuración de programas, licencias, actualizaciones y migraciones." },
          { icon: "🌐", titulo: "Redes y WiFi", desc: "Configuración de redes, routers, WiFi empresarial, VPN y conexiones remotas seguras." },
          { icon: "🖨️", titulo: "Impresoras y Periféricos", desc: "Configuración de impresoras, escáneres, cámaras y dispositivos en red." },
          { icon: "💾", titulo: "Copias de Seguridad", desc: "Sistemas de backup automáticos (Veeam, Restic) para proteger tus datos críticos." },
          { icon: "📱", titulo: "Dispositivos Móviles", desc: "Configuración de smartphones y tablets para uso empresarial: email, apps, VPN." },
        ].map(s => (
          <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:24px;transition:border-color 0.2s;" class="service-card">
            <div style="font-size:2rem;margin-bottom:12px;">{s.icon}</div>
            <h3 style="color:#e2e8f0;font-weight:700;font-size:1rem;margin:0 0 8px;">{s.titulo}</h3>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;margin:0;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       PRECIOS
  ══════════════════════════════════════════════ -->
  <section id="precios" style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 100%); padding: 80px 0; position: relative; overflow: hidden;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at 20% 50%, rgba(37,99,235,0.10), transparent 60%), radial-gradient(circle at 80% 50%, rgba(14,165,233,0.08), transparent 60%);"></div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #e2e8f0;">Precios transparentes</h2>
        <p style="color: #94a3b8; font-size: 1.05rem; max-width: 500px; margin: 0 auto;">Paga solo por las horas que necesites, o ahorra con bolsas prepagadas.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;align-items:start;">

        <!-- 5h -->
        <div style="background:rgba(37,99,235,0.07);border:1px solid rgba(37,99,235,0.25);border-radius:1.25rem;padding:32px;display:flex;flex-direction:column;gap:20px;">
          <div>
            <h3 style="color:#fff;font-size:1.25rem;font-weight:700;margin:0 0 4px;">Bolsa 5h</h3>
            <p style="color:#60a5fa;font-size:0.875rem;margin:0 0 16px;">€37/hora · Ahorra €15</p>
            <div style="font-size:2.5rem;font-weight:800;color:#fff;margin-bottom:8px;">€185</div>
            <p style="color:#64748b;font-size:0.8rem;margin:0;">Ideal para uso ocasional</p>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:20px;">
            <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;">
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#60a5fa;">✓</span> 5 horas prepagadas</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#60a5fa;">✓</span> Soporte remoto o presencial</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#60a5fa;">✓</span> Descuento 7.5%</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#60a5fa;">✓</span> Primera incidencia gratis</li>
            </ul>
          </div>
          <button data-plan="5h" class="checkout-btn"
            style="display:block;width:100%;padding:13px;background:rgba(37,99,235,0.3);border:1px solid rgba(37,99,235,0.5);color:#93c5fd;font-weight:700;font-size:0.95rem;border-radius:10px;cursor:pointer;transition:all 0.2s;">
            Contratar
          </button>
        </div>

        <!-- 10h — POPULAR -->
        <div style="background:rgba(37,99,235,0.1);border:2px solid rgba(37,99,235,0.5);border-radius:1.25rem;padding:32px;display:flex;flex-direction:column;gap:20px;position:relative;">
          <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#1d4ed8,#0ea5e9);color:#fff;font-size:0.7rem;font-weight:700;padding:4px 14px;border-radius:20px;white-space:nowrap;">MÁS POPULAR</div>
          <div>
            <h3 style="color:#fff;font-size:1.25rem;font-weight:700;margin:0 0 4px;">Bolsa 10h</h3>
            <p style="color:#38b1ff;font-size:0.875rem;margin:0 0 16px;">€35/hora · Ahorra €50</p>
            <div style="font-size:2.5rem;font-weight:800;color:#fff;margin-bottom:8px;">€350</div>
            <p style="color:#64748b;font-size:0.8rem;margin:0;">Perfecto para pequeñas empresas</p>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:20px;">
            <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;">
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#38b1ff;">✓</span> 10 horas prepagadas</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#38b1ff;">✓</span> Descuento 12.5%</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#38b1ff;">✓</span> Atención prioritaria</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#38b1ff;">✓</span> Respuesta &lt;2h garantizada</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#38b1ff;">✓</span> Válidas 12 meses</li>
            </ul>
          </div>
          <button data-plan="10h" class="checkout-btn"
            style="display:block;width:100%;padding:13px;background:linear-gradient(135deg,#2563eb,#0ea5e9);color:#fff;font-weight:700;font-size:0.95rem;border-radius:10px;border:none;cursor:pointer;">
            Contratar
          </button>
        </div>

        <!-- 20h -->
        <div style="background:rgba(6,182,212,0.06);border:1px solid rgba(6,182,212,0.25);border-radius:1.25rem;padding:32px;display:flex;flex-direction:column;gap:20px;">
          <div>
            <h3 style="color:#fff;font-size:1.25rem;font-weight:700;margin:0 0 4px;">Bolsa 20h</h3>
            <p style="color:#22d3ee;font-size:0.875rem;margin:0 0 16px;">€30/hora · Ahorra €200</p>
            <div style="font-size:2.5rem;font-weight:800;color:#fff;margin-bottom:8px;">€600</div>
            <p style="color:#64748b;font-size:0.8rem;margin:0;">Máximo ahorro para empresas</p>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:20px;">
            <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;">
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#22d3ee;">✓</span> 20 horas prepagadas</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#22d3ee;">✓</span> Descuento 25%</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#22d3ee;">✓</span> Atención VIP</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#22d3ee;">✓</span> Informes mensuales</li>
              <li style="color:#94a3b8;font-size:0.85rem;display:flex;align-items:center;gap:8px;"><span style="color:#22d3ee;">✓</span> Válidas 12 meses</li>
            </ul>
          </div>
          <button data-plan="20h" class="checkout-btn"
            style="display:block;width:100%;padding:13px;background:rgba(6,182,212,0.2);border:1px solid rgba(6,182,212,0.4);color:#67e8f9;font-weight:700;font-size:0.95rem;border-radius:10px;cursor:pointer;transition:all 0.2s;">
            Contratar
          </button>
        </div>

      </div>

      <div style="margin-top:32px;text-align:center;">
        <p style="color:#475569;font-size:0.875rem;">¿Prefieres una hora suelta? Tarifa de <strong style="color:#94a3b8;">€40/hora</strong> sin compromiso ni permanencia.</p>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       FAQ
  ══════════════════════════════════════════════ -->
  <section style="background: #0a0d1a; padding: 80px 0;">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #e2e8f0;">Preguntas frecuentes</h2>
        <p style="color: #94a3b8; font-size: 1.05rem; max-width: 500px; margin: 0 auto;">Lo que nos preguntan las empresas antes de contratar.</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {[
          { q: "¿El soporte es presencial o podéis ayudarme si estoy en otra ciudad?", a: "El soporte es 100% remoto. Trabajamos con empresas de toda España: Madrid, Barcelona, Valencia, Sevilla, Bilbao, Zaragoza... Si tienes conexión a internet, podemos ayudarte. Usamos herramientas de acceso remoto seguras (TeamViewer, AnyDesk) para resolver incidencias como si estuviéramos en tu oficina." },
          { q: "¿Cuánto tiempo tardáis en responder cuando hay una urgencia?", a: "Garantizamos respuesta en menos de 2 horas en horario laboral (L-V 9:00-18:00) para clientes con bolsa de horas activa. Para la primera hora gratuita, el tiempo de respuesta habitual es el mismo día. Si la incidencia bloquea completamente el trabajo de tu equipo, lo tratamos como urgencia máxima." },
          { q: "¿Qué incluye exactamente la primera hora gratuita?", a: "La primera hora incluye diagnóstico completo y resolución si el problema se puede solucionar en ese tiempo. No es una 'demo' ni una consultoría de ventas — trabajamos en tu problema real. Si no se resuelve en la primera hora, te explicamos exactamente qué hace falta y te damos un presupuesto sin compromiso. Sin tarjeta, sin contrato previo." },
          { q: "¿Puedo contratar horas sueltas sin comprar una bolsa?", a: "Sí. La tarifa por hora suelta es €40/hora. Las bolsas de horas existen porque salen más económicas (desde €30/h) y tienen ventajas adicionales como atención prioritaria. Pero si tienes una incidencia puntual, puedes contratarla directamente sin compromiso ni permanencia." },
          { q: "¿Con qué sistemas operativos y software trabajáis?", a: "Trabajamos con Windows (10/11/Server), Linux y macOS. En cuanto a software, cubrimos el ecosistema habitual de empresa: Microsoft 365, Google Workspace, Outlook, Teams, OneDrive, impresoras en red, VPNs, NAS, backups con Veeam/Restic. Si usas algo específico, consúltanos." },
          { q: "¿Las horas de la bolsa caducan?", a: "Las horas prepagadas tienen validez de 12 meses desde la compra. Para la mayoría de PyMEs de 10-50 empleados, una bolsa de 10h se consume en 3-6 meses. Si en algún momento ves que no vas a usarlas, podemos acordar soluciones — no queremos que pierdas lo que has pagado." },
        ].map(item => (
          <div class="faq-item" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;transition:border-color 0.2s;">
            <button class="faq-btn" style="width:100%;text-align:left;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;cursor:pointer;background:none;border:none;">
              <span style="color:#e2e8f0;font-weight:600;font-size:0.95rem;line-height:1.4;">{item.q}</span>
              <svg class="faq-chevron" style="width:20px;height:20px;color:#60a5fa;flex-shrink:0;transition:transform 0.25s;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer" style="display:none;padding:0 24px 20px;">
              <p style="color:#94a3b8;font-size:0.875rem;line-height:1.75;margin:0;border-top:1px solid rgba(255,255,255,0.06);padding-top:16px;">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
  (function(){
    document.querySelectorAll('.faq-btn').forEach(function(btn){
      btn.addEventListener('click',function(){
        var item=btn.closest('.faq-item');
        var answer=item.querySelector('.faq-answer');
        var icon=btn.querySelector('.faq-chevron');
        var open=answer.style.display==='block';
        document.querySelectorAll('.faq-answer').forEach(function(a){a.style.display='none';});
        document.querySelectorAll('.faq-chevron').forEach(function(i){i.style.transform='rotate(0deg)';});
        document.querySelectorAll('.faq-item').forEach(function(i){i.style.borderColor='rgba(255,255,255,0.08)';});
        if(!open){answer.style.display='block';icon.style.transform='rotate(180deg)';item.style.borderColor='rgba(96,165,250,0.3)';}
      });
    });
  })();
  </script>


