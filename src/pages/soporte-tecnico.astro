---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Soporte IT y Administración de Sistemas - Linux, Windows, Cloud";
const description = "Administración profesional de sistemas Linux/Windows. Copias de seguridad, microinformática, desarrollo web, consultoría cloud. Soporte técnico para PyMEs.";
const canonical = "https://aisecurity.es/soporte-tecnico";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero + Banner combinados -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover opacity-40" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/60 via-blue-600/70 to-accent-500/60"></div>

    <!-- SMB Value Proposition (arriba) -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24 pt-16 pb-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block px-4 py-2 bg-white/20 text-white rounded-full text-sm font-semibold mb-4 border border-white/30">
            Para empresas de 5 a 50 empleados
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6" style="color: white;">
            Tu departamento IT <span style="color: #38b1ff;">sin contratar</span> un informático
          </h2>
          <p class="text-lg mb-6 leading-relaxed" style="color: rgba(255,255,255,0.80); max-width: none;">
            Muchas PyMEs no pueden justificar un técnico a tiempo completo, pero sí necesitan
            <strong style="color: white;">soporte profesional de forma periódica</strong>: resolver incidencias,
            automatizar tareas, consultoría para decisiones técnicas...
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-4 p-4 rounded-xl border border-white/20 backdrop-blur-sm" style="background-color: rgba(255,255,255,0.12);">
              <span class="text-2xl">🆘</span>
              <div>
                <h4 class="font-bold text-white" style="font-size: 1rem; color: white;">Soporte de emergencia</h4>
                <p class="text-sm" style="color: rgba(255,255,255,0.80); max-width: none;">PC que no arranca, virus, email caído... Incidencias que bloquean tu trabajo.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-4 rounded-xl border border-white/20 backdrop-blur-sm" style="background-color: rgba(255,255,255,0.12);">
              <span class="text-2xl">⚙️</span>
              <div>
                <h4 class="font-bold text-white" style="font-size: 1rem; color: white;">Automatización de tareas</h4>
                <p class="text-sm" style="color: rgba(255,255,255,0.80); max-width: none;">Backups automáticos, informes, actualizaciones... Libera tiempo de tu equipo.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-4 rounded-xl border border-white/20 backdrop-blur-sm" style="background-color: rgba(255,255,255,0.12);">
              <span class="text-2xl">🧠</span>
              <div>
                <h4 class="font-bold text-white" style="font-size: 1rem; color: white;">Consultoría IT</h4>
                <p class="text-sm" style="color: rgba(255,255,255,0.80); max-width: none;">Problemas técnicos complejos que tu técnico habitual no puede resolver.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="rounded-2xl p-8 border border-white/20 backdrop-blur-sm" style="background-color: rgba(0,0,0,0.5);">
          <h3 class="text-xl font-bold text-white mb-6 text-center" style="color: white; font-size: 1.25rem;">¿Te identificas con esto?</h3>
          <ul class="space-y-4">
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-500/30 rounded-full flex items-center justify-center text-red-300 text-sm flex-shrink-0">✗</span>
              <span style="color: rgba(255,255,255,0.85);">"No tenemos presupuesto para un informático fijo"</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-500/30 rounded-full flex items-center justify-center text-red-300 text-sm flex-shrink-0">✗</span>
              <span style="color: rgba(255,255,255,0.85);">"El sobrino del jefe ya no nos puede ayudar"</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-500/30 rounded-full flex items-center justify-center text-red-300 text-sm flex-shrink-0">✗</span>
              <span style="color: rgba(255,255,255,0.85);">"Perdemos horas con problemas técnicos tontos"</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-red-500/30 rounded-full flex items-center justify-center text-red-300 text-sm flex-shrink-0">✗</span>
              <span style="color: rgba(255,255,255,0.85);">"Nuestro técnico no sabe de servidores/redes"</span>
            </li>
          </ul>
          <div class="mt-8 p-4 rounded-xl border border-white/30" style="background-color: rgba(255,255,255,0.15);">
            <p class="text-center font-semibold text-white" style="color: white; max-width: none;">
              <span class="text-2xl">✓</span> Nosotros somos tu solución
            </p>
          </div>
          <a
            href="/abrir-ticket"
            class="block w-full mt-6 py-4 px-6 text-white font-bold text-center rounded-xl shadow-lg hover:shadow-xl transition-all duration-300"
            style="background-color: #0065ff; color: white;"
          >
            Prueba gratis (1ª hora sin coste)
          </a>

          <!-- Banner Oferta Especial -->
          <div class="mt-6 pt-6 border-t border-white/20">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-3xl animate-pulse">🎁</span>
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-white/20 text-white rounded-full text-xs font-bold uppercase tracking-wider border border-white/30">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path></svg>
                Oferta Especial
              </span>
            </div>
            <p class="text-xl font-black text-white mb-2" style="color: white; max-width: none;">
              Primera Hora de Soporte <span style="color: #7dd3fc;">GRATIS</span>
            </p>
            <p class="text-sm" style="color: rgba(255,255,255,0.85); max-width: none;">
              ¿Problema técnico urgente? <strong style="color: white;">Abre un ticket ahora</strong> y te ayudamos sin compromiso.
            </p>
            <a
              href="/abrir-ticket"
              class="group inline-flex items-center gap-2 mt-4 px-6 py-3 bg-white hover:bg-base-50 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 w-full justify-center"
              style="color: #0065ff;"
            >
              <svg class="w-5 h-5 transition-transform group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
              </svg>
              Abrir Ticket Gratis
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
            <p class="text-center text-xs mt-2" style="color: rgba(255,255,255,0.6); max-width: none;">Sin tarjeta · Sin compromiso</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 bg-gradient-to-b from-base-50 to-base-100">
    <div class="max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-base-900 mb-4">
          ¿En qué te podemos ayudar?
        </h2>
        <p class="text-xl text-base-600 max-w-3xl mx-auto">
          Soporte técnico integral para todas las necesidades informáticas de tu empresa
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Service Cards -->
        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            💻
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Reparación de PCs</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Diagnóstico y reparación de ordenadores lentos, virus, problemas de arranque y hardware.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            📧
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Configuración Email</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de correo corporativo (Outlook, Gmail, Office 365) en todos tus dispositivos.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🛒
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Compra de Equipos</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Asesoramiento y compra de equipos informáticos adaptados a tus necesidades y presupuesto.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-yellow-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🔧
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Instalación Software</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Instalación y configuración de programas, licencias, actualizaciones y migraciones.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-red-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🌐
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Redes y WiFi</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de redes, routers, WiFi empresarial, VPN y conexiones remotas.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🖨️
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Impresoras y Periféricos</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de impresoras, escáneres, cámaras y otros dispositivos en red.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-pink-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            💾
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Copias de Seguridad</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Implementación de sistemas de backup automáticos para proteger tus datos.
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-teal-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            📱
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Dispositivos Móviles</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Configuración de smartphones y tablets para uso empresarial (email, apps, VPN).
          </p>
        </div>

        <div class="bg-base-100 rounded-xl p-8 border border-base-300 hover:border-accent-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center text-3xl mb-6 shadow-md transition-transform duration-300 group-hover:scale-110">
            🎓
          </div>
          <h3 class="text-xl font-bold text-base-900 mb-3">Formación Básica</h3>
          <p class="text-base-600 text-sm leading-relaxed">
            Formación para tu equipo en herramientas ofimáticas y buenas prácticas de seguridad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 bg-base-50 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 opacity-40">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Dark overlay to maintain visibility -->
    <div class="absolute inset-0 bg-base-50/60"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Precios Transparentes
        </h2>
        <p class="text-xl text-white/90 mx-auto">
          Paga solo por las horas que necesites o ahorra con bolsas de horas
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- 5 hours pack -->
        <div class="bg-base-50 rounded-xl p-6 border-1 flex flex-col">
          <h4 class="text-xl font-bold mb-2 text-white">Bolsa 5h</h4>
          <p class="text-sm text-gray-300 mb-4">€37/hora</p>

          <div class="text-3xl font-bold mb-4 text-white">€185</div>
          <p class="text-sm text-gray-300 mb-4">Ahorra €15 - Ideal para uso ocasional</p>

          <ul class="space-y-2 text-sm text-gray-300 mb-6 flex-grow">
            <li><span class="text-blue-400">✅</span> 5 horas prepagadas</li>
            <li><span class="text-blue-400">✅</span> Soporte remoto o presencial</li>
            <li><span class="text-blue-400">✅</span> Descuento 7.5%</li>
            <li><span class="text-blue-400">✅</span> Primera incidencia gratis</li>
          </ul>
          <button
            data-plan="5h"
            class="checkout-btn block w-full px-4 py-3 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors mt-auto cursor-pointer"
          >
            Contratar
          </button>
        </div>

        <!-- 10 hours pack - POPULAR -->
        <div class="bg-base-50 rounded-xl p-6 border-2 border-blue-500 relative flex flex-col">
          <div class="absolute -top-3 left-1/2 transform -translate-x-1/2 bg-blue-600 px-4 py-1 rounded-full text-xs font-bold text-white">
            MÁS POPULAR
          </div>
          <h4 class="text-xl font-bold mb-2 text-white">Bolsa 10h</h4>
          <p class="text-sm text-gray-300 mb-4">€35/hora</p>

          <div class="text-3xl font-bold mb-4 text-white">€350</div>
          <p class="text-sm text-gray-300 mb-4">Ahorra €50 - Perfecto para pequeñas empresas</p>

          <ul class="space-y-2 text-sm text-gray-300 mb-6 flex-grow">
            <li><span class="text-blue-400">✅</span> Todo lo anterior +</li>
            <li><span class="text-blue-400">✅</span> 10 horas prepagadas</li>
            <li><span class="text-blue-400">✅</span> Descuento 12.5%</li>
            <li><span class="text-blue-400">✅</span> Atención prioritaria</li>
            <li><span class="text-blue-400">✅</span> Respuesta &lt; 2h</li>
          </ul>
          <button
            data-plan="10h"
            class="checkout-btn block w-full px-4 py-3 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors mt-auto cursor-pointer"
          >
            Contratar
          </button>
        </div>

        <!-- 20 hours pack - BEST DEAL -->
        <div class="bg-base-50 rounded-xl p-6 border-1 flex flex-col">
          <h4 class="text-xl font-bold mb-2 text-white">Bolsa 20h</h4>
          <p class="text-sm text-gray-300 mb-4">€30/hora</p>

          <div class="text-3xl font-bold mb-4 text-white">€600</div>
          <p class="text-sm text-gray-300 mb-4">Ahorra €200 - Máximo ahorro para empresas</p>

          <ul class="space-y-2 text-sm text-gray-300 mb-6 flex-grow">
            <li><span class="text-blue-400">✅</span> Todo lo anterior +</li>
            <li><span class="text-blue-400">✅</span> 20 horas prepagadas</li>
            <li><span class="text-blue-400">✅</span> Descuento 25%</li>
            <li><span class="text-blue-400">✅</span> Atención VIP</li>
            <li><span class="text-blue-400">✅</span> Informes mensuales</li>
          </ul>
          <button
            data-plan="20h"
            class="checkout-btn block w-full px-4 py-3 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors mt-auto cursor-pointer"
          >
            Contratar
          </button>
        </div>
      </div>

   
    </div>
  </section>



  <!-- Final CTA -->
  <section class="py-20 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/60 via-blue-600/70 to-accent-500/60"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-8 md:px-12 text-center text-white">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/20 backdrop-blur-sm border border-white/30 rounded-full text-sm font-semibold mb-6">
        <span class="text-xl">🎁</span>
        Primera Hora GRATIS
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        ¿Tienes un Problema Técnico Ahora?
      </h2>
      <p class="text-xl mb-4 opacity-90">
        No pierdas más tiempo. Abre un ticket y te llamamos en menos de 2 horas.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/abrir-ticket"
          class="inline-flex items-center justify-center gap-3 px-10 py-5 text-lg font-bold bg-white hover:bg-base-50 text-accent-600 rounded-xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
          </svg>
          Abrir Ticket Gratis
        </a>
        <a
          href="mailto:info@aisecurity.es"
          class="inline-flex items-center justify-center gap-2 px-8 py-5 text-lg font-semibold bg-white/10 hover:bg-white/20 text-white border-2 border-white/30 rounded-xl backdrop-blur-sm transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          info@aisecurity.es
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  details summary::after {
    content: '+';
    float: right;
    font-size: 1.5rem;
    font-weight: bold;
  }

  details[open] summary::after {
    content: '−';
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.checkout-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const planId = btn.dataset.plan;
      if (!planId) return;

      btn.disabled = true;
      btn.textContent = 'Redirigiendo...';

      try {
        const res = await fetch('/api/soporte/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ planId }),
        });

        const data = await res.json();

        if (data.url) {
          window.location.href = data.url;
        } else {
          alert('Error al iniciar el pago. Inténtalo de nuevo o contáctanos en info@aisecurity.es');
          btn.disabled = false;
          btn.textContent = 'Contratar';
        }
      } catch {
        alert('Error de conexión. Inténtalo de nuevo.');
        btn.disabled = false;
        btn.textContent = 'Contratar';
      }
    });
  });
</script>
