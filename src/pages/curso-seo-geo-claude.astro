<script is:inline>
  // Tema naranja para header y footer
  (function() {
    document.body.classList.add('seogeo-theme');
    const h = document.getElementById('main-header');
    const f = document.querySelector('footer');
    if (h) { h.style.setProperty('background','linear-gradient(135deg,#0a0700 0%,#0d0900 50%,#0a0700 100%)','important'); h.style.setProperty('border-bottom','1px solid rgba(245,158,11,0.18)','important'); }
    if (f) { f.style.backgroundColor = '#0a0700'; f.style.borderTopColor = 'rgba(245,158,11,0.12)'; }
    window.addEventListener('scroll', () => {
      if (!h) return;
      const bg = window.scrollY > 20 ? 'linear-gradient(135deg,#070500 0%,#0a0700 100%)' : 'linear-gradient(135deg,#0a0700 0%,#0d0900 50%,#0a0700 100%)';
      h.style.setProperty('background', bg, 'important');
      h.style.setProperty('border-bottom','1px solid rgba(245,158,11,0.18)','important');
    });
  })();

  // Cuenta atrás — 26 de Julio 2026
  const target = new Date('2026-07-26T18:00:00').getTime();
  function tick() {
    const diff = target - Date.now();
    if (diff <= 0) return;
    const pad = n => String(Math.floor(n)).padStart(2,'0');
    document.getElementById('cd-d').textContent = pad(diff/86400000);
    document.getElementById('cd-h').textContent = pad((diff%86400000)/3600000);
    document.getElementById('cd-m').textContent = pad((diff%3600000)/60000);
    document.getElementById('cd-s').textContent = pad((diff%60000)/1000);
  }
  tick(); setInterval(tick, 1000);

  // Terminal SEO
  const lines = [
    { t: '$ claude analyze-page --url=miweb.es/servicios', c: '#f59e0b' },
    { t: '> [ANALIZANDO estructura SEO...]', c: 'rgba(240,240,240,0.4)', d: 800 },
    { t: '⚠ H1 duplicado en /servicios', c: '#f97316', d: 1400 },
    { t: '⚠ Meta description ausente en 3 páginas', c: '#f97316', d: 1900 },
    { t: '✓ Schema LocalBusiness detectado', c: '#fbbf24', d: 2400 },
    { t: '', c: '', d: 3000 },
    { t: '$ claude keywords --nicho="fontanero madrid"', c: '#f59e0b', d: 3400 },
    { t: '→ "fontanero urgencias madrid" Vol:2.4k', c: '#fbbf24', d: 4100 },
    { t: '→ "desatascar tuberías madrid" Vol:1.2k', c: '#fbbf24', d: 4600 },
    { t: '', c: '', d: 5200 },
    { t: '$ geo-optimize --target=ChatGPT,Perplexity', c: '#f59e0b', d: 5600 },
    { t: '> Estructura GEO aplicada ✓', c: '#fbbf24', d: 6300 },
    { t: '> FAQ schema generado ✓', c: '#fbbf24', d: 6800 },
    { t: '', c: '', d: 7300 },
    { t: '# Resultado: +340% tráfico orgánico en 90 días', c: 'rgba(245,158,11,0.5)', d: 7700 },
  ];
  const out = document.getElementById('terminal-output');
  if (out) {
    lines.forEach(({ t, c, d = 0 }) => {
      setTimeout(() => {
        const el = document.createElement('div');
        el.textContent = t;
        el.style.color = c;
        if (!t) el.style.height = '10px';
        out.appendChild(el);
        out.parentElement.scrollTop = 9999;
      }, d);
    });
  }

  // Formularios
  async function submitForm(emailId, formId, successId, btnId, btnText) {
    const email = document.getElementById(emailId)?.value;
    const btn = document.getElementById(btnId);
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
    try {
      const res = await fetch('/api/lista-espera-seo-geo', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (data.success) {
        const form = document.getElementById(formId);
        const success = document.getElementById(successId);
        if (form) form.style.display = 'none';
        if (success) success.style.display = 'block';
      } else {
        if (btn) { btn.disabled = false; btn.textContent = btnText; }
      }
    } catch {
      if (btn) { btn.disabled = false; btn.textContent = btnText; }
    }
  }
  document.getElementById('hero-form')?.addEventListener('submit', e => { e.preventDefault(); submitForm('hero-email','hero-form','hero-success','hero-btn','Avísame →'); });
  document.getElementById('bottom-form')?.addEventListener('submit', e => { e.preventDefault(); submitForm('bottom-email','bottom-form','bottom-success','bottom-btn','Apúntame a la lista de espera →'); });
</script>

