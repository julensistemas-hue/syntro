---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Cómo posicionarte en Google y en IAs con Claude | Curso SEO + GEO";
const description = "Usa Claude para keywords, SEO y GEO: aparece en Google, ChatGPT y Perplexity. Schema markup, auditorías con IA y comunidad activa. 50€ acceso permanente.";
const canonical = "https://aisecurity.es/curso-seo-geo-claude";

const schemaCourse = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "SEO + GEO con Claude — Posiciónate en Google y en IAs",
  "description": "Curso práctico para autónomos, marketers y dueños de negocio. Aprende a usar Claude para investigar keywords, optimizar contenido, aparecer en ChatGPT y Perplexity, y generar schema markup automáticamente.",
  "url": "https://aisecurity.es/curso-seo-geo-claude",
  "provider": { "@type": "Organization", "name": "AI Security", "url": "https://aisecurity.es" },
  "educationalLevel": "Beginner to Intermediate",
  "teaches": ["SEO con inteligencia artificial", "GEO - Generative Engine Optimization", "Investigación de keywords con Claude", "Schema markup generado con IA", "Estrategia de contenido SEO con Claude"],
  "timeRequired": "PT2H",
  "inLanguage": "es",
  "isAccessibleForFree": false,
  "offers": { "@type": "Offer", "price": "50", "priceCurrency": "EUR", "availability": "https://schema.org/PreOrder" },
  "audience": { "@type": "Audience", "audienceType": "Autónomos, marketers, dueños de negocio, freelancers, agencias digitales" },
  "keywords": "curso SEO con IA, GEO posicionamiento inteligencia artificial, Claude para SEO, cómo posicionarse en ChatGPT, Generative Engine Optimization España"
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Qué es el GEO y por qué importa en 2026?",
      "acceptedAnswer": { "@type": "Answer", "text": "GEO (Generative Engine Optimization) es la técnica de optimizar tu contenido para que aparezca citado en IAs como ChatGPT, Perplexity, Gemini o Copilot cuando alguien hace una búsqueda. En 2026, cada vez más personas buscan directamente en estas IAs en lugar de Google. Si no apareces ahí, pierdes visibilidad." }},
    { "@type": "Question", "name": "¿Necesito conocimientos previos de SEO?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. El curso está diseñado para funcionar tanto si empiezas desde cero como si ya tienes base en SEO. Claude simplifica la parte técnica: le describes tu negocio y te genera el análisis, el contenido optimizado y el schema markup listo para pegar." }},
    { "@type": "Question", "name": "¿Qué es Claude y cómo ayuda al SEO?",
      "acceptedAnswer": { "@type": "Answer", "text": "Claude es un asistente de IA de Anthropic. Para SEO es muy útil: analiza páginas y sugiere mejoras, genera meta descriptions optimizadas, crea artículos de blog con estructura SEO correcta, genera schema markup en JSON-LD y detecta oportunidades de keywords que estás perdiendo." }},
    { "@type": "Question", "name": "¿El acceso es permanente y recibo actualizaciones?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. Pago único de 50€ con acceso de por vida. El SEO y el GEO evolucionan rápido — cuando cambie algo relevante (nuevo algoritmo, nueva IA, nueva táctica) se añade contenido al curso sin coste adicional." }},
    { "@type": "Question", "name": "¿Funciona para cualquier tipo de negocio?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. El curso cubre tanto SEO local (para negocios con ubicación física como clínicas, talleres o tiendas) como SEO para servicios online. Hay módulos específicos para cada caso." }}
  ]
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "AI Security", "item": "https://aisecurity.es" },
    { "@type": "ListItem", "position": 2, "name": "Formación", "item": "https://aisecurity.es/cursos" },
    { "@type": "ListItem", "position": 3, "name": "SEO + GEO con Claude", "item": "https://aisecurity.es/curso-seo-geo-claude" }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaCourse)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
    <meta property="og:type" content="product" />
    <meta property="og:locale" content="es_ES" />
    <meta name="theme-color" content="#0d0800" />
    <meta property="product:price:amount" content="50" />
    <meta property="product:price:currency" content="EUR" />
  </Fragment>

  <!-- HERO -->
  <section style="background:#0d0800;min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:80px 0;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(245,158,11,0.04) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;"></div>
    <div style="position:absolute;top:-200px;right:-100px;width:600px;height:600px;background:radial-gradient(circle,rgba(245,158,11,0.08),transparent 65%);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-100px;left:-50px;width:400px;height:400px;background:radial-gradient(circle,rgba(249,115,22,0.05),transparent 65%);pointer-events:none;"></div>

    <div style="max-width:1280px;margin:0 auto;padding:0 24px;width:100%;position:relative;z-index:1;">
      <div class="hero-grid">

        <!-- LEFT -->
        <div style="display:flex;flex-direction:column;justify-content:center;">
          <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border:1px solid rgba(245,158,11,0.35);border-radius:4px;margin-bottom:32px;width:fit-content;">
            <span style="width:7px;height:7px;border-radius:50%;background:#f59e0b;animation:blink 1.2s infinite;display:inline-block;"></span>
            <span style="font-family:'JetBrains Mono','Fira Code',monospace;font-size:12px;color:#f59e0b;letter-spacing:0.1em;">VÍDEOS · COMUNIDAD · SIEMPRE ACTUALIZADO · 50€</span>
          </div>

          <div style="line-height:1;">
            <div style="font-size:clamp(52px,9vw,120px);font-weight:900;color:#f59e0b;font-family:'Inter',sans-serif;letter-spacing:-4px;line-height:0.9;">SEO</div>
            <div style="font-size:clamp(28px,4.5vw,64px);font-weight:900;color:#f97316;font-family:'Inter',sans-serif;letter-spacing:-2px;line-height:0.95;">+ GEO</div>
            <h1 style="font-size:clamp(16px,2.2vw,26px);font-weight:700;color:#f0f0f0;letter-spacing:0.02em;text-transform:uppercase;margin-top:10px;line-height:1.2;">con Claude — Posiciónate en<br>Google <span style="color:#f59e0b;">y en las IAs</span></h1>
          </div>

          <p style="color:rgba(240,240,240,0.6);font-size:17px;line-height:1.65;max-width:480px;margin-top:24px;">
            Aprende los prompts exactos para investigar keywords, crear contenido que posiciona, aparecer en ChatGPT y Perplexity, y generar schema markup con IA. <strong style="color:#f0f0f0;">Sin agencias. Sin tecnicismos.</strong>
          </p>

          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:28px;">
            <span class="chip">Google SEO</span>
            <span class="chip">GEO / LLM SEO</span>
            <span class="chip">Keywords con IA</span>
            <span class="chip">Schema markup</span>
            <span class="chip">Contenido optimizado</span>
          </div>

          <div style="margin-top:36px;">
            <p style="font-family:'JetBrains Mono','Fira Code',monospace;font-size:12px;color:#f59e0b;margin-bottom:12px;letter-spacing:0.08em;">// 2 horas · 50€ · acceso permanente — apúntate</p>
            <form id="hero-form" style="display:flex;gap:10px;max-width:460px;flex-wrap:wrap;">
              <input id="hero-email" type="email" placeholder="tu@negocio.com" required
                style="flex:1;min-width:220px;background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.28);border-radius:6px;padding:14px 16px;color:#f0f0f0;font-family:'JetBrains Mono','Fira Code',monospace;font-size:14px;outline:none;" />
              <button type="submit" id="hero-btn" class="btn-primary">Avísame →</button>
            </form>
            <div id="hero-success" style="display:none;margin-top:12px;">
              <span style="font-family:'JetBrains Mono',monospace;color:#f59e0b;font-size:14px;">✓ apuntado. te avisamos antes que nadie.</span>
            </div>
            <p style="font-size:12px;color:rgba(240,240,240,0.3);margin-top:10px;">Sin spam. Solo te avisamos cuando abren inscripciones.</p>
          </div>
        </div>

        <!-- RIGHT: terminal SEO -->
        <div class="terminal-col">
          <div class="terminal-window">
            <div style="background:#1a1a1a;padding:10px 16px;border-radius:12px 12px 0 0;display:flex;align-items:center;gap:8px;border-bottom:1px solid rgba(245,158,11,0.15);">
              <span style="width:12px;height:12px;border-radius:50%;background:#ff5f57;display:inline-block;"></span>
              <span style="width:12px;height:12px;border-radius:50%;background:#ffbd2e;display:inline-block;"></span>
              <span style="width:12px;height:12px;border-radius:50%;background:#28c840;display:inline-block;"></span>
              <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:rgba(240,240,240,0.35);margin-left:8px;">claude-seo@aisecurity:~$</span>
            </div>
            <div style="background:#0d0800;padding:24px;border-radius:0 0 12px 12px;font-family:'JetBrains Mono','Fira Code',monospace;font-size:13px;line-height:1.75;min-height:400px;">
              <div id="terminal-output"></div>
              <span id="cursor" style="display:inline-block;width:8px;height:14px;background:#f59e0b;vertical-align:middle;animation:blink 1s infinite;"></span>
            </div>
          </div>

          <div style="margin-top:20px;">
            <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:rgba(245,158,11,0.5);letter-spacing:0.08em;margin-bottom:10px;text-align:center;">// lanzamiento en</p>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">
              <div class="cd-box"><span id="cd-d" class="cd-num">--</span><span class="cd-lbl">días</span></div>
              <div class="cd-box"><span id="cd-h" class="cd-num">--</span><span class="cd-lbl">horas</span></div>
              <div class="cd-box"><span id="cd-m" class="cd-num">--</span><span class="cd-lbl">min</span></div>
              <div class="cd-box"><span id="cd-s" class="cd-num">--</span><span class="cd-lbl">seg</span></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div style="background:#f59e0b;padding:12px 0;overflow:hidden;white-space:nowrap;">
    <div class="marquee-track">
      <span class="mq-item">$ claude keywords --nicho="fontanero madrid" --intención=local</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ geo-optimize --target=ChatGPT,Perplexity,Gemini</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ claude schema --tipo=LocalBusiness --negocio="Clínica dental"</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ audit-seo --url=miweb.es --output=informe.md</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ claude blog --keyword="mejor CRM para pymes" --longitud=1500</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ meta-tags --página=servicios --max-chars=160</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ claude keywords --nicho="fontanero madrid" --intención=local</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ geo-optimize --target=ChatGPT,Perplexity,Gemini</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ claude schema --tipo=LocalBusiness --negocio="Clínica dental"</span>
      <span class="mq-sep">◆</span>
      <span class="mq-item">$ audit-seo --url=miweb.es --output=informe.md</span>
      <span class="mq-sep">◆</span>
    </div>
  </div>

  <!-- QUÉ ES -->
  <section style="background:#111108;padding:80px 0;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;">
      <div style="text-align:center;margin-bottom:56px;">
        <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#f59e0b;letter-spacing:0.12em;margin-bottom:12px;">// qué es este curso</p>
        <h2 style="font-size:clamp(28px,4vw,52px);font-weight:900;color:#f0f0f0;line-height:1.1;">Google ya no es el único buscador.<br><span style="color:#f59e0b;">Las IAs también posicionan.</span></h2>
        <p style="color:rgba(240,240,240,0.55);font-size:17px;max-width:640px;margin:16px auto 0;line-height:1.65;">Cada vez más personas buscan directamente en ChatGPT, Perplexity o Gemini. Si no apareces ahí, estás perdiendo visibilidad. Este curso te enseña a posicionarte en ambos mundos usando Claude.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;" class="pillars-grid">
        <div style="background:#1a1508;border:1px solid rgba(245,158,11,0.15);border-radius:16px;padding:36px;text-align:center;">
          <div style="font-size:40px;margin-bottom:16px;">🔍</div>
          <h3 style="font-size:20px;font-weight:800;color:#f0f0f0;margin-bottom:10px;">SEO clásico con IA</h3>
          <p style="font-size:14px;color:rgba(240,240,240,0.55);line-height:1.65;">Keywords, contenido, on-page, schema markup y auditorías técnicas — todo generado y analizado con Claude en minutos.</p>
        </div>
        <div style="background:#1a1508;border:1px solid rgba(245,158,11,0.4);border-radius:16px;padding:36px;text-align:center;position:relative;">
          <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#f59e0b;color:#0d0800;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:4px 14px;border-radius:0 0 8px 8px;letter-spacing:0.08em;">LO NUEVO</div>
          <div style="font-size:40px;margin-bottom:16px;">🤖</div>
          <h3 style="font-size:20px;font-weight:800;color:#f0f0f0;margin-bottom:10px;">GEO — IA Search</h3>
          <p style="font-size:14px;color:rgba(240,240,240,0.55);line-height:1.65;">Optimiza tu contenido para aparecer citado en ChatGPT, Perplexity y Gemini cuando alguien pregunta por tu sector.</p>
        </div>
        <div style="background:#1a1508;border:1px solid rgba(245,158,11,0.15);border-radius:16px;padding:36px;text-align:center;">
          <div style="font-size:40px;margin-bottom:16px;">🔄</div>
          <h3 style="font-size:20px;font-weight:800;color:#f0f0f0;margin-bottom:10px;">Siempre actualizado</h3>
          <p style="font-size:14px;color:rgba(240,240,240,0.55);line-height:1.65;">El SEO cambia constantemente. Cuando cambie algo importante, se añade un módulo nuevo. Tu acceso incluye todas las actualizaciones.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BENTO: herramientas -->
  <section style="background:#0d0800;padding:80px 0;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;">
      <div style="margin-bottom:48px;">
        <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#f59e0b;letter-spacing:0.12em;margin-bottom:12px;">// lo que aprenderás a hacer</p>
        <h2 style="font-size:clamp(28px,4vw,52px);font-weight:900;color:#f0f0f0;line-height:1.1;max-width:640px;">5 cosas que harás con Claude<br>que cambiarán tu SEO</h2>
      </div>

      <div class="bento-grid">

        <!-- Grande: Keywords -->
        <div class="bento-card bento-large" style="border-color:rgba(245,158,11,0.3);">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
            <div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#f59e0b;letter-spacing:0.1em;margin-bottom:8px;">01 / INVESTIGACIÓN DE KEYWORDS</div>
              <h3 style="font-size:30px;font-weight:900;color:#f0f0f0;">Keywords con Claude</h3>
            </div>
            <div style="width:48px;height:48px;border-radius:12px;background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;font-size:24px;">🔍</div>
          </div>
          <p style="color:rgba(240,240,240,0.6);line-height:1.65;font-size:15px;margin-bottom:24px;">No más pagar por herramientas de keywords. Claude analiza tu nicho, detecta intención de búsqueda y genera clusters de keywords con dificultad estimada — en segundos.</p>
          <div style="background:#0a0700;border-radius:8px;padding:16px;font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.8;border:1px solid rgba(245,158,11,0.1);">
            <div style="color:rgba(245,158,11,0.5);"># Ejemplo real</div>
            <div><span style="color:#f59e0b;">❯</span> <span style="color:#f0f0f0;">Dame keywords para "clínica dental Madrid" con intención local</span></div>
            <div style="color:#fbbf24;margin-top:4px;">→ "dentista urgencias madrid" — Vol: 2.4k · Dif: baja</div>
            <div style="color:#fbbf24;">→ "limpieza dental precio madrid" — Vol: 1.8k · Dif: media</div>
            <div style="color:#fbbf24;">→ "ortodoncia invisible madrid" — Vol: 3.1k · Dif: alta</div>
          </div>
        </div>

        <!-- GEO -->
        <div class="bento-card" style="border-color:rgba(249,115,22,0.3);">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#f97316;letter-spacing:0.1em;margin-bottom:8px;">02 / GENERATIVE ENGINE OPT.</div>
          <h3 style="font-size:24px;font-weight:900;color:#f0f0f0;margin-bottom:12px;">Aparecer en las IAs</h3>
          <p style="color:rgba(240,240,240,0.55);font-size:14px;line-height:1.6;margin-bottom:20px;">Aprenderás a estructurar tu contenido para que ChatGPT, Perplexity y Gemini te citen cuando alguien pregunte por tu sector.</p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;background:rgba(249,115,22,0.07);border-radius:4px;color:#fdba74;">ChatGPT te cita ✓</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;background:rgba(249,115,22,0.07);border-radius:4px;color:#fdba74;">Perplexity te indexa ✓</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;background:rgba(249,115,22,0.07);border-radius:4px;color:#fdba74;">Gemini te recomienda ✓</div>
          </div>
        </div>

        <!-- Contenido -->
        <div class="bento-card">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#f59e0b;letter-spacing:0.1em;margin-bottom:8px;">03 / CONTENIDO SEO</div>
          <h3 style="font-size:24px;font-weight:900;color:#f0f0f0;margin-bottom:12px;">Artículos que posicionan</h3>
          <p style="color:rgba(240,240,240,0.55);font-size:14px;line-height:1.6;margin-bottom:20px;">Los prompts exactos para que Claude genere artículos con estructura H1-H6 correcta, densidad de keyword natural y enlazado interno sugerido.</p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;background:rgba(245,158,11,0.06);border-radius:4px;color:#fcd34d;">blog_post_seo.md ✓</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;background:rgba(245,158,11,0.06);border-radius:4px;color:#fcd34d;">pagina_servicio_opt.md ✓</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;background:rgba(245,158,11,0.06);border-radius:4px;color:#fcd34d;">faq_schema_ready.md ✓</div>
          </div>
        </div>

        <!-- Schema markup — ancho -->
        <div class="bento-card bento-wide" style="border-color:rgba(245,158,11,0.25);">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
            <div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#f59e0b;letter-spacing:0.1em;margin-bottom:8px;">04 / DATOS ESTRUCTURADOS</div>
              <h3 style="font-size:26px;font-weight:900;color:#f0f0f0;">Schema markup con Claude</h3>
            </div>
          </div>
          <p style="color:rgba(240,240,240,0.55);font-size:14px;line-height:1.6;margin-bottom:20px;max-width:440px;">Describe tu negocio y Claude genera el JSON-LD correcto para tus páginas. Sin tocar código, sin errores.</p>
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;">
            <div class="schema-demo"><span class="sc-key">LocalBusiness</span><span class="sc-val">→ Negocios locales</span></div>
            <div class="schema-demo"><span class="sc-key">FAQPage</span><span class="sc-val">→ Rich snippets</span></div>
            <div class="schema-demo"><span class="sc-key">Article</span><span class="sc-val">→ Blog y noticias</span></div>
            <div class="schema-demo"><span class="sc-key">Course</span><span class="sc-val">→ Formación online</span></div>
          </div>
        </div>

        <!-- Auditorías -->
        <div class="bento-card" style="border-color:rgba(234,179,8,0.2);">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#eab308;letter-spacing:0.1em;margin-bottom:8px;">05 / AUDITORÍA SEO</div>
          <h3 style="font-size:24px;font-weight:900;color:#f0f0f0;margin-bottom:12px;">Análisis automático</h3>
          <p style="color:rgba(240,240,240,0.55);font-size:14px;line-height:1.6;margin-bottom:20px;">Copia el HTML de tu página y Claude detecta todos los problemas SEO con prioridad y solución incluida.</p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <div class="audit-item">⚠ H1 duplicado → corregir</div>
            <div class="audit-item">⚠ Meta desc. > 160 chars</div>
            <div class="audit-item">✓ Schema LocalBusiness OK</div>
            <div class="audit-item">⚠ Alt en 3 imágenes vacío</div>
