    dptos: [
      { nombre: "Administración", herramienta: "Mindee + n8n", ahorro: "Proveedores del automóvil de Valladolid procesan automáticamente ordenes de compra, albaranes y no conformidades de Renault." },
      { nombre: "Sistemas", herramienta: "Wazuh + Ansible", ahorro: "Empresas industriales del Polígono San Cristóbal monitorizan su seguridad IT y cumplen con normativas de proveedores de Tier 0." },
      { nombre: "Comercial", herramienta: "Claude + CRM", ahorro: "Bodegas de Ribera del Duero generan fichas de vino y materiales de exportación en inglés, alemán y chino automáticamente." },
      { nombre: "Atención al cliente", herramienta: "Chatbot IA", ahorro: "Empresas de servicios vallisoletanas atienden consultas frecuentes sin agentes. El 80% de preguntas resueltas automáticamente." },
    ],
    faq: [
      { q: "¿Podéis ayudar a proveedores de Renault en Valladolid a implementar IA?", a: "Sí. Los proveedores de Renault y su cadena de suministro tienen grandes volúmenes de documentación técnica (QAP, PPAP, AMFE) y comunicación estructurada con el OEM. La automatización de ese flujo documental puede ahorrar decenas de horas al mes." },
      { q: "¿Tenéis experiencia con bodegas y empresas agroalimentarias en Castilla y León?", a: "Sí. La generación automática de fichas de vino y productos en múltiples idiomas, la gestión de pedidos de importadores internacionales y el procesado de documentación de exportación son servicios especialmente relevantes para bodegas de Ribera del Duero y Rueda." },
      { q: "¿El servicio cubre toda Castilla y León o solo Valladolid?", a: "Cubre toda Castilla y León. Nos desplazamos a Valladolid, Burgos, Salamanca, León, Segovia y el resto de la región para el análisis inicial. El servicio posterior es remoto." },
    ],
  },
  {
    slug: "murcia",
    nombre: "Murcia",
    region: "Región de Murcia",
    contexto: "La Región de Murcia es la huerta de Europa: el sector agroalimentario (frutas, hortalizas, flor cortada) mueve miles de millones al año y exporta a toda la UE. Junto a la agricultura intensiva, la industria de conservas y congelados, las empresas de servicios y un tejido de PYMES comerciales configuran una economía regional con mucho potencial de automatización.",
    contextoCorto: "Agroalimentación y horticultura de exportación, conservas, flor cortada y sector servicios.",
    sectores: [
      { nombre: "Agroalimentación y horticultura", icon: "🥦", desc: "Gestión de pedidos de exportación, comunicación con distribuidores europeos y trazabilidad documental con IA." },
      { nombre: "Conservas y procesado", icon: "🥫", desc: "Automatización de fichas técnicas, gestión de calidad (certificados) y atención a distribuidores de la gran distribución." },
      { nombre: "Servicios y comercio", icon: "🏪", desc: "Chatbots para atención al cliente, gestión de citas y automatización de tareas administrativas para PYMES murcianas." },
    ],
    dptos: [
      { nombre: "Administración", herramienta: "Claude + Mindee", ahorro: "Empresas exportadoras de frutas y hortalizas procesan facturas, albaranes y documentación de exportación automáticamente. 80% menos tiempo administrativo." },
      { nombre: "Atención al cliente", herramienta: "Chatbot multiidioma", ahorro: "Conserveras murcianas atienden a distribuidores alemanes, británicos y franceses en su idioma sin ampliar el equipo comercial." },
      { nombre: "Comercial", herramienta: "Claude + HeyGen", ahorro: "Fichas técnicas de producto generadas en 5 idiomas para ferias internacionales (Fruit Logistica, Anuga). Sin trabajo manual." },
      { nombre: "Sistemas", herramienta: "Wazuh", ahorro: "Empresas con obligaciones de trazabilidad (BRC, IFS, GlobalGAP) implementan control de accesos y auditoría IT sin CISO." },
    ],
    faq: [
      { q: "¿Podéis ayudar a empresas agroalimentarias de Murcia a implementar IA?", a: "Sí. El sector agroalimentario murciano es uno de los que más retorno obtiene de la automatización: alto volumen de documentación de exportación, comunicación internacional en múltiples idiomas y gestión de calidad repetitiva. La IA puede asumir gran parte de ese trabajo." },
      { q: "¿Podéis gestionar fichas de producto en inglés, alemán y francés para exportación?", a: "Sí. El sistema genera automáticamente fichas técnicas de producto, certificados y materiales de marketing en los idiomas que necesites. Conectado a tu ERP o catálogo de producto, se actualiza automáticamente cuando hay cambios." },
      { q: "¿Cuánto cuesta la consultoría IA para una empresa en Murcia?", a: "La primera consulta es gratuita. Las implementaciones parten desde 1.500€ para un único proceso (ej: automatización de facturas de exportación o chatbot para distribuidores). Tras el análisis damos precio fijo por el alcance acordado." },
    ],
  },
];

export async function getStaticPaths() {
  return ciudades.map((ciudad) => ({
    params: { ciudad: ciudad.slug },
    props: ciudad,
  }));
}

type Props = CiudadData;
const ciudad = Astro.props;

const title = `Consultoría de Inteligencia Artificial para Empresas en ${ciudad.nombre} — AI Security`;
const description = `Implementamos IA en empresas de ${ciudad.nombre} y la ${ciudad.region}: automatización por departamento, formación incluida y ROI visible en 2-3 meses. Primera consulta gratuita.`;
const canonical = `https://aisecurity.es/consultoria-ia/${ciudad.slug}`;
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Schema JSON-LD — Service + LocalBusiness context + FAQPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": `Consultoría de Inteligencia Artificial para Empresas en ${ciudad.nombre}`,
      "description": `Servicio de análisis, implementación y formación de herramientas de IA adaptadas a empresas de ${ciudad.nombre} y la ${ciudad.region}. Cubre todos los departamentos: administración, comercial, atención al cliente, comunicación, desarrollo y sistemas.`,
      "provider": {
        "@type": "Organization",
        "name": "AI Security",
        "url": "https://aisecurity.es",
        "areaServed": "ES"
      },
      "areaServed": {
        "@type": "City",
        "name": ciudad.nombre,
        "containedInPlace": {
          "@type": "AdministrativeArea",
          "name": ciudad.region
        }
      },
      "serviceType": "Consultoría de Inteligencia Artificial para empresas",
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": `https://aisecurity.es/consultoria-ia/${ciudad.slug}`,
        "availableLanguage": ["Spanish", "Catalan", "English"]
      },
      "offers": {
        "@type": "Offer",
        "description": "Primera consulta gratuita. Propuesta personalizada sin compromiso.",
        "availability": "https://schema.org/InStock"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": ciudad.faq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      })).concat([
        {
          "@type": "Question",
          "name": `¿Qué departamentos de una empresa de ${ciudad.nombre} pueden beneficiarse de la IA?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Prácticamente todos. Los más habituales en empresas de ${ciudad.nombre} son: Administración (facturas, presupuestos automáticos), Atención al cliente (chatbot 24/7), Comercial (propuestas y seguimiento automático), Comunicación (contenido visual con IA generativa), Desarrollo (Claude Code, GitHub Copilot) y Sistemas (Wazuh, Ansible con IA).`
          }
        }
      ])
    }
  ])}></script>


  <!-- HERO -->
  <section style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 50%, #0a0d1a 100%); padding: 80px 0 60px; position: relative; overflow: hidden;">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 50%, #4f7cff 0%, transparent 50%), radial-gradient(circle at 80% 50%, #8b5cf6 0%, transparent 50%);"></div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">
        <a href="/consultoria-ia" style="color:#60a5fa;font-size:0.875rem;text-decoration:none;">← Consultoría IA</a>
        <span style="color:#475569;font-size:0.875rem;">/</span>
        <span style="color:#94a3b8;font-size:0.875rem;">{ciudad.nombre}</span>
      </div>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium mb-6" style="background: rgba(79,124,255,0.15); border: 1px solid rgba(79,124,255,0.3); color: #7da4ff;">
        <span>🤖</span> Consultoría IA · {ciudad.nombre}
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight" style="color: #fff;">
        IA para empresas en {ciudad.nombre},<br/>
        <span style="background: linear-gradient(90deg, #4f7cff, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">departamento a departamento</span>
      </h1>
      <p class="text-lg max-w-3xl mb-4" style="color: #94a3b8; line-height: 1.75;">
        {ciudad.contexto}
      </p>
      <p class="text-base max-w-3xl mb-8" style="color: #64748b;">
        Analizamos tu empresa, entendemos cómo trabajáis y os implementamos las mejores herramientas de IA del mercado. Con formación para tu equipo incluida.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href={`/presupuesto?plan=Consultoria-IA-${ciudad.nombre}`}
          style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:linear-gradient(135deg,#4f7cff,#7c3aed);color:#fff;font-weight:700;font-size:1rem;border-radius:12px;text-decoration:none;">
          Solicitar consulta gratuita en {ciudad.nombre} →
        </a>
        <a href="/consultoria-ia"
          style="display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:#cbd5e1;font-weight:600;font-size:0.95rem;border-radius:12px;text-decoration:none;">
          Ver todos los servicios
        </a>
      </div>
    </div>
  </section>


  <!-- SECTORES LOCALES -->
  <section style="background: #0a0d1a; padding: 80px 0;">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4" style="color: #e2e8f0;">Sectores clave en {ciudad.nombre}</h2>
        <p style="color: #94a3b8; font-size: 1rem; max-width: 580px; margin: 0 auto;">{ciudad.contextoCorto}</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
        {ciudad.sectores.map(sector => (
          <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(79,124,255,0.2);border-radius:1.25rem;padding:28px;">
            <div style="font-size:2rem;margin-bottom:12px;">{sector.icon}</div>
            <h3 style="color:#e2e8f0;font-weight:700;font-size:1rem;margin:0 0 8px;">{sector.nombre}</h3>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;margin:0;">{sector.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- CASOS POR DEPARTAMENTO -->
  <section style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 100%); padding: 80px 0; position:relative;overflow:hidden;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at 20% 50%, rgba(79,124,255,0.08), transparent 60%), radial-gradient(circle at 80% 50%, rgba(139,92,246,0.06), transparent 60%);"></div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4" style="color: #e2e8f0;">Qué implementamos en empresas de {ciudad.nombre}</h2>
        <p style="color: #94a3b8; font-size: 1rem; max-width: 560px; margin: 0 auto;">Ejemplos reales de ahorro por departamento en empresas similares a la tuya en la región.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;">
        {ciudad.dptos.map((dpto, i) => (
          <div style={`background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:28px;border-left:3px solid ${['#4f7cff','#a78bfa','#22c55e','#f59e0b'][i % 4]};`}>
            <div style={`color:${['#60a5fa','#a78bfa','#4ade80','#fbbf24'][i % 4]};font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;`}>{dpto.nombre}</div>
            <div style="color:#64748b;font-size:0.78rem;margin-bottom:10px;">Herramienta: {dpto.herramienta}</div>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;margin:0;">{dpto.ahorro}</p>
          </div>
        ))}
      </div>

      <div style="margin-top:48px;text-align:center;">
        <a href="/consultoria-ia" style="color:#60a5fa;font-size:0.9rem;text-decoration:none;">Ver todos los departamentos y herramientas disponibles →</a>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section style="background: #0f1628; padding: 80px 0;">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4" style="color: #e2e8f0;">Preguntas frecuentes — {ciudad.nombre}</h2>
        <p style="color: #94a3b8; font-size: 1rem; max-width: 500px; margin: 0 auto;">Dudas habituales de empresas en {ciudad.nombre} y {ciudad.region} antes de implementar IA.</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {ciudad.faq.map(item => (
          <div class="faq-item" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;transition:border-color 0.2s;">
            <button class="faq-btn" style="width:100%;text-align:left;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;cursor:pointer;background:none;border:none;">
              <span style="color:#e2e8f0;font-weight:600;font-size:0.95rem;line-height:1.4;">{item.q}</span>
              <svg class="faq-chevron" style="width:20px;height:20px;color:#60a5fa;flex-shrink:0;transition:transform 0.25s;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer" style="display:none;padding:0 24px 20px;">
              <p style="color:#94a3b8;font-size:0.875rem;line-height:1.75;margin:0;border-top:1px solid rgba(255,255,255,0.06);padding-top:16px;">{item.a}</p>
            </div>
          </div>
        ))}

        <!-- FAQ genérica -->
        <div class="faq-item" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;transition:border-color 0.2s;">
          <button class="faq-btn" style="width:100%;text-align:left;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;cursor:pointer;background:none;border:none;">
            <span style="color:#e2e8f0;font-weight:600;font-size:0.95rem;line-height:1.4;">¿Necesito equipo técnico propio en {ciudad.nombre} para implementar IA?</span>
            <svg class="faq-chevron" style="width:20px;height:20px;color:#60a5fa;flex-shrink:0;transition:transform 0.25s;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="faq-answer" style="display:none;padding:0 24px 20px;">
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.75;margin:0;border-top:1px solid rgba(255,255,255,0.06);padding-top:16px;">No. AI Security se encarga de toda la parte técnica: configuración, integración con tus herramientas actuales (ERP, CRM, email, Google Workspace) y puesta en marcha. La formación del equipo está incluida para que puedas usarlo de forma autónoma desde el primer día.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
  (function(){
    document.querySelectorAll('.faq-btn').forEach(function(btn){
      btn.addEventListener('click',function(){
        var item=btn.closest('.faq-item');
        var answer=item.querySelector('.faq-answer');
        var icon=btn.querySelector('.faq-chevron');
        var open=answer.style.display==='block';
        document.querySelectorAll('.faq-answer').forEach(function(a){a.style.display='none';});
        document.querySelectorAll('.faq-chevron').forEach(function(i){i.style.transform='rotate(0deg)';});
        document.querySelectorAll('.faq-item').forEach(function(i){i.style.borderColor='rgba(255,255,255,0.08)';});
        if(!open){answer.style.display='block';icon.style.transform='rotate(180deg)';item.style.borderColor='rgba(79,124,255,0.3)';}
      });
    });
  })();
  </script>


  <!-- CTA FINAL -->
  <section style="background: #0a0d1a; padding: 80px 0;">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div style="font-size:2.5rem;margin-bottom:16px;">🤖</div>
      <h2 class="text-3xl md:text-4xl font-bold mb-5" style="color:#fff;">
        Tu empresa en {ciudad.nombre},<br/>más eficiente con IA
      </h2>
      <p style="color:#94a3b8;font-size:1.05rem;margin-bottom:36px;line-height:1.7;max-width:520px;margin-left:auto;margin-right:auto;">
        Analizamos tus procesos actuales y te decimos exactamente qué puede automatizarse y cuánto puede ahorrar tu empresa. Primera consulta gratuita y sin compromiso.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;">
        <a href={`/presupuesto?plan=Consultoria-IA-${ciudad.nombre}`}
          style="display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:15px 34px;background:linear-gradient(135deg,#4f7cff,#7c3aed);color:#fff;font-weight:700;font-size:1rem;border-radius:14px;text-decoration:none;box-shadow:0 16px 36px -8px rgba(79,124,255,0.4);">
          Solicitar consulta gratuita
        </a>
        <a href="/consultoria-ia"
          style="display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:15px 34px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.14);color:#cbd5e1;font-weight:600;font-size:1rem;border-radius:14px;text-decoration:none;">
          Ver todos los servicios IA
        </a>
      </div>

      <!-- Enlace a otras ciudades -->
      <div style="margin-top:48px;padding-top:32px;border-top:1px solid rgba(255,255,255,0.06);">
        <p style="color:#475569;font-size:0.8rem;margin-bottom:12px;">También en otras ciudades de España:</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;">
          {[
            {slug:'madrid',nombre:'Madrid'},{slug:'barcelona',nombre:'Barcelona'},
            {slug:'valencia',nombre:'Valencia'},{slug:'sevilla',nombre:'Sevilla'},
            {slug:'bilbao',nombre:'Bilbao'},{slug:'zaragoza',nombre:'Zaragoza'},
            {slug:'malaga',nombre:'Málaga'},{slug:'alicante',nombre:'Alicante'},
            {slug:'valladolid',nombre:'Valladolid'},{slug:'murcia',nombre:'Murcia'},
          ].filter(c => c.slug !== ciudad.slug).map(c => (
            <a href={`/consultoria-ia/${c.slug}`}
              style="padding:5px 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:20px;color:#64748b;font-size:0.78rem;text-decoration:none;">
              {c.nombre}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
