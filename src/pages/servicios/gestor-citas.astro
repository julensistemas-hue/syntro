---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Gestor de Citas con IA — WhatsApp, Llamada y Widget Web | AI Security";
const description = "Sistema de reservas automático con IA. Tus clientes piden cita por WhatsApp, llamada telefónica o desde un widget incrustado en tu web. Confirmaciones y recordatorios automáticos. Sin trabajo manual para tu equipo.";
const canonical = "https://aisecurity.es/servicios/gestor-citas";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Schema JSON-LD — Service + FAQ para GEO -->
  <script type="application/ld+json" is:inline>
  [
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Gestor de Citas con IA",
      "alternateName": "Sistema de reservas automático por WhatsApp, llamada y widget web",
      "description": "Sistema de gestión de citas automatizado con IA. Permite a los clientes reservar cita por WhatsApp, llamada telefónica o widget incrustado en la web. Incluye confirmaciones automáticas, recordatorios y sincronización con Google Calendar y Outlook.",
      "provider": {
        "@type": "Organization",
        "name": "AI Security",
        "url": "https://aisecurity.es",
        "areaServed": "ES"
      },
      "serviceType": "Automatización de gestión de citas con IA",
      "areaServed": "España",
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://aisecurity.es/servicios/gestor-citas",
        "availableLanguage": ["Spanish", "Catalan", "English"]
      },
      "offers": [
        {
          "@type": "Offer",
          "name": "Plan Básico — Gestor de citas",
          "description": "Reservas por WhatsApp o llamada con IA, confirmaciones automáticas, recordatorios 24h y 1h antes, sincronización con Google Calendar.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Medio — Gestor de citas multicanal",
          "description": "WhatsApp + llamada + widget en web, lista de espera automática, integración con Google Calendar y Outlook, gestión de cancelaciones y reprogramaciones.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Avanzado — Gestor de citas completo",
          "description": "Todos los canales más CRM integrado, pagos online al reservar, notificaciones por SMS, análisis de ocupación y reportes de no-shows.",
          "availability": "https://schema.org/InStock"
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo funciona un gestor de citas con IA por WhatsApp?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El cliente escribe un mensaje de WhatsApp —de forma natural, como lo haría a una persona— y la IA entiende su intención, consulta la disponibilidad en tiempo real y confirma la cita en la misma conversación. Gestiona también cancelaciones, reprogramaciones y envía recordatorios automáticos 24h y 1h antes de la cita. No requiere que el cliente instale nada ni salga de la app que ya usa."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es un widget de reservas incrustado en la web?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Es un calendario interactivo que se integra directamente en tu página web. El cliente ve los huecos disponibles en tiempo real y reserva en menos de 2 minutos sin salir de tu web. Se personaliza con los colores y el diseño de tu marca, sincroniza con Google Calendar y Outlook, y envía confirmaciones automáticas por email y SMS."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto se reducen las llamadas entrantes con un gestor de citas IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En negocios con alto volumen de citas, el sistema puede gestionar entre el 70% y el 85% de las reservas de forma completamente automática, sin que ningún miembro del equipo intervenga. Esto reduce significativamente las llamadas entrantes para reservas y las consultas por email, liberando al equipo para tareas de mayor valor."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué tipos de negocio se benefician más de un gestor de citas automatizado?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los negocios con mayor retorno son: clínicas dentales y médicas (alta frecuencia de citas y recordatorios), centros de estética y peluquerías (múltiples profesionales y servicios), talleres mecánicos (citas ITV y revisiones), asesorías y despachos (primera visita y consultas), restaurantes (reservas de mesa) y centros deportivos (clases y entrenadores personales)."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tarda en implementarse un gestor de citas con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El plan básico (WhatsApp + llamada con sincronización a Google Calendar) puede estar activo en 7-10 días hábiles. El plan medio, que incluye el widget web y gestión de cancelaciones avanzada, requiere 3-4 semanas. El plan avanzado con CRM y pagos online se implementa en 5-6 semanas. El plazo depende principalmente de la integración con el sistema de agenda existente."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo evita el gestor de citas IA los no-shows?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El sistema envía recordatorios automáticos por WhatsApp, SMS o email en dos momentos: 24 horas y 1 hora antes de la cita. Si el cliente no puede asistir, puede cancelar o reprogramar desde el propio recordatorio con un clic, liberando el hueco para otro cliente automáticamente. Los negocios que implementan esta automatización reducen los no-shows entre un 40% y un 70%."
          }
        }
      ]
    }
  ]
  </script>


  <!-- ══════════════════════════════════════════════
       HERO + DEMOS DE CANAL
  ══════════════════════════════════════════════ -->
  <section style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 50%, #0a0d1a 100%); padding: 80px 0 60px; position: relative; overflow: hidden;">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, #2563eb 0%, transparent 50%), radial-gradient(circle at 80% 70%, #0ea5e9 0%, transparent 50%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">

      <!-- Título -->
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight" style="color: #fff;">
          Tus clientes reservan cita<br/>
          <span style="background: linear-gradient(90deg, #22c55e, #38b1ff, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">como prefieran</span>
        </h1>
        <p class="text-xl max-w-3xl mx-auto" style="color: #94a3b8; line-height: 1.7;">
          Por <strong style="color: #22c55e;">WhatsApp</strong>, por <strong style="color: #38b1ff;">llamada telefónica</strong> o desde un <strong style="color: #a78bfa;">widget en tu web</strong>.
          La IA gestiona reservas, confirmaciones y recordatorios. Sin trabajo manual para tu equipo.
        </p>
      </div>

      <!-- Selector de canal -->
      <div id="demo" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1.5rem; overflow: hidden;">

        <!-- Barra tipo terminal -->
        <div style="background: rgba(0,0,0,0.4); padding: 14px 24px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="display: flex; gap: 6px;">
              <div style="width:12px;height:12px;border-radius:50%;background:#ef4444;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#eab308;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#22c55e;"></div>
            </div>
            <span style="color: #64748b; font-size: 0.875rem; font-family: monospace;">Gestor de Citas IA — Elige tu canal</span>
          </div>
          <div style="display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: #22c55e;">
            <span style="width:8px;height:8px;background:#22c55e;border-radius:50%;display:inline-block;" class="animate-pulse"></span>
            Disponible 24/7
          </div>
        </div>

        <!-- Botones de canal -->
        <div style="display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; padding: 24px 24px 0;">
          <button class="channel-btn" data-channel="whatsapp"
            style="text-align:left;border-radius:1rem;padding:20px;border:2px solid rgba(34,197,94,0.35);background:rgba(34,197,94,0.08);cursor:pointer;transition:all 0.2s;">
            <div style="font-size:1.75rem;margin-bottom:8px;">💬</div>
            <div style="color:#22c55e;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;">WhatsApp</div>
            <div style="color:#fff;font-weight:700;font-size:0.95rem;margin-bottom:4px;">Reserva por mensaje</div>
            <div style="color:rgba(255,255,255,0.5);font-size:0.8rem;">El cliente escribe y la IA gestiona</div>
            <div style="margin-top:12px;display:flex;align-items:center;gap:6px;font-size:0.8rem;font-weight:600;color:#22c55e;">
              <span class="w-2 h-2 rounded-full" style="width:6px;height:6px;background:#22c55e;border-radius:50%;display:inline-block;"></span>
              <span class="ch-label">Ver demo</span>
            </div>
          </button>

          <button class="channel-btn" data-channel="llamada"
            style="text-align:left;border-radius:1rem;padding:20px;border:2px solid rgba(56,177,255,0.25);background:rgba(56,177,255,0.05);cursor:pointer;transition:all 0.2s;">
            <div style="font-size:1.75rem;margin-bottom:8px;">📞</div>
            <div style="color:#38b1ff;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;">Llamada</div>
            <div style="color:#fff;font-weight:700;font-size:0.95rem;margin-bottom:4px;">Reserva por teléfono</div>
            <div style="color:rgba(255,255,255,0.5);font-size:0.8rem;">Agente IA con voz natural</div>
            <div style="margin-top:12px;display:flex;align-items:center;gap:6px;font-size:0.8rem;font-weight:600;color:#38b1ff;">
              <span style="width:6px;height:6px;background:#38b1ff;border-radius:50%;display:inline-block;"></span>
              <span class="ch-label">Ver demo</span>
            </div>
          </button>

          <button class="channel-btn" data-channel="widget"
            style="text-align:left;border-radius:1rem;padding:20px;border:2px solid rgba(139,92,246,0.25);background:rgba(139,92,246,0.05);cursor:pointer;transition:all 0.2s;">
            <div style="font-size:1.75rem;margin-bottom:8px;">🗓️</div>
            <div style="color:#a78bfa;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;">Widget web</div>
            <div style="color:#fff;font-weight:700;font-size:0.95rem;margin-bottom:4px;">Reserva desde tu web</div>
            <div style="color:rgba(255,255,255,0.5);font-size:0.8rem;">Calendario incrustado en tu página</div>
            <div style="margin-top:12px;display:flex;align-items:center;gap:6px;font-size:0.8rem;font-weight:600;color:#a78bfa;">
              <span style="width:6px;height:6px;background:#8b5cf6;border-radius:50%;display:inline-block;"></span>
              <span class="ch-label">Ver demo</span>
            </div>
          </button>
        </div>

        <!-- ── PANEL WHATSAPP ── -->
        <div id="panel-whatsapp" class="demo-panel" style="display:none;padding:24px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;border-radius:1.25rem;overflow:hidden;border:1px solid rgba(34,197,94,0.2);">
            <!-- Chat WhatsApp -->
            <div style="background:#111b21;">
              <div style="background:#202c33;display:flex;align-items:center;gap:12px;padding:14px 18px;">
                <div style="width:36px;height:36px;border-radius:50%;background:#00a884;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.8rem;color:#fff;">CG</div>
                <div>
                  <div style="color:#fff;font-weight:600;font-size:0.875rem;">Clínica García</div>
                  <div style="color:#00a884;font-size:0.75rem;">Gestor de citas · En línea</div>
                </div>
              </div>
              <div id="wa-messages" style="padding:16px;display:flex;flex-direction:column;gap:10px;min-height:280px;max-height:320px;overflow-y:auto;"></div>
            </div>
            <!-- Info -->
            <div style="background:#0b1524;padding:32px;display:flex;flex-direction:column;justify-content:center;">
              <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);border-radius:20px;padding:4px 12px;width:fit-content;margin-bottom:16px;">
                <span style="width:6px;height:6px;background:#22c55e;border-radius:50%;display:inline-block;"></span>
                <span style="color:#22c55e;font-size:0.75rem;font-weight:700;">WhatsApp Business API</span>
              </div>
              <h3 style="color:#fff;font-size:1.35rem;font-weight:700;margin:0 0 10px;">El canal que ya usan tus clientes</h3>
              <p style="color:rgba(255,255,255,0.6);font-size:0.875rem;line-height:1.7;margin:0 0 18px;">El 85% de los españoles tiene WhatsApp instalado. Sin apps, sin formularios. Solo escriben como siempre.</p>
              <ul style="list-style:none;margin:0 0 24px;padding:0;display:flex;flex-direction:column;gap:8px;">
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#22c55e;flex-shrink:0;">✓</span>Reserva, cancelación y reprogramación por chat</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#22c55e;flex-shrink:0;">✓</span>Recordatorios automáticos 24h y 1h antes</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#22c55e;flex-shrink:0;">✓</span>Detecta intención: "quiero cita para mañana"</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#22c55e;flex-shrink:0;">✓</span>Sincroniza con Google Calendar y Outlook</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#22c55e;flex-shrink:0;">✓</span>Lista de espera automática si no hay hueco</li>
              </ul>
              <a href="/contacto-migracion?plan=Gestor-Citas-WhatsApp"
                style="display:inline-flex;align-items:center;justify-content:center;padding:12px 24px;background:#22c55e;color:#052e16;font-weight:700;font-size:0.875rem;border-radius:10px;text-decoration:none;width:fit-content;">
                Quiero el gestor por WhatsApp →
              </a>
            </div>
          </div>
        </div>

        <!-- ── PANEL LLAMADA ── -->
        <div id="panel-llamada" class="demo-panel" style="display:none;padding:24px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;border-radius:1.25rem;overflow:hidden;border:1px solid rgba(56,177,255,0.2);">
            <!-- Simulación llamada -->
            <div style="background:#0a0e1a;padding:32px;display:flex;flex-direction:column;align-items:center;">
              <div style="width:72px;height:72px;border-radius:50%;background:rgba(56,177,255,0.1);border:2px solid rgba(56,177,255,0.3);display:flex;align-items:center;justify-content:center;font-size:2rem;margin-bottom:12px;">📞</div>
              <div style="color:#fff;font-weight:700;margin-bottom:4px;">Agente IA de Citas</div>
              <div style="color:#38b1ff;font-size:0.8rem;display:flex;align-items:center;gap:6px;margin-bottom:24px;">
                <span style="width:6px;height:6px;background:#38b1ff;border-radius:50%;display:inline-block;" class="animate-pulse"></span>
                Llamada en curso
              </div>
              <div id="call-transcript" style="width:100%;display:flex;flex-direction:column;gap:10px;font-size:0.8rem;font-family:monospace;"></div>
            </div>
            <!-- Info -->
            <div style="background:#0b1524;padding:32px;display:flex;flex-direction:column;justify-content:center;">
              <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(56,177,255,0.1);border:1px solid rgba(56,177,255,0.2);border-radius:20px;padding:4px 12px;width:fit-content;margin-bottom:16px;">
                <span style="width:6px;height:6px;background:#38b1ff;border-radius:50%;display:inline-block;"></span>
                <span style="color:#38b1ff;font-size:0.75rem;font-weight:700;">Agente de voz con IA</span>
              </div>
              <h3 style="color:#fff;font-size:1.35rem;font-weight:700;margin:0 0 10px;">Para quien prefiere llamar</h3>
              <p style="color:rgba(255,255,255,0.6);font-size:0.875rem;line-height:1.7;margin:0 0 18px;">Voz natural en español. Atiende la llamada, entiende lo que necesita el cliente y reserva la cita. Sin esperas, sin contestador.</p>
              <ul style="list-style:none;margin:0 0 24px;padding:0;display:flex;flex-direction:column;gap:8px;">
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#38b1ff;flex-shrink:0;">✓</span>Voz natural en español, sin sonar robótico</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#38b1ff;flex-shrink:0;">✓</span>Atiende 24/7, fines de semana incluidos</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#38b1ff;flex-shrink:0;">✓</span>Deriva a persona real si lo necesita</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#38b1ff;flex-shrink:0;">✓</span>Transcripción automática de cada llamada</li>
                <li style="color:rgba(255,255,255,0.75);font-size:0.825rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#38b1ff;flex-shrink:0;">✓</span>Integra con tu número de teléfono actual</li>
              </ul>
              <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <a href="/servicios/atencion-llamadas"
                  style="display:inline-flex;align-items:center;padding:12px 20px;border:1px solid #38b1ff;color:#38b1ff;font-weight:600;font-size:0.875rem;border-radius:10px;text-decoration:none;">
                  Demo completa →
                </a>
                <a href="/contacto-migracion?plan=Gestor-Citas-Llamada"
                  style="display:inline-flex;align-items:center;padding:12px 20px;background:#38b1ff;color:#020817;font-weight:700;font-size:0.875rem;border-radius:10px;text-decoration:none;">
                  Lo quiero
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- ── PANEL WIDGET ── -->
        <div id="panel-widget" class="demo-panel" style="display:none;padding:24px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;border-radius:1.25rem;overflow:hidden;border:1px solid rgba(139,92,246,0.2);">
            <!-- Demo calendario -->
            <div style="background:#1a1030;padding:24px;">
              <div style="border-radius:12px;overflow:hidden;box-shadow:0 20px 40px rgba(0,0,0,0.4);">
                <!-- Barra browser -->
                <div style="background:#2d2d2d;display:flex;align-items:center;gap:6px;padding:10px 14px;">
                  <div style="width:10px;height:10px;border-radius:50%;background:#ff5f57;"></div>
                  <div style="width:10px;height:10px;border-radius:50%;background:#ffbd2e;"></div>
                  <div style="width:10px;height:10px;border-radius:50%;background:#28c840;"></div>
                  <div style="flex:1;margin-left:8px;background:#3d3d3d;border-radius:4px;padding:4px 10px;color:#aaa;font-size:0.7rem;">tuclinica.com/reservar</div>
                </div>
                <!-- Calendario (fondo blanco — UI del cliente, no del sitio) -->
                <div style="background:#fff;padding:20px;">
                  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                    <button style="padding:4px;background:none;border:none;cursor:pointer;color:#555;">◀</button>
                    <span id="widget-month-label" style="font-weight:700;font-size:0.875rem;color:#111;">Junio 2026</span>
                    <button style="padding:4px;background:none;border:none;cursor:pointer;color:#555;">▶</button>
                  </div>
                  <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:6px;">
                    {['L','M','X','J','V','S','D'].map(d => (
                      <div style="text-align:center;font-size:0.65rem;font-weight:600;color:#888;padding:4px 0;">{d}</div>
                    ))}
                  </div>
                  <div id="widget-calendar" style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;"></div>
                  <div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb;">
                    <div style="font-size:0.7rem;font-weight:700;color:#333;margin-bottom:8px;">Horas disponibles</div>
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;">
                      {['09:00','09:30','10:00','10:30','11:00','11:30','16:00','16:30'].map(t => (
                        <button class="widget-slot" style="padding:6px 4px;border-radius:6px;border:1px solid #d1d5db;font-size:0.7rem;font-weight:600;color:#374151;background:white;cursor:pointer;">{t}</button>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <!-- Info -->
            <div style="background:#0b1524;padding:32px;display:flex;flex-direction:column;justify-content:center;">
              <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(139,92,246,0.12);border:1px solid rgba(139,92,246,0.2);border-radius:20px;padding:4px 12px;width:fit-content;margin-bottom:16px;">
                <span style="width:6px;height:6px;background:#8b5cf6;border-radius:50%;display:inline-block;"></span>
                <span style="color:#a78bfa;font-size:0.75rem;font-weight:700;">Widget embebido</span>
