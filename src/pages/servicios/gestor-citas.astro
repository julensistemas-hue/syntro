<script is:inline>
(function() {
  // ── Selector de canal ─────────────────────────────────────────
  const STYLES = {
    whatsapp: { on: 'rgba(34,197,94,0.15)',   off: 'rgba(34,197,94,0.08)',   bon: 'rgba(34,197,94,0.7)',   boff: 'rgba(34,197,94,0.35)' },
    llamada:  { on: 'rgba(56,177,255,0.15)',  off: 'rgba(56,177,255,0.05)',  bon: 'rgba(56,177,255,0.6)',  boff: 'rgba(56,177,255,0.25)' },
    widget:   { on: 'rgba(139,92,246,0.15)',  off: 'rgba(139,92,246,0.05)',  bon: 'rgba(139,92,246,0.6)',  boff: 'rgba(139,92,246,0.25)' },
  };
  let active = null;

  document.querySelectorAll('.channel-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const ch = btn.dataset.channel;
      const isOpen = active === ch;

      document.querySelectorAll('.channel-btn').forEach(b => {
        const s = STYLES[b.dataset.channel];
        b.style.background = s.off;
        b.style.borderColor = s.boff;
        b.querySelector('.ch-label').textContent = 'Ver demo';
      });
      document.querySelectorAll('.demo-panel').forEach(p => p.style.display = 'none');

      if (!isOpen) {
        const s = STYLES[ch];
        btn.style.background = s.on;
        btn.style.borderColor = s.bon;
        btn.querySelector('.ch-label').textContent = 'Ocultar demo';
        active = ch;
        const panel = document.getElementById('panel-' + ch);
        panel.style.display = 'block';
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        if (ch === 'whatsapp') initWA();
        if (ch === 'llamada')  initCall();
        if (ch === 'widget')   initWidget();
      } else {
        active = null;
      }
    });
  });

  // ── WhatsApp ──────────────────────────────────────────────────
  function initWA() {
    const box = document.getElementById('wa-messages');
    if (!box || box.dataset.init) return;
    box.dataset.init = '1';
    const msgs = [
      { from: 'c', text: 'Hola, quería pedir cita para mañana si es posible' },
      { from: 'b', text: '¡Hola! Claro 😊 ¿Para qué servicio necesitas la cita?' },
      { from: 'c', text: 'Limpieza dental' },
      { from: 'b', text: 'Perfecto. Para mañana tengo las 10:00 o las 17:00. ¿Cuál te viene mejor?' },
      { from: 'c', text: 'Las 10 está bien' },
      { from: 'b', text: '✅ Cita confirmada:\n📅 Mañana · 10:00\n🦷 Limpieza dental\n📍 Clínica García\n\nTe enviaré un recordatorio 1h antes.' },
    ];
    let i = 0;
    (function next() {
      if (i >= msgs.length) return;
      const m = msgs[i++];
      const div = document.createElement('div');
      div.style.cssText = 'display:flex;justify-content:' + (m.from === 'c' ? 'flex-end' : 'flex-start');
      div.innerHTML = '<div style="max-width:78%;padding:9px 13px;border-radius:' + (m.from === 'c' ? '18px 18px 4px 18px' : '18px 18px 18px 4px') + ';background:' + (m.from === 'c' ? '#005c4b' : '#202c33') + ';color:#e9edef;font-size:13px;line-height:1.5;white-space:pre-line;">' + m.text + '</div>';
      box.appendChild(div);
      box.scrollTop = 9999;
      setTimeout(next, 980);
    })();
  }

  // ── Llamada ───────────────────────────────────────────────────
  function initCall() {
    const box = document.getElementById('call-transcript');
    if (!box || box.dataset.init) return;
    box.dataset.init = '1';
    const lines = [
      { r: 'a', t: 'Centro de Salud García, buenos días. ¿En qué puedo ayudarle?' },
      { r: 'c', t: 'Hola, quería pedir cita para revisión' },
      { r: 'a', t: '¿Para esta semana o la próxima?' },
      { r: 'c', t: 'Esta semana si puede ser, por las mañanas' },
      { r: 'a', t: 'Tengo disponible el jueves a las 10:30. ¿Le viene bien?' },
      { r: 'c', t: 'Sí, perfecto' },
      { r: 'a', t: '¡Listo! Cita confirmada para el jueves a las 10:30. Le enviaré SMS de confirmación.' },
    ];
    let i = 0;
    (function next() {
      if (i >= lines.length) return;
      const l = lines[i++];
      const div = document.createElement('div');
      div.style.cssText = 'display:flex;gap:8px;align-items:flex-start;';
      div.innerHTML = '<span style="font-size:10px;font-weight:700;min-width:50px;padding-top:2px;color:' + (l.r === 'a' ? '#38b1ff' : 'rgba(255,255,255,0.35)') + '">' + (l.r === 'a' ? 'AGENTE' : 'CLIENTE') + '</span><span style="color:' + (l.r === 'a' ? '#fff' : 'rgba(255,255,255,0.6)') + ';font-size:0.8rem;line-height:1.5;">' + l.t + '</span>';
      box.appendChild(div);
      setTimeout(next, 1100);
    })();
  }

  // ── Widget ────────────────────────────────────────────────────
  function initWidget() {
    const grid = document.getElementById('widget-calendar');
    if (!grid || grid.dataset.init) return;
    grid.dataset.init = '1';
    const today = new Date();
    const y = today.getFullYear(), m = today.getMonth();
    const firstDay = (new Date(y, m, 1).getDay() || 7);
    const days = new Date(y, m + 1, 0).getDate();
    const lbl = document.getElementById('widget-month-label');
    if (lbl) lbl.textContent = new Date(y, m).toLocaleString('es-ES', { month: 'long', year: 'numeric' }).replace(/^\w/, c => c.toUpperCase());
    for (let i = 1; i < firstDay; i++) grid.innerHTML += '<div></div>';
    for (let d = 1; d <= days; d++) {
      const past = d < today.getDate();
      const isToday = d === today.getDate();
      const btn = document.createElement('button');
      btn.textContent = d;
      btn.disabled = past;
      btn.style.cssText = 'aspect-ratio:1;padding:4px;border-radius:6px;font-size:11px;font-weight:500;border:none;color:' + (past ? '#bbb' : isToday ? '#7c3aed' : '#111') + ';background:' + (isToday ? '#ede9fe' : 'transparent') + ';cursor:' + (past ? 'not-allowed' : 'pointer') + ';';
      if (!past) btn.addEventListener('click', () => {
        grid.querySelectorAll('button').forEach(b => { b.style.background = +b.textContent === today.getDate() ? '#ede9fe' : 'transparent'; b.style.color = '#111'; });
        btn.style.background = '#7c3aed'; btn.style.color = 'white';
      });
      grid.appendChild(btn);
    }
    document.querySelectorAll('.widget-slot').forEach(s => {
      s.addEventListener('click', () => {
        document.querySelectorAll('.widget-slot').forEach(x => { x.style.background = 'white'; x.style.color = '#374151'; x.style.borderColor = '#d1d5db'; });
        s.style.background = '#7c3aed'; s.style.color = 'white'; s.style.borderColor = '#7c3aed';
      });
    });
  }

  // Abrir WhatsApp por defecto
  document.querySelector('[data-channel="whatsapp"]').click();
})();
</script>
