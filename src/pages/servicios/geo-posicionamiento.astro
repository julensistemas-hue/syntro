<script>
  const canvas = document.getElementById('geo-chart') as HTMLCanvasElement;
  const totalLabel = document.getElementById('geo-chart-total');
  if (!canvas) throw new Error('canvas not found');
  const ctx = canvas.getContext('2d')!;

  const months = ['Mes 1', 'Mes 2', 'Mes 3', 'Mes 4', 'Mes 5', 'Mes 6'];
  const impressions = [90,  380,  1100, 3200, 7800, 12542];
  const clicks      = [6,   35,   140,  480,  1200, 3092];

  const MAX = 13800;
  const PAD = { top: 40, right: 32, bottom: 44, left: 60 };
  const DURATION = 2800;

  function resize() {
    const rect = canvas.getBoundingClientRect();
    canvas.width  = rect.width  * devicePixelRatio;
    canvas.height = rect.height * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

  function pt(vals: number[], i: number, W: number, H: number) {
    const cW = W - PAD.left - PAD.right;
    const cH = H - PAD.top - PAD.bottom;
    return {
      x: PAD.left + (i / (vals.length - 1)) * cW,
      y: PAD.top + cH - (vals[i] / MAX) * cH,
    };
  }

  function drawLine(
    vals: number[], progress: number,
    W: number, H: number,
    colorStart: string, colorEnd: string,
    fillColor: string, dotColor: string,
    showLabel: boolean
  ) {
    const cW = W - PAD.left - PAD.right;
    const cH = H - PAD.top - PAD.bottom;
    const total = (vals.length - 1) * progress;
    const idx   = Math.min(Math.floor(total), vals.length - 2);
    const frac  = total - idx;

    const pC = pt(vals, idx, W, H);
    const pN = pt(vals, Math.min(idx + 1, vals.length - 1), W, H);
    const ex = pC.x + frac * (pN.x - pC.x);
    const ey = pC.y + frac * (pN.y - pC.y);

    // Area fill
    const areaGrad = ctx.createLinearGradient(0, PAD.top, 0, PAD.top + cH);
    areaGrad.addColorStop(0, fillColor);
    areaGrad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.beginPath();
    const p0 = pt(vals, 0, W, H);
    ctx.moveTo(p0.x, PAD.top + cH);
    ctx.lineTo(p0.x, p0.y);
    for (let i = 1; i <= idx; i++) { const p = pt(vals, i, W, H); ctx.lineTo(p.x, p.y); }
    ctx.lineTo(ex, ey);
    ctx.lineTo(ex, PAD.top + cH);
    ctx.closePath();
    ctx.fillStyle = areaGrad;
    ctx.fill();

    // Line
    const lineGrad = ctx.createLinearGradient(PAD.left, 0, PAD.left + cW, 0);
    lineGrad.addColorStop(0, colorStart);
    lineGrad.addColorStop(1, colorEnd);
    ctx.beginPath();
    ctx.moveTo(p0.x, p0.y);
    for (let i = 1; i <= idx; i++) { const p = pt(vals, i, W, H); ctx.lineTo(p.x, p.y); }
    ctx.lineTo(ex, ey);
    ctx.strokeStyle = lineGrad;
    ctx.lineWidth = 2.5;
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    ctx.stroke();

    // Dots
    for (let i = 0; i <= idx; i++) {
      const p = pt(vals, i, W, H);
      ctx.beginPath(); ctx.arc(p.x, p.y, 3.5, 0, Math.PI * 2);
      ctx.fillStyle = colorStart; ctx.fill();
      ctx.strokeStyle = '#0d1117'; ctx.lineWidth = 1.5; ctx.stroke();
    }
    // Leading dot
    ctx.beginPath(); ctx.arc(ex, ey, 5, 0, Math.PI * 2);
    ctx.fillStyle = dotColor; ctx.fill();
    ctx.strokeStyle = '#0d1117'; ctx.lineWidth = 2; ctx.stroke();

    // Value label
    if (showLabel) {
      const curVal = Math.round(vals[idx] + frac * (vals[Math.min(idx + 1, vals.length - 1)] - vals[idx]));
      ctx.fillStyle = dotColor;
      ctx.font = 'bold 11px Inter, ui-sans-serif, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(curVal.toLocaleString('es-ES'), ex, ey - 10);
    }

    return Math.round(vals[idx] + frac * (vals[Math.min(idx + 1, vals.length - 1)] - vals[idx]));
  }

  function draw(progress: number) {
    const W = canvas.width / devicePixelRatio;
    const H = canvas.height / devicePixelRatio;
    const cW = W - PAD.left - PAD.right;
    const cH = H - PAD.top - PAD.bottom;

    ctx.clearRect(0, 0, W, H);

    // Grid
    for (let i = 0; i <= 4; i++) {
      const y = PAD.top + (i / 4) * cH;
      ctx.strokeStyle = 'rgba(255,255,255,0.06)';
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(PAD.left, y); ctx.lineTo(PAD.left + cW, y); ctx.stroke();
      const label = Math.round((MAX / 4) * (4 - i));
      ctx.fillStyle = 'rgba(255,255,255,0.30)';
      ctx.font = '11px Inter, ui-sans-serif, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(label >= 1000 ? (label / 1000).toFixed(1) + 'k' : String(label), PAD.left - 8, y + 4);
    }

    // Clicks line (debajo para que impresiones quede encima)
    const curClicks = drawLine(
      clicks, progress, W, H,
      '#10b981', '#34d399',
      'rgba(16,185,129,0.15)', '#34d399',
      true
    );

    // Impressions line (encima)
    const curImp = drawLine(
      impressions, progress, W, H,
      '#8b5cf6', '#06b6d4',
      'rgba(139,92,246,0.20)', '#06b6d4',
      true
    );

    // X labels
    ctx.fillStyle = 'rgba(255,255,255,0.40)';
    ctx.font = '11px Inter, ui-sans-serif, sans-serif';
    ctx.textAlign = 'center';
    months.forEach((m, i) => {
      const p = pt(impressions, i, W, H);
      ctx.fillText(m, p.x, PAD.top + cH + 18);
    });

    // Leyenda
    const lx = PAD.left;
    const ly = 14;
    ctx.font = '11px Inter, ui-sans-serif, sans-serif';
    ctx.textAlign = 'left';

    ctx.beginPath(); ctx.arc(lx + 6, ly, 5, 0, Math.PI * 2);
    ctx.fillStyle = '#8b5cf6'; ctx.fill();
    ctx.fillStyle = 'rgba(255,255,255,0.65)';
    ctx.fillText('Impresiones', lx + 14, ly + 4);

    ctx.beginPath(); ctx.arc(lx + 110, ly, 5, 0, Math.PI * 2);
    ctx.fillStyle = '#10b981'; ctx.fill();
    ctx.fillStyle = 'rgba(255,255,255,0.65)';
    ctx.fillText('Clics', lx + 118, ly + 4);

    // Header label
    if (totalLabel) {
      totalLabel.textContent =
        curImp.toLocaleString('es-ES') + ' imp · ' +
        curClicks.toLocaleString('es-ES') + ' clics';
    }
  }

  let startTime: number | null = null;
  let animating = false;

  function animate(ts: number) {
    if (!startTime) startTime = ts;
    const p = easeOut(Math.min((ts - startTime) / DURATION, 1));
    draw(p);
    if (p < 1) requestAnimationFrame(animate);
    else animating = false;
  }

  function start() {
    if (animating) return;
    animating = true;
    startTime = null;
    resize();
    requestAnimationFrame(animate);
  }

  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) { start(); observer.disconnect(); }
  }, { threshold: 0.3 });
  observer.observe(canvas);
</script>

