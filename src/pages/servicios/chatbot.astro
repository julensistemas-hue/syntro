<script>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('demo-chat-input') as HTMLInputElement;
    const sendBtn = document.getElementById('demo-chat-send');
    const container = document.getElementById('chat-container') as HTMLDivElement;

    const responses: Record<string, { text: string; panel: string }> = {
      factura: {
        text: '🔍 He encontrado tu información:\n\n👤 María García López\n📧 maria.garcia@email.com\n\n📄 Última factura:\n• Nº: FAC-2024-03456\n• Fecha: 15/01/2025\n• Importe: 899,99€\n• Producto: Portátil HP Pavilion 15\n\n✅ Te he enviado la factura por email.',
        panel: 'factura',
      },
      producto: {
        text: '💻 HP 15-dy — Especificaciones:\n\n✅ Intel Core i5-1235U (12ª Gen)\n✅ RAM: 16GB DDR4\n✅ SSD 512GB NVMe ← sí, tiene SSD\n✅ Pantalla: 15.6" Full HD\n✅ Batería: hasta 8h\n\n💰 699,99€ · Stock: disponible\n📦 Envío 24-48h',
        panel: 'producto',
      },
      pedido: {
        text: '📦 Pedido #TS-2845:\n\n✅ Confirmado: 20/01/2025\n✅ Preparado: 20/01/2025\n✅ Enviado: 21/01/2025\n🚚 En reparto — llega mañana antes de las 14:00h\n\n📍 Calle Mayor 123, 2ºB · Madrid\n👤 Transportista: SEUR\n🔗 Tracking: ES1234567890YZ',
        panel: 'pedido',
      },
      default: {
        text: 'Entiendo tu consulta. Puedo ayudarte con:\n\n📄 Facturas (dime tu DNI)\n💻 Especificaciones de productos\n📦 Estado de pedidos\n🔄 Devoluciones y garantías\n\n¿Sobre qué te ayudo?',
        panel: '',
      },
    };

    function showPanel(key: string) {
      if (!key) return;
      ['default','factura','producto','pedido'].forEach(id => {
        const el = document.getElementById('info-' + id);
        if (el) el.style.display = id === key ? 'block' : 'none';
      });
    }

    function getResponse(msg: string): { text: string; panel: string } {
      const m = msg.toLowerCase();
      if (m.includes('factura') || m.includes('dni') || m.includes('12345678')) return responses.factura;
      if (m.includes('portátil') || m.includes('portatil') || m.includes('hp') || m.includes('ssd')) return responses.producto;
      if (m.includes('pedido') || m.includes('ts-2845') || m.includes('envío') || m.includes('dónde')) return responses.pedido;
      return responses.default;
    }

    function addMsg(text: string, isUser: boolean) {
      const wrap = document.createElement('div');
      wrap.style.cssText = 'display:flex;align-items:flex-start;gap:8px;' + (isUser ? 'flex-direction:row-reverse;' : '');

      const avatar = document.createElement('div');
      avatar.style.cssText = 'width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;flex-shrink:0;';
      if (isUser) {
        avatar.style.background = 'rgba(255,255,255,0.15)';
        avatar.style.color = '#fff';
        avatar.textContent = 'TÚ';
      } else {
        avatar.style.background = 'linear-gradient(135deg,#2563eb,#0ea5e9)';
        avatar.style.color = '#fff';
        avatar.textContent = 'AI';
      }

      const bubble = document.createElement('div');
      bubble.style.cssText = 'max-width:82%;padding:10px 14px;border-radius:' + (isUser ? '16px 16px 4px 16px' : '16px 16px 16px 4px') + ';font-size:0.8rem;line-height:1.55;white-space:pre-wrap;';
      if (isUser) {
        bubble.style.background = 'rgba(255,255,255,0.12)';
        bubble.style.color = '#e2e8f0';
      } else {
        bubble.style.background = 'linear-gradient(135deg,rgba(37,99,235,0.8),rgba(14,165,233,0.8))';
        bubble.style.color = '#fff';
      }
      bubble.textContent = text;

      wrap.appendChild(avatar);
      wrap.appendChild(bubble);
      container.appendChild(wrap);
      container.scrollTop = container.scrollHeight;
    }

    function addTyping() {
      const wrap = document.createElement('div');
      wrap.id = 'typing';
      wrap.style.cssText = 'display:flex;align-items:flex-start;gap:8px;';
      wrap.innerHTML = '<div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#0ea5e9);display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;color:#fff;flex-shrink:0;">AI</div><div style="background:linear-gradient(135deg,rgba(37,99,235,0.8),rgba(14,165,233,0.8));border-radius:16px 16px 16px 4px;padding:10px 14px;"><span style="display:inline-flex;gap:3px;"><span style="width:6px;height:6px;background:rgba(255,255,255,0.8);border-radius:50%;display:inline-block;" class="animate-bounce"></span><span style="width:6px;height:6px;background:rgba(255,255,255,0.8);border-radius:50%;display:inline-block;animation-delay:0.1s;" class="animate-bounce"></span><span style="width:6px;height:6px;background:rgba(255,255,255,0.8);border-radius:50%;display:inline-block;animation-delay:0.2s;" class="animate-bounce"></span></span></div>';
      container.appendChild(wrap);
      container.scrollTop = container.scrollHeight;
    }

    let sending = false;

    function send(msg: string) {
      if (sending) return;
      sending = true;
      const qb = document.getElementById('quick-btns');
      if (qb) qb.remove(); // eliminar del DOM para que no ocupe espacio
      addMsg(msg, true);
      if (input) input.value = '';
      addTyping();
      setTimeout(() => {
        document.getElementById('typing')?.remove();
        const r = getResponse(msg);
        addMsg(r.text, false);
        if (r.panel) showPanel(r.panel); // solo actualiza si hay panel concreto
        sending = false;
        input?.focus();
      }, 900 + Math.random() * 600);
    }

    sendBtn?.addEventListener('click', () => { const v = input?.value.trim(); if (v) send(v); });
    input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { const v = input.value.trim(); if (v) send(v); } });
    document.querySelectorAll('.quick-question').forEach(btn => {
      btn.addEventListener('click', () => { const t = btn.textContent?.trim().replace(/^[^\s]+\s/, ''); if (t) send(t); });
    });
  });
</script>
