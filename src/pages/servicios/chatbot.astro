            <span style="color:#cbd5e1;font-size:0.82rem;line-height:1.4;">"${q}"</span>
          </div>
        `).join('');
        panel.style.opacity = '1';
      }, 150);
    }

    function selectSector(key: string) {
      document.querySelectorAll<HTMLElement>('.sector-btn').forEach(btn => {
        const s = btn.getAttribute('data-sector')!;
        const sector = SECTORS[s];
        if (s === key) {
          btn.style.background = `rgba(${hexToComponents(sector.color)},0.15)`;
          btn.style.borderColor = sector.color;
          const tag = btn.querySelector('div > div:last-child') as HTMLElement;
          if (tag) tag.style.color = sector.color;
        } else {
          btn.style.background = 'rgba(255,255,255,0.04)';
          btn.style.borderColor = 'rgba(255,255,255,0.08)';
          const tag = btn.querySelector('div > div:last-child') as HTMLElement;
          if (tag) tag.style.color = '#64748b';
        }
      });
      renderQuestions(key);
    }

    document.querySelectorAll<HTMLElement>('.sector-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = btn.getAttribute('data-sector');
        if (s) selectSector(s);
      });
    });

    selectSector('ecommerce');
  })();
  </script>


