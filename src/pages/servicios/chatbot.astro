---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Chatbot Inteligente con IA para Empresas — Atención al Cliente 24/7 | AI Security";
const description = "Chatbot empresarial con IA que responde preguntas, consulta pedidos y facturas en tiempo real, y escala a humanos cuando es necesario. Integración con CRM, ERP y WhatsApp. Demo interactiva disponible.";
const canonical = "https://aisecurity.es/servicios/chatbot";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Schema JSON-LD — Service + FAQ para GEO -->
  <script type="application/ld+json" is:inline>
  [
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Chatbot Inteligente con IA",
      "alternateName": "Asistente virtual para atención al cliente empresarial",
      "description": "Chatbot empresarial con inteligencia artificial que atiende consultas 24/7, consulta bases de datos en tiempo real (pedidos, facturas, stock), se integra con CRM y ERP, y escala automáticamente a un agente humano cuando el caso lo requiere.",
      "provider": {
        "@type": "Organization",
        "name": "AI Security",
        "url": "https://aisecurity.es",
        "areaServed": "ES"
      },
      "serviceType": "Automatización de atención al cliente con IA conversacional",
      "areaServed": "España",
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://aisecurity.es/servicios/chatbot",
        "availableLanguage": ["Spanish", "Catalan", "English", "French", "German", "Portuguese"]
      },
      "offers": [
        {
          "@type": "Offer",
          "name": "Plan Básico — Chatbot con base de conocimiento",
          "description": "Chatbot entrenado con la información de tu empresa: preguntas frecuentes, horarios, precios, políticas y servicios. Responde en tiempo real sin acceder a sistemas externos.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Medio — Chatbot conectado al CRM/ERP",
          "description": "Todo lo del básico más acceso en tiempo real a tus sistemas: consulta pedidos, facturas, stock e historial del cliente. El chatbot responde con datos reales de tu base de datos.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Avanzado — Chatbot multicanal con escalado inteligente",
          "description": "Operación completa en web, WhatsApp, Telegram y más canales. Análisis de sentimiento, escalado automático a agente humano, generación de tickets y analítica avanzada.",
          "availability": "https://schema.org/InStock"
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué puede hacer un chatbot con IA para empresas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un chatbot empresarial con IA puede responder preguntas frecuentes, consultar el estado de pedidos, enviar facturas, informar del stock disponible, gestionar devoluciones, agendar citas y escalar al agente humano correcto cuando el caso lo requiere. A diferencia de un chatbot con respuestas predefinidas, entiende el lenguaje natural y accede a los datos de tus sistemas en tiempo real para dar respuestas precisas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo se integra un chatbot con IA con el CRM o ERP de la empresa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La integración se realiza mediante API REST. El chatbot puede conectarse con los principales CRM (Salesforce, HubSpot, Zoho, Dynamics) y ERP (SAP, Odoo, Holded, Sage) para consultar y actualizar datos en tiempo real durante la conversación. También puede integrarse con bases de datos propias, Google Sheets o cualquier sistema que tenga API disponible."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué porcentaje de consultas resuelve un chatbot sin intervención humana?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En implementaciones bien configuradas con acceso a datos en tiempo real, un chatbot empresarial resuelve entre el 70% y el 85% de las consultas de forma autónoma. Las consultas repetitivas como estado de pedidos, facturas, horarios o precios tienen tasas de resolución superiores al 90%. El 15-30% restante —reclamaciones complejas, negociaciones o casos fuera del ámbito— se deriva automáticamente a un agente humano."
          }
        },
        {
          "@type": "Question",
          "name": "¿En qué canales puede desplegarse un chatbot empresarial?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un chatbot con IA puede desplegarse simultáneamente en el widget de la web, WhatsApp Business, Telegram, Facebook Messenger, Instagram Direct y correo electrónico. Todas las conversaciones se unifican en un mismo panel de gestión, independientemente del canal por el que contacte el cliente."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tarda en implementarse un chatbot con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El plan básico (sin integración con sistemas externos) puede estar activo en 7-10 días hábiles. El plan medio, con acceso a CRM o ERP mediante API, requiere 3-4 semanas. El plan avanzado con multicanal, escalado inteligente y analítica avanzada se implementa en 5-6 semanas. El plazo depende principalmente de la complejidad y documentación disponible de los sistemas a integrar."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo sabe el chatbot cuándo derivar a un agente humano?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El chatbot detecta automáticamente situaciones que requieren intervención humana: cuando el cliente expresa frustración o urgencia elevada (análisis de sentimiento), cuando la consulta está fuera del ámbito configurado, cuando el cliente lo solicita explícitamente, o cuando se supera un número de intentos fallidos. En ese momento deriva la conversación al agente disponible con un resumen del contexto, evitando que el cliente tenga que repetir todo."
          }
        }
      ]
    }
  ]
  </script>


  <!-- ══════════════════════════════════════════════
       HERO + DEMO
  ══════════════════════════════════════════════ -->
  <section style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 50%, #0a0d1a 100%); padding: 80px 0 60px; position: relative; overflow: hidden;">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, #2563eb 0%, transparent 50%), radial-gradient(circle at 80% 70%, #0ea5e9 0%, transparent 50%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="text-center mb-10">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight" style="color: #fff;">
          Atención al cliente con IA<br/>
          <span style="background: linear-gradient(90deg, #60a5fa, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">que conoce tu negocio</span>
        </h1>
        <p class="text-xl max-w-3xl mx-auto" style="color: #94a3b8; line-height: 1.7;">
          Responde preguntas, consulta <strong style="color: #e2e8f0;">pedidos, facturas y stock en tiempo real</strong>,
          y deriva a tu equipo solo cuando realmente lo necesitan. Las 24 horas, los 7 días de la semana.
        </p>
      </div>

      <!-- DEMO INTERACTIVA -->
      <div id="demo" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1.5rem; overflow: hidden;">

        <!-- Barra terminal -->
        <div style="background: rgba(0,0,0,0.4); padding: 14px 24px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="display: flex; gap: 6px;">
              <div style="width:12px;height:12px;border-radius:50%;background:#ef4444;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#eab308;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#22c55e;"></div>
            </div>
            <span style="color: #64748b; font-size: 0.875rem; font-family: monospace;">Chatbot IA — Demo interactiva</span>
          </div>
          <div style="display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: #22c55e;">
            <span style="width:8px;height:8px;background:#22c55e;border-radius:50%;display:inline-block;" class="animate-pulse"></span>
            En línea 24/7
          </div>
        </div>

        <!-- Contenido demo: chat + panel info -->
        <div style="background: linear-gradient(135deg, #1d4ed8 0%, #0369a1 100%); padding: 2rem;">
          <div class="grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto items-start">

            <!-- Chat Mockup -->
            <div style="background: linear-gradient(to bottom, #0f172a, #1e293b); border-radius: 1.5rem; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.08);">

              <!-- Chat header -->
              <div style="background: rgba(0,0,0,0.4); padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:space-between;">
                <div style="display:flex;align-items:center;gap:10px;">
                  <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#0ea5e9);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.8rem;color:#fff;">AI</div>
                  <div>
                    <div style="color:#fff;font-weight:600;font-size:0.875rem;">Asistente TechStore</div>
                    <div style="color:#22c55e;font-size:0.7rem;display:flex;align-items:center;gap:4px;">
                      <span style="width:5px;height:5px;background:#22c55e;border-radius:50%;display:inline-block;" class="animate-pulse"></span> Online
                    </div>
                  </div>
                </div>
                <div style="color:#64748b;font-size:0.75rem;">Chat de soporte</div>
              </div>

              <!-- Mensajes -->
              <div id="chat-container" style="padding:20px;min-height:380px;max-height:420px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;">
                <!-- Bienvenida -->
                <div style="display:flex;align-items:flex-start;gap:8px;">
                  <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#0ea5e9);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;color:#fff;flex-shrink:0;">AI</div>
                  <div style="background:linear-gradient(135deg,rgba(37,99,235,0.8),rgba(14,165,233,0.8));color:#fff;padding:10px 14px;border-radius:16px 16px 16px 4px;font-size:0.82rem;line-height:1.5;max-width:85%;">
                    ¡Hola! 👋 Soy el asistente de TechStore. Puedo consultar pedidos, facturas y productos en tiempo real.<br/><br/>
                    <span style="opacity:0.85;">Prueba alguna de estas consultas:</span>
                  </div>
                </div>
                <!-- Botones rápidos -->
                <div id="quick-btns" style="display:flex;flex-direction:column;gap:6px;padding-left:36px;">
                  <button class="quick-question" style="text-align:left;padding:8px 14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);border-radius:10px;color:#e2e8f0;font-size:0.8rem;cursor:pointer;transition:all 0.15s;">
                    📄 Necesito mi factura, mi DNI es 12345678A
                  </button>
                  <button class="quick-question" style="text-align:left;padding:8px 14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);border-radius:10px;color:#e2e8f0;font-size:0.8rem;cursor:pointer;transition:all 0.15s;">
                    💻 ¿El portátil HP 15-dy tiene SSD?
                  </button>
                  <button class="quick-question" style="text-align:left;padding:8px 14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);border-radius:10px;color:#e2e8f0;font-size:0.8rem;cursor:pointer;transition:all 0.15s;">
                    📦 ¿Dónde está mi pedido #TS-2845?
                  </button>
                </div>
              </div>

              <!-- Input -->
              <div style="padding:14px 20px;border-top:1px solid rgba(255,255,255,0.06);display:flex;gap:8px;">
                <input id="demo-chat-input" type="text" placeholder="Escribe tu consulta..."
                  style="flex:1;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:10px;padding:10px 14px;color:#fff;font-size:0.82rem;outline:none;" />
                <button id="demo-chat-send"
                  style="padding:10px 18px;background:linear-gradient(135deg,#2563eb,#0ea5e9);color:#fff;font-weight:600;font-size:0.8rem;border-radius:10px;border:none;cursor:pointer;">
                  Enviar
                </button>
              </div>
            </div>

            <!-- Panel info -->
            <div style="background:rgba(255,255,255,0.97);border-radius:1.25rem;padding:28px;box-shadow:0 25px 50px -12px rgba(0,0,0,0.4);">
              <h3 style="color:#1e3a5f;font-size:1.1rem;font-weight:700;margin:0 0 16px;display:flex;align-items:center;gap:8px;">
                <svg width="18" height="18" fill="#2563eb" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
                Qué acaba de pasar en el chat
              </h3>
              <div id="info-default" style="display:block;">
                <p style="color:#475569;font-size:0.82rem;line-height:1.6;margin:0 0 16px;">
                  El chatbot no solo responde preguntas genéricas — consulta tu base de datos en tiempo real para dar respuestas exactas con los datos del cliente.
                </p>
                <div style="display:flex;flex-direction:column;gap:8px;">
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:#eff6ff;border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">🔍</span>
                    <div style="font-size:0.78rem;color:#1e40af;line-height:1.4;"><strong>Consulta en tiempo real</strong> — Accede a CRM, ERP y bases de datos mientras el cliente escribe</div>
                  </div>
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:#f0fdf4;border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">⚡</span>
                    <div style="font-size:0.78rem;color:#166534;line-height:1.4;"><strong>Respuesta en &lt;2 segundos</strong> — Sin esperas, sin formularios, sin menús de teclado</div>
                  </div>
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:#fef3c7;border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">🧠</span>
                    <div style="font-size:0.78rem;color:#92400e;line-height:1.4;"><strong>Contexto acumulado</strong> — Recuerda todo lo dicho en la conversación, sin que el cliente repita</div>
                  </div>
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:#fdf4ff;border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">🌍</span>
                    <div style="font-size:0.78rem;color:#6b21a8;line-height:1.4;"><strong>Multiidioma automático</strong> — Detecta el idioma del cliente y responde en español, catalán, inglés u otros</div>
                  </div>
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:#fff1f2;border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">👤</span>
                    <div style="font-size:0.78rem;color:#9f1239;line-height:1.4;"><strong>Escalado con contexto</strong> — Si deriva a un agente, le pasa toda la conversación para que no empiece de cero</div>
                  </div>
                </div>
              </div>
              <div id="info-factura" style="display:none;">
                <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:14px;margin-bottom:12px;">
                  <div style="font-size:0.7rem;font-weight:700;color:#2563eb;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">🔍 Consulta ejecutada en CRM</div>
                  <div style="font-size:0.78rem;color:#1e40af;font-family:monospace;line-height:1.6;">DNI: 12345678A → Cliente encontrado<br/>Última factura: FAC-2024-03456<br/>Importe: 899,99€ · Estado: Pagada</div>
                </div>
                <p style="color:#475569;font-size:0.8rem;line-height:1.5;margin:0;">El chatbot identificó al cliente por DNI, consultó su historial en el CRM y envió la factura automáticamente. Sin intervención humana.</p>
              </div>
              <div id="info-producto" style="display:none;">
                <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:14px;margin-bottom:12px;">
                  <div style="font-size:0.7rem;font-weight:700;color:#16a34a;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">📦 Consulta ejecutada en ERP</div>
                  <div style="font-size:0.78rem;color:#166534;font-family:monospace;line-height:1.6;">SKU: HP-15DY-I5 → Stock: 8 unidades<br/>Precio: 699,99€ · SSD: 512GB NVMe ✓<br/>Envío 24-48h disponible</div>
                </div>
                <p style="color:#475569;font-size:0.8rem;line-height:1.5;margin:0;">Consultó el catálogo en tiempo real: especificaciones técnicas, precio actual y stock disponible. Datos siempre actualizados.</p>
              </div>
              <div id="info-pedido" style="display:none;">
                <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:14px;margin-bottom:12px;">
                  <div style="font-size:0.7rem;font-weight:700;color:#d97706;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">🚚 Consulta en plataforma logística</div>
                  <div style="font-size:0.78rem;color:#92400e;font-family:monospace;line-height:1.6;">#TS-2845 → En reparto SEUR<br/>Tracking: ES1234567890YZ<br/>Entrega estimada: mañana antes 14h</div>
                </div>
                <p style="color:#475569;font-size:0.8rem;line-height:1.5;margin:0;">Accedió a la API del operador logístico para dar el estado exacto del envío. El cliente no necesita llamar ni buscar el email de confirmación.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Nota -->
        <div style="padding: 12px 24px; background: rgba(0,0,0,0.3); border-top: 1px solid rgba(255,255,255,0.06); text-align:center;">
          <p style="color:#475569;font-size:0.8rem;margin:0;">Demo simulada con datos de ejemplo. El sistema real se entrena con la información y sistemas de tu empresa.</p>
        </div>
      </div>

      <!-- Stats + CTAs -->
      <div class="text-center mt-10">
        <div class="flex flex-wrap justify-center gap-6 mb-8">
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">24/7</div>
            <div class="text-xs mt-1" style="color: #64748b;">Sin festivos ni vacaciones</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #22d3ee;">~80%</div>
            <div class="text-xs mt-1" style="color: #64748b;">Consultas sin agente humano</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">&lt;2s</div>
            <div class="text-xs mt-1" style="color: #64748b;">Tiempo de respuesta</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #22d3ee;">-70%</div>
            <div class="text-xs mt-1" style="color: #64748b;">Tickets de soporte manuales</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/presupuesto?plan=Chatbot-IA"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold transition-all"
            style="background: linear-gradient(135deg, #2563eb, #0ea5e9); color: #ffffff;">
            Solicitar análisis gratuito →
          </a>
          <a href="#como-funciona"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold transition-all"
            style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); color: #cbd5e1;">
            ¿Cómo funciona?
          </a>
        </div>
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       TRES NIVELES
  ══════════════════════════════════════════════ -->
  <section id="como-funciona" style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 100%); padding: 80px 0; position: relative; overflow: hidden;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at 20% 50%, rgba(37,99,235,0.12), transparent 60%), radial-gradient(circle at 80% 50%, rgba(14,165,233,0.10), transparent 60%);"></div>
    <div class="relative max-w-6xl mx-auto px-6" style="z-index:1;">

      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #e2e8f0;">Tres niveles de implantación</h2>
        <p style="color: #94a3b8; font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.7;">
          Empieza respondiendo preguntas frecuentes, añade acceso a tus datos en tiempo real
          y escala a multicanal cuando el volumen lo justifique.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;align-items:start;">

        <!-- NIVEL 1 -->
        <div style="background:rgba(37,99,235,0.07);border:1px solid rgba(37,99,235,0.3);border-radius:1.25rem;padding:32px;display:flex;flex-direction:column;gap:20px;">
          <div>
            <div style="display:inline-flex;background:rgba(37,99,235,0.15);border:1px solid rgba(37,99,235,0.3);border-radius:8px;padding:4px 12px;margin-bottom:14px;">
              <span style="color:#60a5fa;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;">Nivel 1</span>
            </div>
            <h3 style="color:#fff;font-size:1.25rem;font-weight:700;margin:0 0 6px;">Básico</h3>
