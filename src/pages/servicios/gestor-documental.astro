  <script>
  (function() {
    const SECTORS: Record<string, { label: string; color: string; questions: string[] }> = {
      asesorias: {
        label: 'Despachos y asesorías',
        color: '#7c3aed',
        questions: [
          '¿Qué dice la cláusula de penalización del contrato X?',
          '¿Cuál es el plazo para recurrir una sanción?',
          'Busca jurisprudencia sobre despido improcedente en 2024',
          '¿Qué documentación pide la Agencia Tributaria para esto?',
          '¿Cuáles son los requisitos del Convenio Colectivo para horas extra?',
          '¿Qué dice nuestro modelo de contrato sobre propiedad intelectual?',
          'Encuentra la última resolución de la DGT sobre esto',
          '¿Cuánto tiempo tenemos para presentar el recurso?',
          '¿Qué incluye nuestra póliza de responsabilidad civil?',
          '¿Cuál es el procedimiento para una baja por maternidad?',
          'Busca precedentes de casos similares en nuestro archivo',
          '¿Qué dice la normativa sobre protección de datos en este caso?',
        ],
      },
      clinicas: {
        label: 'Clínicas y hospitales',
        color: '#0891b2',
        questions: [
          '¿Cuál es el protocolo de actuación en caso de anafilaxia?',
          '¿Qué dice la guía clínica sobre dosificación de X fármaco?',
          '¿Cuáles son los criterios de ingreso en UCI?',
          '¿Qué documentación necesita el paciente para este procedimiento?',
          'Encuentra el procedimiento de esterilización del instrumental',
          '¿Cuáles son las contraindicaciones de este tratamiento?',
          '¿Qué dice la normativa de gestión de residuos sanitarios?',
          'Busca el protocolo de aislamiento por COVID',
          '¿Cuánto tiempo se conservan las historias clínicas?',
          '¿Qué dice el manual de calidad sobre quejas de pacientes?',
          '¿Cuál es el proceso para notificar un efecto adverso?',
          '¿Qué incluye el consentimiento informado para esta cirugía?',
        ],
      },
      industrial: {
        label: 'Empresas industriales',
        color: '#d97706',
        questions: [
          '¿Cuál es el torque de apriete del tornillo M8 en este componente?',
          '¿Qué dice la ficha técnica del material XY?',
          '¿Cuáles son los parámetros de temperatura del proceso Z?',
          'Encuentra la instrucción de mantenimiento preventivo de la máquina 3',
          '¿Qué EPIs son obligatorios en la sección de pintura?',
          '¿Cuál es el procedimiento de parada de emergencia?',
          '¿Qué dice la certificación ISO 9001 sobre trazabilidad?',
          '¿Cuánto es la tolerancia dimensional de la pieza X?',
          'Busca el protocolo de actuación en caso de vertido',
          '¿Cuáles son los límites de exposición al ruido en planta?',
          '¿Qué dice el plan de prevención sobre trabajos en altura?',
          '¿Cuál es la lista de proveedores homologados para este material?',
        ],
      },
      consultoras: {
        label: 'Consultoras y agencias',
        color: '#059669',
        questions: [
          '¿Cómo explicamos nuestra metodología de implementación?',
          'Encuentra propuestas anteriores para clientes del sector retail',
          '¿Qué decíamos en el informe de la auditoría de X empresa?',
          '¿Cuál es nuestro modelo de contrato de servicios?',
          'Busca casos de éxito similares en nuestro archivo',
          '¿Qué incluye el onboarding de nuevos consultores?',
          '¿Cuáles son las tarifas que aplicamos por tipo de proyecto?',
          '¿Qué KPIs usamos habitualmente en proyectos de transformación?',
          'Encuentra la plantilla de acta de reunión de proyecto',
          '¿Qué dice nuestra política de confidencialidad con clientes?',
          '¿Cuál es el proceso de aprobación de propuestas económicas?',
          'Busca el checklist de cierre de proyecto',
        ],
      },
      rrhh: {
        label: 'RRHH y administración',
        color: '#db2777',
        questions: [
          '¿Cuáles son los días de vacaciones que corresponden?',
          '¿Qué dice la política de teletrabajo sobre días disponibles?',
          '¿Cuál es el proceso para solicitar una excedencia?',
          '¿Qué documentación hay que presentar para una baja médica?',
          '¿Cuál es la política de gastos de representación?',
          '¿Cómo se calcula el complemento de antigüedad?',
          '¿Qué beneficios incluye el plan de retribución flexible?',
          '¿Cuál es el protocolo de acoso laboral?',
          '¿Qué dice el convenio colectivo sobre horas extraordinarias?',
          '¿Cuáles son los criterios para la evaluación del desempeño?',
          '¿Qué formación obligatoria debe completar cada puesto?',
          '¿Cuál es el proceso de offboarding al salir de la empresa?',
        ],
      },
      publico: {
        label: 'Sector público',
        color: '#2563eb',
        questions: [
          '¿Cuáles son los requisitos de la convocatoria X?',
          '¿Qué plazos tiene este procedimiento administrativo?',
          'Encuentra la resolución sobre el expediente número X',
          '¿Qué dice la normativa autonómica sobre esta subvención?',
          '¿Cuáles son las causas de inadmisión del recurso?',
          '¿Qué documentación exige el pliego de condiciones?',
          '¿Qué dice la Ley de Contratos sobre licitaciones menores?',
          'Busca el criterio del Tribunal de Cuentas sobre esto',
          '¿Cuánto tiempo tiene la administración para resolver?',
          '¿Qué dice el reglamento interno sobre dietas y desplazamientos?',
          '¿Cuáles son los requisitos del puesto según la RPT?',
          '¿Qué protocolo se aplica en este caso de protección de datos?',
        ],
      },
    };

    function hexToComponents(hex: string): string {
      const r = parseInt(hex.slice(1,3),16);
      const g = parseInt(hex.slice(3,5),16);
      const b = parseInt(hex.slice(5,7),16);
      return `${r},${g},${b}`;
    }

    function renderQuestions(key: string) {
      const sector = SECTORS[key];
      if (!sector) return;
      const list = document.getElementById('questions-list')!;
      const title = document.getElementById('panel-title')!;
      const panel = document.getElementById('questions-panel')!;

      panel.style.opacity = '0';
      panel.style.borderColor = `rgba(${hexToComponents(sector.color)},0.3)`;
      title.textContent = `Información que encuentra en segundos — ${sector.label}`;

      setTimeout(() => {
        list.innerHTML = sector.questions.map(q => `
          <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:0.75rem;padding:10px 14px;display:flex;align-items:flex-start;gap:8px;">
            <span style="color:#a78bfa;font-size:0.75rem;flex-shrink:0;margin-top:1px;">📄</span>
            <span style="color:#cbd5e1;font-size:0.82rem;line-height:1.4;">"${q}"</span>
          </div>
        `).join('');
        panel.style.opacity = '1';
      }, 150);
    }

    function selectSector(key: string) {
      document.querySelectorAll<HTMLElement>('.sector-btn').forEach(btn => {
        const s = btn.getAttribute('data-sector')!;
        const sector = SECTORS[s];
        if (s === key) {
          btn.style.background = `rgba(${hexToComponents(sector.color)},0.15)`;
          btn.style.borderColor = sector.color;
          const tag = btn.querySelector('div > div:last-child') as HTMLElement;
          if (tag) tag.style.color = sector.color;
        } else {
          btn.style.background = 'rgba(255,255,255,0.04)';
          btn.style.borderColor = 'rgba(255,255,255,0.08)';
          const tag = btn.querySelector('div > div:last-child') as HTMLElement;
          if (tag) tag.style.color = '#64748b';
        }
      });
      renderQuestions(key);
    }

    document.querySelectorAll<HTMLElement>('.sector-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = btn.getAttribute('data-sector');
        if (s) selectSector(s);
      });
    });

    selectSector('asesorias');
  })();
  </script>


