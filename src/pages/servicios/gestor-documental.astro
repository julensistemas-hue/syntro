<script>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('doc-search-input') as HTMLInputElement;
    const btn = document.getElementById('doc-search-btn');
    const results = document.getElementById('doc-results') as HTMLDivElement;

    const docs = [
      { title: 'Política de Teletrabajo 2024', cat: 'Recursos Humanos', excerpt: 'Los empleados pueden trabajar de forma remota hasta 3 días por semana previa aprobación del supervisor directo. Se requiere disponibilidad durante horario laboral (9:00-18:00) y conexión mínima de 10 Mbps.', rel: 96, info: 'El sistema identificó la pregunta sobre teletrabajo, localizó el párrafo con las condiciones exactas y la versión vigente del documento (2024).' },
      { title: 'Manual de Procedimientos — Compras', cat: 'Administración', excerpt: 'Las solicitudes de compra superiores a 500€ requieren aprobación del departamento de Finanzas. Completar formulario FC-102 y adjuntar mínimo 3 cotizaciones de proveedores distintos.', rel: 91, info: 'Búsqueda por "procedimiento compras" localizó el manual de administración, extrayendo el párrafo sobre aprobaciones y el formulario requerido.' },
      { title: 'Política de Vacaciones y Permisos', cat: 'Recursos Humanos', excerpt: 'Los empleados tienen derecho a 22 días laborables de vacaciones anuales. Las solicitudes deben presentarse con 15 días naturales de antelación a través del portal de RRHH. Se priorizan por orden de solicitud.', rel: 94, info: 'La consulta sobre "solicitar vacaciones" encontró la política de RRHH con los requisitos concretos: días, plazo y canal de solicitud.' },
    ];

    function showLoading() {
      results.innerHTML = `<div style="text-align:center;padding:40px 0;color:rgba(255,255,255,0.5);display:flex;align-items:center;justify-content:center;gap:10px;"><svg style="animation:spin 1s linear infinite;width:20px;height:20px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle style="opacity:0.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity:0.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg><span style="font-size:0.875rem;">Buscando en 1.247 documentos...</span></div>`;
    }

    function showResults(query: string) {
      showLoading();
      const q = query.toLowerCase();
      let doc = docs[0];
      if (q.includes('vacacion') || q.includes('permiso')) doc = docs[2];
      if (q.includes('compra') || q.includes('procedimiento')) doc = docs[1];

      setTimeout(() => {
        results.innerHTML = `
          <div style="background:rgba(124,58,237,0.2);border:1px solid rgba(124,58,237,0.4);border-radius:10px;padding:10px 14px;margin-bottom:12px;font-size:0.8rem;color:#a78bfa;">
            ✓ Encontré 1 documento relevante
          </div>
          <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:12px;padding:20px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;gap:10px;">
              <div>
                <div style="color:#fff;font-weight:700;font-size:0.9rem;margin-bottom:4px;">${doc.title}</div>
                <span style="background:rgba(124,58,237,0.2);color:#a78bfa;font-size:0.7rem;font-weight:600;padding:2px 8px;border-radius:10px;">${doc.cat}</span>
              </div>
              <span style="background:#16a34a;color:#fff;font-size:0.75rem;font-weight:700;padding:4px 10px;border-radius:8px;white-space:nowrap;flex-shrink:0;">${doc.rel}% relevante</span>
            </div>
            <p style="color:#cbd5e1;font-size:0.82rem;line-height:1.6;margin:0 0 14px;padding:12px;background:rgba(255,255,255,0.04);border-radius:8px;border-left:3px solid #7c3aed;">"${doc.excerpt}"</p>
            <div style="display:flex;gap:10px;">
              <button style="font-size:0.75rem;color:#a78bfa;background:none;border:1px solid rgba(124,58,237,0.3);border-radius:6px;padding:5px 10px;cursor:pointer;">📄 Ver documento</button>
              <button style="font-size:0.75rem;color:#64748b;background:none;border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:5px 10px;cursor:pointer;">📋 Copiar extracto</button>
            </div>
          </div>`;

        // Panel info
        const infoDefault = document.getElementById('info-default');
        const infoResult = document.getElementById('info-result');
        const infoProcess = document.getElementById('info-process');
        const infoExp = document.getElementById('info-explanation');
        if (infoDefault) infoDefault.style.display = 'none';
        if (infoResult) infoResult.style.display = 'block';
        if (infoProcess) infoProcess.textContent = 'Vectorizando consulta → Buscando en 1.247 embeddings → Reranking → Extrayendo párrafo';
        if (infoExp) infoExp.textContent = doc.info;
      }, 1000);
    }

    btn?.addEventListener('click', () => { const v = input?.value.trim(); if (v) showResults(v); });
    input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { const v = input.value.trim(); if (v) showResults(v); } });
    document.querySelectorAll('.quick-search-btn').forEach(b => {
      b.addEventListener('click', () => {
        const q = b.getAttribute('data-query');
        if (q && input) { input.value = q; showResults(q); }
      });
    });
  });
</script>

