---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Gestor Documental con IA — Búsqueda Semántica en tu Documentación Interna | AI Security";
const description = "Encuentra cualquier información en tus documentos corporativos en segundos usando lenguaje natural. Busca en PDFs, Word, políticas y procedimientos. Reduce de 15 minutos a 3 segundos por consulta.";
const canonical = "https://aisecurity.es/servicios/gestor-documental";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Schema JSON-LD — Service + FAQ para GEO -->
  <script type="application/ld+json" is:inline>
  [
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Gestor Documental con IA",
      "alternateName": "Búsqueda semántica en documentación corporativa con inteligencia artificial",
      "description": "Sistema de búsqueda semántica con IA para documentación interna empresarial. Permite encontrar información en PDFs, Word, políticas y procedimientos usando lenguaje natural, reduciendo el tiempo de búsqueda de 10-15 minutos a menos de 5 segundos.",
      "provider": {
        "@type": "Organization",
        "name": "AI Security",
        "url": "https://aisecurity.es",
        "areaServed": "ES"
      },
      "serviceType": "Gestión documental con inteligencia artificial y búsqueda semántica",
      "areaServed": "España",
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://aisecurity.es/servicios/gestor-documental",
        "availableLanguage": ["Spanish", "Catalan", "English"]
      },
      "offers": [
        {
          "@type": "Offer",
          "name": "Plan Básico — Gestor documental con subida manual",
          "description": "Indexación de documentos internos subidos manualmente (PDF, Word, Excel). Búsqueda semántica con lenguaje natural, extracto exacto del párrafo relevante y fuente del documento.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Medio — Conectado a Google Drive y SharePoint",
          "description": "Sincronización automática con Google Drive, SharePoint, Notion o Confluence. Los documentos se actualizan en tiempo real sin trabajo manual del equipo.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Avanzado — Permisos, historial y analítica",
          "description": "Control de acceso por departamento o usuario, historial de consultas, detección de información desactualizada, soporte multiidioma y analítica de qué se busca más.",
          "availability": "https://schema.org/InStock"
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué es la búsqueda semántica en documentos con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La búsqueda semántica con IA entiende el significado de lo que preguntas, no solo las palabras exactas. Puedes escribir 'cuántos días de vacaciones tengo' y el sistema encontrará la respuesta aunque el documento diga 'días de descanso retribuido'. A diferencia de un buscador tradicional, extrae el párrafo exacto que responde tu pregunta y te indica en qué documento y página está."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué tipo de documentos puede indexar el gestor documental con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El sistema puede indexar PDF, Word (.doc, .docx), Excel (.xls, .xlsx), PowerPoint (.ppt, .pptx), documentos de texto plano, páginas web internas y notas de Notion o Confluence. También procesa imágenes escaneadas mediante OCR. Es compatible con documentos en español, catalán, inglés y otros idiomas europeos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo se tarda en implementar un gestor documental con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El plan básico (con subida manual de documentos) puede estar operativo en 5-7 días hábiles. El plan medio, con sincronización automática a Google Drive o SharePoint, requiere 2-3 semanas. El plan avanzado con permisos por departamento, historial y analítica se implementa en 4-5 semanas. La mayor parte del tiempo se dedica a organizar y limpiar la documentación existente."
          }
        },
        {
          "@type": "Question",
          "name": "¿Es seguro para documentos confidenciales de la empresa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. El sistema puede desplegarse en la infraestructura propia de la empresa (on-premise) o en la nube con cifrado AES-256 en reposo y en tránsito. En el plan avanzado, los permisos de acceso a documentos se replican desde los roles de Google Drive o SharePoint, por lo que cada usuario solo ve los documentos a los que ya tiene acceso en el sistema original."
          }
        },
        {
          "@type": "Question",
          "name": "¿Con cuántos documentos puede trabajar el sistema?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No hay un límite práctico. El sistema funciona igual de rápido con 100 documentos que con 50.000. La velocidad de respuesta (menos de 3 segundos) se mantiene independientemente del volumen porque la búsqueda opera sobre embeddings vectoriales precomputados, no sobre el texto completo en tiempo real."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué empresas se benefician más de un gestor documental con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Las empresas con mayor retorno son aquellas con documentación interna voluminosa y equipos que pierden tiempo buscando información: despachos de abogados y asesorías (jurisprudencia, contratos, expedientes), clínicas y hospitales (protocolos, guías clínicas), empresas industriales (manuales técnicos, fichas de producto), consultoras (metodologías, propuestas anteriores) y organismos públicos (normativa, procedimientos internos)."
          }
        }
      ]
    }
  ]
  </script>


  <!-- ══════════════════════════════════════════════
       HERO + DEMO
  ══════════════════════════════════════════════ -->
  <section style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 50%, #0a0d1a 100%); padding: 80px 0 60px; position: relative; overflow: hidden;">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, #7c3aed 0%, transparent 50%), radial-gradient(circle at 80% 70%, #2563eb 0%, transparent 50%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="text-center mb-10">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight" style="color: #fff;">
          Encuentra cualquier dato<br/>
          <span style="background: linear-gradient(90deg, #a78bfa, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">en tu documentación en segundos</span>
        </h1>
        <p class="text-xl max-w-3xl mx-auto" style="color: #94a3b8; line-height: 1.7;">
          Pregunta en lenguaje natural. La IA busca en <strong style="color: #e2e8f0;">todos tus documentos internos</strong>
          y extrae el párrafo exacto que necesitas. De 15 minutos a 3 segundos.
        </p>
      </div>

      <!-- DEMO INTERACTIVA -->
      <div id="demo" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1.5rem; overflow: hidden;">

        <!-- Barra terminal -->
        <div style="background: rgba(0,0,0,0.4); padding: 14px 24px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="display: flex; gap: 6px;">
              <div style="width:12px;height:12px;border-radius:50%;background:#ef4444;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#eab308;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#22c55e;"></div>
            </div>
            <span style="color: #64748b; font-size: 0.875rem; font-family: monospace;">Gestor Documental IA — Demo interactiva</span>
          </div>
          <div style="color: #64748b; font-size: 0.8rem; display:flex;align-items:center;gap:6px;">
            <span>📚</span> 1.247 documentos indexados
          </div>
        </div>

        <!-- Demo: search + panel -->
        <div style="background: linear-gradient(135deg, #4c1d95 0%, #1e3a8a 100%); padding: 2rem;">
          <div class="grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto items-start">

            <!-- Buscador -->
            <div style="background: linear-gradient(to bottom, #0f172a, #1e293b); border-radius: 1.5rem; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.08);">
              <div style="background:rgba(0,0,0,0.3);padding:14px 20px;border-bottom:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:space-between;">
                <span style="color:#a78bfa;font-size:0.8rem;font-weight:600;">🔍 Búsqueda semántica</span>
                <span style="color:#64748b;font-size:0.75rem;">Pregunta en lenguaje natural</span>
              </div>

              <div style="padding:20px;">
                <!-- Search bar -->
                <div style="display:flex;gap:8px;margin-bottom:16px;">
                  <input id="doc-search-input" type="text" placeholder="¿Cuál es la política de teletrabajo?"
                    style="flex:1;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);border-radius:10px;padding:12px 16px;color:#fff;font-size:0.85rem;outline:none;" />
                  <button id="doc-search-btn"
                    style="padding:10px 20px;background:linear-gradient(135deg,#7c3aed,#4f46e5);color:#fff;font-weight:600;font-size:0.8rem;border-radius:10px;border:none;cursor:pointer;white-space:nowrap;">
                    Buscar
                  </button>
                </div>

                <!-- Quick searches -->
                <div style="margin-bottom:16px;">
                  <p style="color:rgba(255,255,255,0.5);font-size:0.75rem;margin-bottom:8px;">Prueba estas búsquedas:</p>
                  <div style="display:flex;flex-wrap:wrap;gap:6px;">
                    <button class="quick-search-btn" data-query="¿Cuál es la política de teletrabajo?"
                      style="padding:6px 12px;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.35);border-radius:20px;color:#a78bfa;font-size:0.75rem;cursor:pointer;">
                      📱 Política de teletrabajo
                    </button>
                    <button class="quick-search-btn" data-query="¿Cuáles son los requisitos para solicitar vacaciones?"
                      style="padding:6px 12px;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.35);border-radius:20px;color:#a78bfa;font-size:0.75rem;cursor:pointer;">
                      🏖️ Requisitos vacaciones
                    </button>
                    <button class="quick-search-btn" data-query="¿Cómo funciona el procedimiento de compras?"
                      style="padding:6px 12px;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.35);border-radius:20px;color:#a78bfa;font-size:0.75rem;cursor:pointer;">
                      🛒 Procedimiento de compras
                    </button>
                  </div>
                </div>

                <!-- Results -->
                <div id="doc-results" style="min-height:300px;">
                  <div style="text-align:center;padding:48px 0;color:rgba(255,255,255,0.4);">
                    <div style="font-size:2.5rem;margin-bottom:12px;">🔍</div>
                    <p style="font-size:0.875rem;">Haz clic en una búsqueda o escribe tu pregunta</p>
                    <p style="font-size:0.75rem;margin-top:6px;color:rgba(255,255,255,0.25);">El sistema buscará en todos tus documentos</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Panel info -->
            <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:28px;box-shadow:0 25px 50px -12px rgba(0,0,0,0.4);">
              <h3 style="color:#e2e8f0;font-size:1rem;font-weight:700;margin:0 0 16px;display:flex;align-items:center;gap:8px;">
                <svg width="18" height="18" fill="#a78bfa" viewBox="0 0 20 20"><path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/></svg>
                Qué hace el sistema al buscar
              </h3>
              <div id="info-default" style="display:block;">
                <!-- Antes / Ahora -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;">
                  <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);border-radius:10px;padding:14px;">
                    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">
                      <span>😓</span>
                      <span style="font-size:0.75rem;font-weight:700;color:#f87171;">Antes</span>
                    </div>
                    <p style="font-size:0.78rem;color:#fca5a5;line-height:1.4;margin:0;">10-15 min navegando carpetas y versiones obsoletas</p>
                  </div>
                  <div style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);border-radius:10px;padding:14px;">
                    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">
                      <span>⚡</span>
                      <span style="font-size:0.75rem;font-weight:700;color:#4ade80;">Ahora</span>
                    </div>
                    <p style="font-size:0.78rem;color:#86efac;line-height:1.4;margin:0;">Extracto exacto en menos de 3 segundos, con fuente</p>
                  </div>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;">
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.2);border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">🧠</span>
                    <div style="font-size:0.78rem;color:#c4b5fd;line-height:1.4;"><strong style="color:#e2e8f0;">Búsqueda por significado</strong> — Entiende lo que preguntas aunque uses palabras distintas al documento</div>
                  </div>
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:rgba(37,99,235,0.1);border:1px solid rgba(37,99,235,0.2);border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">📌</span>
                    <div style="font-size:0.78rem;color:#93c5fd;line-height:1.4;"><strong style="color:#e2e8f0;">Extracto exacto</strong> — Devuelve el párrafo concreto, no el documento completo</div>
                  </div>
                  <div style="display:flex;align-items:flex-start;gap:8px;padding:10px;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:8px;">
                    <span style="font-size:1rem;flex-shrink:0;">📂</span>
                    <div style="font-size:0.78rem;color:#86efac;line-height:1.4;"><strong style="color:#e2e8f0;">Fuente verificable</strong> — Indica qué documento, versión y página contiene la respuesta</div>
                  </div>
                </div>
              </div>
              <div id="info-result" style="display:none;">
                <div style="background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.3);border-radius:10px;padding:14px;margin-bottom:12px;">
                  <div style="font-size:0.7rem;font-weight:700;color:#a78bfa;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">⚡ Proceso ejecutado en &lt;2s</div>
                  <div style="font-size:0.78rem;color:#c4b5fd;font-family:monospace;line-height:1.6;" id="info-process">Vectorizando consulta → Buscando en 1.247 embeddings → Reranking → Extrayendo párrafo</div>
                </div>
                <p id="info-explanation" style="color:#94a3b8;font-size:0.8rem;line-height:1.5;margin:0;"></p>
              </div>
            </div>

          </div>
        </div>

        <!-- Nota -->
        <div style="padding: 12px 24px; background: rgba(0,0,0,0.3); border-top: 1px solid rgba(255,255,255,0.06); text-align:center;">
          <p style="color:#475569;font-size:0.8rem;margin:0;">Demo con documentación de ejemplo (empresa de consultoría, 50 empleados). El sistema real se entrena con tus propios documentos.</p>
        </div>
      </div>

      <!-- Stats + CTAs -->
      <div class="text-center mt-10">
        <div class="flex flex-wrap justify-center gap-6 mb-8">
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #a78bfa;">-95%</div>
            <div class="text-xs mt-1" style="color: #64748b;">Tiempo de búsqueda</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">&lt;3s</div>
            <div class="text-xs mt-1" style="color: #64748b;">Respuesta en cualquier doc</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #a78bfa;">-15h</div>
            <div class="text-xs mt-1" style="color: #64748b;">Horas/mes por equipo</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">∞</div>
            <div class="text-xs mt-1" style="color: #64748b;">Documentos indexables</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/presupuesto?plan=Gestor-Documental-IA"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold transition-all"
            style="background: linear-gradient(135deg, #7c3aed, #4f46e5); color: #ffffff;">
            Solicitar análisis gratuito →
          </a>
          <a href="#como-funciona"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold transition-all"
            style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); color: #cbd5e1;">
            ¿Cómo funciona?
          </a>
        </div>
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       TRES NIVELES
  ══════════════════════════════════════════════ -->
  <section id="como-funciona" style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 100%); padding: 80px 0; position: relative; overflow: hidden;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at 20% 50%, rgba(124,58,237,0.12), transparent 60%), radial-gradient(circle at 80% 50%, rgba(37,99,235,0.10), transparent 60%);"></div>
    <div class="relative max-w-6xl mx-auto px-6" style="z-index:1;">

      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #e2e8f0;">Tres niveles de implantación</h2>
        <p style="color: #94a3b8; font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.7;">
          Empieza indexando tus documentos más críticos, conecta luego tu almacenamiento en la nube
          y añade control de permisos cuando el equipo crezca.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;align-items:start;">

        <!-- NIVEL 1 -->
        <div style="background:rgba(124,58,237,0.07);border:1px solid rgba(124,58,237,0.3);border-radius:1.25rem;padding:32px;display:flex;flex-direction:column;gap:20px;">
          <div>
            <div style="display:inline-flex;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.3);border-radius:8px;padding:4px 12px;margin-bottom:14px;">
              <span style="color:#a78bfa;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;">Nivel 1</span>
            </div>
            <h3 style="color:#fff;font-size:1.25rem;font-weight:700;margin:0 0 6px;">Básico</h3>
            <p style="color:#a78bfa;font-size:0.875rem;font-weight:500;margin:0 0 12px;">Subida manual + búsqueda semántica</p>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;margin:0;">
              Subes tus documentos (PDF, Word, Excel) y el sistema los indexa automáticamente. El equipo puede buscar en lenguaje natural desde ese mismo día.
            </p>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:20px;">
            <p style="color:#64748b;font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 10px;">Incluye</p>
            <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;">
              <li style="color:#94a3b8;font-size:0.8rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#a78bfa;flex-shrink:0;font-weight:700;">✓</span>Indexación de PDF, Word, Excel, PowerPoint</li>
              <li style="color:#94a3b8;font-size:0.8rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#a78bfa;flex-shrink:0;font-weight:700;">✓</span>Búsqueda en lenguaje natural</li>
              <li style="color:#94a3b8;font-size:0.8rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#a78bfa;flex-shrink:0;font-weight:700;">✓</span>Extracto del párrafo exacto + fuente</li>
              <li style="color:#94a3b8;font-size:0.8rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#a78bfa;flex-shrink:0;font-weight:700;">✓</span>OCR para documentos escaneados</li>
              <li style="color:#94a3b8;font-size:0.8rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#a78bfa;flex-shrink:0;font-weight:700;">✓</span>Acceso web para todos los usuarios</li>
              <li style="color:#94a3b8;font-size:0.8rem;display:flex;align-items:flex-start;gap:8px;"><span style="color:#a78bfa;flex-shrink:0;font-weight:700;">✓</span>Puntuación de relevancia por resultado</li>
            </ul>
          </div>
          <div style="background:rgba(124,58,237,0.1);border-radius:10px;padding:14px;">
            <p style="color:#c4b5fd;font-size:0.8rem;line-height:1.5;margin:0;">
              <strong style="color:#fff;">Ideal para:</strong> Equipos que pierden tiempo buscando políticas, procedimientos o manuales internos y quieren resultados en días, no semanas.
