    function renderQuestions(key: string) {
      const sector = SECTORS[key];
      if (!sector) return;

      const list = document.getElementById('questions-list')!;
      const title = document.getElementById('panel-title')!;
      const panel = document.getElementById('questions-panel')!;

      panel.style.opacity = '0';
      panel.style.borderColor = `rgba(${hexToComponents(sector.color)},0.3)`;
      title.textContent = `Preguntas que resuelve sin agente humano — ${sector.label}`;

      setTimeout(() => {
        list.innerHTML = sector.questions.map(q => `
          <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:0.75rem;padding:10px 14px;display:flex;align-items:flex-start;gap:8px;">
