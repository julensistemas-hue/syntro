---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Recepcionista Virtual con IA para Empresas - Atención Telefónica 24/7 | AI Security";
const description = "Recepcionista virtual con IA y voz natural en español. Atiende llamadas 24/7, agenda citas, responde preguntas frecuentes y deriva a humanos cuando es necesario. Tres niveles: básico, integrado con CRM y avanzado con tickets y WhatsApp.";
const canonical = "https://aisecurity.es/servicios/atencion-llamadas";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Schema JSON-LD — Service + FAQ para GEO (Google AI Overviews, ChatGPT, Perplexity) -->
  <script type="application/ld+json" is:inline>
  [
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Recepcionista Virtual con IA",
      "alternateName": "Atención de Llamadas con Inteligencia Artificial",
      "description": "Sistema de atención telefónica automatizada con IA y voz natural en español. Gestiona llamadas entrantes 24/7, agenda y cancela citas, responde preguntas frecuentes e integra con CRM, ERP y WhatsApp Business.",
      "provider": {
        "@type": "Organization",
        "name": "AI Security",
        "url": "https://aisecurity.es",
        "areaServed": "ES"
      },
      "serviceType": "Automatización de atención telefónica con IA",
      "areaServed": "España",
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://aisecurity.es/servicios/atencion-llamadas",
        "availableLanguage": ["Spanish", "Catalan", "English", "French", "German", "Portuguese"]
      },
      "offers": [
        {
          "@type": "Offer",
          "name": "Plan Básico — Recepcionista IA",
          "description": "Atención automática 24/7 con voz natural, base de conocimiento personalizada, recogida de incidencias y email automático al responsable tras cada llamada.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Medio — Recepcionista IA con CRM",
          "description": "Todo lo del básico más integración bidireccional con CRM/ERP, respuestas personalizadas por cliente, registro automático en expediente y análisis de urgencia.",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Plan Avanzado — Recepcionista IA multicanal",
          "description": "Operación completa: tickets automáticos, envío de documentos por email, WhatsApp Business, derivación al gremio correcto y agentes especializados por tipo de consulta.",
          "availability": "https://schema.org/InStock"
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué es un recepcionista virtual con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un recepcionista virtual con IA es un sistema de atención telefónica automatizada que usa inteligencia artificial para atender llamadas con voz natural, entender el lenguaje conversacional, responder preguntas frecuentes, gestionar citas y derivar los casos complejos a un agente humano. A diferencia de un IVR clásico con menús de teclado, entiende el lenguaje natural y mantiene una conversación fluida."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta un sistema de atención de llamadas con IA para empresas en España?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "AI Security ofrece tres niveles de servicio de atención de llamadas con IA: un plan básico (atención automática con derivación por email), un plan medio (conectado al CRM con respuestas personalizadas) y un plan avanzado (operación completa con tickets, WhatsApp y multi-agente). Los plazos de implantación van de 7 días para el básico hasta 5-6 semanas para el avanzado. Solicita un análisis gratuito para obtener el coste según tu volumen de llamadas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Puede una IA atender llamadas en español de forma natural?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Los sistemas actuales de IA conversacional con síntesis de voz neural producen voz natural en español con entonación y pronunciación correctas. El sistema entiende interrupciones, reformulaciones e imprecisiones del hablante, y puede detectar automáticamente el idioma del interlocutor (español, catalán, inglés, francés, alemán, portugués, entre otros)."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué porcentaje de llamadas puede resolver la IA sin intervención humana?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En implementaciones bien configuradas, aproximadamente el 80-85% de las llamadas habituales se resuelven de forma autónoma: reservas y cancelaciones de citas, consultas de horarios y precios, información sobre servicios, estado de pedidos o incidencias recurrentes. El 15-20% restante —urgencias, negociaciones o casos fuera del ámbito configurado— se deriva automáticamente a un agente humano."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tarda en implementarse un recepcionista virtual con IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El plan básico (sin integración con sistemas internos) puede estar operativo en 7-10 días hábiles. El plan medio, que integra el CRM o ERP de la empresa mediante API, requiere 3-4 semanas. El plan avanzado, con tickets automáticos, WhatsApp Business y multi-agente, se implanta en 5-6 semanas. El plazo depende principalmente de la disponibilidad de la API del sistema de gestión del cliente."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué empresas pueden beneficiarse de un recepcionista IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Cualquier empresa que reciba un volumen significativo de llamadas repetitivas: clínicas dentales y consultas médicas (citas, horarios, seguros), hoteles y alojamientos (reservas, check-in, servicios), despachos de abogados y asesorías (primera atención, citas), talleres mecánicos (estado de reparaciones, citas ITV), inmobiliarias (disponibilidad de pisos, visitas) y e-commerce (estado de pedidos, devoluciones)."
          }
        }
      ]
    }
  ]
  </script>

  <!-- ══════════════════════════════════════════════
       HERO + DEMO — todo en una sección oscura
  ══════════════════════════════════════════════ -->
  <section style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 50%, #0a0d1a 100%); padding: 80px 0 60px; position: relative; overflow: hidden;">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, #2563eb 0%, transparent 50%), radial-gradient(circle at 80% 70%, #0ea5e9 0%, transparent 50%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <!-- Badge + Título -->
      <div class="text-center mb-10">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight" style="color: #fff;">
          Recepcionista virtual<br/>
          <span style="background: linear-gradient(90deg, #60a5fa, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">que nunca descansa</span>
        </h1>
        <p class="text-xl max-w-3xl mx-auto" style="color: #94a3b8; line-height: 1.7;">
          Atención telefónica con <strong style="color: #e2e8f0;">voz natural en español</strong>. Gestiona llamadas, reserva citas,
          responde preguntas frecuentes y deriva casos complejos a tu equipo solo cuando realmente lo necesitan.
        </p>
      </div>

      <!-- DEMO INTERACTIVA -->
      <div id="demo" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1.5rem; overflow: hidden;">
        <!-- Barra superior tipo terminal -->
        <div style="background: rgba(0,0,0,0.4); padding: 14px 24px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="display: flex; gap: 6px;">
              <div style="width:12px;height:12px;border-radius:50%;background:#ef4444;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#eab308;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#22c55e;"></div>
            </div>
            <span style="color: #64748b; font-size: 0.875rem; font-family: monospace;">Atención Telefónica IA — Demo interactiva</span>
          </div>
          <div style="display: flex; align-items: center; gap: 8px; font-size: 0.8rem;" class="text-green-400">
            <span style="width:8px;height:8px;background:#22c55e;border-radius:50%;display:inline-block;" class="animate-pulse"></span>
            En línea 24/7
          </div>
        </div>

        <!-- Contenido del demo: phone + transcript -->
        <div style="background: linear-gradient(135deg, #1d4ed8 0%, #0369a1 100%); padding: 2rem;">
          <div class="grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto items-start">

            <!-- Phone Mockup -->
            <div style="background: linear-gradient(to bottom, #111827, #1f2937, #111827); border-radius: 3rem; padding: 12px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); border: 8px solid #1f2937; width: 100%; max-width: 340px; margin: 0 auto; height: 700px;">
              <div style="background: #000; border-radius: 2.5rem; overflow: hidden; height: 100%; display: flex; flex-direction: column;">
                <!-- Status bar -->
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 20px;background:#000;color:#fff;font-size:0.7rem;flex-shrink:0;">
                  <span style="font-weight:600;">9:41</span>
                  <div style="display:flex;gap:4px;align-items:center;">
                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>
                    <span>100%</span>
                  </div>
                </div>

                <!-- Main content -->
                <div style="background:linear-gradient(to bottom,#111827,#000);flex:1;position:relative;overflow:hidden;">
                  <!-- Pre-Call Screen -->
                  <div id="pre-call-screen" style="position:absolute;inset:0;padding:24px;display:flex;flex-direction:column;">
                    <div style="text-align:center;margin-bottom:24px;">
                      <div style="width:100px;height:100px;margin:0 auto 12px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#0ea5e9);display:flex;align-items:center;justify-content:center;color:white;font-size:2rem;font-weight:700;box-shadow:0 0 40px rgba(37,99,235,0.4);">DG</div>
                      <h3 style="color:#fff;font-size:1.1rem;font-weight:600;margin:0 0 4px;">Clínica Dental Dr. García</h3>
                      <p style="color:#6b7280;font-size:0.8rem;margin:0;">+34 900 123 456</p>
                    </div>

                    <div style="flex:1;">
                      <p style="color:#6b7280;font-size:0.7rem;font-weight:600;text-align:center;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">Motivo de la llamada</p>
                      <div style="display:flex;flex-direction:column;gap:8px;">
                        <button data-scenario="reservar" class="scenario-button" style="width:100%;text-align:left;padding:10px 14px;background:rgba(37,99,235,0.2);border:1px solid rgba(37,99,235,0.5);border-radius:12px;color:#fff;font-size:0.8rem;cursor:pointer;box-shadow:0 4px 15px rgba(37,99,235,0.2);">
                          <span style="margin-right:8px;">📅</span> Reservar una cita
                        </button>
                        <button data-scenario="modificar" class="scenario-button" style="width:100%;text-align:left;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:12px;color:#fff;font-size:0.8rem;cursor:pointer;">
                          <span style="margin-right:8px;">✏️</span> Modificar/Eliminar cita
                        </button>
                        <button data-scenario="pago" class="scenario-button" style="width:100%;text-align:left;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:12px;color:#fff;font-size:0.8rem;cursor:pointer;">
                          <span style="margin-right:8px;">💳</span> Consulta sobre pago
                        </button>
                      </div>
                    </div>

                    <div style="display:flex;justify-content:center;padding-top:20px;">
                      <button id="call-button" style="display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer;background:none;border:none;">
                        <div style="width:72px;height:72px;border-radius:50%;background:#22c55e;display:flex;align-items:center;justify-content:center;box-shadow:0 0 30px rgba(34,197,94,0.5);transition:transform 0.2s;">
                          <svg width="32" height="32" fill="white" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                        </div>
                        <span style="color:#fff;font-size:0.7rem;">Llamar</span>
                      </button>
                    </div>
                  </div>

                  <!-- In-Call Screen -->
                  <div id="in-call-screen" style="position:absolute;inset:0;padding:24px;display:none;flex-direction:column;justify-content:space-between;">
                    <div style="text-align:center;padding-top:20px;">
                      <div style="width:80px;height:80px;margin:0 auto 10px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#0ea5e9);display:flex;align-items:center;justify-content:center;color:white;font-size:1.6rem;font-weight:700;">DG</div>
                      <h3 style="color:#fff;font-size:1rem;font-weight:600;margin:0 0 4px;">Clínica Dental Dr. García</h3>
                      <p style="color:#22c55e;font-size:0.8rem;">En llamada</p>
                    </div>
                    <div style="text-align:center;">
                      <div id="duration-text" style="color:#fff;font-size:2.5rem;font-weight:300;margin-bottom:4px;">00:00</div>
                      <p style="color:#6b7280;font-size:0.75rem;">Duración de la llamada</p>
                    </div>
                    <div style="display:flex;justify-content:center;padding-bottom:20px;">
                      <button id="hangup-button-in-phone" style="display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer;background:none;border:none;">
                        <div style="width:72px;height:72px;border-radius:50%;background:#ef4444;display:flex;align-items:center;justify-content:center;box-shadow:0 0 30px rgba(239,68,68,0.5);">
                          <svg width="32" height="32" fill="white" viewBox="0 0 20 20" style="transform:rotate(135deg);"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                        </div>
                        <span style="color:#fff;font-size:0.7rem;">Colgar</span>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Transcription Panel -->
            <div id="transcription-panel" style="background:rgba(255,255,255,0.97);border-radius:1.25rem;padding:24px;height:700px;display:flex;flex-direction:column;box-shadow:0 25px 50px -12px rgba(0,0,0,0.4);">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #e5e7eb;flex-shrink:0;">
                <h4 style="color:#4f46e5;font-size:1rem;font-weight:600;display:flex;align-items:center;gap:8px;margin:0;">
                  <svg width="18" height="18" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd"/></svg>
                  Transcripción en vivo
                </h4>
                <div id="recording-indicator" style="display:none;align-items:center;gap:6px;">
                  <span style="width:8px;height:8px;background:#ef4444;border-radius:50%;display:inline-block;" class="animate-pulse"></span>
                  <span style="font-size:0.75rem;color:#6b7280;font-weight:500;">Grabando</span>
                </div>
              </div>

              <div id="conversation-log" style="flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding-right:4px;">
                <div id="empty-state" style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;padding:32px 0;">
                  <svg width="56" height="56" fill="none" stroke="#d1d5db" stroke-width="2" viewBox="0 0 24 24" style="margin-bottom:12px;"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                  <p style="color:#111;font-size:0.875rem;font-weight:500;margin:0 0 4px;">La transcripción aparecerá aquí</p>
                  <p style="color:#6b7280;font-size:0.75rem;margin:0;">Selecciona un motivo y pulsa "Llamar"</p>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- Nota -->
        <div style="padding: 14px 24px; background: rgba(0,0,0,0.3); border-top: 1px solid rgba(255,255,255,0.06); text-align:center;">
          <p style="color:#475569;font-size:0.8rem;margin:0;">Demo simulada. El sistema real usa síntesis de voz natural y procesamiento de lenguaje avanzado.</p>
        </div>
      </div>

      <!-- Stats + CTAs debajo de la demo -->
      <div class="text-center mt-10">
        <div class="flex flex-wrap justify-center gap-6 mb-8">
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">24/7</div>
            <div class="text-xs mt-1" style="color: #64748b;">Sin festivos ni vacaciones</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #22d3ee;">~85%</div>
            <div class="text-xs mt-1" style="color: #64748b;">Llamadas resueltas sin humano</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #60a5fa;">0s</div>
            <div class="text-xs mt-1" style="color: #64748b;">Tiempo de espera</div>
          </div>
          <div class="w-px h-10 self-center" style="background: rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-3xl font-bold" style="color: #22d3ee;">-60%</div>
            <div class="text-xs mt-1" style="color: #64748b;">Coste telefónico</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/presupuesto?plan=Atencion-Llamadas-IA"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold transition-all"
            style="background: linear-gradient(135deg, #2563eb, #0ea5e9); color: #ffffff;">
            Solicitar análisis gratuito →
          </a>
          <a href="#como-funciona"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold transition-all"
            style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); color: #cbd5e1;">
            ¿Cómo funciona?
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       TRES NIVELES DE IMPLANTACIÓN
  ══════════════════════════════════════════════ -->
  <section id="como-funciona" style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 100%); padding: 80px 0; position: relative; overflow: hidden;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at 20% 50%, rgba(37,99,235,0.12), transparent 60%), radial-gradient(circle at 80% 50%, rgba(14,165,233,0.10), transparent 60%);"></div>
    <div class="relative max-w-6xl mx-auto px-6" style="z-index:1;">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #e2e8f0;">Tres niveles de implantación</h2>
        <p style="color: #94a3b8; font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.7;">
          La propuesta está pensada para escalar progresivamente. Empieza por el nivel básico, valida resultados con datos reales
          y sube de nivel cuando los indicadores lo justifiquen.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;align-items:start;">

        <!-- NIVEL 1 — BÁSICO -->
        <div style="background:rgba(37,99,235,0.07);border:1px solid rgba(37,99,235,0.3);border-radius:1.25rem;padding:32px;display:flex;flex-direction:column;gap:20px;">
          <div>
            <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(37,99,235,0.15);border:1px solid rgba(37,99,235,0.3);border-radius:8px;padding:4px 12px;margin-bottom:14px;">
              <span style="color:#60a5fa;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;">Nivel 1</span>
            </div>
            <h3 style="color:#fff;font-size:1.25rem;font-weight:700;margin:0 0 6px;">Básico</h3>
            <p style="color:#60a5fa;font-size:0.875rem;font-weight:500;margin:0 0 12px;">Atención automática con derivación</p>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;margin:0;">
              La IA atiende llamadas con el contexto de tu empresa y resuelve las preguntas frecuentes.
              Al finalizar, envía un resumen estructurado al responsable correspondiente.
            </p>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:20px;">
