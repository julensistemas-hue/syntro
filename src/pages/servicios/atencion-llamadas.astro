    };

    function addConversationLine(speaker: string, text: string, audioSrc?: string) {
      if (!conversationLog) return;

      const es = document.getElementById('empty-state');
      if (es) es.style.display = 'none';

      const line = document.createElement('div');
      line.style.cssText = speaker === 'AI'
        ? 'display:flex;gap:8px;align-items:flex-start;'
        : 'display:flex;gap:8px;align-items:flex-start;justify-content:flex-end;';

      const bubble = document.createElement('div');
      bubble.style.cssText = speaker === 'AI'
        ? 'background:#eff6ff;color:#1e3a5f;padding:10px 14px;border-radius:16px 16px 16px 4px;max-width:85%;'
        : 'background:#2563eb;color:#fff;padding:10px 14px;border-radius:16px 16px 4px 16px;max-width:85%;';

      const label = document.createElement('div');
      label.style.cssText = 'font-size:0.7rem;font-weight:600;margin-bottom:4px;opacity:0.7;';
      label.textContent = speaker === 'AI' ? '🤖 Asistente' : '👤 Tú';

      const message = document.createElement('div');
      message.style.cssText = 'font-size:0.8rem;line-height:1.5;';
      message.textContent = text;

      bubble.appendChild(label);
      bubble.appendChild(message);
      line.appendChild(bubble);
      conversationLog.appendChild(line);
      conversationLog.scrollTop = conversationLog.scrollHeight;

      if (audioSrc) playAudio(audioSrc);
    }

    function playAudio(src: string) {
      if (currentAudio) { currentAudio.pause(); currentAudio.currentTime = 0; }
      currentAudio = new Audio(src);
      currentAudio.play().catch(() => {});
    }

    function stopAllAudio() {
      if (currentAudio) { currentAudio.pause(); currentAudio.currentTime = 0; currentAudio = null; }
      audioTimeouts.forEach(t => clearTimeout(t));
      audioTimeouts = [];
    }

    function updateDuration() {
      const elapsed = Math.floor((Date.now() - callStartTime) / 1000);
      const m = Math.floor(elapsed / 60).toString().padStart(2, '0');
      const s = (elapsed % 60).toString().padStart(2, '0');
      if (durationText) durationText.textContent = `${m}:${s}`;
    }

    function startCall() {
      isInCall = true;
      callStartTime = Date.now();
      const conversation = scenarios[selectedScenario];

      if (preCallScreen) preCallScreen.style.display = 'none';
      if (inCallScreen) inCallScreen.style.display = 'flex';
      if (recordingIndicator) recordingIndicator.style.display = 'flex';

      durationInterval = setInterval(updateDuration, 1000) as unknown as number;

      conversation.forEach(line => {
        const t = setTimeout(() => {
          if (isInCall) addConversationLine(line.speaker, line.text, line.audio);
        }, line.delay) as unknown as number;
        audioTimeouts.push(t);
      });
    }

    function endCall() {
      isInCall = false;
      clearInterval(durationInterval);
      stopAllAudio();

      if (inCallScreen) inCallScreen.style.display = 'none';
      if (recordingIndicator) recordingIndicator.style.display = 'none';
      if (preCallScreen) preCallScreen.style.display = 'flex';
      if (durationText) durationText.textContent = '00:00';

      if (conversationLog) {
        conversationLog.innerHTML = `
          <div id="empty-state" style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;padding:32px 0;">
            <svg width="56" height="56" fill="none" stroke="#d1d5db" stroke-width="2" viewBox="0 0 24 24" style="margin-bottom:12px;"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            <p style="color:#111;font-size:0.875rem;font-weight:500;margin:0 0 4px;">La transcripción aparecerá aquí</p>
            <p style="color:#6b7280;font-size:0.75rem;margin:0;">Selecciona un motivo y pulsa "Llamar"</p>
          </div>`;
      }
    }

    function updateSelectedScenario(scenario: keyof typeof scenarios) {
      selectedScenario = scenario;
      scenarioButtons.forEach(btn => {
        const s = btn.getAttribute('data-scenario');
        if (s === scenario) {
          btn.style.background = 'rgba(37,99,235,0.2)';
          btn.style.border = '1px solid rgba(37,99,235,0.5)';
          btn.style.boxShadow = '0 4px 15px rgba(37,99,235,0.2)';
        } else {
          btn.style.background = 'rgba(255,255,255,0.05)';
          btn.style.border = '1px solid rgba(255,255,255,0.1)';
          btn.style.boxShadow = 'none';
        }
      });
    }

    callButton?.addEventListener('click', startCall);
    hangupButtonInPhone?.addEventListener('click', endCall);
    scenarioButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const s = btn.getAttribute('data-scenario') as keyof typeof scenarios;
        if (s) updateSelectedScenario(s);
      });
    });
  });
</script>
