</WazuhLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Demo tabs (existing)
    const tabs = document.querySelectorAll('.demo-tab');
    const contents = document.querySelectorAll('.demo-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');

        // Remove active class from all tabs
        tabs.forEach(t => {
          t.classList.remove('active', 'bg-[#0052cc]', 'text-black');
          t.classList.add('text-white', 'hover:bg-[#0052cc]/70');
        });

        // Add active class to clicked tab
        tab.classList.add('active', 'bg-[#0052cc]', 'text-black');
        tab.classList.remove('text-white', 'hover:bg-[#0052cc]/70');

        // Hide all content
        contents.forEach(content => {
          content.classList.add('hidden');
        });

        // Show target content
        const targetContent = document.getElementById(`tab-${targetTab}`);
        if (targetContent) {
          targetContent.classList.remove('hidden');
        }
      });
    });

    // Wazuh demo tabs (Aprende Haciendo section)
    const wazuhDemoTabs = document.querySelectorAll('.wazuh-demo-tab');
    const wazuhDemoContents = document.querySelectorAll('.wazuh-demo-content');

    wazuhDemoTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');

        // Remove active class from all tabs
        wazuhDemoTabs.forEach(t => {
          t.classList.remove('text-blue-600', 'border-blue-600');
          t.classList.add('text-gray-600', 'border-transparent');
        });

        // Add active class to clicked tab
        tab.classList.add('text-blue-600', 'border-blue-600');
        tab.classList.remove('text-gray-600', 'border-transparent');

        // Hide all content
        wazuhDemoContents.forEach(content => {
          content.classList.add('hidden');
        });

        // Show target content
        const targetContent = document.getElementById(targetTab);
        if (targetContent) {
          targetContent.classList.remove('hidden');
        }
      });
    });
  });
</script>

