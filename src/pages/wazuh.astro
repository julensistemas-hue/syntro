    }
    85% {
      transform: translateX(-5px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
      box-shadow: 0 0 20px rgba(147, 51, 234, 0.4), 0 0 40px rgba(147, 51, 234, 0.2);
    }
  }

  .animate-bounce-subtle {
