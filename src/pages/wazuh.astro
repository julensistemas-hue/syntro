---
import WazuhLayout from "../layouts/WazuhLayout.astro";
// Force rebuild - 2025-12-02 - Fix 404 assets v2
export const prerender = false; // Force SSR to bypass cache
const buildTimestamp = new Date().toISOString();

const title = "Wazuh España: Implementación, ENS y Soporte | AI Security";
const description = "Implementamos Wazuh para PyMEs españolas: instalación, configuración para ENS, monitoreo de amenazas y formación del equipo. Servicio completo desde 0.";
const canonical = "https://aisecurity.es/wazuh";
---

<WazuhLayout title={title} description={description} canonical={canonical}>
  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden" data-page="wazuh">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover opacity-40" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/60 via-blue-600/70 to-accent-500/60"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
        
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white">
            Monitorización 24/7 con Wazuh
          </h1>
          <p class="text-xl text-white/90 mb-8 leading-relaxed">
            Implementación profesional de Wazuh con especialización en ENS.<br>
            Monitoreo 24/7, cumplimiento normativo certificado y soporte en tu horario.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#demo"
              class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold bg-accent-600 hover:bg-accent-700 rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 hover:-translate-y-0.5"
              style="color: #000000;"
            >
              Ver Demo Interactiva
            </a>
            <a
              href="/contacto-migracion?plan=wazuh-consultoria"
              class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-base-800 bg-base-50 hover:bg-accent-50 rounded-xl border-2 border-base-200 hover:border-accent-300 transition-all duration-200 shadow-sm hover:shadow-md"
            >
              Solicitar Consulta Gratuita
            </a>
          </div>

          <!-- Key Stats -->
          <div class="grid grid-cols-3 gap-6 mt-12 pt-8 border-t border-white/30">
            <div>
              <div class="text-3xl font-bold text-white mb-1">24/7</div>
              <div class="text-sm text-white/80 font-medium">Monitoreo continuo</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white mb-1">ENS</div>
              <div class="text-sm text-white/80 font-medium">Cumplimiento certificado</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white mb-1">100%</div>
              <div class="text-sm text-white/80 font-medium">Open Source</div>
            </div>
          </div>

          <!-- Course CTA - Compact with animation -->
          <a href="/curso-wazuh" class="course-cta mt-6 flex items-center gap-3 p-3 bg-purple-700/70 hover:bg-purple-800/80 border border-purple-400/50 rounded-xl transition-all duration-200 group backdrop-blur-sm">
            <div class="text-2xl animate-bounce-subtle">🎓</div>
            <div class="flex-1">
              <span class="text-white font-medium text-sm">¿Prefieres implementarlo tú mismo?</span>
              <span class="text-purple-200 text-sm ml-1">Curso práctico por 50€</span>
            </div>
            <svg class="w-5 h-5 text-purple-300 group-hover:translate-x-1 transition-transform arrow-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>

        <!-- Dashboard Preview - Interactive -->
        <div class="relative">
          <div class="relative z-10 bg-base-50 rounded-2xl shadow-2xl border border-base-200 p-6 md:p-7">
            <!-- Simulated Wazuh Dashboard -->
            <div class="space-y-5">
              <div class="flex items-center gap-3 pb-4 border-b border-base-200">
                <div class="flex gap-2">
                  <div class="w-3 h-3 bg-red-400 rounded-full" aria-hidden="true"></div>
                  <div class="w-3 h-3 bg-yellow-400 rounded-full" aria-hidden="true"></div>
                  <div class="w-3 h-3 bg-green-400 rounded-full" aria-hidden="true"></div>
                </div>
                <span class="text-sm font-semibold text-base-700 ml-2">Dashboard Wazuh - Monitoreo Activo</span>
              </div>

              <div class="space-y-3">
                <!-- Alert 1: Critical -->
                <details class="group">
                  <summary class="flex items-center gap-3 p-4 rounded-xl border-2 cursor-pointer transition-all hover:shadow-lg" style="background-color: #1F2937; border-color: #EF4444;">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white text-lg shadow-sm" style="background-color: #EF4444;">🚨</div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-bold text-white">Intento acceso no autorizado</div>
                      <div class="text-xs text-gray-300 mt-0.5">15 intentos SSH desde IP sospechosa</div>
                    </div>
                    <div class="w-2.5 h-2.5 bg-red-400 rounded-full animate-pulse" aria-label="Crítico"></div>
                    <svg class="w-4 h-4 text-gray-300 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </summary>
                  <div class="mt-2 ml-12 p-4 rounded-lg border-l-4" style="background-color: #374151; border-color: #EF4444;">
                    <div class="text-sm font-bold text-white">Nivel 12 - Crítico</div>
                    <div class="text-xs text-gray-300 mt-1">IP: 45.142.212.61 → Servidor: web-prod-01</div>
                    <div class="text-xs text-gray-300">Acción: Bloqueado automáticamente por firewall</div>
                  </div>
                </details>

                <!-- Alert 2: Warning -->
                <details class="group">
                  <summary class="flex items-center gap-3 p-4 rounded-xl border-2 cursor-pointer transition-all hover:shadow-lg" style="background-color: #1F2937; border-color: #F59E0B;">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white text-lg shadow-sm" style="background-color: #F59E0B;">⚠️</div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-bold text-white">Cambio configuración firewall</div>
                      <div class="text-xs text-gray-300 mt-0.5">Puerto 3306 abierto en fw-01</div>
                    </div>
                    <div class="w-2.5 h-2.5 rounded-full animate-pulse" aria-label="Advertencia" style="background-color: #F59E0B;"></div>
                    <svg class="w-4 h-4 text-gray-300 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </summary>
                  <div class="mt-2 ml-12 p-4 rounded-lg border-l-4" style="background-color: #374151; border-color: #F59E0B;">
                    <div class="text-sm font-bold text-white">Nivel 7 - Advertencia</div>
                    <div class="text-xs text-gray-300 mt-1">Usuario: admin | Requiere revisión ENS</div>
                  </div>
                </details>

                <!-- Alert 3: Info -->
                <details class="group">
                  <summary class="flex items-center gap-3 p-4 rounded-xl border-2 cursor-pointer transition-all hover:shadow-lg" style="background-color: #1F2937; border-color: #3B82F6;">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white text-lg shadow-sm" style="background-color: #3B82F6;">✅</div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-bold text-white">Actualización completada</div>
                      <div class="text-xs text-gray-300 mt-0.5">23 paquetes actualizados en db-prod-02</div>
                    </div>
                    <div class="w-2.5 h-2.5 bg-green-400 rounded-full animate-pulse" aria-label="Activo"></div>
                    <svg class="w-4 h-4 text-gray-300 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </summary>
                  <div class="mt-2 ml-12 p-4 rounded-lg border-l-4" style="background-color: #374151; border-color: #3B82F6;">
                    <div class="text-sm font-bold text-white">Nivel 3 - Informativo</div>
                    <div class="text-xs text-gray-300 mt-1">Parches de seguridad aplicados correctamente</div>
                  </div>
                </details>

                <!-- Alert 4: Compliance -->
                <details class="group">
                  <summary class="flex items-center gap-3 p-4 rounded-xl border-2 cursor-pointer transition-all hover:shadow-lg" style="background-color: #1F2937; border-color: #8B5CF6;">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white text-lg shadow-sm" style="background-color: #8B5CF6;">📋</div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-bold text-white">Cumplimiento ENS</div>
                      <div class="text-xs text-gray-300 mt-0.5">Auditoría semanal completada</div>
                    </div>
                    <div class="w-2.5 h-2.5 rounded-full animate-pulse" aria-label="Activo" style="background-color: #8B5CF6;"></div>
                    <svg class="w-4 h-4 text-gray-300 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </summary>
                  <div class="mt-2 ml-12 p-4 rounded-lg border-l-4" style="background-color: #374151; border-color: #8B5CF6;">
                    <div class="text-sm font-bold text-white">Estado: 96% Conforme</div>
                    <div class="text-xs text-white mt-1">Marco Operacional: 98% | Protección: 95%</div>
                  </div>
                </details>
              </div>

              <div class="mt-6 p-5 bg-gradient-to-br from-accent-600 to-blue-600 rounded-xl text-white shadow-lg">
                <div class="text-center">
                  <div class="text-3xl md:text-4xl font-extrabold">24/7</div>
                  <div class="text-sm font-medium opacity-90 mt-1">Monitoreo continuo de seguridad</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Decorative elements -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-accent-600/10 rounded-full blur-2xl" aria-hidden="true"></div>
          <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-blue-600/10 rounded-full blur-2xl" aria-hidden="true"></div>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="py-20 bg-base-50 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 opacity-40">
      <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Dark overlay to maintain visibility -->
    <div class="absolute inset-0 bg-base-50/60"></div>

    <!-- Content -->
  <div class="relative z-10">
    <div class="max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-16">
        <h2 id="precios" class="text-3xl md:text-4xl font-bold text-white mb-4">
          Precios Transparentes
        </h2>
        <p class="text-xl text-white/90 max-w-3xl mx-auto">
          Sin sorpresas, sin costes ocultos
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- Basic Package -->
        <div class="bg-base-50 rounded-xl p-6 border-1 flex flex-col">
          <h4 class="text-xl font-bold mb-2 text-white">Básico</h4>
          <p class="text-sm text-gray-300 mb-4">Hasta 20 servidores</p>

          <div class="text-3xl font-bold mb-4 text-white">999-1,499€</div>
          <p class="text-sm text-gray-300 mb-4">Pago único de implementación</p>

          <ul class="space-y-2 text-sm text-gray-300 mb-6 flex-grow">
            <li><span class="text-blue-400">✅</span> Hasta 20 servidores monitorizados</li>
            <li><span class="text-blue-400">✅</span> Configuración ENS básica</li>
            <li><span class="text-blue-400">✅</span> 2 días de formación presencial</li>
            <li><span class="text-blue-400">✅</span> 30 días de soporte post-implementación</li>
            <li><span class="text-blue-400">✅</span> Documentación completa</li>
            <li><span class="text-blue-400">✅</span> Servidor Wazuh configurado</li>
          </ul>

          <a
            href="/contacto-migracion?plan=wazuh-basico"
            style="color: white;"
            class="block w-full px-4 py-3 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors mt-auto"
          >
            Solicitar Presupuesto
          </a>
        </div>

        <!-- Support Package - MOST POPULAR -->
        <div class="bg-base-50 rounded-xl p-6 border-2 border-blue-500 relative flex flex-col">
          <div class="absolute -top-3 left-1/2 transform -translate-x-1/2 bg-blue-600 px-4 py-1 rounded-full text-xs font-bold text-white">
            MÁS POPULAR
          </div>
          <h4 class="text-xl font-bold mb-2 text-white">Wazuh Gestionado</h4>
          <p class="text-sm text-gray-300 mb-4">Hosting + gestión completa</p>

          <div class="text-3xl font-bold mb-4 text-white">200€/mes</div>
          <p class="text-sm text-gray-300 mb-4">Todo incluido, sin sorpresas</p>

          <div class="bg-green-600/20 border border-green-500 rounded-lg px-3 py-2 mb-4">
            <p class="text-green-400 text-sm font-semibold text-center">Tu Wazuh en nuestros servidores · Listo en 48h</p>
          </div>

          <ul class="space-y-2 text-sm text-gray-300 mb-6 flex-grow">
            <li><span class="text-blue-400">✅</span> Servidor Wazuh alojado por nosotros</li>
            <li><span class="text-blue-400">✅</span> Sin preocuparte de hardware ni actualizaciones</li>
            <li><span class="text-blue-400">✅</span> Instalación y configuración inicial incluida</li>
            <li><span class="text-blue-400">✅</span> Backups diarios y alta disponibilidad</li>
            <li><span class="text-blue-400">✅</span> Actualizaciones y parches de seguridad</li>
            <li><span class="text-blue-400">✅</span> Soporte técnico prioritario</li>
            <li><span class="text-blue-400">✅</span> Informes mensuales ejecutivos</li>
          </ul>

          <a
            href="/contacto-migracion?plan=wazuh-gestionado"
            style="color: white;"
            class="block w-full px-4 py-3 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors mt-auto"
          >
            Contratar Hosting Wazuh
          </a>
        </div>

        <!-- Complete Package -->
        <div class="bg-base-50 rounded-xl p-6 border-1 flex flex-col">
          <h4 class="text-xl font-bold mb-2 text-white">Completo</h4>
          <p class="text-sm text-gray-300 mb-4">Hasta 50 servidores</p>

          <div class="text-3xl font-bold mb-4 text-white">1,999-3,999€</div>
          <p class="text-sm text-gray-300 mb-4">Pago único de implementación</p>

          <ul class="space-y-2 text-sm text-gray-300 mb-6 flex-grow">
            <li><span class="text-blue-400">✅</span> Todo lo del plan Básico +</li>
            <li><span class="text-blue-400">✅</span> Hasta 50 servidores monitorizados</li>
            <li><span class="text-blue-400">✅</span> Configuración ENS avanzada + auditoría</li>
            <li><span class="text-blue-400">✅</span> Dashboards ejecutivos personalizados</li>
            <li><span class="text-blue-400">✅</span> 10 Horas formación</li>
            <li><span class="text-blue-400">✅</span> 90 días de soporte post-implementación</li>
          </ul>

          <a
            href="/contacto-migracion?plan=wazuh-empresarial"
            style="color: white;"
            class="block w-full px-4 py-3 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors mt-auto"
          >
            Solicitar Presupuesto
          </a>
        </div>
      </div>

      <div class="mt-12 text-center max-w-5xl mx-auto">
        <p class="text-white/90 max-w-3xl mx-auto">
          💡 <strong class="text-white">Nota:</strong> Los precios varían según la complejidad de tu infraestructura. Solicita un presupuesto personalizado sin compromiso.
        </p>
      </div>
    </div>
    </div>
  </section>

  <!-- Demo Interactive Section -->
  <section id="demo" class="py-20 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 opacity-40">
      <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/40 via-blue-600/50 to-accent-500/40"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-12">
        <h2 id="demo" class="text-3xl md:text-4xl font-bold text-white mb-4">
          Demo Interactiva
        </h2>
        <p class="text-xl text-white/90 max-w-3xl mx-auto">
          Explora las capacidades de Wazuh en tiempo real
        </p>
      </div>

      <div class="bg-gradient-to-br from-base-100 to-blue-100 rounded-2xl shadow-2xl overflow-hidden border border-base-200">
        <!-- Demo Tabs -->
        <div class="bg-base-100 px-6 py-4 border-b border-base-300 flex gap-4 overflow-x-auto">
          <button
            class="demo-tab active px-4 py-2 rounded-lg font-medium transition-colors whitespace-nowrap"
            data-tab="alerts"
          >
            🚨 Alertas en Tiempo Real
          </button>
          <button
            class="demo-tab px-4 py-2 rounded-lg font-medium transition-colors whitespace-nowrap"
            data-tab="compliance"
          >
            📋 Cumplimiento ENS
          </button>
          <button
            class="demo-tab px-4 py-2 rounded-lg font-medium transition-colors whitespace-nowrap"
            data-tab="dashboard"
          >
            📊 Dashboard Ejecutivo
          </button>
          <button
            class="demo-tab px-4 py-2 rounded-lg font-medium transition-colors whitespace-nowrap"
            data-tab="software"
          >
            💻 Software Windows
          </button>
          <button
            class="demo-tab px-4 py-2 rounded-lg font-medium transition-colors whitespace-nowrap"
            data-tab="nas"
          >
            🗄️ Acceso a NAS
          </button>
        </div>

        <!-- Tab Content -->
        <div style="background-color: #10181f;" class="p-8">
          <!-- Alerts Tab -->
          <div id="tab-alerts" style="background-color: #10181f;" class="demo-content">
            <div class="space-y-4">
              <div class="bg-red-900/30 border-2 border-red-500 rounded-lg p-4">
                <div class="flex items-start justify-between mb-2">
                  <div class="flex items-center gap-3">
                    <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
                    <span class="font-semibold text-red-300">Nivel 12 - Crítico</span>
                  </div>
                  <span class="text-sm text-base-300">Hace 2 min</span>
                </div>
                <h4 class="text-white font-semibold mb-2">Intento de acceso no autorizado detectado</h4>
                <p class="text-base-200 text-sm mb-3">
                  Se han detectado 15 intentos fallidos de SSH desde IP 45.142.212.61 (Rusia) al servidor web-prod-01
                </p>
                <div class="flex gap-2 flex-wrap">
                  <span class="px-2 py-1 bg-red-900/50 text-red-200 rounded text-xs font-medium border border-red-500">auth_failed</span>
                  <span class="px-2 py-1 bg-red-900/50 text-red-200 rounded text-xs font-medium border border-red-500">brute_force</span>
                  <span class="px-2 py-1 bg-red-900/50 text-red-200 rounded text-xs font-medium border border-red-500">ssh</span>
                </div>
              </div>

              <div class="bg-yellow-900/30 border-2 border-yellow-500 rounded-lg p-4">
                <div class="flex items-start justify-between mb-2">
                  <div class="flex items-center gap-3">
                    <span class="w-3 h-3 bg-yellow-500 rounded-full"></span>
                    <span class="font-semibold text-yellow-300">Nivel 7 - Advertencia</span>
                  </div>
                  <span class="text-sm text-base-300">Hace 8 min</span>
                </div>
                <h4 class="text-white font-semibold mb-2">Cambio de configuración en firewall</h4>
                <p class="text-base-200 text-sm mb-3">
                  Usuario 'admin' ha modificado reglas del firewall en fw-01. Se ha abierto puerto 3306 (MySQL).
                </p>
                <div class="flex gap-2 flex-wrap">
                  <span class="px-2 py-1 bg-yellow-900/50 text-yellow-200 rounded text-xs font-medium border border-yellow-500">config_change</span>
                  <span class="px-2 py-1 bg-yellow-900/50 text-yellow-200 rounded text-xs font-medium border border-yellow-500">firewall</span>
                </div>
              </div>

              <div class="bg-blue-900/30 border-2 border-blue-500 rounded-lg p-4">
                <div class="flex items-start justify-between mb-2">
                  <div class="flex items-center gap-3">
                    <span class="w-3 h-3 bg-blue-500 rounded-full"></span>
                    <span class="font-semibold text-blue-300">Nivel 3 - Informativo</span>
                  </div>
                  <span class="text-sm text-base-300">Hace 15 min</span>
                </div>
                <h4 class="text-white font-semibold mb-2">Actualización de sistema completada</h4>
                <p class="text-base-200 text-sm mb-3">
                  Servidor db-prod-02 ha completado actualización de seguridad. 23 paquetes actualizados.
                </p>
                <div class="flex gap-2 flex-wrap">
                  <span class="px-2 py-1 bg-blue-900/50 text-blue-200 rounded text-xs font-medium border border-blue-500">system_update</span>
                  <span class="px-2 py-1 bg-blue-900/50 text-blue-200 rounded text-xs font-medium border border-blue-500">success</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Compliance Tab -->
          <div id="tab-compliance" class="demo-content hidden">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="bg-blue-900/30 border-2 border-blue-500 rounded-lg p-6">
                <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
                  <span class="text-2xl">📋</span>
                  Cumplimiento ENS
                </h4>
                <div class="space-y-4">
                  <div>
                    <div class="flex justify-between mb-2">
                      <span class="text-white text-sm font-medium">Marco Operacional</span>
