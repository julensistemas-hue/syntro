---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto — AI Security"
  description="Escríbenos para cualquier consulta sobre servicios de IA o ciberseguridad."
  canonical="https://aisecurity.es/contacto"
>
  <section style="min-height:100vh;background:linear-gradient(180deg,#05070f 0%,#0d1120 60%,#111827 100%);display:flex;align-items:center;justify-content:center;padding:80px 24px;">
    <div style="width:100%;max-width:520px;">

      <!-- Cabecera -->
      <div style="text-align:center;margin-bottom:40px;">
        <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(59,130,246,0.12);border:1px solid rgba(59,130,246,0.25);border-radius:100px;padding:6px 16px;margin-bottom:20px;">
          <div style="width:6px;height:6px;border-radius:50%;background:#3b82f6;"></div>
          <span style="font-size:0.7rem;font-weight:700;color:#60a5fa;letter-spacing:0.1em;text-transform:uppercase;">Contacto</span>
        </div>
        <h1 style="color:#f1f5f9;font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;margin:0 0 12px;line-height:1.2;">¿Hablamos?</h1>
        <p style="color:#94a3b8;font-size:1rem;margin:0;">Cuéntanos en qué podemos ayudarte. Te respondemos en menos de 24h.</p>
      </div>

      <!-- Formulario -->
      <form id="contact-form" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:32px;display:flex;flex-direction:column;gap:20px;">

        <div>
          <label for="email" style="display:block;font-size:0.875rem;font-weight:500;color:#cbd5e1;margin-bottom:8px;">
            Email <span style="color:#f87171;">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="tu@empresa.com"
            style="width:100%;box-sizing:border-box;padding:12px 16px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#f1f5f9;font-size:1rem;outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#3b82f6'"
            onblur="this.style.borderColor='rgba(255,255,255,0.12)'"
          />
        </div>

        <div>
          <label for="nombre" style="display:block;font-size:0.875rem;font-weight:500;color:#cbd5e1;margin-bottom:8px;">Nombre</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            placeholder="Tu nombre"
            style="width:100%;box-sizing:border-box;padding:12px 16px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#f1f5f9;font-size:1rem;outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#3b82f6'"
            onblur="this.style.borderColor='rgba(255,255,255,0.12)'"
          />
        </div>

        <div>
          <label for="mensaje" style="display:block;font-size:0.875rem;font-weight:500;color:#cbd5e1;margin-bottom:8px;">Mensaje</label>
          <textarea
            id="mensaje"
            name="mensaje"
            rows="4"
            placeholder="¿En qué podemos ayudarte?"
            style="width:100%;box-sizing:border-box;padding:12px 16px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#f1f5f9;font-size:1rem;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
            onfocus="this.style.borderColor='#3b82f6'"
            onblur="this.style.borderColor='rgba(255,255,255,0.12)'"
          ></textarea>
        </div>

        <!-- Estado de envío -->
        <div id="form-status" style="display:none;padding:12px 16px;border-radius:8px;font-size:0.875rem;text-align:center;"></div>

        <button
          type="submit"
          id="submit-btn"
          style="width:100%;padding:14px;background:linear-gradient(135deg,#3b82f6,#2563eb);border:none;border-radius:8px;color:#fff;font-size:1rem;font-weight:600;cursor:pointer;transition:opacity 0.2s;"
          onmouseover="this.style.opacity='0.9'"
          onmouseout="this.style.opacity='1'"
        >
          Enviar mensaje
        </button>
      </form>

      <!-- Info adicional -->
      <div style="text-align:center;margin-top:24px;display:flex;justify-content:center;gap:32px;flex-wrap:wrap;">
        <a href="mailto:info@aisecurity.es" style="color:#60a5fa;font-size:0.875rem;text-decoration:none;">info@aisecurity.es</a>
        <a href="/presupuesto" style="color:#60a5fa;font-size:0.875rem;text-decoration:none;">Solicitar presupuesto →</a>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const nombre = (document.getElementById('nombre') as HTMLInputElement).value.trim();
    const mensaje = (document.getElementById('mensaje') as HTMLTextAreaElement).value.trim();

    btn.disabled = true;
    btn.textContent = 'Enviando...';
    status.style.display = 'none';

    try {
      const res = await fetch('/api/send-contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, nombre, mensaje }),
      });

      const data = await res.json();

      if (res.ok) {
        status.style.display = 'block';
        status.style.background = 'rgba(34,197,94,0.15)';
        status.style.border = '1px solid rgba(34,197,94,0.3)';
        status.style.color = '#86efac';
        status.textContent = '✅ Mensaje enviado. Te respondemos pronto.';
        form.reset();
      } else {
        throw new Error(data.error || 'Error al enviar');
      }
    } catch (err: any) {
      status.style.display = 'block';
      status.style.background = 'rgba(239,68,68,0.15)';
      status.style.border = '1px solid rgba(239,68,68,0.3)';
      status.style.color = '#fca5a5';
      status.textContent = '❌ ' + (err.message || 'Error al enviar. Inténtalo de nuevo.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
    }
  });
</script>