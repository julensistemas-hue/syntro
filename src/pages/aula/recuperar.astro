---
import AulaAuthLayout from '../../layouts/AulaAuthLayout.astro';

// If user is already logged in, redirect to dashboard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/aula');
}
---

<AulaAuthLayout title="Recuperar Contraseña - Aula Virtual" description="Recupera tu contraseña del aula virtual">
  <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8" style="background: linear-gradient(135deg, #0f1419 0%, #1a1f26 50%, #0f1419 100%);">
    <div class="max-w-md w-full">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-block">
          <img src="/logo.svg" alt="AI Security" class="h-12 w-auto mx-auto" />
        </a>
        <h1 class="mt-6 text-3xl font-bold" style="color: #ffffff;">
          Recuperar contraseña
        </h1>
        <p class="mt-2" style="color: #9ca3af;">
          Te enviaremos un enlace para restablecer tu contraseña
        </p>
      </div>

      <!-- Recovery Card -->
      <div class="rounded-2xl shadow-xl p-8" style="background-color: #1a1f26; border: 1px solid #2d3748;">
        <!-- Form -->
        <form id="recovery-form" class="space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium mb-2" style="color: #e5e7eb;">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 rounded-lg transition-colors"
              style="background-color: #0f1419; border: 1px solid #374151; color: #ffffff;"
              placeholder="tu@email.com"
            />
          </div>

          <div id="error-message" class="hidden p-4 rounded-lg" style="background-color: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3);">
            <p class="text-sm" style="color: #fca5a5;"></p>
          </div>

          <div id="success-message" class="hidden p-4 rounded-lg" style="background-color: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3);">
            <p class="text-sm" style="color: #86efac;"></p>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-3 px-4 font-semibold rounded-lg transition-colors hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
            style="background-color: #0065ff; color: #ffffff;"
          >
            Enviar enlace de recuperación
          </button>
        </form>

        <div class="mt-6 text-center">
          <p class="text-sm" style="color: #9ca3af;">
            ¿Recordaste tu contraseña?
            <a href="/aula/login" class="font-medium transition-colors hover:opacity-80" style="color: #38b1ff;">
              Iniciar sesión
            </a>
          </p>
        </div>
      </div>

      <!-- Back to home -->
      <div class="mt-6 text-center">
        <a href="/" class="text-sm transition-colors hover:opacity-80 inline-flex items-center gap-1" style="color: #6b7280;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver a la web
        </a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('recovery-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errorDiv = document.getElementById('error-message') as HTMLDivElement;
    const errorText = errorDiv.querySelector('p') as HTMLParagraphElement;
    const successDiv = document.getElementById('success-message') as HTMLDivElement;
    const successText = successDiv.querySelector('p') as HTMLParagraphElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const email = formData.get('email') as string;

      // Disable button
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      try {
        const response = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Error al enviar el email');
        }

        // Show success message
        successText.textContent = 'Si el email existe en nuestro sistema, recibirás un enlace para restablecer tu contraseña.';
        successDiv.classList.remove('hidden');
        submitBtn.textContent = 'Email enviado';

        // Hide form fields
        const emailInput = document.getElementById('email') as HTMLInputElement;
        emailInput.disabled = true;

      } catch (error: any) {
        errorText.textContent = error.message || 'Error al enviar el email. Por favor, inténtalo de nuevo.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar enlace de recuperación';
      }
    });
  </script>
</AulaAuthLayout>
