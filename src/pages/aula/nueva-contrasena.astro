---
import AulaAuthLayout from '../../layouts/AulaAuthLayout.astro';
---

<AulaAuthLayout title="Nueva Contraseña - Aula Virtual" description="Establece tu nueva contraseña">
  <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8" style="background: linear-gradient(135deg, #0f1419 0%, #1a1f26 50%, #0f1419 100%);">
    <div class="max-w-md w-full">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-block">
          <img src="/logo.svg" alt="AI Security" class="h-12 w-auto mx-auto" />
        </a>
        <h1 class="mt-6 text-3xl font-bold" style="color: #ffffff;">
          Nueva contraseña
        </h1>
        <p class="mt-2" style="color: #9ca3af;">
          Introduce tu nueva contraseña
        </p>
      </div>

      <!-- Password Reset Card -->
      <div class="rounded-2xl shadow-xl p-8" style="background-color: #1a1f26; border: 1px solid #2d3748;">
        <!-- Form -->
        <form id="new-password-form" class="space-y-6">
          <div>
            <label for="password" class="block text-sm font-medium mb-2" style="color: #e5e7eb;">
              Nueva contraseña
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="6"
              autocomplete="new-password"
              class="w-full px-4 py-3 rounded-lg transition-colors"
              style="background-color: #0f1419; border: 1px solid #374151; color: #ffffff;"
              placeholder="••••••••"
            />
            <p class="mt-1 text-xs" style="color: #6b7280;">Mínimo 6 caracteres</p>
          </div>

          <div>
            <label for="confirm-password" class="block text-sm font-medium mb-2" style="color: #e5e7eb;">
              Confirmar contraseña
            </label>
            <input
              type="password"
              id="confirm-password"
              name="confirm-password"
              required
              minlength="6"
              autocomplete="new-password"
              class="w-full px-4 py-3 rounded-lg transition-colors"
              style="background-color: #0f1419; border: 1px solid #374151; color: #ffffff;"
              placeholder="••••••••"
            />
          </div>

          <div id="error-message" class="hidden p-4 rounded-lg" style="background-color: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3);">
            <p class="text-sm" style="color: #fca5a5;"></p>
          </div>

          <div id="success-message" class="hidden p-4 rounded-lg" style="background-color: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3);">
            <p class="text-sm" style="color: #86efac;"></p>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-3 px-4 font-semibold rounded-lg transition-colors hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
            style="background-color: #0065ff; color: #ffffff;"
          >
            Cambiar contraseña
          </button>
        </form>
      </div>

      <!-- Back to login -->
      <div class="mt-6 text-center">
        <a href="/aula/login" class="text-sm transition-colors hover:opacity-80 inline-flex items-center gap-1" style="color: #6b7280;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al login
        </a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('new-password-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errorDiv = document.getElementById('error-message') as HTMLDivElement;
    const errorText = errorDiv.querySelector('p') as HTMLParagraphElement;
    const successDiv = document.getElementById('success-message') as HTMLDivElement;
    const successText = successDiv.querySelector('p') as HTMLParagraphElement;

    // Get tokens from URL - try hash first (Supabase default), then query params
    let accessToken: string | null = null;
    let refreshToken: string | null = null;

    // Try hash fragment first (#access_token=...)
    if (window.location.hash) {
      const hashParams = new URLSearchParams(window.location.hash.substring(1));
      accessToken = hashParams.get('access_token');
      refreshToken = hashParams.get('refresh_token');
    }

    // If not in hash, try query params (?access_token=...)
    if (!accessToken) {
      const queryParams = new URLSearchParams(window.location.search);
      accessToken = queryParams.get('access_token');
      refreshToken = queryParams.get('refresh_token');
    }

    // Also check for 'token' parameter (some Supabase versions use this)
    if (!accessToken) {
      const queryParams = new URLSearchParams(window.location.search);
      accessToken = queryParams.get('token');
    }

    // Debug: log what we found
    console.log('URL:', window.location.href);
    console.log('Hash:', window.location.hash);
    console.log('Search:', window.location.search);
    console.log('Access token found:', !!accessToken);

    if (!accessToken) {
      errorText.textContent = 'Enlace inválido o expirado. Solicita un nuevo enlace de recuperación.';
      errorDiv.classList.remove('hidden');
      submitBtn.disabled = true;
      form.style.display = 'none';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const password = formData.get('password') as string;
      const confirmPassword = formData.get('confirm-password') as string;

      // Validate passwords match
      if (password !== confirmPassword) {
        errorText.textContent = 'Las contraseñas no coinciden';
        errorDiv.classList.remove('hidden');
        return;
      }

      // Disable button
      submitBtn.disabled = true;
      submitBtn.textContent = 'Cambiando contraseña...';
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      try {
        const response = await fetch('/api/auth/update-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            password,
            access_token: accessToken,
            refresh_token: refreshToken,
          }),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Error al cambiar la contraseña');
        }

        // Show success message
        successText.textContent = 'Contraseña cambiada correctamente. Redirigiendo al login...';
        successDiv.classList.remove('hidden');
        form.style.display = 'none';

        // Redirect to login after 2 seconds
        setTimeout(() => {
          window.location.href = '/aula/login';
        }, 2000);

      } catch (error: any) {
        errorText.textContent = error.message || 'Error al cambiar la contraseña';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Cambiar contraseña';
      }
    });
  </script>
</AulaAuthLayout>
