---
import AulaLayout from '../../layouts/AulaLayout.astro';
import { createServerClient } from '../../lib/supabase';

const user = Astro.locals.user;

// Only allow admin access
const ADMIN_EMAIL = 'julen.sistemas@gmail.com';

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/aula');
}

const supabaseAdmin = createServerClient();

// Emails to exclude from stats (test accounts)
const EXCLUDED_EMAILS = [
  'julenproyecto@gmail.com',
  'jvergara@nostravant.es',
  'proyectozeropersonal404@gmail.com',
  'info@aisecurity.es',
  'julen.sistemas@gmail.com'
];

// Fetch all course users
const { data: courseUsers, error } = await supabaseAdmin
  .from('course_users')
  .select('*')
  .order('created_at', { ascending: false });

const allUsers = courseUsers || [];

// Filter out test accounts
const users = allUsers.filter(u => !EXCLUDED_EMAILS.includes(u.email?.toLowerCase()));

// Calculate stats
const totalUsers = users.length;
const paidUsers = users.filter(u => u.payment_verified === true);
const pendingUsers = users.filter(u => u.payment_verified !== true);
const totalRevenue = paidUsers.length * 50; // 50€ per course

// Group by payment method
const stripePayments = paidUsers.filter(u => u.payment_method === 'stripe').length;
const manualPayments = paidUsers.filter(u => u.payment_method === 'manual').length;
const otherPayments = paidUsers.filter(u => u.payment_method && u.payment_method !== 'stripe' && u.payment_method !== 'manual').length;

// Recent activity (last 7 days)
const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
const recentSignups = users.filter(u => new Date(u.created_at) > sevenDaysAgo).length;
const recentPaid = paidUsers.filter(u => u.payment_date && new Date(u.payment_date) > sevenDaysAgo).length;

// Format date helper
function formatDate(dateStr: string): string {
  if (!dateStr) return '-';
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}
---

<AulaLayout title="Admin - Curso Wazuh">
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold" style="color: #ffffff;">
          Panel de Administracion
        </h1>
        <p class="mt-2" style="color: #9ca3af;">
          Curso Intensivo de Wazuh
        </p>
      </div>
      <a href="/aula" class="px-4 py-2 rounded-lg transition-colors hover:opacity-80" style="background-color: #374151; color: #e5e7eb;">
        Volver al curso
      </a>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <!-- Total Registrados -->
    <div class="rounded-xl p-6" style="background-color: #1a1f26; border: 1px solid #2d3748;">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background-color: rgba(59, 130, 246, 0.2);">
          <svg class="w-6 h-6" style="color: #60a5fa;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <div>
          <p class="text-sm" style="color: #9ca3af;">Total Registrados</p>
          <p class="text-2xl font-bold" style="color: #ffffff;">{totalUsers}</p>
        </div>
      </div>
    </div>

    <!-- Pagados -->
    <div class="rounded-xl p-6" style="background-color: #1a1f26; border: 1px solid #2d3748;">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background-color: rgba(34, 197, 94, 0.2);">
          <svg class="w-6 h-6" style="color: #4ade80;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-sm" style="color: #9ca3af;">Pagados</p>
          <p class="text-2xl font-bold" style="color: #4ade80;">{paidUsers.length}</p>
        </div>
      </div>
    </div>

    <!-- Pendientes -->
    <div class="rounded-xl p-6" style="background-color: #1a1f26; border: 1px solid #2d3748;">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background-color: rgba(245, 158, 11, 0.2);">
          <svg class="w-6 h-6" style="color: #fbbf24;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-sm" style="color: #9ca3af;">Pendientes de pago</p>
          <p class="text-2xl font-bold" style="color: #fbbf24;">{pendingUsers.length}</p>
        </div>
      </div>
    </div>

    <!-- Ingresos -->
    <div class="rounded-xl p-6" style="background-color: #1a1f26; border: 1px solid #22c55e;">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background-color: rgba(34, 197, 94, 0.2);">
          <svg class="w-6 h-6" style="color: #4ade80;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-sm" style="color: #9ca3af;">Ingresos totales</p>
          <p class="text-2xl font-bold" style="color: #4ade80;">{totalRevenue}€</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Secondary Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <!-- Payment Methods -->
    <div class="rounded-xl p-6" style="background-color: #1a1f26; border: 1px solid #2d3748;">
      <h3 class="text-sm font-medium mb-4" style="color: #9ca3af;">Metodos de pago</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span style="color: #e5e7eb;">Stripe (tarjeta)</span>
          <span class="font-bold" style="color: #60a5fa;">{stripePayments}</span>
        </div>
        <div class="flex items-center justify-between">
          <span style="color: #e5e7eb;">Manual (verificado)</span>
          <span class="font-bold" style="color: #fbbf24;">{manualPayments}</span>
        </div>
        {otherPayments > 0 && (
          <div class="flex items-center justify-between">
            <span style="color: #e5e7eb;">Otros</span>
            <span class="font-bold" style="color: #9ca3af;">{otherPayments}</span>
          </div>
        )}
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="rounded-xl p-6" style="background-color: #1a1f26; border: 1px solid #2d3748;">
      <h3 class="text-sm font-medium mb-4" style="color: #9ca3af;">Ultimos 7 dias</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span style="color: #e5e7eb;">Nuevos registros</span>
          <span class="font-bold" style="color: #60a5fa;">{recentSignups}</span>
        </div>
        <div class="flex items-center justify-between">
          <span style="color: #e5e7eb;">Nuevos pagos</span>
          <span class="font-bold" style="color: #4ade80;">{recentPaid}</span>
        </div>
      </div>
    </div>

    <!-- Conversion Rate -->
    <div class="rounded-xl p-6" style="background-color: #1a1f26; border: 1px solid #2d3748;">
      <h3 class="text-sm font-medium mb-4" style="color: #9ca3af;">Tasa de conversion</h3>
      <div class="flex items-end gap-2">
        <span class="text-3xl font-bold" style="color: #ffffff;">
          {totalUsers > 0 ? Math.round((paidUsers.length / totalUsers) * 100) : 0}%
        </span>
        <span class="text-sm mb-1" style="color: #9ca3af;">
          ({paidUsers.length} de {totalUsers})
        </span>
      </div>
      <div class="mt-3 h-2 rounded-full overflow-hidden" style="background-color: #374151;">
        <div
          class="h-full rounded-full"
          style={`width: ${totalUsers > 0 ? (paidUsers.length / totalUsers) * 100 : 0}%; background-color: #4ade80;`}
        ></div>
      </div>
    </div>
  </div>

  <!-- Users Table -->
  <div class="rounded-xl overflow-hidden" style="background-color: #1a1f26; border: 1px solid #2d3748;">
    <div class="p-4 border-b" style="border-color: #2d3748;">
      <h2 class="text-lg font-bold" style="color: #ffffff;">Usuarios registrados</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr style="background-color: #0f1419;">
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider" style="color: #9ca3af;">Estado</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider" style="color: #9ca3af;">Email</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider" style="color: #9ca3af;">Nombre</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider" style="color: #9ca3af;">Metodo</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider" style="color: #9ca3af;">Registro</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider" style="color: #9ca3af;">Pago</th>
          </tr>
        </thead>
        <tbody class="divide-y" style="border-color: #2d3748;">
          {users.map((u: any) => (
            <tr class="hover:bg-white/5 transition-colors">
              <td class="px-4 py-3">
                {u.payment_verified ? (
                  <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium" style="background-color: rgba(34, 197, 94, 0.2); color: #4ade80;">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Pagado
                  </span>
                ) : (
                  <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium" style="background-color: rgba(245, 158, 11, 0.2); color: #fbbf24;">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Pendiente
                  </span>
                )}
              </td>
              <td class="px-4 py-3 text-sm" style="color: #ffffff;">{u.email}</td>
              <td class="px-4 py-3 text-sm" style="color: #e5e7eb;">{u.name || '-'}</td>
              <td class="px-4 py-3 text-sm" style="color: #9ca3af;">
                {u.payment_method === 'stripe' ? 'Tarjeta' : u.payment_method === 'manual' ? 'Manual' : u.payment_method || '-'}
              </td>
              <td class="px-4 py-3 text-sm" style="color: #9ca3af;">{formatDate(u.created_at)}</td>
              <td class="px-4 py-3 text-sm" style="color: #9ca3af;">{formatDate(u.payment_date)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AulaLayout>
