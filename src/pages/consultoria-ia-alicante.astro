---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Consultoría IA para Empresas en Alicante | AI Security";
const description = "Implementamos herramientas de inteligencia artificial en empresas de Alicante. Automatización, chatbots, atención al cliente IA y formación. Primera consulta gratuita.";
const canonical = "https://aisecurity.es/consultoria-ia-alicante";

const sectores = [
  { icon: "🏨", nombre: "Turismo y hostelería", uso: "Recepcionista virtual, gestión de reservas automática y atención al cliente 24/7 en varios idiomas" },
  { icon: "👟", nombre: "Calzado y textil", uso: "Automatización de pedidos, catálogos digitales y comunicación con distribuidores internacionales" },
  { icon: "🏗️", nombre: "Construcción e inmobiliaria", uso: "Gestión documental, presupuestos automáticos y atención a clientes potenciales" },
  { icon: "🍽️", nombre: "Restauración y ocio", uso: "Chatbots de reservas, gestión de reseñas y automatización de comunicaciones" },
  { icon: "🌱", nombre: "Agroalimentación", uso: "Trazabilidad, informes automáticos de producción y atención a distribuidores" },
  { icon: "⚖️", nombre: "Servicios profesionales", uso: "Automatización de informes, gestión documental y atención al cliente IA" },
];

const departamentos = [
  {
    id: "comunicacion",
    nombre: "Comunicación",
    icon: "🎨",
    color: "#84cc16",
    resumen: "Genera contenido visual, vídeos y creatividades con IA generativa",
    objetivos: [
      { icono: "⏱️", texto: "Reduce un 70% el tiempo de producción de contenido visual" },
      { icono: "📈", texto: "Multiplica por 10 el volumen de publicaciones sin ampliar el equipo" },
    ],
    herramientas: [
      { nombre: "Midjourney", uso: "Imágenes y creatividades profesionales por prompt" },
      { nombre: "HeyGen", uso: "Avatares de vídeo con voz natural en español" },
      { nombre: "Canva AI", uso: "Diseño asistido, fondo automático, redimensionado inteligente" },
    ],
  },
  {
    id: "comercial",
    nombre: "Comercial & SEO",
    icon: "📊",
    color: "#f59e0b",
    resumen: "Analítica automática, SEO con IA y seguimiento de oportunidades",
    objetivos: [
      { icono: "📬", texto: "Informes semanales automáticos enviados a tu email sin trabajo manual" },
      { icono: "🎯", texto: "Detecta keywords y oportunidades de captación antes que la competencia" },
    ],
    herramientas: [
      { nombre: "Claude + Excel/Word", uso: "Genera propuestas comerciales, analiza datos de ventas y resume reuniones por chat" },
      { nombre: "GSC + GA4 Automation", uso: "Scripts propios que analizan tu web semanalmente con IA" },
      { nombre: "n8n + LLM", uso: "Flujos automáticos de seguimiento de leads y CRM" },
    ],
  },
  {
    id: "callcenter",
    nombre: "Call Center & Soporte",
    icon: "📞",
    color: "#10b981",
    resumen: "Atención telefónica y chat con IA que nunca descansa",
    objetivos: [
      { icono: "🤖", texto: "Resuelve el 80% de consultas habituales sin intervención humana" },
      { icono: "🕐", texto: "Disponible 24/7 sin coste adicional de personal" },
    ],
    herramientas: [
      { nombre: "Atención Llamadas IA", uso: "Recepcionista virtual 24/7 con voz natural en español" },
      { nombre: "Chatbot Empresarial IA", uso: "Chat con acceso a tu base de datos y ERP en tiempo real" },
      { nombre: "ElevenLabs", uso: "Voces IA ultra-realistas en español para agentes telefónicos" },
    ],
  },
  {
    id: "proyectos",
    nombre: "Gestión de Proyectos",
    icon: "📋",
    color: "#3b82f6",
    resumen: "IA integrada en tu herramienta de proyectos para acelerar entregas",
    objetivos: [
      { icono: "⚡", texto: "Reduce un 50% el tiempo de planificación y reporting de sprints" },
      { icono: "🔍", texto: "Detecta bloqueos y riesgos antes de que impacten en el plazo" },
    ],
    herramientas: [
      { nombre: "Jira + Atlassian Intelligence", uso: "Creación automática de subtareas, resumen de issues" },
      { nombre: "Notion AI", uso: "Documentación de proyectos y wikis que se actualizan solas" },
      { nombre: "n8n", uso: "Automatiza notificaciones, asignaciones y reportes entre herramientas" },
    ],
  },
  {
    id: "administracion",
    nombre: "Administración",
    icon: "🧾",
    color: "#ef4444",
    resumen: "Facturas, presupuestos y contabilidad gestionados de forma automática",
    objetivos: [
      { icono: "🧾", texto: "Procesa facturas en segundos en vez de 5-10 minutos por documento" },
      { icono: "✅", texto: "Elimina errores de introducción manual de datos contables" },
    ],
    herramientas: [
      { nombre: "Claude + Excel/Word", uso: "Redacta presupuestos, analiza hojas de cálculo y resume contratos por chat" },
      { nombre: "Mindee", uso: "OCR inteligente que extrae datos de facturas y recibos automáticamente" },
      { nombre: "n8n + ChatGPT", uso: "Flujos que clasifican, registran y notifican facturas entrantes" },
    ],
  },
  {
    id: "desarrollo",
    nombre: "Desarrollo",
    icon: "💻",
    color: "#06b6d4",
    resumen: "Acelera tu equipo de desarrollo con IA en cada paso del ciclo",
    objetivos: [
      { icono: "🚀", texto: "Multiplica por 2-3x la velocidad de entrega de features" },
      { icono: "🛡️", texto: "Reduce un 60% los bugs que llegan a producción" },
    ],
    herramientas: [
      { nombre: "Claude Code", uso: "Agente de desarrollo que lee tu repo y ejecuta tareas completas" },
      { nombre: "GitHub Copilot", uso: "Autocompletado de código en tiempo real en el IDE" },
      { nombre: "GitHub Actions + IA", uso: "Pipelines que generan tests y detectan bugs automáticamente" },
    ],
  },
  {
    id: "devops",
    nombre: "DevOps",
    icon: "⚙️",
    color: "#f97316",
    resumen: "Infraestructura como código y automatización de despliegues con IA",
    objetivos: [
      { icono: "📡", texto: "Resuelve incidencias hasta 3x más rápido con diagnóstico automático" },
      { icono: "🔄", texto: "Despliegues continuos sin downtime ni intervención manual" },
    ],
    herramientas: [
      { nombre: "Ansible + IA", uso: "Playbooks generados automáticamente para configuración de servidores" },
      { nombre: "Kubernetes + K8sGPT", uso: "Diagnóstico automático de errores en clústeres K8s" },
      { nombre: "Datadog AI", uso: "Monitorización con detección de anomalías y alertas inteligentes" },
    ],
  },
  {
    id: "sistemas",
    nombre: "Sistemas",
    icon: "🖥️",
    color: "#8b5cf6",
    resumen: "Administración de sistemas con documentación automática y seguridad IA",
    objetivos: [
      { icono: "🛡️", texto: "Detección de amenazas en tiempo real con cumplimiento ENS automático" },
      { icono: "📝", texto: "Cada cambio en producción genera documentación automática en la wiki" },
    ],
    herramientas: [
      { nombre: "Wazuh", uso: "SIEM open-source: detección de amenazas y cumplimiento ENS" },
      { nombre: "Ansible + LLM", uso: "Automatiza tareas repetitivas de administración por lenguaje natural" },
      { nombre: "Netdata", uso: "Monitorización en tiempo real de servidores con IA predictiva" },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Schema.org LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "AI Security — Consultoría IA Alicante",
    "description": "Consultoría de inteligencia artificial para empresas en Alicante. Implementación de herramientas IA, automatización de procesos y formación.",
    "url": "https://aisecurity.es/consultoria-ia-alicante",
    "areaServed": [
      { "@type": "City", "name": "Alicante" },
      { "@type": "AdministrativeArea", "name": "Alicante" },
      { "@type": "AdministrativeArea", "name": "Comunitat Valenciana" }
    ],
    "serviceType": "Consultoría de Inteligencia Artificial",
    "provider": {
      "@type": "Organization",
      "name": "AI Security",
      "url": "https://aisecurity.es"
    }
  })} />

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0a0d1a 0%, #0f1628 50%, #0a0d1a 100%); padding: 80px 0 60px;">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 50%, #4f7cff 0%, transparent 50%), radial-gradient(circle at 80% 50%, #8b5cf6 0%, transparent 50%);"></div>
    <div class="max-w-5xl mx-auto px-6 text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium mb-6" style="background: rgba(79,124,255,0.15); border: 1px solid rgba(79,124,255,0.3); color: #7da4ff;">
        <span>📍</span> Consultoría IA · Alicante
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight" style="color: #fff;">
        Consultoría de IA para empresas<br/>
        <span style="background: linear-gradient(90deg, #4f7cff, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">en Alicante</span>
      </h1>
      <p class="text-lg max-w-3xl mx-auto mb-8" style="color: #94a3b8; line-height: 1.7;">
        Del sector turístico al calzado, pasando por la construcción y los servicios. Implementamos la IA que tu empresa en Alicante necesita para trabajar mejor, con menos tareas repetitivas y más tiempo para lo que importa.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/presupuesto?plan=Consultoria-IA-Alicante"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold transition-all"
          style="background: linear-gradient(135deg, #4f7cff, #7c3aed); color: #ffffff;">
          Consulta gratuita en Alicante →
        </a>
        <a href="/consultoria-ia"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold"
          style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); color: #cbd5e1;">
          Ver todos los servicios IA →
        </a>
      </div>
    </div>
  </section>

  <!-- SECTORES ALICANTE -->
  <section style="background: #0a0d1a; padding: 80px 0;">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-3" style="color: #e2e8f0;">
          Sectores en Alicante donde implementamos IA
        </h2>
        <p style="color: #64748b; max-width: 520px; margin: 0 auto;">Alicante combina un sector turístico potente con una industria diversa. La IA tiene aplicaciones concretas en todos ellos.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {sectores.map(s => (
          <div class="rounded-xl p-5" style="background: #1a1d27; border: 1px solid #2a2d3a;">
            <div style="font-size: 28px; margin-bottom: 10px;">{s.icon}</div>
            <h3 style="font-size: 1rem; font-weight: 700; color: #e2e8f0; margin-bottom: 6px;">{s.nombre}</h3>
            <p style="color: #64748b; font-size: 0.875rem; line-height: 1.6;">{s.uso}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUÉ IMPLEMENTAMOS -->
  <section style="background: #0f1117; padding: 80px 0; border-top: 1px solid #1e2130;">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-3" style="color: #e2e8f0;">¿Qué IA implementamos en tu empresa?</h2>
        <p style="color: #64748b; max-width: 480px; margin: 0 auto;">Herramientas reales con resultados medibles desde el primer mes.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { icon: "💬", titulo: "Chatbot empresarial IA", desc: "Atiende el 80% de las consultas habituales en varios idiomas, 24 horas al día. Especialmente útil en el sector turístico de Alicante con clientes internacionales.", ahorro: "Atención multiidioma sin coste adicional de personal" },
          { icon: "⚙️", titulo: "Automatización de procesos", desc: "Elimina tareas repetitivas: reservas, confirmaciones, facturas, actualizaciones de disponibilidad. Todo automático con integraciones a tu software actual.", ahorro: "Ahorra entre 10 y 40 horas/mes por departamento" },
          { icon: "📞", titulo: "Recepcionista virtual IA", desc: "Atiende llamadas con voz natural en español e inglés, gestiona reservas, responde preguntas frecuentes y deriva a persona humana cuando es necesario.", ahorro: "Disponible 24/7 sin coste de personal adicional" },
          { icon: "📄", titulo: "Gestor documental IA", desc: "Encuentra contratos, licencias, manuales y documentación interna en segundos. Búsqueda semántica en toda la documentación de tu empresa.", ahorro: "Reduce de 10-15 min a segundos la búsqueda de información" },
          { icon: "📊", titulo: "Analítica e informes automáticos", desc: "Datos de ocupación, ventas o producción analizados automáticamente cada semana y enviados a tu email. Sin exportar ni copiar datos a mano.", ahorro: "Decisiones basadas en datos sin trabajo extra" },
          { icon: "🤖", titulo: "Asistentes IA para el equipo", desc: "Configuramos asistentes con el contexto de tu empresa: respuestas a clientes, redacción de presupuestos, gestión de reseñas online, análisis de temporada.", ahorro: "Multiplica la productividad de cada empleado" },
        ].map(item => (
          <div class="rounded-xl p-6" style="background: #1a1d27; border: 1px solid #2a2d3a;">
            <div style="font-size: 28px; margin-bottom: 12px;">{item.icon}</div>
            <h3 style="font-size: 1.05rem; font-weight: 700; color: #e2e8f0; margin-bottom: 8px;">{item.titulo}</h3>
            <p style="color: #64748b; font-size: 0.875rem; line-height: 1.6; margin-bottom: 10px;">{item.desc}</p>
            <div style="font-size: 0.8rem; font-weight: 600; color: #86efac; background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); padding: 6px 10px; border-radius: 8px;">💡 {item.ahorro}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DIAGRAMA INTERACTIVO -->
  <section style="background: #0a0d1a; padding: 80px 0; border-top: 1px solid #1e2130;">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-3" style="color: #e2e8f0;">
          ¿Qué IA puede usar cada departamento?
        </h2>
        <p style="color: #64748b; font-size: 1.05rem; max-width: 480px; margin: 0 auto;">Selecciona un departamento para ver las herramientas y el ahorro estimado</p>
      </div>

      <div class="flex flex-col xl:flex-row gap-8 items-start justify-center">

        <div id="diagram-container" style="flex-shrink: 0; display: flex; flex-direction: column; gap: 16px;">
          <svg id="diagram-svg" width="560" height="560" viewBox="0 0 560 560" style="display: block; margin: 0 auto;">
            <g id="lines"></g>
            <g id="center-node">
              <circle cx="280" cy="280" r="62" fill="#1a1d27" stroke="#4f7cff" stroke-width="2"/>
              <circle cx="280" cy="280" r="56" fill="#0f1628" stroke="#4f7cff" stroke-width="1" opacity="0.5"/>
              <text x="280" y="272" text-anchor="middle" fill="#e2e8f0" font-size="14" font-weight="700">Tu</text>
              <text x="280" y="290" text-anchor="middle" fill="#e2e8f0" font-size="14" font-weight="700">Empresa</text>
              <text x="280" y="308" text-anchor="middle" fill="#4f7cff" font-size="10">+ IA</text>
            </g>
            <g id="nodes"></g>
          </svg>
        </div>

        <div id="info-panel" style="flex: 1; min-width: 300px; max-width: 480px; position: sticky; top: 24px;">
          <div id="panel-default" style="background: #1a1d27; border: 1px solid #2a2d3a; border-radius: 16px; padding: 32px; text-align: center;">
            <div style="font-size: 48px; margin-bottom: 16px; opacity: 0.4;">👆</div>
            <p style="color: #64748b; font-size: 1rem;">Haz clic en cualquier departamento del diagrama para ver las herramientas de IA recomendadas</p>
          </div>
          <div id="panel-active" style="display: none; background: #1a1d27; border-radius: 16px; overflow: hidden; min-height: 560px;">
            <div id="panel-header" style="padding: 20px 24px; display: flex; align-items: center; gap: 12px;">
              <span id="panel-icon" style="font-size: 28px;"></span>
              <div>
                <h3 id="panel-title" style="font-size: 1.2rem; font-weight: 700; color: #e2e8f0; margin-bottom: 4px;"></h3>
                <p id="panel-resumen" style="font-size: 0.85rem; color: #94a3b8;"></p>
              </div>
            </div>
            <div style="padding: 0 24px 4px;">
              <p style="font-size: 0.75rem; font-weight: 600; color: #a78bfa; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; margin-top: 16px;">Qué gana tu empresa</p>
              <div id="panel-objetivos" style="display: flex; flex-direction: column; gap: 6px;"></div>
            </div>
            <div style="padding: 0 24px;">
              <p style="font-size: 0.75rem; font-weight: 600; color: #4f7cff; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; margin-top: 12px;">Herramientas que utilizamos</p>
              <div id="panel-tools" style="display: flex; flex-direction: column; gap: 8px;"></div>
            </div>
            <div style="padding: 0 24px 24px; margin-top: 16px;">
              <a href="/presupuesto?plan=Consultoria-IA-Alicante" style="display: block; text-align: center; background: linear-gradient(135deg, #4f7cff, #7c3aed); color: #ffffff; border-radius: 10px; padding: 12px; font-size: 0.9rem; font-weight: 600; text-decoration: none;">
                Quiero implementar esto →
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CÓMO TRABAJAMOS -->
  <section style="background: #0f1117; padding: 80px 0; border-top: 1px solid #1e2130;">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-3" style="color: #e2e8f0;">Cómo trabajamos con empresas en Alicante</h2>
        <p style="color: #64748b; max-width: 480px; margin: 0 auto;">Sin humo. Sin herramientas genéricas. Con resultados medibles.</p>
      </div>
      <div class="grid md:grid-cols-4 gap-6">
        {[
          { paso: "01", titulo: "Diagnóstico", desc: "Reunión presencial en Alicante o videoconferencia. Analizamos tu empresa, herramientas actuales y dónde tiene más sentido aplicar IA.", icon: "🔍" },
          { paso: "02", titulo: "Propuesta", desc: "Plan concreto con qué implementar, en qué orden y con qué inversión. Sin sorpresas ni compromiso previo.", icon: "📐" },
          { paso: "03", titulo: "Implementación", desc: "Configuramos cada solución en vuestro entorno real. Probamos hasta que funciona exactamente como necesitáis.", icon: "🛠️" },
          { paso: "04", titulo: "Formación", desc: "Formamos a tu equipo en Alicante. Sesiones prácticas, guías en castellano y soporte post-implantación.", icon: "🎓" },
        ].map(item => (
          <div style="text-align: center;">
            <div style="font-size: 32px; margin-bottom: 12px;">{item.icon}</div>
            <div style="font-size: 0.75rem; font-weight: 700; color: #4f7cff; letter-spacing: 0.1em; margin-bottom: 6px;">PASO {item.paso}</div>
            <h3 style="font-size: 1rem; font-weight: 700; color: #e2e8f0; margin-bottom: 8px;">{item.titulo}</h3>
            <p style="color: #64748b; font-size: 0.875rem; line-height: 1.6;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background: #0a0d1a; padding: 80px 0; border-top: 1px solid #1e2130;">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-10 text-center" style="color: #e2e8f0;">Preguntas frecuentes</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        {[
          { q: "¿Funcionan los chatbots en inglés para el sector turístico?", a: "Sí. Configuramos chatbots y recepcionistas virtuales en los idiomas que necesites: español, inglés, francés, alemán... Especialmente útil para hoteles, restaurantes y empresas turísticas de Alicante." },
          { q: "¿Es necesario cambiar el software que ya usamos?", a: "No. Integramos la IA con las herramientas que ya tenéis: PMS hotelero, ERP, CRM, email. No hace falta cambiar nada, añadimos la capa de automatización por encima." },
          { q: "¿Cuánto tarda en verse el retorno de la inversión?", a: "En el sector turístico, un chatbot de reservas o una recepcionista virtual suelen amortizarse en la primera temporada alta. En otros sectores, generalmente en 1-3 meses." },
          { q: "¿Hacéis visitas presenciales en Alicante?", a: "Sí. Podemos desplazarnos a Alicante para reuniones, demostraciones o formaciones, o hacerlo en remoto si lo prefieres." },
          { q: "¿Trabajáis con empresas pequeñas o solo grandes empresas?", a: "La mayoría de nuestros clientes son PyMEs de 5 a 150 empleados. Adaptamos siempre la propuesta al tamaño y presupuesto de cada empresa." },
        ].map(item => (
          <div style="background: #1a1d27; border: 1px solid #2a2d3a; border-radius: 12px; padding: 20px 24px;">
            <h3 style="font-size: 0.95rem; font-weight: 700; color: #e2e8f0; margin-bottom: 8px;">{item.q}</h3>
            <p style="color: #64748b; font-size: 0.875rem; line-height: 1.7; margin: 0;">{item.a}</p>
          </div>
        ))}
      </div>
      <div class="flex flex-col items-center gap-3 mt-12 pt-10" style="border-top: 1px solid #2a2d3a;">
        <p style="color: #64748b; font-size: 0.875rem; text-align: center;">También ofrecemos consultoría IA en otras provincias de la Comunitat Valenciana:</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/consultoria-ia-valencia" style="padding: 8px 18px; border-radius: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; font-size: 0.875rem; text-decoration: none;">Valencia →</a>
          <a href="/consultoria-ia-castellon" style="padding: 8px 18px; border-radius: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; font-size: 0.875rem; text-decoration: none;">Castellón →</a>
          <a href="/consultoria-ia" style="padding: 8px 18px; border-radius: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; font-size: 0.875rem; text-decoration: none;">Ver todos los servicios IA →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section style="background: linear-gradient(135deg, #0f1628, #1a0a2e); padding: 80px 0; border-top: 1px solid #1e2130;">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #fff;">¿Tu empresa en Alicante lista para usar IA?</h2>
      <p class="text-lg mb-8" style="color: #94a3b8;">Primera consulta gratuita. Te decimos con honestidad qué tiene sentido implementar en tu caso y qué no.</p>
      <a href="/presupuesto?plan=Consultoria-IA-Alicante"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-xl font-bold text-lg transition-all"
        style="background: linear-gradient(135deg, #4f7cff, #7c3aed); color: #ffffff;">
        Solicitar consulta gratuita en Alicante
      </a>
    </div>
  </section>

</BaseLayout>

<script define:vars={{ departamentos }} is:inline>
  const SVG_SIZE = 560;
  const CENTER = SVG_SIZE / 2;
  const ORBIT_RADIUS = 200;
  const NODE_RADIUS = 46;

  const linesGroup = document.getElementById('lines');
  const nodesGroup = document.getElementById('nodes');
  const panelDefault = document.getElementById('panel-default');
  const panelActive = document.getElementById('panel-active');
  const panelHeader = document.getElementById('panel-header');
  const panelIcon = document.getElementById('panel-icon');
  const panelTitle = document.getElementById('panel-title');
  const panelResumen = document.getElementById('panel-resumen');
  const panelTools = document.getElementById('panel-tools');
  let activeId = null;

  function getPos(index, total) {
    const angle = (index / total) * 2 * Math.PI - Math.PI / 2;
    return { x: CENTER + ORBIT_RADIUS * Math.cos(angle), y: CENTER + ORBIT_RADIUS * Math.sin(angle) };
  }

  departamentos.forEach((dep, i) => {
    const pos = getPos(i, departamentos.length);
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', CENTER); line.setAttribute('y1', CENTER);
    line.setAttribute('x2', pos.x); line.setAttribute('y2', pos.y);
    line.setAttribute('stroke', dep.color); line.setAttribute('stroke-width', '1.5');
    line.setAttribute('opacity', '0.3'); line.id = `line-${dep.id}`;
    linesGroup.appendChild(line);
  });

  departamentos.forEach((dep, i) => {
    const pos = getPos(i, departamentos.length);
    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('cursor', 'pointer'); g.id = `node-${dep.id}`;

    const bg = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    bg.setAttribute('cx', pos.x); bg.setAttribute('cy', pos.y); bg.setAttribute('r', NODE_RADIUS);
    bg.setAttribute('fill', '#1a1d27'); bg.setAttribute('stroke', dep.color);
    bg.setAttribute('stroke-width', '1.5'); bg.setAttribute('opacity', '0.8'); bg.id = `bg-${dep.id}`;

    const icon = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    icon.setAttribute('x', pos.x); icon.setAttribute('y', pos.y - 8);
    icon.setAttribute('text-anchor', 'middle'); icon.setAttribute('dominant-baseline', 'middle');
    icon.setAttribute('font-size', '20'); icon.textContent = dep.icon;

    const words = dep.nombre.split(' & ');
    if (words.length > 1) {
      const t1 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t1.setAttribute('x', pos.x); t1.setAttribute('y', pos.y + 10);
      t1.setAttribute('text-anchor', 'middle'); t1.setAttribute('fill', '#cbd5e1');
      t1.setAttribute('font-size', '9'); t1.setAttribute('font-weight', '600'); t1.textContent = words[0];
      const t2 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t2.setAttribute('x', pos.x); t2.setAttribute('y', pos.y + 22);
      t2.setAttribute('text-anchor', 'middle'); t2.setAttribute('fill', '#4f7cff');
      t2.setAttribute('font-size', '8'); t2.setAttribute('font-weight', '600'); t2.textContent = '& ' + words[1];
      g.appendChild(bg); g.appendChild(icon); g.appendChild(t1); g.appendChild(t2);
    } else {
      const nameWords = dep.nombre.split(' ');
      if (nameWords.length > 2) {
        const t1 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        t1.setAttribute('x', pos.x); t1.setAttribute('y', pos.y + 10);
        t1.setAttribute('text-anchor', 'middle'); t1.setAttribute('fill', '#cbd5e1');
        t1.setAttribute('font-size', '9'); t1.setAttribute('font-weight', '600');
        t1.textContent = nameWords.slice(0, 2).join(' ');
        const t2 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        t2.setAttribute('x', pos.x); t2.setAttribute('y', pos.y + 22);
        t2.setAttribute('text-anchor', 'middle'); t2.setAttribute('fill', '#cbd5e1');
        t2.setAttribute('font-size', '9'); t2.setAttribute('font-weight', '600');
        t2.textContent = nameWords.slice(2).join(' ');
        g.appendChild(bg); g.appendChild(icon); g.appendChild(t1); g.appendChild(t2);
      } else {
        const name = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        name.setAttribute('x', pos.x); name.setAttribute('y', pos.y + 16);
        name.setAttribute('text-anchor', 'middle'); name.setAttribute('fill', '#cbd5e1');
        name.setAttribute('font-size', '9.5'); name.setAttribute('font-weight', '600');
        name.textContent = dep.nombre;
        g.appendChild(bg); g.appendChild(icon); g.appendChild(name);
      }
    }

    g.addEventListener('click', () => selectDep(dep.id));
    g.addEventListener('mouseenter', () => { if (activeId !== dep.id) { bg.setAttribute('opacity', '1'); bg.setAttribute('stroke-width', '2'); } });
    g.addEventListener('mouseleave', () => { if (activeId !== dep.id) { bg.setAttribute('opacity', '0.8'); bg.setAttribute('stroke-width', '1.5'); } });
    nodesGroup.appendChild(g);
  });

  function selectDep(id) {
    activeId = id;
    const dep = departamentos.find(d => d.id === id);
    if (!dep) return;

    departamentos.forEach(d => {
      const bg = document.getElementById(`bg-${d.id}`);
      const line = document.getElementById(`line-${d.id}`);
      if (bg) { bg.setAttribute('opacity', '0.8'); bg.setAttribute('stroke-width', '1.5'); bg.setAttribute('fill', '#1a1d27'); }
      if (line) { line.setAttribute('opacity', '0.3'); line.setAttribute('stroke-width', '1.5'); }
    });

    const activeBg = document.getElementById(`bg-${id}`);
    const activeLine = document.getElementById(`line-${id}`);
    if (activeBg) { activeBg.setAttribute('opacity', '1'); activeBg.setAttribute('stroke-width', '3'); activeBg.setAttribute('fill', dep.color + '22'); }
    if (activeLine) { activeLine.setAttribute('opacity', '0.8'); activeLine.setAttribute('stroke-width', '2.5'); }

    panelDefault.style.display = 'none';
    panelActive.style.display = 'block';
    panelActive.style.border = `1px solid ${dep.color}40`;
    panelHeader.style.background = `${dep.color}18`;
    panelHeader.style.borderBottom = `1px solid ${dep.color}30`;
    panelIcon.textContent = dep.icon;
    panelTitle.textContent = dep.nombre;
    panelTitle.style.color = dep.color;
    panelResumen.textContent = dep.resumen;

    const panelObjetivos = document.getElementById('panel-objetivos');
    if (panelObjetivos) {
      panelObjetivos.innerHTML = dep.objetivos.map(o => `
        <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:${dep.color}12;border:1px solid ${dep.color}28;border-radius:8px;">
          <span style="font-size:15px;flex-shrink:0;">${o.icono}</span>
          <span style="font-size:0.82rem;font-weight:600;color:#e2e8f0;line-height:1.4;">${o.texto}</span>
        </div>`).join('');
    }

    panelTools.innerHTML = '';
    dep.herramientas.forEach(h => {
      const item = document.createElement('div');
      item.style.cssText = `background: rgba(255,255,255,0.04); border-radius: 8px; padding: 10px 12px; border-left: 3px solid ${dep.color};`;
      item.innerHTML = `<div style="font-size: 0.85rem; font-weight: 600; color: #e2e8f0; margin-bottom: 2px;">${h.nombre}</div><div style="font-size: 0.78rem; color: #64748b;">${h.uso}</div>`;
      panelTools.appendChild(item);
    });
  }

  document.addEventListener('DOMContentLoaded', () => selectDep('desarrollo'));
  if (document.readyState === 'complete' || document.readyState === 'interactive') { selectDep('desarrollo'); }
</script>
