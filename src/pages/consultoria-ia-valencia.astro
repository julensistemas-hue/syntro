---
// Página de ciudad: solo DATOS de Valencia. Lo genérico está en CiudadConsultoria.
import CiudadConsultoria from "../components/consultoria/CiudadConsultoria.astro";

const sectores = [
  { icon: "🚚", nombre: "Logística y distribución", uso: "Automatización de albaranes, rutas y comunicación con clientes" },
  { icon: "🏭", nombre: "Industria y manufactura", uso: "Gestión documental, control de calidad y reporting automático" },
  { icon: "🛒", nombre: "Comercio y e-commerce", uso: "Atención al cliente 24/7, gestión de pedidos e inventario" },
  { icon: "🏥", nombre: "Clínicas y salud", uso: "Recepcionista virtual, citas automáticas y seguimiento de pacientes" },
  { icon: "🏗️", nombre: "Construcción e ingeniería", uso: "Gestión de proyectos, presupuestos automáticos y documentación" },
  { icon: "⚖️", nombre: "Servicios profesionales", uso: "Automatización de informes, contratos y comunicación con clientes" },
];

const faq = [
  { q: "¿Trabajáis con empresas pequeñas en Valencia?", a: "Sí. La mayoría de nuestros clientes son PyMEs de 10 a 100 empleados. Adaptamos la propuesta al tamaño y presupuesto de cada empresa." },
  { q: "¿Es necesario tener conocimientos técnicos?", a: "No. Nos encargamos de toda la configuración técnica. Tu equipo solo necesita aprender a usar las herramientas, que es lo que cubrimos en la formación." },
  { q: "¿Cuánto tarda la implementación?", a: "Depende de la complejidad. Un chatbot básico o un flujo de automatización puede estar funcionando en 2-3 semanas. Una implementación completa por departamentos puede llevar 2-3 meses." },
  { q: "¿Hacéis visitas presenciales en Valencia?", a: "Sí. Podemos hacer la reunión de diagnóstico y las sesiones de formación de forma presencial en Valencia, o en remoto si lo prefieres." },
  { q: "¿Qué pasa si una herramienta deja de funcionar o cambia?", a: "El ecosistema IA cambia constantemente. Por eso ofrecemos mantenimiento y actualización. Si una herramienta queda obsoleta, te proponemos la alternativa y la configuramos." },
];
---

<CiudadConsultoria
  nombre="Valencia"
  slug="consultoria-ia-valencia"
  title="Consultoría IA para Empresas en Valencia | AI Security"
  description="Implementamos herramientas de inteligencia artificial en empresas de Valencia. Automatización de procesos, chatbots, gestión documental y formación al equipo. Primera consulta gratuita."
  heroIntro="Analizamos tu empresa departamento a departamento e implementamos las herramientas de IA que realmente tienen sentido para tu negocio en Valencia. Sin soluciones genéricas. Con formación para tu equipo incluida."
  sectoresIntro="Valencia tiene un tejido empresarial diverso. Trabajamos con empresas de todos los sectores."
  sectores={sectores}
  faq={faq}
/>
