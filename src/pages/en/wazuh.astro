---
import WazuhLayout from "../../layouts/WazuhLayoutEn.astro";
export const prerender = false; // Force SSR to bypass cache

const title = "Wazuh Implementation & Managed SIEM Services | AI Security";
const description = "Professional Wazuh implementation, deployment and managed services. Open source SIEM/XDR setup, threat detection, compliance and consulting for companies worldwide.";
const canonical = "https://aisecurity.es/en/wazuh";
---

<WazuhLayout title={title} description={description} canonical={canonical}>

  <!-- FAQ Schema JSON-LD for GEO (Google AI Overviews, ChatGPT, Perplexity) -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "inLanguage": "en",
    "url": "https://aisecurity.es/en/wazuh",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Wazuh and what is it used for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wazuh is an open source SIEM/XDR platform that centralizes security logs, detects threats in real time, monitors file integrity and helps meet compliance requirements such as GDPR, PCI-DSS, HIPAA and NIST. It is free and runs on Linux, Windows, macOS and cloud environments."
        }
      },
      {
        "@type": "Question",
        "name": "How much does a Wazuh implementation service cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wazuh implementation at AI Security starts from €1,500 for basic deployments (up to 20 servers), €3,500–€7,000 for a complete deployment with advanced configuration and auditing, and €300/month for the fully managed Wazuh service with hosting, support and continuous maintenance."
        }
      },
      {
        "@type": "Question",
        "name": "Why do I need Wazuh for security compliance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most security and data-protection frameworks require continuous log management, intrusion detection and incident response. Wazuh directly covers activity monitoring, intrusion detection, log management and incident response, making it a cost-effective backbone for compliance with GDPR, PCI-DSS, HIPAA, NIST and ISO 27001."
        }
      },
      {
        "@type": "Question",
        "name": "How long does a Wazuh deployment take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A standard Wazuh deployment takes between 2 and 4 weeks: server installation (1-2 days), rolling out agents across all endpoints (3-5 days), tuning rules and alerts (1 week) and team training (1-2 days). Complex environments can take up to 2 months."
        }
      },
      {
        "@type": "Question",
        "name": "Does Wazuh work with Windows and Linux?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Wazuh has native agents for Windows (Server 2008 onward and Windows 10/11), Linux (Ubuntu, Debian, CentOS, Rocky Linux, RHEL), macOS, and it also monitors cloud environments such as AWS, Azure, GCP and Docker/Kubernetes containers."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need technical knowledge to use Wazuh?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wazuh requires systems administration knowledge for installation and advanced configuration. AI Security offers the full service: installation, configuration, integration with your infrastructure and training for your technical team so you can manage it autonomously."
        }
      }
    ]
  }
  </script>

  <!-- ═══ LEFT SIDEBAR NAV ═══ -->
  <nav id="wz-sidenav" class="fixed z-50 hidden xl:flex flex-col items-start" style="left:1.5rem;top:50%;transform:translateY(-50%);">
    <div class="relative flex flex-col">
      <!-- Vertical gradient line -->
      <div class="absolute w-px rounded-full" style="left:6px;top:20px;bottom:20px;background:linear-gradient(to bottom,rgba(96,165,250,0.4),rgba(129,140,248,0.4),rgba(34,211,238,0.4),rgba(96,165,250,0.4),rgba(139,92,246,0.4),rgba(74,222,128,0.4));"></div>

      <!-- Pricing -->
      <a href="#precios" data-wz-target="precios" class="wz-sn-link flex items-center gap-3 py-3 group">
        <div class="wz-sn-dot relative z-10 w-3 h-3 rounded-full border-2 transition-all duration-300" style="border-color:rgba(96,165,250,0.6);background:#020817;"></div>
        <span class="wz-sn-label text-xs font-mono transition-all duration-200 opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none" style="color:#60a5fa;">Pricing</span>
      </a>

      <!-- Why Wazuh -->
      <a href="#por-que-wazuh" data-wz-target="por-que-wazuh" class="wz-sn-link flex items-center gap-3 py-3 group">
        <div class="wz-sn-dot relative z-10 w-3 h-3 rounded-full border-2 transition-all duration-300" style="border-color:rgba(129,140,248,0.6);background:#020817;"></div>
        <span class="wz-sn-label text-xs font-mono transition-all duration-200 opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none" style="color:#818cf8;">Why Wazuh?</span>
      </a>

      <!-- Monitoring -->
      <a href="#monitorización" data-wz-target="monitorización" class="wz-sn-link flex items-center gap-3 py-3 group">
        <div class="wz-sn-dot relative z-10 w-3 h-3 rounded-full border-2 transition-all duration-300" style="border-color:rgba(34,211,238,0.6);background:#020817;"></div>
        <span class="wz-sn-label text-xs font-mono transition-all duration-200 opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none" style="color:#22d3ee;">Monitoring</span>
      </a>

      <!-- Why us -->
      <a href="#por-que-espana" data-wz-target="por-que-espana" class="wz-sn-link flex items-center gap-3 py-3 group">
        <div class="wz-sn-dot relative z-10 w-3 h-3 rounded-full border-2 transition-all duration-300" style="border-color:rgba(96,165,250,0.6);background:#020817;"></div>
        <span class="wz-sn-label text-xs font-mono transition-all duration-200 opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none" style="color:#60a5fa;">Why us</span>
      </a>

      <!-- CTA -->
      <a href="#cta-wazuh" data-wz-target="cta-wazuh" class="wz-sn-link flex items-center gap-3 py-3 group">
        <div class="wz-sn-dot relative z-10 w-3 h-3 rounded-full border-2 transition-all duration-300" style="border-color:rgba(139,92,246,0.6);background:#020817;"></div>
        <span class="wz-sn-label text-xs font-mono transition-all duration-200 opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none" style="color:#a78bfa;">Get started</span>
      </a>

      <!-- FAQ -->
      <a href="#faq" data-wz-target="faq" class="wz-sn-link flex items-center gap-3 py-3 group">
        <div class="wz-sn-dot relative z-10 w-3 h-3 rounded-full border-2 transition-all duration-300" style="border-color:rgba(74,222,128,0.6);background:#020817;"></div>
        <span class="wz-sn-label text-xs font-mono transition-all duration-200 opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none" style="color:#4ade80;">FAQ</span>
      </a>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" data-page="wazuh" style="background-color: #020817;">
    <!-- Grid pattern -->
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(59,130,246,0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.12) 1px, transparent 1px); background-size: 40px 40px; opacity: 0.6;"></div>
    <!-- Glows -->
    <div class="absolute rounded-full blur-3xl" style="width:700px;height:700px;top:-200px;left:50%;transform:translateX(-50%);background:radial-gradient(circle,rgba(59,130,246,0.14),transparent 70%);"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-8 pt-12 pb-4">

      <!-- TWO-COLUMN: globe left · text right -->
      <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12 mb-6">

      <!-- ─── GLOBE — left ─── -->
      <div class="flex-shrink-0 flex flex-col items-center">
        <!-- Badge above globe -->
        <div class="inline-flex items-center gap-2 mb-4 px-4 py-2 rounded-full border text-sm font-medium" style="background:rgba(59,130,246,0.08);border-color:rgba(59,130,246,0.25);color:#93c5fd;">
          <span class="w-2 h-2 rounded-full animate-pulse" style="background:#60a5fa;"></span>
          Open Source SIEM · XDR · Compliance
        </div>
        <div class="relative" style="width:clamp(240px,80vw,480px);height:clamp(240px,80vw,480px);">
          <!-- Glow -->
          <div class="absolute inset-0 rounded-full blur-3xl opacity-30" style="background:radial-gradient(circle,#3b82f6,transparent 65%);transform:scale(1.1);"></div>

          <!-- SVG Globe with animateMotion (attacks travel from origin to the protected node) -->
          <svg viewBox="-110 -110 220 220" style="width:100%;height:100%;overflow:visible;">
            <defs>
              <clipPath id="gc"><circle r="95"/></clipPath>
              <radialGradient id="gf" cx="32%" cy="28%">
                <stop offset="0%" stop-color="rgba(59,130,246,0.18)"/>
                <stop offset="100%" stop-color="rgba(2,8,23,0.95)"/>
              </radialGradient>
              <!-- Attack routes (bezier curves toward the protected node at -8,-16) -->
              <path id="p-ru" d="M 68,-54 Q 30,-98 -8,-16"/>
              <path id="p-cn" d="M 82,-8  Q 48,-90 -8,-16"/>
              <path id="p-us" d="M -84,-20 Q -50,-92 -8,-16"/>
              <path id="p-br" d="M -32,65  Q -52,18  -8,-16"/>
            </defs>

            <!-- Background -->
            <circle r="95" fill="url(#gf)"/>

            <!-- Parallels (latitude) -->
            <g clip-path="url(#gc)" stroke="rgba(59,130,246,0.12)" stroke-width="0.5" fill="none">
              <ellipse rx="95" ry="20"/>
              <ellipse rx="95" ry="48"/>
              <ellipse rx="95" ry="72"/>
              <ellipse rx="95" ry="88"/>
            </g>

            <!-- Animated meridians -->
            <g clip-path="url(#gc)" fill="none" stroke-width="0.5">
              <ellipse class="wg-m1" ry="95" stroke="rgba(59,130,246,0.15)"/>
              <ellipse class="wg-m2" ry="95" stroke="rgba(99,102,241,0.12)"/>
              <ellipse class="wg-m3" ry="95" stroke="rgba(59,130,246,0.1)"/>
              <ellipse class="wg-m4" ry="95" stroke="rgba(139,92,246,0.08)"/>
            </g>

            <!-- Continents (over the grid) -->
            <g class="wg-continents" clip-path="url(#gc)" fill="rgba(20,50,110,0.82)" stroke="rgba(96,165,250,0.9)" stroke-width="1" stroke-linejoin="round">
              <!-- Europe -->
              <path d="M -15,-10 L -12,-8 L -10,-30 L -13,-37 L -4,-58 L 13,-75 L 13,-63 L 11,-50 L 6,-42 L 13,-24 L 9,-8 Z"/>
              <!-- Africa -->
              <path d="M -12,-7 L 16,-16 L 26,14 L 22,55 L 10,70 L -5,70 L -15,40 L -20,10 Z"/>
              <!-- Asia -->
              <path d="M 16,-10 L 25,-30 L 45,-62 L 88,-62 L 92,-35 L 88,14 L 68,22 L 42,20 L 35,8 L 28,-14 Z"/>
              <!-- North America -->
              <path d="M -35,-70 L -50,-65 L -90,-55 L -92,-25 L -68,-2 L -50,-2 L -32,-25 L -40,-52 Z"/>
              <!-- South America -->
              <path d="M -62,-2 L -33,-2 L -20,30 L -35,75 L -52,70 L -68,25 Z"/>
              <!-- Australia -->
              <path d="M 50,28 L 88,20 L 90,50 L 60,54 L 48,42 Z"/>
            </g>

            <!-- Outer border -->
            <circle r="95" fill="none" stroke="rgba(59,130,246,0.4)" stroke-width="1.2"/>

            <!-- Attack routes (static dashed strokes) -->
            <use href="#p-ru" fill="none" stroke="rgba(239,68,68,0.18)" stroke-width="0.8" stroke-dasharray="3,5"/>
            <use href="#p-cn" fill="none" stroke="rgba(239,68,68,0.18)" stroke-width="0.8" stroke-dasharray="3,5"/>
            <use href="#p-us" fill="none" stroke="rgba(245,158,11,0.18)" stroke-width="0.8" stroke-dasharray="3,5"/>
            <use href="#p-br" fill="none" stroke="rgba(239,68,68,0.18)" stroke-width="0.8" stroke-dasharray="3,5"/>

            <!-- ── ATTACK RU ── travels 2.8s, pause 4.2s, cycle=7s -->
            <circle r="4" fill="#ef4444" opacity="0">
              <animateMotion id="ru-m" dur="2.8s" begin="0s;ru-m.end+4.2s" calcMode="spline" keySplines="0.4 0 0.2 1">
                <mpath href="#p-ru"/>
              </animateMotion>
              <animate attributeName="opacity" dur="2.8s" begin="0s;ru-m.end+4.2s"
                values="0;1;1;0" keyTimes="0;0.04;0.88;1"/>
              <animate attributeName="r" dur="2.8s" begin="0s;ru-m.end+4.2s"
                values="3;4;3" keyTimes="0;0.5;1"/>
            </circle>
            <!-- Blocked flash RU → node -->
            <circle cx="-8" cy="-16" fill="none" stroke="#4ade80" stroke-width="2" opacity="0">
              <animate attributeName="r" from="6" to="26" dur="0.7s"
                begin="ru-m.end;ru-m.end+7s;ru-m.end+14s;ru-m.end+21s"/>
              <animate attributeName="opacity" from="1" to="0" dur="0.7s"
                begin="ru-m.end;ru-m.end+7s;ru-m.end+14s;ru-m.end+21s"/>
            </circle>

            <!-- ── ATTACK CN ── offset 1.75s -->
            <circle r="3.5" fill="#ef4444" opacity="0">
              <animateMotion id="cn-m" dur="2.8s" begin="1.75s;cn-m.end+4.2s" calcMode="spline" keySplines="0.4 0 0.2 1">
                <mpath href="#p-cn"/>
              </animateMotion>
              <animate attributeName="opacity" dur="2.8s" begin="1.75s;cn-m.end+4.2s"
                values="0;1;1;0" keyTimes="0;0.04;0.88;1"/>
            </circle>
            <circle cx="-8" cy="-16" fill="none" stroke="#4ade80" stroke-width="2" opacity="0">
              <animate attributeName="r" from="6" to="26" dur="0.7s"
                begin="cn-m.end;cn-m.end+7s;cn-m.end+14s"/>
              <animate attributeName="opacity" from="1" to="0" dur="0.7s"
                begin="cn-m.end;cn-m.end+7s;cn-m.end+14s"/>
            </circle>

            <!-- ── ATTACK US ── offset 3.5s -->
            <circle r="3.5" fill="#f59e0b" opacity="0">
              <animateMotion id="us-m" dur="2.8s" begin="3.5s;us-m.end+4.2s" calcMode="spline" keySplines="0.4 0 0.2 1">
                <mpath href="#p-us"/>
              </animateMotion>
              <animate attributeName="opacity" dur="2.8s" begin="3.5s;us-m.end+4.2s"
                values="0;1;1;0" keyTimes="0;0.04;0.88;1"/>
            </circle>
            <circle cx="-8" cy="-16" fill="none" stroke="#4ade80" stroke-width="2" opacity="0">
              <animate attributeName="r" from="6" to="26" dur="0.7s"
                begin="us-m.end;us-m.end+7s;us-m.end+14s"/>
              <animate attributeName="opacity" from="1" to="0" dur="0.7s"
                begin="us-m.end;us-m.end+7s;us-m.end+14s"/>
            </circle>

            <!-- ── ATTACK BR ── offset 5.25s -->
            <circle r="3" fill="#ef4444" opacity="0">
              <animateMotion id="br-m" dur="2.8s" begin="5.25s;br-m.end+4.2s" calcMode="spline" keySplines="0.4 0 0.2 1">
                <mpath href="#p-br"/>
              </animateMotion>
              <animate attributeName="opacity" dur="2.8s" begin="5.25s;br-m.end+4.2s"
                values="0;1;1;0" keyTimes="0;0.04;0.88;1"/>
            </circle>
            <circle cx="-8" cy="-16" fill="none" stroke="#4ade80" stroke-width="2" opacity="0">
              <animate attributeName="r" from="6" to="26" dur="0.7s"
                begin="br-m.end;br-m.end+7s;br-m.end+14s"/>
              <animate attributeName="opacity" from="1" to="0" dur="0.7s"
                begin="br-m.end;br-m.end+7s;br-m.end+14s"/>
            </circle>

            <!-- Origin points (static) -->
            <circle cx="68"  cy="-54" r="3"   fill="rgba(239,68,68,0.7)"/>
            <circle cx="82"  cy="-8"  r="2.5" fill="rgba(239,68,68,0.7)"/>
            <circle cx="-84" cy="-20" r="2.5" fill="rgba(245,158,11,0.7)"/>
            <circle cx="-32" cy="65"  r="2.5" fill="rgba(239,68,68,0.7)"/>

            <!-- Country labels -->
            <text x="68"  y="-59" text-anchor="middle" font-size="5.5" fill="rgba(239,68,68,0.8)" font-family="monospace">RU</text>
            <text x="85"  y="-13" text-anchor="middle" font-size="5.5" fill="rgba(239,68,68,0.8)" font-family="monospace">CN</text>
            <text x="-84" y="-25" text-anchor="middle" font-size="5.5" fill="rgba(245,158,11,0.8)" font-family="monospace">US</text>
            <text x="-32" y="73"  text-anchor="middle" font-size="5.5" fill="rgba(239,68,68,0.8)" font-family="monospace">BR</text>

            <!-- Protected node -->
            <circle cx="-8" cy="-16" r="6" fill="#4ade80" opacity="0.9"/>
            <circle cx="-8" cy="-16" r="10" fill="none" stroke="rgba(74,222,128,0.35)" stroke-width="1.2"/>
            <text x="-8" y="-22" text-anchor="middle" font-size="5" fill="#4ade80" font-family="monospace" font-weight="bold" letter-spacing="0.5">WAZUH</text>
          </svg>

          <!-- Wazuh notifications that appear on block -->
          <!-- RU blocked: appears at t≈2.8s, 7s cycle -->
          <div class="wg-notif wg-notif-ru absolute top-3 right-0 max-w-[160px] text-xs font-mono px-3 py-2 rounded-lg border" style="background:rgba(74,222,128,0.1);border-color:rgba(74,222,128,0.4);color:#4ade80;">
            🛡️ BLOCKED · RU → SRV
          </div>
          <!-- CN blocked: appears at t≈4.55s -->
          <div class="wg-notif wg-notif-cn absolute top-3 right-0 max-w-[160px] text-xs font-mono px-3 py-2 rounded-lg border" style="background:rgba(74,222,128,0.1);border-color:rgba(74,222,128,0.4);color:#4ade80;">
            🛡️ BLOCKED · CN → SRV
          </div>
          <!-- US blocked: appears at t≈6.3s -->
          <div class="wg-notif wg-notif-us absolute bottom-12 right-0 max-w-[160px] text-xs font-mono px-3 py-2 rounded-lg border" style="background:rgba(245,158,11,0.1);border-color:rgba(245,158,11,0.4);color:#fbbf24;">
            ⚠️ INTERCEPTED · US → SRV
          </div>
          <!-- BR blocked: appears at t≈8.05s -->
          <div class="wg-notif wg-notif-br absolute bottom-4 left-0 max-w-[160px] text-xs font-mono px-3 py-2 rounded-lg border" style="background:rgba(74,222,128,0.1);border-color:rgba(74,222,128,0.4);color:#4ade80;">
            🛡️ BLOCKED · BR → SRV
          </div>
        </div>
      </div><!-- end globe -->

      <!-- ─── TEXT — right ─── -->
      <div class="flex-1 min-w-0">
        <h1 class="font-bold text-white leading-tight mb-4" style="font-size:clamp(2rem,3.2vw,3.2rem);letter-spacing:-0.02em;">
          <span style="background:linear-gradient(135deg,#60a5fa 0%,#818cf8 50%,#c084fc 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Wazuh</span> protecting<br/>your business 24/7
        </h1>
        <p class="text-lg mb-6 leading-relaxed" style="color:#94a3b8;">
          We deliver a Wazuh implementation ready to detect and block threats from day one — fully configured for compliance and with zero learning curve for your team.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <button type="button" id="wazuh-demo-btn" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold rounded-xl transition-all duration-200 hover:-translate-y-1" style="background:linear-gradient(135deg,#3b82f6,#6366f1);color:white;box-shadow:0 4px 32px rgba(99,102,241,0.4);cursor:pointer;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            See Interactive Demo
          </button>
          <a href="/en/presupuesto?plan=wazuh-consultoria" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold rounded-xl border transition-all duration-200 hover:-translate-y-1" style="border-color:rgba(255,255,255,0.12);color:white;background:rgba(255,255,255,0.04);">
            Free Consultation
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <!-- Stats pills -->
        <div class="flex flex-wrap gap-3 mb-6">
          <span class="px-4 py-2 rounded-lg text-sm font-medium" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:#e2e8f0;">⏱ <strong>24/7</strong> monitoring</span>
          <span class="px-4 py-2 rounded-lg text-sm font-medium" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:#e2e8f0;">🏛 <strong>Compliance</strong> ready</span>
          <span class="px-4 py-2 rounded-lg text-sm font-medium" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:#e2e8f0;">💰 <strong>€0</strong> licensing</span>
          <span class="px-4 py-2 rounded-lg text-sm font-medium" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:#e2e8f0;">🔓 <strong>100%</strong> Open Source</span>
        </div>
      </div><!-- end text -->

      </div><!-- end two-column -->

      <!-- Full-width ticker -->
      <div class="relative overflow-hidden rounded-xl border py-3 mb-6" style="background:rgba(255,255,255,0.02);border-color:rgba(255,255,255,0.07);">
        <div class="absolute left-0 top-0 bottom-0 w-16 z-10" style="background:linear-gradient(90deg,#020817,transparent);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-16 z-10" style="background:linear-gradient(270deg,#020817,transparent);"></div>
        <div class="flex gap-12 wazuh-ticker" style="width:max-content;padding:0 2rem;">
