            Show me the demo →
          </button>
        </form>
        <p style="font-size:0.72rem;color:#64748b;text-align:center;margin:14px 0 0;">No commitment · We only contact you about the demo</p>
      </div>
    </div>
  </div>
</WazuhLayout>

<script>
  (function () {
    const modal = document.getElementById('wazuh-demo-modal');
    const card = document.getElementById('wazuh-demo-card');
    const openBtn = document.getElementById('wazuh-demo-btn');
    const closeBtn = document.getElementById('wazuh-demo-close');
    const form = document.getElementById('wazuh-demo-form');
    const emailInput = document.getElementById('wazuh-demo-email');
    const submitBtn = document.getElementById('wazuh-demo-submit');
    const msg = document.getElementById('wazuh-demo-msg');
    if (!modal || !openBtn) return;

    function open() { modal.classList.remove('hidden'); modal.classList.add('flex'); document.body.style.overflow = 'hidden'; setTimeout(() => emailInput && emailInput.focus(), 50); }
    function close() { modal.classList.add('hidden'); modal.classList.remove('flex'); document.body.style.overflow = ''; }

    openBtn.addEventListener('click', open);
    closeBtn && closeBtn.addEventListener('click', close);
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

    form && form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (emailInput.value || '').trim();
      msg.style.display = 'none';
      if (!email || !email.includes('@')) {
        emailInput.style.borderColor = 'rgba(239,68,68,0.6)';
        return;
      }
      emailInput.style.borderColor = 'rgba(255,255,255,0.14)';
      submitBtn.disabled = true; submitBtn.textContent = 'Sending...';
      try {
        const fd = new FormData();
        fd.append('email', email);
        const res = await fetch('/api/demo-wazuh', { method: 'POST', body: fd });
        if (res.ok) {
          form.style.display = 'none';
          msg.style.display = 'block';
          msg.style.color = '#6ee7b7';
          msg.innerHTML = '✓ Got it! We\'ll be in touch very soon to walk you through the live Wazuh demo.';
        } else {
          const d = await res.json().catch(() => ({}));
          msg.style.display = 'block'; msg.style.color = '#fca5a5';
          msg.textContent = d.error || 'Could not send. Please try again.';
          submitBtn.disabled = false; submitBtn.textContent = 'Show me the demo →';
        }
      } catch {
        msg.style.display = 'block'; msg.style.color = '#fca5a5';
        msg.textContent = 'Connection error. Email us at info@aisecurity.es';
        submitBtn.disabled = false; submitBtn.textContent = 'Show me the demo →';
      }
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Wazuh demo tabs (Real Monitoring section)
    const wazuhDemoTabs = document.querySelectorAll('.wazuh-demo-tab');
    const wazuhDemoContents = document.querySelectorAll('.wazuh-demo-content');

    wazuhDemoTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');

        // Remove active class from all tabs
        wazuhDemoTabs.forEach(t => {
          t.classList.remove('text-blue-600', 'border-blue-600');
          t.classList.add('text-gray-600', 'border-transparent');
        });

        // Add active class to clicked tab
        tab.classList.add('text-blue-600', 'border-blue-600');
        tab.classList.remove('text-gray-600', 'border-transparent');

        // Hide all content
        wazuhDemoContents.forEach(content => {
          content.classList.add('hidden');
        });

        // Show target content
        const targetContent = document.getElementById(targetTab!);
        if (targetContent) {
          targetContent.classList.remove('hidden');
        }
      });
    });
  });

  // ── Sidebar nav: IntersectionObserver ──
  const sidenav = document.getElementById('wz-sidenav');
  const sectionIds = ['precios','por-que-wazuh','monitorización','por-que-espana','faq','cta-wazuh'];
  const dotColors = {
    'precios':        { border:'#60a5fa', bg:'rgba(96,165,250,0.85)' },
    'por-que-wazuh':  { border:'#818cf8', bg:'rgba(129,140,248,0.85)' },
    'monitorización': { border:'#22d3ee', bg:'rgba(34,211,238,0.85)' },
    'por-que-espana': { border:'#60a5fa', bg:'rgba(96,165,250,0.85)' },
    'cta-wazuh':      { border:'#a78bfa', bg:'rgba(167,139,250,0.85)' },
    'faq':            { border:'#4ade80', bg:'rgba(74,222,128,0.85)' },
  };

  function setActive(id) {
    document.querySelectorAll('.wz-sn-link').forEach(link => {
      const dot = link.querySelector('.wz-sn-dot');
      const target = link.dataset.wzTarget;
      const isActive = target === id;
      link.classList.toggle('active', isActive);
      if (dot && dotColors[target]) {
        dot.style.borderColor = dotColors[target].border;
        dot.style.background = isActive ? dotColors[target].bg : '#020817';
        dot.style.boxShadow = isActive ? `0 0 10px ${dotColors[target].border}` : 'none';
        dot.style.transform = isActive ? 'scale(1.5)' : 'scale(1)';
      }
    });
  }

  // Hide sidebar in hero (scroll < 200px)
  window.addEventListener('scroll', () => {
    if (window.scrollY < 200) {
      sidenav?.classList.add('hidden-nav');
    } else {
      sidenav?.classList.remove('hidden-nav');
    }
  }, { passive: true });
  if (window.scrollY < 200) sidenav?.classList.add('hidden-nav');

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) setActive(entry.target.id);
    });
  }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });

  sectionIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) obs.observe(el);
  });
</script>

