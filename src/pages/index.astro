---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroFusion from "../components/landing/HeroFusion.astro";
import ServicesSection from "../components/ai-services/ServicesSection.astro";
import WhyChooseUs from "../components/landing/WhyChooseUs.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import FAQSection from "../components/landing/FAQSection.astro";

const title = "Automatización con IA y Consultoría IT para PyMEs en España | AI Security";
const description = "Chatbot inteligente, gestor documental IA, atención de llamadas y gestión de citas automatizada para PyMEs españolas. Consultoría IT y primera consulta gratuita.";
const canonical = "https://aisecurity.es/";

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "AI Security",
  "url": "https://aisecurity.es",
  "logo": "https://aisecurity.es/og-image.png",
  "description": "Soluciones de automatización con inteligencia artificial y consultoría IT para PyMEs españolas. Chatbot empresarial, gestor documental, atención de llamadas IA, gestión de citas automatizada, Wazuh SIEM y cumplimiento ENS.",
  "foundingDate": "2024",
  "founder": {
    "@type": "Person",
    "jobTitle": "Consultor IA y Administrador de Sistemas"
  },
  "areaServed": {
    "@type": "Country",
    "name": "España"
  },
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "ES"
  },
  "serviceType": [
    "Chatbot inteligente para empresas",
    "Gestor documental con IA",
    "Atención de llamadas con IA",
    "Gestor de citas automatizado",
    "Automatización de procesos con IA",
    "Consultoría IT para PyMEs",
    "Implementación Wazuh SIEM",
    "Cumplimiento ENS"
  ],
  "knowsAbout": [
    "Automatización con inteligencia artificial",
    "Chatbot empresarial",
    "Gestor documental IA",
    "Consultoría IT PyMEs España",
    "Wazuh SIEM",
    "Esquema Nacional de Seguridad"
  ],
  "sameAs": [
    "https://www.youtube.com/@Systems_Boy"
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  <HeroFusion />
  <ServicesSection />
  <WhyChooseUs />
  <HowItWorks />
  <FAQSection />
</BaseLayout>