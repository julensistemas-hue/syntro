---
import BaseLayout from "../../layouts/BaseLayout.astro";

const ciudad = "Benicarló";
const slug = "benicarlo";
const comarca = "Baix Maestrat";
const vecinas = ["Vinaròs", "Peñíscola", "Càlig"];

const title = "Soporte Técnico Informático para Empresas en " + ciudad + " — Remoto, sin desplazamientos";
const description = "Soporte IT para PyMEs en " + ciudad + " y comarca del " + comarca + ". Reparación de PCs, redes, Microsoft 365, backup. 100% remoto · Primera hora gratis · Respuesta en menos de 2h.";
const canonical = "https://aisecurity.es/soporte-tecnico/" + slug;

const schemaLocal = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "AI Security — Soporte Técnico " + ciudad,
  "description": "Soporte técnico informático remoto para empresas en " + ciudad + " y comarca del " + comarca + ". Primera hora gratis.",
  "url": "https://aisecurity.es/soporte-tecnico/" + slug,
  "email": "info@aisecurity.es",
  "areaServed": [
    { "@type": "City", "name": ciudad },
    ...vecinas.map(v => ({ "@type": "City", "name": v })),
    { "@type": "AdministrativeArea", "name": comarca }
  ],
  "serviceType": "Soporte Técnico Informático Remoto",
  "priceRange": "€€",
  "offers": {
    "@type": "Offer",
    "name": "Primera hora de soporte gratuita",
    "price": "0",
    "priceCurrency": "EUR"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Podéis ayudarme si mi empresa está en " + ciudad + " o en un pueblo de la comarca?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, sin problema. El soporte es 100% remoto así que da igual si estás en " + ciudad + ", " + vecinas[0] + ", " + vecinas[1] + " o cualquier municipio de la comarca del " + comarca + ". Lo único que necesitas es conexión a internet."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tarda en responder un técnico?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Garantizamos respuesta en menos de 2 horas en horario laboral (L-V 9:00-18:00) para clientes con bolsa de horas activa. Para la primera hora gratuita, el tiempo habitual también es el mismo día."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo funciona la primera hora gratis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Abres un ticket, te llamamos, conectamos con acceso remoto y trabajamos en tu problema durante una hora sin coste. Si no se resuelve, te explicamos exactamente qué falta y cuánto costaría. Sin tarjeta, sin contrato."
      }
    },
    {
      "@type": "Question",
      "name": "¿Las horas de la bolsa caducan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Las horas tienen validez de 12 meses desde la compra. Para una empresa de 5-20 empleados, una bolsa de 10h suele durar entre 3 y 6 meses."
      }
    }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="pt-12 pb-20 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Soporte técnico informático remoto para empresas" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-bl from-blue-900/70 via-blue-900/80 to-accent-500/60"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="flex justify-center mb-6">
        <span class="inline-flex items-center gap-2 px-4 py-2 border border-white/30 rounded-full text-white/90 text-sm font-semibold backdrop-blur-sm" style="background-color: rgba(255,255,255,0.12);">
          <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
          Soporte remoto · {ciudad} y comarca del {comarca}
        </span>
      </div>

      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight">
          Técnico informático para<br>
          <span class="bg-gradient-to-r from-blue-300 via-cyan-300 to-blue-200 bg-clip-text text-transparent">
            empresas en {ciudad}
          </span>
        </h1>
        <p class="text-lg md:text-xl text-white/85 max-w-3xl mx-auto leading-relaxed">
          PC caído, correo que no va, red lenta... Resolvemos las incidencias IT de tu empresa
          <strong class="text-white">100% en remoto</strong>, sin desplazamiento, el mismo día.
          Primera hora <strong class="text-white">sin coste</strong>.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-12">
        <div class="rounded-2xl p-5 border border-white/20 text-center" style="background-color: rgba(255,255,255,0.08);">
          <div class="text-3xl font-extrabold text-white mb-1">&lt; 2h</div>
          <p class="text-white/70 text-sm">Tiempo de respuesta garantizado</p>
        </div>
        <div class="rounded-2xl p-5 border border-white/20 text-center" style="background-color: rgba(255,255,255,0.08);">
          <div class="text-3xl font-extrabold text-white mb-1">1ª hora</div>
          <p class="text-white/70 text-sm">Gratis · sin tarjeta · sin compromiso</p>
        </div>
        <div class="rounded-2xl p-5 border border-white/20 text-center" style="background-color: rgba(255,255,255,0.08);">
          <div class="text-3xl font-extrabold text-white mb-1">100%</div>
          <p class="text-white/70 text-sm">Remoto · desde €30/h con bolsa</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/abrir-ticket"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white hover:bg-blue-50 font-bold rounded-xl transition-all duration-300 shadow-xl hover:-translate-y-0.5"
          style="color: #1e3a5f;"
        >
          Abrir ticket gratis
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a
          href="/reunion"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 font-semibold rounded-xl border border-white/30 backdrop-blur-sm transition-all duration-200 hover:bg-white/10"
          style="color: white; background-color: rgba(255,255,255,0.10);"
        >
          Hablar con un técnico
        </a>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       COMPARATIVA — patrón oscuro profundo
  ══════════════════════════════════════════════ -->
  <section class="py-20 relative overflow-hidden" style="background-color: #0d1117;">
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover" style="opacity: 0.10;" />
    </div>
    <div class="absolute inset-0" style="background-color: rgba(13,17,23,0.80);"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          El técnico de siempre tarda días.<br>
          <span class="text-blue-300">Nosotros, horas.</span>
        </h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">
          Las pequeñas empresas de {ciudad}, {vecinas[0]}, {vecinas[1]} y la comarca del {comarca}
          no tienen un informático a mano. Y cuando algo falla, pierden horas de trabajo esperando.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Sin soporte -->
        <div class="rounded-2xl p-8 border" style="background-color: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12);">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background-color: rgba(239,68,68,0.15);">😰</div>
            <div>
              <h3 class="text-lg font-bold text-white">Sin soporte profesional</h3>
              <p class="text-sm text-white/60 font-medium">Lo habitual en PyMEs de la zona</p>
            </div>
          </div>
          <ul class="space-y-3 text-white/80">
            <li class="flex items-start gap-2"><span class="text-red-400 font-bold flex-shrink-0 mt-0.5">✗</span>El técnico de guardia tarda 2-3 días en venir</li>
            <li class="flex items-start gap-2"><span class="text-red-400 font-bold flex-shrink-0 mt-0.5">✗</span>Pagas desplazamiento aunque el problema sea simple</li>
            <li class="flex items-start gap-2"><span class="text-red-400 font-bold flex-shrink-0 mt-0.5">✗</span>El empleado pierde media jornada esperando</li>
            <li class="flex items-start gap-2"><span class="text-red-400 font-bold flex-shrink-0 mt-0.5">✗</span>Nadie monitoriza que los backups funcionen</li>
          </ul>
        </div>

        <!-- Con AI Security -->
        <div class="bg-blue-700 rounded-2xl p-8 border-2 border-blue-400 relative">
          <div class="absolute -top-3 right-6 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full">
            ASÍ TRABAJAMOS NOSOTROS
          </div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-12 bg-gradient-to-br from-blue-400 to-cyan-500 rounded-xl flex items-center justify-center text-2xl">⚡</div>
            <div>
              <h3 class="text-lg font-bold text-white">Con AI Security — Remoto</h3>
              <p class="text-sm text-blue-200 font-medium">Para empresas de {ciudad} y comarca</p>
            </div>
          </div>
          <ul class="space-y-3 text-white/85">
            <li class="flex items-start gap-2"><span class="text-cyan-300 font-bold mt-0.5 flex-shrink-0">✓</span>Respuesta en menos de 2 horas, el mismo día</li>
            <li class="flex items-start gap-2"><span class="text-cyan-300 font-bold mt-0.5 flex-shrink-0">✓</span>Sin tarifa de desplazamiento, pagas solo el trabajo</li>
            <li class="flex items-start gap-2"><span class="text-cyan-300 font-bold mt-0.5 flex-shrink-0">✓</span>Conexión remota segura, tu equipo no para</li>
            <li class="flex items-start gap-2"><span class="text-cyan-300 font-bold mt-0.5 flex-shrink-0">✓</span>Monitorización de backups con bolsa de horas</li>
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       SERVICIOS — patrón oscuro con imagen
  ══════════════════════════════════════════════ -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Servicios informáticos para empresas" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-bl from-blue-900/70 via-blue-900/80 to-accent-500/60"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Servicios IT para empresas en {ciudad}
        </h2>
        <p class="text-lg text-white/75 max-w-2xl mx-auto">
          Soporte técnico completo para empresas de {ciudad} sin necesidad de técnico propio
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: "💻", title: "PCs lentos o con errores", desc: "Diagnóstico y reparación remota de ordenadores lentos, virus, errores de arranque y software." },
          { icon: "📧", title: "Correo corporativo", desc: "Configuración de Outlook, Microsoft 365 y Gmail en todos los dispositivos de tu equipo." },
          { icon: "🌐", title: "Redes y WiFi", desc: "Problemas de conexión, router, WiFi empresarial, VPN para trabajo en remoto." },
          { icon: "💾", title: "Backup automático", desc: "Implantamos copias de seguridad automáticas para que nunca pierdas datos importantes." },
          { icon: "🛡️", title: "Virus y malware", desc: "Eliminación de virus, ransomware y software malicioso que ralentiza o bloquea tu equipo." },
          { icon: "📱", title: "Móviles y tablets", desc: "Configuración de dispositivos móviles para email corporativo, apps y acceso VPN." },
        ].map(({ icon, title, desc }) => (
          <div class="rounded-2xl p-6 border hover:scale-[1.02] transition-all duration-300" style="background-color: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.18);">
            <div class="text-3xl mb-4">{icon}</div>
            <h3 class="text-white font-bold text-lg mb-2">{title}</h3>
            <p class="text-white/75 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       CÓMO FUNCIONA — patrón oscuro profundo
  ══════════════════════════════════════════════ -->
  <section class="py-20 relative overflow-hidden" style="background-color: #0d1117;">
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover" style="opacity: 0.08;" />
    </div>
    <div class="absolute inset-0" style="background-color: rgba(13,17,23,0.85);"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Cómo funciona el soporte técnico en {ciudad}
        </h2>
        <p class="text-lg text-white/75 max-w-2xl mx-auto">
          Desde que abres el ticket hasta que el problema está resuelto
        </p>
      </div>

      <div class="relative max-w-4xl mx-auto">
        <div class="absolute left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-400 via-cyan-400 to-teal-400 hidden md:block"></div>

        <div class="space-y-10">
          <div class="relative flex flex-col md:flex-row md:items-center gap-6">
            <div class="md:w-1/2 md:text-right md:pr-12">
              <div class="bg-blue-700 rounded-2xl p-6">
                <h3 class="text-lg font-bold text-white mb-2">1. Abres un ticket</h3>
                <p class="text-white/85 text-sm leading-relaxed">
                  Describes el problema en el formulario. Sin esperas telefónicas, sin desplazamientos. Recibes confirmación inmediata.
                </p>
              </div>
            </div>
            <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-10 h-10 bg-blue-600 rounded-full items-center justify-center text-white font-bold text-sm shadow-lg z-10">1</div>
            <div class="md:w-1/2 md:pl-12">
              <p class="text-white/50 text-sm font-medium hidden md:block">Inmediato</p>
            </div>
          </div>

          <div class="relative flex flex-col md:flex-row md:items-center gap-6">
            <div class="md:w-1/2 md:text-right md:pr-12">
              <p class="text-white/50 text-sm font-medium hidden md:block text-right">En menos de 2h</p>
            </div>
            <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-10 h-10 bg-cyan-600 rounded-full items-center justify-center text-white font-bold text-sm shadow-lg z-10">2</div>
            <div class="md:w-1/2 md:pl-12">
              <div class="bg-cyan-700 rounded-2xl p-6">
                <h3 class="text-lg font-bold text-white mb-2">2. Te llamamos y conectamos</h3>
                <p class="text-white/85 text-sm leading-relaxed">
                  Un técnico se pone en contacto, instala el agente de acceso remoto y empieza a trabajar. Tú ves todo en pantalla.
                </p>
              </div>
            </div>
          </div>

          <div class="relative flex flex-col md:flex-row md:items-center gap-6">
            <div class="md:w-1/2 md:text-right md:pr-12">
              <div class="bg-teal-700 rounded-2xl p-6">
                <h3 class="text-lg font-bold text-white mb-2">3. Problema resuelto</h3>
                <p class="text-white/85 text-sm leading-relaxed">
                  En la mayoría de casos resolvemos en la primera sesión. Si requiere más trabajo, te explicamos qué y cuánto cuesta antes de continuar.
                </p>
              </div>
            </div>
            <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-10 h-10 bg-teal-600 rounded-full items-center justify-center text-white font-bold text-sm shadow-lg z-10">3</div>
            <div class="md:w-1/2 md:pl-12">
              <p class="text-white/50 text-sm font-medium hidden md:block">El mismo día</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       PRECIOS — patrón oscuro profundo
  ══════════════════════════════════════════════ -->
  <section class="py-20 relative overflow-hidden" style="background-color: #0d1117;">
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover" style="opacity: 0.10;" />
    </div>
    <div class="absolute inset-0" style="background-color: rgba(13,17,23,0.80);"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-8 md:px-12 lg:px-24">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Precios transparentes</h2>
        <p class="text-lg text-white/70 max-w-xl mx-auto">Sin sorpresas. Sin permanencia. Paga solo por lo que usas.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="rounded-2xl p-6 border flex flex-col" style="background-color: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12);">
          <h4 class="text-lg font-bold text-white mb-1">Hora suelta</h4>
          <div class="text-4xl font-extrabold text-white my-3">€40<span class="text-lg font-normal text-white/50">/hora</span></div>
          <p class="text-white/60 text-sm mb-5">Para incidencias puntuales sin compromiso</p>
          <ul class="space-y-2 text-sm text-white/75 mb-6 flex-grow">
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Sin contrato previo</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Soporte remoto</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Primera hora gratis</li>
          </ul>
          <a href="/abrir-ticket" class="block text-center py-3 px-4 bg-white hover:bg-blue-50 font-semibold rounded-xl transition-colors" style="color: #1e3a5f;">
            Abrir ticket
          </a>
        </div>

        <div class="rounded-2xl p-6 border-2 flex flex-col relative" style="background-color: rgba(255,255,255,0.10); border-color: #3b82f6;">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-blue-600 px-4 py-1 rounded-full text-xs font-bold text-white whitespace-nowrap">MÁS POPULAR</div>
          <h4 class="text-lg font-bold text-white mb-1">Bolsa 10h</h4>
          <div class="text-4xl font-extrabold text-white my-3">€350<span class="text-lg font-normal text-white/50"> total</span></div>
          <p class="text-white/60 text-sm mb-5">€35/hora · Ahorra €50 · Válidas 12 meses</p>
          <ul class="space-y-2 text-sm text-white/75 mb-6 flex-grow">
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Atención prioritaria</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Respuesta &lt;2h garantizada</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Sin permanencia</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Primera hora gratis</li>
          </ul>
          <a href="/abrir-ticket" class="block text-center py-3 px-4 bg-blue-600 hover:bg-blue-500 font-bold rounded-xl transition-colors" style="color: white;">
            Contratar
          </a>
        </div>

        <div class="rounded-2xl p-6 border flex flex-col" style="background-color: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12);">
          <h4 class="text-lg font-bold text-white mb-1">Bolsa 20h</h4>
          <div class="text-4xl font-extrabold text-white my-3">€600<span class="text-lg font-normal text-white/50"> total</span></div>
          <p class="text-white/60 text-sm mb-5">€30/hora · Ahorra €200 · Máximo ahorro</p>
          <ul class="space-y-2 text-sm text-white/75 mb-6 flex-grow">
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Atención VIP</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Informes mensuales</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Descuento 25%</li>
            <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Primera hora gratis</li>
          </ul>
          <a href="/abrir-ticket" class="block text-center py-3 px-4 bg-white hover:bg-blue-50 font-semibold rounded-xl transition-colors" style="color: #1e3a5f;">
            Contratar
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       CTA FINAL — gradiente oscuro
  ══════════════════════════════════════════════ -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/60 via-blue-600/70 to-accent-500/60"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-8 md:px-12 text-center">
      <div class="text-5xl mb-6">🖥️</div>
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">
        ¿Problema técnico en tu empresa<br>de {ciudad} ahora mismo?
      </h2>
      <p class="text-lg md:text-xl text-white/80 mb-10 max-w-2xl mx-auto">
        Abre un ticket y te contactamos en menos de 2 horas. La primera hora es gratis,
        sin tarjeta y sin compromiso de permanencia.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
