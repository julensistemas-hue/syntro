// ---- Gradiente toon (cel-shading por pasos) ----
function toonGradient(steps = 4) {
  const data = new Uint8Array(steps);
  for (let i = 0; i < steps; i++) data[i] = Math.round((i / (steps - 1)) * 255);
  const tex = new THREE.DataTexture(data, steps, 1, THREE.RedFormat);
  tex.needsUpdate = true;
  return tex;
}
const GRAD = toonGradient(4);
function toon(color, opts = {}) {
  return new THREE.MeshToonMaterial({ color, gradientMap: GRAD, ...opts });
}

// ============================================================
//  PLANETA (icosaedro low-poly + relieve por ruido)
// ============================================================
function valueNoise(v) {
  // ruido pseudo-aleatorio barato a partir de la posición normalizada
  return (
    Math.sin(v.x * 1.5 + v.y * 2.3) * 0.5 +
    Math.sin(v.y * 2.1 + v.z * 1.7) * 0.4 +
    Math.sin(v.z * 1.9 + v.x * 2.7) * 0.35
  );
}

// Suelo de oficina: esfera casi lisa, gris azulado corporativo (moqueta)
const planetGeo = new THREE.IcosahedronGeometry(R, 9);
{
  const pos = planetGeo.attributes.position;
  const v = new THREE.Vector3();
  for (let i = 0; i < pos.count; i++) {
    v.fromBufferAttribute(pos, i).normalize();
    const r = R + valueNoise(v) * RELIEF; // casi plano
    pos.setXYZ(i, v.x * r, v.y * r, v.z * r);
  }
  planetGeo.computeVertexNormals();
}
const planet = new THREE.Mesh(planetGeo, toon(0x33384a, { flatShading: true }));
