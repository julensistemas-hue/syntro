      jb.position.set(sx * 3.9, 0.75, pz); group.add(jb);
    }
  }

  return { dep, dir, group, npc, head, glow, sign, mark, baseGlow: accent.clone() };
}

// Cartel: panel con icono grande + nombre
function makeSign(dep) {
  const c = document.createElement('canvas');
  c.width = 512; c.height = 256;
  const ctx = c.getContext('2d');
  ctx.fillStyle = 'rgba(12,16,30,0.92)';
  roundRect(ctx, 8, 8, 496, 240, 28); ctx.fill();
  ctx.lineWidth = 6; ctx.strokeStyle = dep.color; ctx.stroke();
  ctx.textAlign = 'center';
  ctx.font = '110px serif';
  ctx.fillText(dep.icon, 256, 128);
  ctx.fillStyle = '#fff'; ctx.font = 'bold 40px sans-serif';
  ctx.fillText(dep.nombre, 256, 210);
  const tex = new THREE.CanvasTexture(c);
  const spr = new THREE.Sprite(new THREE.SpriteMaterial({ map: tex, transparent: true }));
  spr.scale.set(3.2, 1.6, 1);
  return spr;
}
function makeMark(color) {
  const c = document.createElement('canvas'); c.width = c.height = 128;
  const ctx = c.getContext('2d');
  ctx.fillStyle = '#' + color.getHexString();
  ctx.beginPath(); ctx.arc(64, 64, 60, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = '#fff'; ctx.font = 'bold 90px sans-serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText('!', 64, 70);
  return new THREE.CanvasTexture(c);
}
function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.arcTo(x + w, y, x + w, y + h, r);
  ctx.arcTo(x + w, y + h, x, y + h, r);
  ctx.arcTo(x, y + h, x, y, r);
  ctx.arcTo(x, y, x + w, y, r);
  ctx.closePath();
}

let stations = [];   // se rellena cuando terminan de cargar los modelos glTF

// ============================================================
//  PAISAJISMO DEL CAMPUS (instancing) — mobiliario urbano por todo el planeta
// ============================================================
{
  const TOTAL = 150;
  const spots = [];
  const dir = new THREE.Vector3();
  let tries = 0;
  while (spots.length < TOTAL && tries < TOTAL * 8) {
    tries++;
    dir.set(Math.random() - 0.5, Math.random() - 0.5, Math.random() - 0.5).normalize();
    let close = false;
    for (const a of anchors) if (dir.angleTo(a) < 0.34) { close = true; break; }
    if (dir.y < -0.82) close = true;   // deja libre el polo sur (sede central)
    if (close) continue;
    spots.push({ dir: dir.clone(), yaw: Math.random() * Math.PI * 2, s: 0.8 + Math.random() * 0.5 });
  }

  const dummy = new THREE.Object3D();
  function placeOn(mesh, list, lift) {
    list.forEach((p, i) => {
      const rT = surfaceRadius(p.dir);
      dummy.position.copy(p.dir).multiplyScalar(rT + lift * p.s);
      dummy.quaternion.setFromUnitVectors(UP_Y, p.dir);
      dummy.rotateY(p.yaw);
      dummy.scale.setScalar(p.s);
      dummy.updateMatrix();
      mesh.setMatrixAt(i, dummy.matrix);
    });
    mesh.count = list.length; mesh.instanceMatrix.needsUpdate = true; scene.add(mesh);
  }
  const cat = (m) => spots.filter((_, i) => i % 7 === m);
  const trees = cat(0), hedges = cat(1), lamps = cat(2), benches = cat(3), planters = cat(4), bins = cat(5), cars = cat(6);

  // Árboles de campus (tronco + copa)
  placeOn(new THREE.InstancedMesh(new THREE.CylinderGeometry(0.14, 0.18, 1.0, 6), toon(0x6b4f2a), trees.length), trees, 0.5);
  placeOn(new THREE.InstancedMesh(new THREE.IcosahedronGeometry(0.95, 0), toon(0x2f8f4f, { flatShading: true }), trees.length), trees, 1.55);
  // Setos
  placeOn(new THREE.InstancedMesh(new THREE.BoxGeometry(1.7, 0.7, 0.7), toon(0x35935a, { flatShading: true }), hedges.length), hedges, 0.35);
  // Farolas (poste + cabeza luminosa)
  placeOn(new THREE.InstancedMesh(new THREE.CylinderGeometry(0.07, 0.09, 3.0, 6), toon(0x9aa3bd), lamps.length), lamps, 1.5);
  placeOn(new THREE.InstancedMesh(new THREE.BoxGeometry(0.5, 0.18, 0.5), new THREE.MeshBasicMaterial({ color: 0xfff4c2 }), lamps.length), lamps, 3.0);
  // Bancos
  placeOn(new THREE.InstancedMesh(new THREE.BoxGeometry(1.5, 0.14, 0.5), toon(0x8a6b48), benches.length), benches, 0.5);
  // Jardineras (maceta + arbusto)
  placeOn(new THREE.InstancedMesh(new THREE.CylinderGeometry(0.32, 0.38, 0.6, 8), toon(0x8a5a3c), planters.length), planters, 0.3);
  placeOn(new THREE.InstancedMesh(new THREE.IcosahedronGeometry(0.5, 0), toon(0x2f8f4f, { flatShading: true }), planters.length), planters, 1.0);
  // Papeleras
  placeOn(new THREE.InstancedMesh(new THREE.CylinderGeometry(0.26, 0.22, 0.7, 8), toon(0x4c5470), bins.length), bins, 0.4);
  // Coches aparcados (carrocería + cabina)
  placeOn(new THREE.InstancedMesh(new THREE.BoxGeometry(1.9, 0.6, 0.95), toon(0xb9c0d6), cars.length), cars, 0.45);
  placeOn(new THREE.InstancedMesh(new THREE.BoxGeometry(1.05, 0.5, 0.9), toon(0x5a627e), cars.length), cars, 0.95);
}

