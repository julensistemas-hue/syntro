---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Demo interactiva: pasea por la empresa con IA por departamentos | AI Security";
const description = "Explora un planeta 3D donde cada departamento tiene a alguien trabajando. Habla con ellos, descubre sus tareas manuales repetitivas y qué IA las elimina. Demo interactiva de consultoría IA.";
const canonical = "https://aisecurity.es/consultoria-ia-demo";

// 8 departamentos con su NPC (persona trabajando + su queja sobre trabajo manual repetitivo)
const departamentos = [
  {
    id: "comunicacion",
    nombre: "Comunicación",
    icon: "🎨",
    color: "#38bdf8",
    npc: { nombre: "Marta", rol: "Diseñadora de contenido" },
    problema: "Me paso el día montando creatividades a mano. Cada post para redes me lleva una hora en el editor, y necesito diez al día. Los vídeos de producto ni te cuento: grabar, editar, subtitular… se me va la semana entera.",
    objetivos: [
      "Reduce un 70% el tiempo de producción visual",
      "Multiplica por 10 las publicaciones sin ampliar equipo",
    ],
    herramientas: [
      { nombre: "Midjourney", uso: "Imágenes y creatividades profesionales por prompt" },
      { nombre: "HeyGen", uso: "Avatares de vídeo con voz natural en español" },
      { nombre: "Canva AI", uso: "Diseño asistido y redimensionado inteligente" },
    ],
    ahorro: "Hasta un 70% menos de tiempo en producción de contenido visual",
  },
  {
    id: "comercial",
    nombre: "Comercial & SEO",
    icon: "📊",
    color: "#4f7cff",
    npc: { nombre: "Javi", rol: "Responsable comercial" },
    problema: "Cada lunes exporto datos de Search Console y Analytics a mano, los pego en Excel y monto el informe. Tres horas que se van antes de empezar a vender de verdad. Y seguro que se me escapan oportunidades.",
    objetivos: [
      "Informes semanales automáticos en tu email",
      "Detecta oportunidades antes que la competencia",
    ],
    herramientas: [
      { nombre: "Claude + Excel", uso: "Genera propuestas y analiza datos de ventas por chat" },
      { nombre: "GSC + GA4 Automation", uso: "Scripts propios que analizan tu web cada semana" },
      { nombre: "n8n + LLM", uso: "Flujos de seguimiento de leads y CRM" },
    ],
    ahorro: "Informes semanales sin dedicar horas a exportar datos",
  },
  {
    id: "callcenter",
    nombre: "Call Center & Soporte",
    icon: "📞",
    color: "#60a5fa",
    npc: { nombre: "Lucía", rol: "Atención al cliente" },
    problema: "El teléfono no para. El 80% son las mismas cinco preguntas una y otra vez. Para cuando atiendo lo importante, ya es tarde y tengo veinte llamadas en cola.",
    objetivos: [
      "Resuelve el 80% de consultas sin intervención humana",
      "Disponible 24/7 sin coste extra de personal",
    ],
    herramientas: [
      { nombre: "Atención Llamadas IA", uso: "Recepcionista virtual 24/7 con voz natural" },
      { nombre: "Chatbot Empresarial IA", uso: "Chat con acceso a tu ERP en tiempo real" },
      { nombre: "ElevenLabs", uso: "Voces IA ultra-realistas en español" },
    ],
    ahorro: "Atiende el 80% de consultas comunes sin coste de personal",
  },
  {
    id: "proyectos",
    nombre: "Gestión de Proyectos",
    icon: "📋",
    color: "#6366f1",
    npc: { nombre: "Diego", rol: "Project Manager" },
    problema: "Media jornada creando tareas en Jira, copiando estados de una herramienta a otra y montando el reporte del sprint. Tareas mecánicas que no aportan nada, pero que alguien tiene que hacer.",
    objetivos: [
      "Reduce un 50% el tiempo de planificación y reporting",
      "Detecta bloqueos y riesgos antes de que impacten",
    ],
    herramientas: [
      { nombre: "Jira + Atlassian Intelligence", uso: "Subtareas y resúmenes automáticos" },
      { nombre: "Notion AI", uso: "Documentación y wikis que se actualizan solas" },
      { nombre: "n8n", uso: "Automatiza notificaciones y asignaciones" },
    ],
    ahorro: "Hasta un 50% menos de tiempo en planificación y reporting",
  },
  {
    id: "administracion",
    nombre: "Administración",
    icon: "🧾",
    color: "#818cf8",
    npc: { nombre: "Carmen", rol: "Administración" },
    problema: "Meto las facturas de proveedores una a una, cinco o diez minutos cada documento. Y por mucho cuidado que ponga, siempre se cuela algún error de tecleo que luego hay que perseguir.",
    objetivos: [
      "Procesa facturas en segundos, no en minutos",
      "Elimina errores de tecleo en datos contables",
    ],
    herramientas: [
      { nombre: "Mindee", uso: "OCR que extrae datos de facturas y recibos solo" },
      { nombre: "Claude + Excel", uso: "Redacta presupuestos y resume contratos por chat" },
      { nombre: "n8n + ChatGPT", uso: "Clasifica, registra y notifica facturas entrantes" },
    ],
    ahorro: "Procesa facturas en segundos en vez de 5-10 minutos cada una",
  },
  {
    id: "desarrollo",
    nombre: "Desarrollo",
    icon: "💻",
    color: "#8b5cf6",
    npc: { nombre: "Álex", rol: "Desarrollador" },
    problema: "Escribo el mismo boilerplate mil veces, documento a mano cuando me acuerdo y los tests siempre se quedan para el final. Tareas repetitivas que me roban el tiempo de resolver lo difícil.",
    objetivos: [
      "Multiplica por 2-3x la velocidad de entrega",
      "Reduce un 60% los bugs que llegan a producción",
    ],
    herramientas: [
      { nombre: "Claude Code", uso: "Agente que lee tu repo y ejecuta tareas completas" },
      { nombre: "GitHub Copilot", uso: "Autocompletado de código en el IDE" },
      { nombre: "GitHub Actions + IA", uso: "Pipelines que generan tests y detectan bugs" },
    ],
    ahorro: "2-3x más velocidad de entrega de features",
  },
  {
    id: "devops",
    nombre: "DevOps",
    icon: "⚙️",
    color: "#a78bfa",
    npc: { nombre: "Sara", rol: "Ingeniera DevOps" },
    problema: "Reviso logs a mano buscando la anomalía entre miles de líneas, y cada despliegue lo hago con el corazón en un puño. Lo repetitivo me come el tiempo de prevenir incidencias de verdad.",
    objetivos: [
      "Resuelve incidencias hasta 3x más rápido",
      "Despliegues continuos sin downtime",
    ],
    herramientas: [
      { nombre: "Kubernetes + K8sGPT", uso: "Diagnóstico automático de errores en clústeres" },
      { nombre: "Datadog AI", uso: "Detección de anomalías y alertas inteligentes" },
      { nombre: "Ansible + IA", uso: "Playbooks de configuración generados solos" },
    ],
    ahorro: "Incidencias hasta 3x más rápidas y despliegues sin downtime",
  },
  {
    id: "sistemas",
    nombre: "Sistemas",
    icon: "🖥️",
    color: "#c084fc",
    npc: { nombre: "Pablo", rol: "Administrador de sistemas" },
    problema: "Cada cambio en un servidor habría que documentarlo… y nunca da tiempo. La seguridad la reviso a mano cuando puedo. Sé que se me escapa algo, pero soy una persona para todo.",
    objetivos: [
      "Detección de amenazas en tiempo real con ENS",
      "Cada cambio genera documentación automática",
    ],
    herramientas: [
      { nombre: "Wazuh", uso: "SIEM open-source: amenazas y cumplimiento ENS" },
      { nombre: "Ansible + LLM", uso: "Automatiza tareas repetitivas por lenguaje natural" },
      { nombre: "Netdata", uso: "Monitorización en tiempo real con IA predictiva" },
    ],
    ahorro: "Documenta cambios solo y reduce incidencias por error humano",
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- ===================== ESCENARIO 3D ===================== -->
  <!--
    Modelos 3D (todos CC0 / dominio público):
      · Edificios: Kenney City Kit — https://kenney.nl (CC0)
      · Props de oficina: The Office Pack vía poly.pizza (CC0)
      · Personajes: Quaternius vía poly.pizza (CC0)
    Cargados con three.js GLTFLoader y reconvertidos a MeshToonMaterial (cel-shading).
  -->

  <div id="demo-stage">
    <canvas id="planet-canvas"></canvas>

    <!-- Loader -->
    <div id="loader">
      <div class="loader-inner">
        <div class="loader-ring"></div>
        <p>Construyendo el planeta…</p>
      </div>
    </div>

    <!-- Intro overlay -->
    <div id="intro-overlay">
      <div class="intro-card">
        <div class="intro-badge">🪐 Demo interactiva</div>
        <h1>La IA, departamento a departamento</h1>
        <p class="intro-lead">
          Pasea por este pequeño planeta. En cada departamento hay alguien trabajando.
          Acércate y habla con ellos: te contarán qué tareas manuales y repetitivas les
          comen el día… y qué IA se las quita de encima.
        </p>
        <div class="intro-controls">
          <div class="ctrl"><span class="keys"><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd></span> Moverte por la superficie</div>
          <div class="ctrl"><span class="keys"><kbd>E</kbd></span> Hablar con la persona cercana</div>
          <div class="ctrl"><span class="keys">táctil</span> Usa los botones de pantalla en el móvil</div>
        </div>
        <button id="start-btn">Empezar a explorar →</button>
        <a href="/consultoria-ia" class="intro-skip">Prefiero la versión clásica</a>
      </div>
    </div>

    <!-- HUD: nombre del departamento más cercano -->
    <div id="hud-progress">
      <span id="hud-count">0</span><span class="hud-total">/8 departamentos visitados</span>
    </div>

    <!-- Prompt de interacción -->
    <div id="interact-prompt">
      <span class="prompt-key"><kbd>E</kbd></span>
      <span>Hablar con <strong id="prompt-name">—</strong></span>
    </div>

    <!-- Controles táctiles -->
    <div id="touch-controls">
      <div class="dpad">
        <button class="tbtn" data-dir="up">▲</button>
        <div class="dpad-mid">
          <button class="tbtn" data-dir="left">◀</button>
          <button class="tbtn" data-dir="right">▶</button>
        </div>
        <button class="tbtn" data-dir="down">▼</button>
      </div>
      <button id="touch-talk" class="tbtn-talk">Hablar</button>
    </div>

    <!-- Panel de diálogo -->
    <div id="dialogue" aria-hidden="true">
      <div class="dlg-card">
        <button id="dlg-close" aria-label="Cerrar">✕</button>
        <div class="dlg-head">
          <div class="dlg-avatar" id="dlg-avatar">🎨</div>
          <div>
            <div class="dlg-dept" id="dlg-dept">Departamento</div>
            <div class="dlg-name" id="dlg-name">Nombre · Rol</div>
          </div>
        </div>

        <div class="dlg-section">
          <div class="dlg-label dlg-label-pain">El problema</div>
          <p class="dlg-problema" id="dlg-problema">…</p>
        </div>

        <div class="dlg-section">
          <div class="dlg-label dlg-label-fix">Cómo lo resolvemos con IA</div>
          <div class="dlg-objetivos" id="dlg-objetivos"></div>
          <div class="dlg-tools" id="dlg-tools"></div>
        </div>

        <div class="dlg-ahorro" id="dlg-ahorro">…</div>

        <div class="dlg-actions">
          <a id="dlg-cta" href="/presupuesto?plan=Consultoria-IA">Quiero implementar esto →</a>
          <button id="dlg-continue">Seguir explorando</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===================== CTA bajo el demo ===================== -->
  <section style="background: linear-gradient(135deg, #0f1628, #1a0a2e); padding: 64px 0; border-top: 1px solid #1e2130;">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color:#fff;">¿Y en tu empresa, dónde se pierde el tiempo?</h2>
      <p class="text-lg mb-8" style="color:#94a3b8;">Primera consulta gratuita. Analizamos tu día a día por departamentos y te decimos honestamente qué IA tiene sentido implementar.</p>
      <a href="/presupuesto?plan=Consultoria-IA"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-xl font-bold text-lg"
        style="background: linear-gradient(135deg,#4f7cff,#7c3aed); color:#fff;">
        Solicitar consulta gratuita
      </a>
    </div>
  </section>

</BaseLayout>

<style is:global>
  #demo-stage {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: radial-gradient(circle at 50% 30%, #131a3a 0%, #070a18 60%, #04060f 100%);
    touch-action: none;
    user-select: none;
  }
  #planet-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }

  /* Loader */
  #loader {
    position: absolute; inset: 0; z-index: 30;
    display: flex; align-items: center; justify-content: center;
    background: #070a18; transition: opacity .6s ease;
  }
  #loader.hidden { opacity: 0; pointer-events: none; }
  .loader-inner { text-align: center; color: #94a3b8; font-size: .95rem; }
  .loader-ring {
    width: 48px; height: 48px; margin: 0 auto 16px;
    border: 3px solid rgba(79,124,255,.2); border-top-color: #4f7cff;
    border-radius: 50%; animation: spin 1s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Intro */
  #intro-overlay {
    position: absolute; inset: 0; z-index: 25;
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
    background: radial-gradient(circle at 50% 40%, rgba(15,22,40,.55), rgba(4,6,15,.85));
    backdrop-filter: blur(4px);
    transition: opacity .5s ease;
  }
  #intro-overlay.hidden { opacity: 0; pointer-events: none; }
  .intro-card {
    max-width: 560px; text-align: center;
    background: rgba(18,22,40,.78); border: 1px solid rgba(79,124,255,.25);
    border-radius: 20px; padding: 40px 36px;
    box-shadow: 0 30px 80px rgba(0,0,0,.5);
  }
  .intro-badge {
    display: inline-block; font-size: .8rem; font-weight: 600; color: #7da4ff;
    background: rgba(79,124,255,.15); border: 1px solid rgba(79,124,255,.3);
    padding: 6px 14px; border-radius: 999px; margin-bottom: 18px;
  }
  .intro-card h1 { font-size: 1.9rem; font-weight: 800; color: #fff; margin-bottom: 14px; line-height: 1.15; }
  .intro-lead { color: #a9b4cc; line-height: 1.65; margin-bottom: 24px; font-size: 1.02rem; }
  .intro-controls { display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
  .ctrl { display: flex; align-items: center; gap: 12px; justify-content: center; color: #cbd5e1; font-size: .9rem; }
  .keys { display: inline-flex; gap: 4px; min-width: 132px; justify-content: flex-end; }
  kbd {
    display: inline-block; background: #1f2540; border: 1px solid #38406a;
    border-bottom-width: 2px; border-radius: 6px; padding: 2px 8px;
    font-family: ui-monospace, monospace; font-size: .8rem; color: #e2e8f0;
  }
  .keys:not(:has(kbd)) , .ctrl .keys { } /* noop */
  .ctrl .keys span, .keys:only-child {}
  #start-btn {
    background: linear-gradient(135deg,#4f7cff,#7c3aed); color: #fff;
    border: none; border-radius: 12px; padding: 14px 30px;
    font-size: 1.05rem; font-weight: 700; cursor: pointer;
    transition: transform .15s ease, box-shadow .2s ease;
    box-shadow: 0 10px 30px rgba(79,124,255,.35);
  }
  #start-btn:hover { transform: translateY(-2px); box-shadow: 0 16px 40px rgba(79,124,255,.5); }
  .intro-skip { display: block; margin-top: 16px; color: #64748b; font-size: .85rem; text-decoration: none; }
  .intro-skip:hover { color: #94a3b8; }

  /* HUD */
  #hud-progress {
    position: absolute; top: 18px; left: 50%; transform: translateX(-50%); z-index: 15;
    background: rgba(10,13,26,.7); border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px; padding: 8px 18px; color: #cbd5e1; font-size: .85rem;
    opacity: 0; transition: opacity .4s ease; pointer-events: none;
  }
  #hud-progress.show { opacity: 1; }
  #hud-count { color: #7da4ff; font-weight: 700; }
  .hud-total { color: #64748b; }

  /* Interact prompt */
  #interact-prompt {
    position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(12px);
    z-index: 15; display: flex; align-items: center; gap: 10px;
    background: rgba(10,13,26,.85); border: 1px solid rgba(79,124,255,.4);
    border-radius: 12px; padding: 10px 18px; color: #e2e8f0; font-size: .92rem;
    opacity: 0; transition: opacity .25s ease, transform .25s ease; pointer-events: none;
  }
  #interact-prompt.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  #interact-prompt strong { color: #7da4ff; }
  .prompt-key kbd { background: #4f7cff; border-color: #6d8eff; color: #fff; }

  /* Touch controls */
  #touch-controls {
    position: absolute; bottom: 20px; left: 0; right: 0; z-index: 16;
    display: none; align-items: flex-end; justify-content: space-between;
    padding: 0 22px; pointer-events: none;
  }
  #touch-controls.show { display: flex; }
  .dpad { display: flex; flex-direction: column; align-items: center; gap: 6px; pointer-events: auto; }
  .dpad-mid { display: flex; gap: 44px; }
  .tbtn {
    width: 56px; height: 56px; border-radius: 14px; font-size: 1.3rem;
    background: rgba(20,26,46,.8); border: 1px solid rgba(255,255,255,.18);
    color: #e2e8f0; cursor: pointer; -webkit-tap-highlight-color: transparent;
  }
  .tbtn:active { background: rgba(79,124,255,.5); }
  .tbtn-talk {
    pointer-events: auto; align-self: flex-end;
    background: linear-gradient(135deg,#4f7cff,#7c3aed); color: #fff;
    border: none; border-radius: 14px; padding: 0 26px; height: 56px;
    font-weight: 700; font-size: 1rem; opacity: .45; transition: opacity .2s;
  }
  .tbtn-talk.active { opacity: 1; }

  /* Dialogue */
  #dialogue {
    position: absolute; inset: 0; z-index: 20;
    display: flex; align-items: center; justify-content: center; padding: 20px;
    background: rgba(4,6,15,.6); backdrop-filter: blur(3px);
    opacity: 0; pointer-events: none; transition: opacity .3s ease;
  }
  #dialogue.open { opacity: 1; pointer-events: auto; }
  .dlg-card {
    position: relative; width: 100%; max-width: 520px; max-height: 88svh; overflow-y: auto;
    background: #12162a; border: 1px solid #2a3050; border-radius: 18px; padding: 26px 26px 22px;
    box-shadow: 0 30px 90px rgba(0,0,0,.6); transform: translateY(16px); transition: transform .3s ease;
  }
  #dialogue.open .dlg-card { transform: translateY(0); }
  #dlg-close {
    position: absolute; top: 14px; right: 14px; width: 32px; height: 32px;
    border-radius: 8px; background: rgba(255,255,255,.06); border: none;
    color: #94a3b8; cursor: pointer; font-size: 1rem;
  }
  #dlg-close:hover { background: rgba(255,255,255,.12); color: #fff; }
  .dlg-head { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
  .dlg-avatar {
    width: 54px; height: 54px; border-radius: 14px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 28px;
    background: rgba(255,255,255,.06);
  }
  .dlg-dept { font-size: .78rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; }
  .dlg-name { color: #e2e8f0; font-size: 1.05rem; font-weight: 700; margin-top: 2px; }
  .dlg-section { margin-bottom: 18px; }
  .dlg-label { font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 8px; }
  .dlg-label-pain { color: #fca5a5; }
  .dlg-label-fix { color: #7da4ff; }
  .dlg-problema {
    color: #cbd5e1; line-height: 1.65; font-size: .96rem; font-style: italic;
    border-left: 3px solid rgba(252,165,165,.5); padding-left: 14px;
  }
  .dlg-objetivos { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
  .dlg-obj { display: flex; gap: 8px; align-items: flex-start; color: #e2e8f0; font-size: .88rem; line-height: 1.45; }
  .dlg-obj::before { content: "✓"; color: #34d399; font-weight: 700; flex-shrink: 0; }
  .dlg-tools { display: flex; flex-direction: column; gap: 8px; }
  .dlg-tool { background: rgba(255,255,255,.04); border-radius: 8px; padding: 9px 12px; }
  .dlg-tool-n { font-size: .85rem; font-weight: 600; color: #e2e8f0; }
  .dlg-tool-u { font-size: .78rem; color: #64748b; margin-top: 1px; }
  .dlg-ahorro {
    background: rgba(52,211,153,.1); border: 1px solid rgba(52,211,153,.25); border-radius: 10px;
    padding: 12px 14px; color: #6ee7b7; font-size: .88rem; font-weight: 600; margin-bottom: 18px;
  }
  .dlg-actions { display: flex; flex-direction: column; gap: 10px; }
  #dlg-cta {
    display: block; text-align: center; background: linear-gradient(135deg,#4f7cff,#7c3aed);
    color: #fff; border-radius: 10px; padding: 13px; font-size: .95rem; font-weight: 700; text-decoration: none;
  }
  #dlg-continue {
    background: transparent; border: 1px solid #2a3050; color: #94a3b8;
    border-radius: 10px; padding: 11px; font-size: .9rem; cursor: pointer;
  }
  #dlg-continue:hover { border-color: #4f7cff; color: #cbd5e1; }

  @media (max-width: 640px) {
    .intro-card { padding: 30px 22px; }
    .intro-card h1 { font-size: 1.5rem; }
    .keys { min-width: 0; }
  }
</style>

<!-- Three.js vía importmap CDN (no añade dependencia al build) -->
<script type="importmap" is:inline>
{
  "imports": {
    "three": "https://unpkg.com/three@0.169.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.169.0/examples/jsm/"
  }
}
</script>

<script type="module" define:vars={{ departamentos }} is:inline>
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
import { clone as cloneSkeleton } from 'three/addons/utils/SkeletonUtils.js';

// ============================================================
//  CONFIGURACIÓN GENERAL
// ============================================================
const R = 22;                 // radio del planeta
