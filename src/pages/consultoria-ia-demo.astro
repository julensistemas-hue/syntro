// Convierte los materiales del modelo a MeshToonMaterial para unificar el cel-shading
function toonify(root) {
  root.traverse((o) => {
    if (!o.isMesh) return;
    const arr = Array.isArray(o.material) ? o.material : [o.material];
    const conv = arr.map((m) => new THREE.MeshToonMaterial({
      color: m && m.color ? m.color.clone() : new THREE.Color(0xffffff),
      map: m ? m.map || null : null,
      gradientMap: GRAD,
      vertexColors: !!(o.geometry.attributes && o.geometry.attributes.color),
      transparent: m ? m.transparent : false,
      opacity: m ? m.opacity : 1,
    }));
    o.material = Array.isArray(o.material) ? conv : conv[0];
  });
  return root;
}
function loadGLB(url) {
  return new Promise((res, rej) => gltfLoader.load(url, (g) => res(toonify(g.scene)), undefined, rej));
}

// Clona un modelo, lo centra en XZ con la base en y=0 y lo escala a un tamaño objetivo
function fitClone(proto, opts) {
  const obj = cloneSkeleton(proto);
  const box = new THREE.Box3().setFromObject(obj);
  const size = new THREE.Vector3(); box.getSize(size);
  const center = new THREE.Vector3(); box.getCenter(center);
  const base = opts.mode === 'height' ? size.y : Math.max(size.x, size.z);
  const s = opts.target / (base || 1);
  obj.position.set(-center.x, -box.min.y, -center.z);
  const g = new THREE.Group();
  g.add(obj); g.scale.setScalar(s);
  return { node: g, size: size.clone().multiplyScalar(s) };
}

