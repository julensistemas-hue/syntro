---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Abrir Ticket de Soporte Técnico Gratuito - AI Security";
const description = "Abre un ticket de soporte técnico y recibe la primera hora de asistencia gratis. Soporte remoto para pequeñas y medianas empresas sin departamento IT.";
const canonical = "https://aisecurity.es/abrir-ticket";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero Section -->
  <section class="py-12 md:py-16 bg-base-50">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent-600 text-white rounded-full text-sm font-semibold mb-6">
          <span class="text-xl">🎁</span>
          Primera Hora de Soporte GRATIS
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-base-900 mb-4">
          Abre tu Ticket de Soporte
        </h1>
        <p class="text-lg md:text-xl text-base-700 max-w-3xl mx-auto">
          Describe tu problema técnico y te contactamos en menos de 2 horas
          <br>
          <span class="text-accent-600 font-semibold">(Horario: 08:00-14:00 y 16:00-19:00)</span>
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Formulario de Ticket -->
        <div class="bg-white rounded-2xl shadow-xl border border-base-200 p-6 md:p-8">
          <h2 class="text-2xl font-bold text-base-900 mb-6 flex items-center gap-3">
            <span class="w-10 h-10 bg-accent-100 rounded-xl flex items-center justify-center text-xl">📝</span>
            Describe tu Incidencia
          </h2>

          <form id="ticket-form" class="space-y-5">
            <!-- Nombre -->
            <div>
              <label for="nombre" class="block text-sm font-semibold text-base-800 mb-2">
                Nombre completo <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                class="w-full px-4 py-3 border-2 border-base-300 rounded-xl focus:border-accent-500 focus:ring-2 focus:ring-accent-200 transition-all duration-200 text-base-900 bg-white"
                placeholder="Tu nombre"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-semibold text-base-800 mb-2">
                Email <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border-2 border-base-300 rounded-xl focus:border-accent-500 focus:ring-2 focus:ring-accent-200 transition-all duration-200 text-base-900 bg-white"
                placeholder="tu@empresa.com"
              />
            </div>

            <!-- Empresa (opcional) -->
            <div>
              <label for="empresa" class="block text-sm font-semibold text-base-800 mb-2">
                Empresa <span class="text-base-500 font-normal">(opcional)</span>
              </label>
              <input
                type="text"
                id="empresa"
                name="empresa"
                class="w-full px-4 py-3 border-2 border-base-300 rounded-xl focus:border-accent-500 focus:ring-2 focus:ring-accent-200 transition-all duration-200 text-base-900 bg-white"
                placeholder="Nombre de tu empresa"
              />
            </div>

            <!-- Tipo de Incidencia -->
            <div>
              <label for="tipo" class="block text-sm font-semibold text-base-800 mb-2">
                Tipo de incidencia <span class="text-red-500">*</span>
              </label>
              <select
                id="tipo"
                name="tipo"
                required
                class="w-full px-4 py-3 border-2 border-base-300 rounded-xl focus:border-accent-500 focus:ring-2 focus:ring-accent-200 transition-all duration-200 text-base-900 bg-white"
              >
                <option value="">Selecciona una opción</option>
                <option value="pc-lento">PC lento o no arranca</option>
                <option value="virus">Virus o malware</option>
                <option value="email">Problemas con email</option>
                <option value="red">Problemas de red/WiFi</option>
                <option value="impresora">Impresora no funciona</option>
                <option value="software">Instalación de software</option>
                <option value="backup">Copias de seguridad</option>
                <option value="otro">Otro problema</option>
              </select>
            </div>

            <!-- Descripción -->
            <div>
              <label for="descripcion" class="block text-sm font-semibold text-base-800 mb-2">
                Descripción del problema <span class="text-red-500">*</span>
              </label>
              <textarea
                id="descripcion"
                name="descripcion"
                required
                rows="4"
                class="w-full px-4 py-3 border-2 border-base-300 rounded-xl focus:border-accent-500 focus:ring-2 focus:ring-accent-200 transition-all duration-200 text-base-900 bg-white resize-none"
                placeholder="Describe tu problema con el mayor detalle posible: qué ocurre, cuándo empezó, qué has probado..."
              ></textarea>
            </div>

            <!-- ID de AnyDesk (opcional) -->
            <div class="bg-accent-50 border-2 border-accent-200 rounded-xl p-4">
              <label for="anydesk" class="block text-sm font-semibold text-base-900 mb-2">
                ID de AnyDesk <span class="text-base-700 font-normal">(si ya lo tienes instalado)</span>
              </label>
              <input
                type="text"
                id="anydesk"
                name="anydesk"
                class="w-full px-4 py-3 border-2 border-accent-200 rounded-xl focus:border-accent-500 focus:ring-2 focus:ring-accent-200 transition-all duration-200 text-base-900 bg-white"
                placeholder="Ej: 123 456 789"
              />
              <p class="text-xs text-base-700 mt-2">
                Si no lo tienes instalado, mira las instrucciones a la derecha
              </p>
            </div>

            <!-- Checkbox de aceptación -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="acepto"
                name="acepto"
                required
                class="mt-1 w-5 h-5 rounded border-base-400 text-accent-600 focus:ring-accent-500"
              />
              <label for="acepto" class="text-sm text-base-700">
                Acepto que AI Security se conecte remotamente a mi equipo para resolver la incidencia.
                <a href="/privacy" class="text-accent-600 hover:underline font-medium">Política de privacidad</a>
              </label>
            </div>

            <!-- Botón enviar -->
            <button
              type="submit"
              class="w-full py-4 px-6 bg-accent-600 hover:bg-accent-700 text-white font-bold text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center gap-3"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
              </svg>
              Enviar Ticket (Primera Hora Gratis)
            </button>
          </form>

          <!-- Estado del envío -->
          <div id="form-status" class="hidden mt-6"></div>
        </div>

        <!-- Instrucciones AnyDesk -->
        <div class="space-y-6">
          <!-- Info Card -->
          <div class="bg-accent-600 rounded-2xl shadow-xl p-6 md:p-8 text-white">
            <h2 class="text-2xl font-bold mb-4 flex items-center gap-3">
              <span class="text-3xl">🖥️</span>
              ¿Cómo funciona el soporte remoto?
            </h2>
            <ol class="space-y-4">
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 bg-white/20 rounded-full flex items-center justify-center font-bold">1</span>
                <div>
                  <p class="font-semibold">Rellena el formulario</p>
                  <p class="text-base-100 text-sm">Describe tu problema con el mayor detalle posible</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 bg-white/20 rounded-full flex items-center justify-center font-bold">2</span>
                <div>
                  <p class="font-semibold">Instala AnyDesk</p>
                  <p class="text-base-100 text-sm">Software seguro para conexión remota (instrucciones abajo)</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 bg-white/20 rounded-full flex items-center justify-center font-bold">3</span>
                <div>
                  <p class="font-semibold">Te contactamos</p>
                  <p class="text-base-100 text-sm">En menos de 2 horas nos pondremos en contacto</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 bg-white/20 rounded-full flex items-center justify-center font-bold">4</span>
                <div>
                  <p class="font-semibold">Resolvemos tu problema</p>
                  <p class="text-base-100 text-sm">La primera hora es totalmente gratuita</p>
                </div>
              </li>
            </ol>
          </div>

          <!-- AnyDesk Download Card -->
          <div class="bg-white rounded-2xl shadow-xl border border-base-200 p-6 md:p-8">
            <div class="flex items-center gap-4 mb-6">
              <img src="https://anydesk.com/favicon.ico" alt="AnyDesk" class="w-12 h-12 rounded-xl shadow-md" />
              <div>
                <h3 class="text-xl font-bold text-base-900">Instalar AnyDesk</h3>
                <p class="text-sm text-base-700">Software de escritorio remoto seguro</p>
              </div>
            </div>

            <div class="space-y-3 mb-6">
              <div class="flex items-start gap-3 p-3 bg-base-50 rounded-xl border border-base-200">
                <span class="text-accent-600 text-xl font-bold">✓</span>
                <div>
                  <p class="font-semibold text-base-800 text-sm">100% Seguro</p>
                  <p class="text-xs text-base-700">Conexión cifrada de extremo a extremo</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 bg-base-50 rounded-xl border border-base-200">
                <span class="text-accent-600 text-xl font-bold">✓</span>
                <div>
                  <p class="font-semibold text-base-800 text-sm">Tú controlas el acceso</p>
                  <p class="text-xs text-base-700">Solo nos conectamos cuando tú lo autorizas</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 bg-base-50 rounded-xl border border-base-200">
                <span class="text-accent-600 text-xl font-bold">✓</span>
                <div>
                  <p class="font-semibold text-base-800 text-sm">Instalación rápida</p>
                  <p class="text-xs text-base-700">Solo 3 MB, funciona inmediatamente</p>
                </div>
              </div>
            </div>

            <a
              href="https://anydesk.com/es/downloads/windows"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full py-4 px-6 bg-red-600 hover:bg-red-700 text-white font-bold text-center rounded-xl shadow-lg hover:shadow-xl transition-all duration-300"
            >
              <span class="flex items-center justify-center gap-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Descargar AnyDesk (Windows)
              </span>
            </a>

            <div class="mt-4 text-center">
              <p class="text-sm text-base-700">¿Otro sistema operativo?</p>
              <div class="flex justify-center gap-4 mt-2">
                <a href="https://anydesk.com/es/downloads/mac-os" target="_blank" rel="noopener noreferrer" class="text-accent-600 hover:underline text-sm font-medium">macOS</a>
                <a href="https://anydesk.com/es/downloads/linux" target="_blank" rel="noopener noreferrer" class="text-accent-600 hover:underline text-sm font-medium">Linux</a>
                <a href="https://anydesk.com/es/downloads/android" target="_blank" rel="noopener noreferrer" class="text-accent-600 hover:underline text-sm font-medium">Android</a>
              </div>
            </div>
          </div>

          <!-- Cómo encontrar ID -->
          <div class="bg-base-100 border-2 border-base-200 rounded-2xl p-6">
            <h4 class="font-bold text-base-900 mb-3 flex items-center gap-2">
              <span class="text-xl">💡</span>
              ¿Dónde encuentro mi ID de AnyDesk?
            </h4>
            <ol class="space-y-2 text-sm text-base-700">
              <li><strong class="text-base-800">1.</strong> Descarga e instala AnyDesk</li>
              <li><strong class="text-base-800">2.</strong> Abre el programa</li>
              <li><strong class="text-base-800">3.</strong> Tu ID aparece en la pantalla principal con el título <em>"Esta Mesa"</em> o <em>"This Desk"</em></li>
              <li><strong class="text-base-800">4.</strong> Es un número de 9 dígitos (ej: 123 456 789)</li>
            </ol>
            <div class="mt-4 p-3 bg-white rounded-xl border border-base-200">
              <p class="text-xs text-base-700">
                <strong class="text-base-800">Nota:</strong> Si no quieres instalarlo ahora, no hay problema. Te guiaremos cuando te contactemos.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección de valor para PyMEs -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-base-900 mb-4">
          Tu Departamento IT bajo demanda
        </h2>
        <p class="text-base-700 max-w-2xl mx-auto">
          Ideal para empresas que no pueden contratar un informático a tiempo completo pero necesitan soporte técnico profesional de forma periódica
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-base-50 rounded-xl p-6 border-2 border-base-200 hover:border-accent-300 transition-colors">
          <div class="w-14 h-14 bg-accent-100 rounded-xl flex items-center justify-center text-2xl mb-4">🆘</div>
          <h3 class="text-lg font-bold text-base-900 mb-2">Soporte de emergencia</h3>
          <p class="text-base-700 text-sm">
            PC que no arranca, virus, email caído... Resolvemos urgencias técnicas que bloquean tu trabajo.
          </p>
        </div>

        <div class="bg-base-50 rounded-xl p-6 border-2 border-base-200 hover:border-accent-300 transition-colors">
          <div class="w-14 h-14 bg-accent-100 rounded-xl flex items-center justify-center text-2xl mb-4">⚙️</div>
          <h3 class="text-lg font-bold text-base-900 mb-2">Automatización de tareas</h3>
          <p class="text-base-700 text-sm">
            Automatizamos backups, actualizaciones, informes y tareas repetitivas para que tu equipo se centre en lo importante.
          </p>
        </div>

        <div class="bg-base-50 rounded-xl p-6 border-2 border-base-200 hover:border-accent-300 transition-colors">
          <div class="w-14 h-14 bg-accent-100 rounded-xl flex items-center justify-center text-2xl mb-4">🧠</div>
          <h3 class="text-lg font-bold text-base-900 mb-2">Consultoría IT</h3>
          <p class="text-base-700 text-sm">
            Problemas técnicos complejos que tu técnico habitual no puede resolver. Somos tu escalado experto.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Horario y contacto -->
  <section class="py-12 bg-accent-600">
    <div class="max-w-4xl mx-auto px-4 md:px-8 text-center text-white">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Horario de Atención</h2>
      <div class="flex flex-col sm:flex-row justify-center gap-4 sm:gap-8 mb-6">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl px-6 py-4">
          <p class="text-white/80 text-sm mb-1">Mañanas</p>
          <p class="text-2xl font-bold">08:00 - 14:00</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-xl px-6 py-4">
          <p class="text-white/80 text-sm mb-1">Tardes</p>
          <p class="text-2xl font-bold">16:00 - 19:00</p>
        </div>
      </div>
      <p class="text-base-100">
        Lunes a Viernes · Tiempo de respuesta: &lt; 2 horas
      </p>
      <div class="mt-6">
        <a href="mailto:info@aisecurity.es" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-accent-700 hover:bg-base-50 rounded-xl font-semibold transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          info@aisecurity.es
        </a>
      </div>
    </div>
  </section>

  <!-- Modal de éxito -->
  <div id="success-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="modal-backdrop"></div>
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="relative bg-white rounded-2xl shadow-2xl max-w-md w-full p-8 transform scale-95 opacity-0 transition-all duration-300" id="modal-content">
      <button id="close-modal" class="absolute top-4 right-4 text-base-400 hover:text-base-600 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <div class="text-center">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-base-900 mb-3">¡Ticket enviado!</h3>
        <p class="text-base-700 mb-6">
          Hemos recibido tu solicitud. Te contactaremos en menos de 2 horas durante nuestro horario de atención.
        </p>
        <div class="bg-accent-50 rounded-xl p-4 mb-6 text-left">
          <p class="font-semibold text-base-900 mb-2">Próximos pasos:</p>
          <ol class="list-decimal list-inside text-sm text-base-700 space-y-1">
            <li>Si aún no lo has hecho, descarga e instala AnyDesk</li>
            <li>Te contactaremos para confirmar los detalles</li>
            <li>Nos conectamos y resolvemos tu problema</li>
          </ol>
        </div>
        <button id="modal-ok-btn" class="w-full py-3 px-6 bg-accent-600 hover:bg-accent-700 text-white font-bold rounded-xl transition-colors">
          Entendido
        </button>
      </div>
    </div>
  </div>
</div>
</BaseLayout>

<script>
  const form = document.getElementById('ticket-form') as HTMLFormElement;
  const modal = document.getElementById('success-modal') as HTMLDivElement;
  const modalContent = document.getElementById('modal-content') as HTMLDivElement;
  const modalBackdrop = document.getElementById('modal-backdrop') as HTMLDivElement;
  const closeModalBtn = document.getElementById('close-modal') as HTMLButtonElement;
  const modalOkBtn = document.getElementById('modal-ok-btn') as HTMLButtonElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;

  function showModal() {
    modal.classList.remove('hidden');
    setTimeout(() => {
      modalContent.classList.remove('scale-95', 'opacity-0');
      modalContent.classList.add('scale-100', 'opacity-100');
    }, 10);
  }

  function hideModal() {
    modalContent.classList.remove('scale-100', 'opacity-100');
    modalContent.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 300);
  }

  closeModalBtn?.addEventListener('click', hideModal);
  modalOkBtn?.addEventListener('click', hideModal);
  modalBackdrop?.addEventListener('click', hideModal);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.innerHTML;

    // Mostrar estado de carga
    submitBtn.disabled = true;
    submitBtn.innerHTML = `
      <svg class="animate-spin w-6 h-6" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Enviando ticket...
    `;

    try {
      const formData = new FormData(form);
      const response = await fetch('/api/ticket-soporte', {
        method: 'POST',
        body: formData,
      });

      const result = await response.json();

      if (response.ok) {
        // Éxito - mostrar modal
        form.reset();
        showModal();
        statusDiv.classList.add('hidden');
      } else {
        throw new Error(result.error || 'Error al enviar el ticket');
      }
    } catch (error) {
      // Error
      statusDiv.className = 'mt-6 p-6 bg-red-50 border-2 border-red-200 rounded-xl';
      statusDiv.innerHTML = `
        <div class="flex items-start gap-4">
          <span class="text-4xl">❌</span>
          <div>
            <h3 class="text-lg font-bold text-red-800 mb-2">Error al enviar el ticket</h3>
            <p class="text-red-700">
              Ha ocurrido un error. Por favor, inténtalo de nuevo o contacta directamente por email a
              <a href="mailto:info@aisecurity.es" class="font-bold underline">info@aisecurity.es</a>
            </p>
          </div>
        </div>
      `;
      statusDiv.classList.remove('hidden');
      statusDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });
</script>
