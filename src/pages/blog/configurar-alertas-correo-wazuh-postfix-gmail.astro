        <td style="padding: 12px;">Gestión de incidentes</td>
        <td style="padding: 12px;">Proceso automatizado de notificación para gestión de incidentes</td>
      </tr>
      <tr>
        <td style="padding: 12px; color: #f472b6; font-weight: bold;">op.exp.9</td>
        <td style="padding: 12px;">Registro de la gestión de incidentes</td>
        <td style="padding: 12px;">Los correos proporcionan evidencia documental de las alertas generadas</td>
