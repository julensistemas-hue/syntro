<script is:inline>
  // Tema verde: añadir clase al body (el CSS is:global hace el resto)
  document.body.classList.add('techai-theme');

  // Override del scroll handler de Navigation.astro (que resetea a azul)
  window.addEventListener('scroll', () => {
    const h = document.getElementById('main-header');
    if (!h) return;
    const bg = window.scrollY > 20
      ? 'linear-gradient(135deg, #030703 0%, #060a06 100%)'
      : 'linear-gradient(135deg, #040904 0%, #070c07 50%, #040904 100%)';
    h.style.setProperty('background', bg, 'important');
    h.style.setProperty('border-bottom', '1px solid rgba(0,255,65,0.15)', 'important');
  });

  // Cuenta atrás
  const target = new Date('2026-07-07T18:00:00').getTime();
  function tick() {
    const diff = target - Date.now();
    if (diff <= 0) return;
    const pad = n => String(Math.floor(n)).padStart(2,'0');
    document.getElementById('cd-d').textContent = pad(diff/86400000);
    document.getElementById('cd-h').textContent = pad((diff%86400000)/3600000);
    document.getElementById('cd-m').textContent = pad((diff%3600000)/60000);
    document.getElementById('cd-s').textContent = pad((diff%60000)/1000);
  }
  tick(); setInterval(tick, 1000);

  // Terminal typewriter
  const lines = [
    { t: '$ claude diagnose --paste-log', c: '#00ff41' },
    { t: '> [ANALIZANDO nginx error.log...]', c: 'rgba(240,240,240,0.4)', d: 800 },
    { t: '✓ Causa: SSL cert expirado', c: '#00d4aa', d: 1400 },
    { t: '✓ Fix: certbot renew --force', c: '#00d4aa', d: 1900 },
    { t: '', c: '', d: 2500 },
    { t: '$ whisperflow start', c: '#00ff41', d: 2900 },
    { t: '> [ REC ] "incidencia servidor web..."', c: 'rgba(240,240,240,0.4)', d: 3600 },
    { t: '✓ Ticket generado automáticamente', c: '#00d4aa', d: 4300 },
    { t: '', c: '', d: 4900 },
    { t: '$ ai-script --task="backup diario"', c: '#00ff41', d: 5300 },
    { t: '> Generando backup_daily.sh...', c: 'rgba(240,240,240,0.4)', d: 6000 },
    { t: '✓ Script listo con manejo de errores', c: '#00d4aa', d: 6600 },
    { t: '', c: '', d: 7200 },
    { t: '# Tiempo total: 8 min | Antes: ~3h', c: 'rgba(0,255,65,0.4)', d: 7600 },
  ];
  const out = document.getElementById('terminal-output');
  if (out) {
    lines.forEach(({ t, c, d = 0 }) => {
      setTimeout(() => {
        const el = document.createElement('div');
        el.textContent = t;
        el.style.color = c;
        if (!t) el.style.height = '10px';
        out.appendChild(el);
        out.parentElement.scrollTop = 9999;
      }, d);
    });
  }

  // Formulario
  async function submitForm(emailId, formId, successId, btnId, defaultBtnText) {
    const email = document.getElementById(emailId)?.value;
    const btn = document.getElementById(btnId);
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
    try {
      const res = await fetch('/api/lista-espera-techai-boost', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (data.success) {
        const form = document.getElementById(formId);
        const success = document.getElementById(successId);
        if (form) form.style.display = 'none';
        if (success) success.style.display = 'block';
      } else {
        if (btn) { btn.disabled = false; btn.textContent = defaultBtnText; }
      }
    } catch {
      if (btn) { btn.disabled = false; btn.textContent = defaultBtnText; }
    }
  }

  document.getElementById('hero-form')?.addEventListener('submit', e => {
    e.preventDefault();
    submitForm('hero-email','hero-form','hero-success','hero-btn','Avísame →');
  });
  document.getElementById('bottom-form')?.addEventListener('submit', e => {
    e.preventDefault();
    submitForm('bottom-email','bottom-form','bottom-success','bottom-btn','Apúntame a la lista de espera →');
  });
</script>

