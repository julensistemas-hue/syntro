  <!-- Course Content Section -->
  <section id="temario" class="py-20 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/10 via-blue-600/50 to-accent-500/10"></div>

