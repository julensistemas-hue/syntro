---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Curso Wazuh en Español | SIEM y XDR desde Cero hasta ENS | 50€";
const description = "Curso Wazuh en español: aprende a instalar, configurar y administrar Wazuh SIEM/XDR desde cero. Cumplimiento ENS, detección de amenazas, agentes Windows/Linux. Acceso permanente + actualizaciones. 50€ pago único. +80 alumnos.";
const canonical = "https://aisecurity.es/curso-wazuh";

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Curso Wazuh en Español 2026",
  "description": "Curso 100% práctico de Wazuh SIEM/XDR en español. Aprende instalación, configuración, reglas personalizadas y cumplimiento ENS desde cero hasta implementación real en entornos empresariales.",
  "provider": {
    "@type": "Organization",
    "name": "AI Security",
    "url": "https://aisecurity.es",
    "sameAs": "https://www.youtube.com/@aisecurityes"
  },
  "url": "https://aisecurity.es/curso-wazuh",
  "inLanguage": "es",
  "educationalLevel": "Beginner to Intermediate",
  "teaches": ["Wazuh SIEM", "Wazuh XDR", "Detección de amenazas", "Cumplimiento ENS", "Monitorización de seguridad", "File Integrity Monitoring", "Reglas y decoders Wazuh"],
  "courseMode": "Online",
  "availableLanguage": "Spanish",
  "offers": {
    "@type": "Offer",
    "price": "50",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "url": "https://aisecurity.es/aula/registro"
  },
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "Online",
    "courseWorkload": "PT10H",
    "inLanguage": "es"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es Wazuh?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wazuh es una plataforma open-source de seguridad que actúa como SIEM (Security Information and Event Management) y XDR (Extended Detection and Response). Permite monitorizar en tiempo real servidores Linux, Windows y dispositivos de red, detectar amenazas, analizar logs y cumplir con normativas como ENS, PCI-DSS y GDPR."
      }
    },
    {
      "@type": "Question",
      "name": "¿Para qué sirve Wazuh en empresas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wazuh sirve para detectar intrusiones y amenazas en tiempo real, monitorizar la integridad de archivos críticos, cumplir con el Esquema Nacional de Seguridad (ENS), gestionar vulnerabilidades, analizar logs de sistemas y dispositivos de red, y generar alertas automáticas ante incidentes de seguridad."
      }
    },
    {
      "@type": "Question",
      "name": "¿Necesito conocimientos previos para este curso de Wazuh?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No se requieren conocimientos previos de Wazuh. El curso empieza desde cero con la instalación completa. Se recomienda tener nociones básicas de administración de sistemas Linux/Windows, aunque el curso incluye todo lo necesario paso a paso."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué incluye el precio del curso de Wazuh?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El curso incluye acceso permanente a todos los videos, actualizaciones mensuales sin coste adicional, recursos descargables (scripts, configuraciones, plantillas), casos prácticos reales con cumplimiento ENS, y soporte directo con el formador. Todo por 50€ de pago único."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo instalar Wazuh?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wazuh se instala mediante el Wazuh Manager en un servidor Linux, seguido de la configuración del Wazuh Indexer y el Dashboard. En el curso cubrimos la instalación completa paso a paso: desde los requisitos del sistema, instalación del manager, despliegue de agentes en Linux y Windows, hasta la configuración de comunicación segura con certificados TLS."
      }
    },
    {
      "@type": "Question",
      "name": "¿Wazuh sirve para cumplir el ENS (Esquema Nacional de Seguridad)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Wazuh es una herramienta clave para el cumplimiento del Esquema Nacional de Seguridad (ENS) en España. Proporciona monitorización continua, detección de accesos no autorizados, control de integridad de archivos y generación de informes de cumplimiento. En el curso vemos cómo configurar Wazuh específicamente para los requisitos del ENS."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo se tarda en aprender Wazuh?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Con este curso puedes tener Wazuh instalado y funcionando en tu entorno en pocas horas. Para dominar la configuración avanzada, reglas personalizadas e integraciones, suelen necesitarse entre 1 y 3 semanas de práctica. El acceso permanente te permite avanzar a tu ritmo."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://aisecurity.es"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Curso Wazuh",
      "item": "https://aisecurity.es/curso-wazuh"
    }
  ]
};
