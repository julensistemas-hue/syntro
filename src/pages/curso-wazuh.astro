---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Curso Wazuh 2026 | Práctico + Últimas Integraciones | 50€";
const description = "Curso 100% práctico de Wazuh con contenido actualizado 2026. Aprende SIEM, XDR, integraciones con VirusTotal, Microsoft 365, Chat IA y más. Acceso permanente + actualizaciones mensuales. Desde 0 hasta implementación real.";
const canonical = "https://aisecurity.es/curso-wazuh";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/6107094.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/40 via-blue-600/50 to-accent-500/40"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <!-- Title Section (Centered) -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
          Curso Práctico de Wazuh:<br>
          <span class="text-blue-200">Aprende a tu ritmo con acceso permanente</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <!-- Left Column: Price Box -->
        <div class="w-full">
          <!-- Dashboard Style Card -->
          <div class="relative rounded-2xl shadow-large overflow-hidden border-2" style="background-color: #1F2937; border-color: #6366F1;">
            <!-- Top Header Bar -->
            <div class="flex items-center gap-2 p-4 border-b" style="border-color: #374151;">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 bg-red-400 rounded-full"></div>
                <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
                <div class="w-3 h-3 bg-green-400 rounded-full"></div>
              </div>
              <span  class="text-sm font-semibold text-white ml-2">Curso Wazuh - Inscripción</span>
            </div>

            <div class="p-6 md:p-8">
              <!-- Price Section -->
              <div class="text-center mb-6 p-4 rounded-xl border-2" style="background-color: #374151; border-color: #8B5CF6;">
                <p class="text-gray-300 text-sm uppercase tracking-wider mb-2 font-semibold">PRECIO DEL CURSO</p>
                <div class="mb-2 flex items-center justify-center gap-4">
                  <span class="text-3xl md:text-4xl font-bold text-gray-400 line-through">100€</span>
                  <span class="text-5xl md:text-6xl font-extrabold text-white">50€</span>
                  <span class="px-3 py-1 bg-green-500 text-white text-sm font-bold rounded-lg">-50%</span>
                </div>
                <p class="text-gray-300 text-xs">Incluye material y soporte</p>
              </div>

              <!-- Available Now Badge -->
              <div class="mb-6 p-4 rounded-lg border-2 text-center" style="background-color: rgba(34, 197, 94, 0.2); border-color: #22c55e;">
                <p class="text-green-400 text-lg font-bold flex items-center justify-center gap-2">
                  <span class="text-2xl">✅</span>
                  ¡Curso disponible ahora!
                </p>
                <p class="text-gray-300 text-sm mt-1">Acceso inmediato tras el pago</p>
              </div>

              <!-- CTA Buttons -->
              <div class="flex flex-col gap-3">
                <a
                  style="color: white;"
                  href="/aula/registro"
                  class="inline-flex items-center justify-center px-6 py-4 text-base font-bold bg-gradient-to-br from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 rounded-xl text-white shadow-lg hover:shadow-xl transition-all duration-200 hover:-translate-y-0.5">
                  Crear cuenta y empezar →
                </a>
                <a
                  style="color: white;"
                  href="/aula/login"
                  class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold bg-transparent border-2 border-white/30 hover:border-white/50 rounded-xl text-white transition-all duration-200">
                  Ya tengo cuenta - Iniciar sesión
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Course Info -->
        <div class="w-full">
          <!-- What's Included -->
          <div class="rounded-2xl shadow-large overflow-hidden border-2 p-6" style="background-color: #1F2937; border-color: #6366F1;">
            <!-- Header -->
            <div class="flex items-center gap-2 mb-5 pb-4 border-b" style="border-color: #374151;">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 bg-red-400 rounded-full"></div>
                <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
                <div class="w-3 h-3 bg-green-400 rounded-full"></div>
              </div>
              <span class="text-sm font-semibold text-white ml-2">🎯 Qué incluye</span>
            </div>

            <!-- Features -->
            <div class="space-y-3">
              <div class="p-3 rounded-xl border-l-4 flex items-center gap-3" style="background-color: #374151; border-color: #8B5CF6;">
                <span class="text-2xl">∞</span>
                <div>
                  <div class="text-white font-semibold text-sm">Acceso permanente</div>
                  <div class="text-gray-400 text-xs">Accede a la plataforma y todo el contenido para siempre</div>
                </div>
              </div>
              <div class="p-3 rounded-xl border-l-4 flex items-center gap-3" style="background-color: #374151; border-color: #10B981;">
                <span class="text-2xl">🔄</span>
                <div>
                  <div class="text-white font-semibold text-sm">Actualizado mensualmente</div>
                  <div class="text-gray-400 text-xs">Nuevo contenido cada mes sin coste adicional</div>
                </div>
              </div>
              <div class="p-3 rounded-xl border-l-4 flex items-center gap-3" style="background-color: #374151; border-color: #F59E0B;">
                <span class="text-2xl">📹</span>
                <div>
                  <div class="text-white font-semibold text-sm">Videos prácticos</div>
                  <div class="text-gray-400 text-xs">Aprende paso a paso con ejemplos reales</div>
                </div>
              </div>
              <div class="p-3 rounded-xl border-l-4 flex items-center gap-3" style="background-color: #374151; border-color: #3B82F6;">
                <span class="text-2xl">🏢</span>
                <div>
                  <div class="text-white font-semibold text-sm">Casos prácticos reales</div>
                  <div class="text-gray-400 text-xs">Empresas y cumplimiento ENS</div>
                </div>
              </div>
              <div class="p-3 rounded-xl border-l-4 flex items-center gap-3" style="background-color: #374151; border-color: #EC4899;">
                <span class="text-2xl">🎓</span>
                <div>
                  <div class="text-white font-semibold text-sm">Soporte continuo</div>
                  <div class="text-gray-400 text-xs">Resuelve tus dudas directamente con el formador</div>
                </div>
              </div>
              <div class="p-3 rounded-xl border-l-4 flex items-center gap-3" style="background-color: #374151; border-color: #14B8A6;">
                <span class="text-2xl">🚀</span>
                <div>
                  <div class="text-white font-semibold text-sm">Actualizaciones de por vida</div>
                  <div class="text-gray-400 text-xs">Acceso a todas las mejoras futuras del curso</div>
                </div>
              </div>
              <div class="p-3 rounded-xl border-l-4 flex items-center gap-3" style="background-color: #374151; border-color: #EF4444;">
                <span class="text-2xl">📦</span>
                <div>
                  <div class="text-white font-semibold text-sm">Recursos descargables</div>
                  <div class="text-gray-400 text-xs">Scripts, configuraciones y plantillas listas para usar</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- PC Mockup with Wazuh Screenshots -->
     
    </div>
  </section>

  <!-- Practical Approach Section -->
  <section class="py-20 bg-base-50 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 opacity-40">
      <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-base-50/70"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-6">
        Aprende Haciendo: Monitorización Real de Entornos Empresariales
      </h2>

      <p class="text-lg md:text-xl text-white/90 text-center max-w-3xl mx-auto mb-12">
        Este no es un curso teórico. <strong class="text-white">Configurarás y monitorizarás sistemas reales</strong> desde el primer día.
        Verás cómo detectar amenazas, analizar logs y generar alertas en entornos empresariales reales.
      </p>

       <div class="max-w-5xl mx-auto mt-16">
        <div class="relative bg-gradient-to-b from-gray-900 via-gray-800 to-gray-900 rounded-t-2xl p-3 shadow-2xl">
          <!-- Laptop Header -->
          <div class="bg-gray-800 rounded-t-xl py-2 px-4 flex items-center gap-2">
            <div class="flex gap-2">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
            </div>
            <div class="flex-1 text-center text-white/60 text-sm font-medium">
              Wazuh Dashboard - 
            </div>
          </div>

          <!-- Screenshot Carousel -->
          <div class="bg-white rounded-b-xl overflow-hidden">
            <!-- Tab Navigation -->
            <div class="flex bg-gray-100 border-b border-gray-200">
              <button
                data-tab="tab1"
                class="wazuh-tab active flex-1 px-4 py-3 text-sm font-medium text-blue-600 border-b-2 border-blue-600 transition-colors"
                onclick="switchTab('tab1')">
                Overview Dashboard
              </button>
              <button
                data-tab="tab2"
                class="wazuh-tab flex-1 px-4 py-3 text-sm font-medium text-gray-600 hover:text-blue-600 border-b-2 border-transparent transition-colors"
                onclick="switchTab('tab2')">
                Security Events
              </button>
              <button
                data-tab="tab3"
                class="wazuh-tab flex-1 px-4 py-3 text-sm font-medium text-gray-600 hover:text-blue-600 border-b-2 border-transparent transition-colors"
                onclick="switchTab('tab3')">
                Threat Detection
              </button>
            </div>

            <!-- Tab Content -->
            <div class="relative" style="min-height: 400px;">
              <!-- Tab 1 -->
              <div id="tab1" class="wazuh-content">
                <img
                  src="/images/wazuh-dashboard.png"
                  alt="Wazuh Overview Dashboard"
                  class="w-full h-auto"
                  loading="lazy"
                />
              </div>

              <!-- Tab 2 -->
              <div id="tab2" class="wazuh-content hidden">
                <img
                  src="/images/wazuh-dashboard (1).png"
                  alt="Wazuh Security Events"
                  class="w-full h-auto"
                  loading="lazy"
                />
              </div>

              <!-- Tab 3 -->
              <div id="tab3" class="wazuh-content hidden">
                <img
                  src="/images/save-the-results1.png"
                  alt="Wazuh Threat Detection"
                  class="w-full h-auto"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Laptop Base -->
        <div class="h-4 bg-gray-800 rounded-b-2xl mx-auto" style="width: 80%;"></div>
        <div class="h-2 bg-gray-700 rounded-b-3xl mx-auto" style="width: 95%;"></div>
      </div>


      <!-- Environments Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-16">
        <!-- Linux Server -->
        <div class="bg-base-50 rounded-xl p-6 border-2 border-base-400 hover:border-accent-500 transition-all duration-300 transform hover:-translate-y-1">
          <div class="text-6xl mb-4 text-center">🐧</div>
          <h3 class="text-xl font-bold text-white mb-2 text-center">Servidor Linux</h3>
          <p class="text-base-700 text-center text-sm">
            Monitorización de logs del sistema, autenticación SSH, procesos y servicios críticos
          </p>
        </div>

        <!-- Windows Server -->
        <div class="bg-base-50 rounded-xl p-6 border-2 border-base-400 hover:border-accent-500 transition-all duration-300 transform hover:-translate-y-1">
          <div class="text-6xl mb-4 text-center">🪟</div>
          <h3 class="text-xl font-bold text-white mb-2 text-center">Servidor Windows</h3>
          <p class="text-base-700 text-center text-sm">
            Event Viewer, Active Directory, PowerShell, detección de amenazas en entorno Windows
          </p>
        </div>

        <!-- Firewall -->
        <div class="bg-base-50 rounded-xl p-6 border-2 border-base-400 hover:border-accent-500 transition-all duration-300 transform hover:-translate-y-1">
          <div class="text-6xl mb-4 text-center">🔥</div>
          <h3 class="text-xl font-bold text-white mb-2 text-center">Firewall / Dispositivo de Red</h3>
          <p class="text-base-700 text-center text-sm">
            Análisis de tráfico de red, detección de intrusiones, logs de dispositivos de seguridad
          </p>
        </div>

        <!-- NAS -->
        <div class="bg-base-50 rounded-xl p-6 border-2 border-base-400 hover:border-accent-500 transition-all duration-300 transform hover:-translate-y-1">
          <div class="text-6xl mb-4 text-center">💾</div>
          <h3 class="text-xl font-bold text-white mb-2 text-center">Dispositivo NAS</h3>
          <p class="text-base-700 text-center text-sm">
            Monitorización de almacenamiento, accesos a archivos, integridad de datos
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Content Section -->
  <section class="py-20 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-bl from-accent-500/10 via-blue-600/50 to-accent-500/10"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-8 md:px-12 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">
        Contenido Detallado del Curso
      </h2>

      <div class="space-y-4">
        <!-- Module 1 -->
        <details class="group bg-base-50 rounded-xl border-2 border-base-400 hover:border-accent-500 transition-all duration-300">
          <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-xl text-white hover:text-accent-300">
            <span>📚 Módulo 1: Introducción y Arquitectura</span>
            <svg class="w-6 h-6 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 space-y-3 text-base-800">
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">1.1</span>
              <p><strong>¿Qué es Wazuh y por qué usarlo?</strong> - Ventajas sobre otras soluciones SIEM</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">1.2</span>
              <p><strong>Arquitectura de componentes</strong> - Manager, Agents, Indexer y su interacción</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">1.3</span>
              <p><strong>Casos de uso empresariales</strong> - Ejemplos reales de implementación</p>
            </div>
          </div>
        </details>

        <!-- Module 2 -->
        <details class="group bg-base-50 rounded-xl border-2 border-base-400 hover:border-accent-500 transition-all duration-300">
          <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-xl text-white hover:text-accent-300">
            <span>⚙️ Módulo 2: Instalación y Configuración</span>
            <svg class="w-6 h-6 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 space-y-3 text-base-800">
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">2.1</span>
              <p><strong>Instalación del Wazuh Manager</strong> - Paso a paso en servidor Linux</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">2.2</span>
              <p><strong>Despliegue de Agentes</strong> - Linux y Windows, configuración básica</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">2.3</span>
              <p><strong>Configuración de comunicación segura</strong> - Certificados y encriptación</p>
            </div>
          </div>
        </details>

        <!-- Module 3 -->
        <details class="group bg-base-50 rounded-xl border-2 border-base-400 hover:border-accent-500 transition-all duration-300">
          <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-xl text-white hover:text-accent-300">
            <span>🔍 Módulo 3: Monitorización de Sistemas</span>
            <svg class="w-6 h-6 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 space-y-3 text-base-800">
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">3.1</span>
              <p><strong>Monitorización de logs en tiempo real</strong> - Análisis de syslog, auth.log y más</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">3.2</span>
              <p><strong>File Integrity Monitoring (FIM)</strong> - Detección de cambios no autorizados</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">3.3</span>
              <p><strong>Detección de rootkits y malware</strong> - Análisis de sistema operativo</p>
            </div>
          </div>
        </details>

        <!-- Module 4 -->
        <details class="group bg-base-50 rounded-xl border-2 border-base-400 hover:border-accent-500 transition-all duration-300">
          <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-xl text-white hover:text-accent-300">
            <span>📝 Módulo 4: Reglas, Decoders y Alertas</span>
            <svg class="w-6 h-6 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 space-y-3 text-base-800">
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">4.1</span>
              <p><strong>Estructura de reglas de Wazuh</strong> - Sintaxis, niveles de severidad, grupos</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">4.2</span>
              <p><strong>Creación de decoders personalizados</strong> - Parseo de logs específicos</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">4.3</span>
              <p><strong>Configuración de alertas y notificaciones</strong> - Email, Slack, webhooks</p>
            </div>
          </div>
        </details>

        <!-- Module 5 -->
        <details class="group bg-base-50 rounded-xl border-2 border-base-400 hover:border-accent-500 transition-all duration-300">
          <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-xl text-white hover:text-accent-300">
            <span>📊 Módulo 5: Dashboard y Cumplimiento</span>
            <svg class="w-6 h-6 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 space-y-3 text-base-800">
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">5.1</span>
              <p><strong>Kibana/OpenSearch Dashboards</strong> - Navegación y personalización de interfaz</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">5.2</span>
              <p><strong>Visualización de datos de seguridad</strong> - Gráficos, mapas, tablas dinámicas</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-white text-base font-bold flex-shrink-0 min-w-[2rem]">5.3</span>
              <p><strong>Cumplimiento normativo</strong> - PCI-DSS, GDPR, ENS básico y reportes</p>
            </div>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Additional Information Section -->
  <section class="py-20 bg-base-50 relative overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 opacity-40">
      <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
    </div>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-base-50/60"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-24">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">
        Información del Curso
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Access -->
        <div class="bg-base-50 rounded-xl p-6 border border-base-200 hover:border-accent-400 transition-all duration-300">
          <div class="text-5xl mb-4 text-center">🎯</div>
          <h3 class="text-xl font-bold text-white mb-3 text-center">Acceso Inmediato</h3>
          <p class="text-base-700 text-center">
            Aprende a tu ritmo desde cualquier lugar. Plataforma disponible 24/7 con todo el contenido organizado y actualizado.
          </p>
        </div>

        <!-- Contact -->
        <div class="bg-base-50 rounded-xl p-6 border border-base-200 hover:border-accent-400 transition-all duration-300">
          <div class="text-5xl mb-4 text-center">📧</div>
          <h3 class="text-xl font-bold text-white mb-3 text-center">¿Tienes Preguntas?</h3>
          <p class="text-base-700 text-center mb-2">
