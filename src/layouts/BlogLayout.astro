---
import BaseHead from "../components/BaseHead.astro";
import Navigation from "../components/global/Navigation.astro";
import Footer from "../components/global/Footer.astro";
import GoogleAnalytics from "../components/global/GoogleAnalytics.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { stripLocale, localizePath, hasTranslation } from "../i18n/config";

interface Props {
  title: string;
  description: string;
  publishDate: string;
  modifiedDate?: string;
  author?: string;
  readTime?: string;
  tags?: string[];
  canonical?: string;
  ogImage?: string;
  faqSchema?: Array<{question: string; answer: string}>;
}

const {
  title,
  description,
  publishDate,
  modifiedDate,
  author = "AI Security",
  readTime = "5 min",
  tags = [],
  canonical,
  ogImage = "https://aisecurity.es/og-image.png",
  faqSchema
} = Astro.props;

const fullTitle = `${title} | Blog AI Security`;
const isWazuh = tags.some((t: string) => t.toLowerCase() === 'wazuh');

// hreflang automático si este post tiene versión inglesa (mismo slug bajo /en)
const canonicalPath = stripLocale(Astro.url.pathname);
const showAlternates = hasTranslation(canonicalPath);
const esAltUrl = new URL(canonicalPath, Astro.site).href;
const enAltUrl = new URL(localizePath(canonicalPath, "en"), Astro.site).href;
---

<html
  lang="es"
  class="scroll-smooth selection:bg-accent-500 selection:text-white no-touchevents hydrated">
  <head>
    <GoogleAnalytics />
    <BaseHead
      title={fullTitle}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
    />
    {showAlternates && (
      <>
        <link rel="alternate" hreflang="es" href={esAltUrl} />
        <link rel="alternate" hreflang="en" href={enAltUrl} />
        <link rel="alternate" hreflang="x-default" href={esAltUrl} />
      </>
    )}
    <!-- Article Schema.org for SEO -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "author": {
        "@type": "Organization",
        "name": author,
        "url": "https://aisecurity.es"
      },
      "publisher": {
        "@type": "Organization",
        "name": "AI Security",
        "logo": {
          "@type": "ImageObject",
          "url": "https://aisecurity.es/favicon.png"
        }
      },
      "datePublished": publishDate,
      "dateModified": modifiedDate || publishDate,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonical
      },
      "image": ogImage,
      "keywords": tags.join(", ")
    })} />
    {faqSchema && faqSchema.length > 0 && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqSchema.map((faq: {question: string; answer: string}) => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
          }
        }))
      })} />
    )}
  </head>
  <body class="flex flex-col min-h-svh">
    <Navigation />

    <main class="grow">
      <!-- Article Header -->
      <section class="py-16 relative overflow-hidden" style="background:#050f1f;border-bottom:1px solid rgba(255,255,255,0.08);">
        <canvas id="blog-hero-canvas" class="absolute inset-0 w-full h-full" style="opacity:0.45;"></canvas>
        <div class="absolute inset-x-0 bottom-0 h-12" style="background:linear-gradient(to bottom,transparent,#020817);"></div>

        <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
          <!-- Breadcrumb -->
          <nav class="mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-sm text-white/70">
              <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
              <li aria-hidden="true">→</li>
              <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
              <li aria-hidden="true">→</li>
              <li class="text-white font-medium" aria-current="page">Artículo</li>
            </ol>
          </nav>

          <!-- Tags -->
          {tags.length > 0 && (
            <div  class="flex flex-wrap gap-2 mb-4">
              {tags.map(tag => (
                <span class="px-3 py-1 bg-white/20 backdrop-blur-sm text-white text-xs font-semibold rounded-full border border-white/30">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
            {title}
          </h1>

          <!-- Description -->
          <p class="text-lg md:text-xl text-white/90 mb-6 leading-relaxed">
            {description}
          </p>

          <!-- Meta info -->
          <div  class="flex flex-wrap items-center gap-4 text-sm text-white/80">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              <span>{author}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>{readTime} lectura</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Article Content -->
      <article class="py-12 md:py-16 relative overflow-hidden" style="background-color: #010303;">
        <!-- Background Image -->
        <div class="absolute inset-0 opacity-15">
          <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
        </div>

        <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
          <div class="prose prose-lg prose-base max-w-none
            prose-headings:font-bold prose-headings:text-white
            prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4 prose-h2:border-b prose-h2:border-base-700 prose-h2:pb-3
            prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3
            prose-p:text-white/90 prose-p:leading-relaxed prose-p:mb-4
            prose-a:text-accent-400 prose-a:no-underline hover:prose-a:underline
            prose-strong:text-white prose-strong:font-semibold
            prose-code:bg-black prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:before:content-none prose-code:after:content-none prose-code:border prose-code:border-emerald-500/30
            prose-pre:bg-black prose-pre:rounded-xl prose-pre:border-2 prose-pre:border-blue-500/30 prose-pre:shadow-lg prose-pre:shadow-blue-500/10
            prose-ul:my-4 prose-li:text-white/90 prose-li:my-2
            prose-ol:my-4
            prose-img:rounded-xl prose-img:shadow-lg prose-img:border prose-img:border-base-700">
            <slot />
          </div>
        </div>
      </article>

      <!-- Back to Blog -->
      <section class="py-8 border-t border-base-700 relative overflow-hidden" style="background-color: #121416;">
        <!-- Background Image -->
        <div class="absolute inset-0 opacity-15">
          <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
        </div>

        <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-300 font-medium transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al blog
          </a>
        </div>
      </section>
    </main>

    <Footer />
    <Analytics />
    <SpeedInsights />

    <!-- ══ OVERLAY + POPUP CURSO WAZUH (solo en artículos Wazuh) ══ -->
    {isWazuh && (
      <>
        <!-- Overlay oscuro de fondo -->
        <div id="wazuh-popup-overlay" aria-hidden="true" style="
          position:fixed;inset:0;
          z-index:9997;
          background:rgba(0,0,0,0.65);
          backdrop-filter:blur(3px);
          -webkit-backdrop-filter:blur(3px);
          opacity:0;
          pointer-events:none;
          transition:opacity 0.35s ease;
        "></div>

        <!-- Popup centrado -->
        <div id="wazuh-course-popup" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Curso Wazuh disponible" style="
          position:fixed;
          top:50%;left:50%;
          transform:translate(-50%,-50%) scale(0.92);
          z-index:9998;
          width:min(480px,calc(100vw - 2rem));
          background:linear-gradient(145deg,#070f20 0%,#0d1a38 55%,#080f22 100%);
          border:1px solid rgba(59,130,246,0.4);
          border-radius:20px;
          box-shadow:
            0 0 0 1px rgba(59,130,246,0.1),
            0 30px 80px rgba(0,0,0,0.75),
            0 0 60px rgba(59,130,246,0.12),
            inset 0 1px 0 rgba(255,255,255,0.04);
          padding:0;
          overflow:hidden;
          opacity:0;
          pointer-events:none;
          transition:opacity 0.4s ease,transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
        ">
          <!-- Barra superior degradado animado -->
          <div style="height:4px;background:linear-gradient(90deg,#2563eb,#818cf8,#a78bfa,#818cf8,#2563eb);background-size:200%;animation:wazuhBar 3s linear infinite;"></div>

          <div style="padding:1.6rem 1.8rem 1.8rem;">
            <!-- Header -->
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:14px;">
              <div style="display:flex;align-items:center;gap:14px;">
                <!-- Icono escudo grande -->
                <div style="
                  width:52px;height:52px;border-radius:14px;flex-shrink:0;
                  background:linear-gradient(135deg,rgba(37,99,235,0.25),rgba(129,140,248,0.15));
                  border:1px solid rgba(59,130,246,0.35);
                  display:flex;align-items:center;justify-content:center;
                  box-shadow:0 0 20px rgba(59,130,246,0.2);
                ">
                  <svg width="26" height="26" fill="none" stroke="#60a5fa" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                </div>
                <div>
                  <p style="font-size:0.65rem;font-weight:700;color:#60a5fa;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 4px;">Nuevo curso disponible</p>
                  <p style="font-size:1.15rem;font-weight:900;color:white;margin:0;line-height:1.2;letter-spacing:-0.01em;">Curso Wazuh en español</p>
                </div>
              </div>
              <!-- Botón cerrar -->
              <button id="wazuh-popup-close" aria-label="Cerrar popup" style="
                background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.1);
                color:rgba(255,255,255,0.55);
                width:30px;height:30px;border-radius:50%;cursor:pointer;
                display:flex;align-items:center;justify-content:center;
                font-size:0.85rem;flex-shrink:0;
                transition:background 0.2s,color 0.2s,border-color 0.2s;
              " onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.color='white'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.color='rgba(255,255,255,0.55)'">✕</button>
            </div>

            <!-- Descripción -->
            <p style="font-size:0.875rem;color:rgba(255,255,255,0.7);line-height:1.6;margin:0 0 14px;">
              Instalación completa, agentes Windows/Linux, reglas personalizadas y cumplimiento del <strong style="color:rgba(255,255,255,0.9);">ENS</strong>. Todo desde cero, sin experiencia previa necesaria.
            </p>

            <!-- Pills de contenido -->
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px;">
              <span style="font-size:0.7rem;font-weight:600;padding:4px 10px;border-radius:20px;background:rgba(59,130,246,0.12);border:1px solid rgba(59,130,246,0.28);color:#93c5fd;">Instalación</span>
              <span style="font-size:0.7rem;font-weight:600;padding:4px 10px;border-radius:20px;background:rgba(167,139,250,0.12);border:1px solid rgba(167,139,250,0.28);color:#c4b5fd;">Reglas personalizadas</span>
              <span style="font-size:0.7rem;font-weight:600;padding:4px 10px;border-radius:20px;background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.22);color:#86efac;">Cumplimiento ENS</span>
              <span style="font-size:0.7rem;font-weight:600;padding:4px 10px;border-radius:20px;background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.22);color:#fde68a;">Acceso permanente</span>
            </div>

            <!-- Divisor -->
            <div style="height:1px;background:rgba(59,130,246,0.15);margin-bottom:18px;"></div>

            <!-- Precio + CTA -->
            <div style="display:flex;align-items:center;gap:14px;">
              <div style="flex-shrink:0;text-align:center;">
                <div style="font-size:2rem;font-weight:900;color:white;line-height:1;">50€</div>
                <div style="font-size:0.65rem;color:rgba(255,255,255,0.4);margin-top:2px;white-space:nowrap;">pago único · acceso de por vida</div>
              </div>
              <a id="wazuh-popup-cta" href="/curso-wazuh" style="
                flex:1;display:flex;align-items:center;justify-content:center;gap:8px;
                padding:13px 18px;border-radius:12px;
                background:linear-gradient(135deg,#2563eb 0%,#1d4ed8 100%);
                color:white;font-size:0.9rem;font-weight:700;
                text-decoration:none;
                transition:opacity 0.2s,transform 0.15s,box-shadow 0.2s;
                box-shadow:0 6px 20px rgba(37,99,235,0.45);
                letter-spacing:0.01em;
              " onmouseover="this.style.opacity='0.92';this.style.transform='scale(1.02)';this.style.boxShadow='0 8px 28px rgba(37,99,235,0.6)'" onmouseout="this.style.opacity='1';this.style.transform='scale(1)';this.style.boxShadow='0 6px 20px rgba(37,99,235,0.45)'">
                Ver el curso
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <style is:inline>
          @keyframes wazuhBar {
            0%   { background-position: 0% center; }
            100% { background-position: 200% center; }
          }
        </style>
      </>
    )}

    <!-- JS popup Wazuh -->
    {isWazuh && (
      <script is:inline>
        (function () {
          var STORAGE_KEY = 'wazuh-popup-dismissed';
          if (localStorage.getItem(STORAGE_KEY)) return;

          var overlay = document.getElementById('wazuh-popup-overlay');
          var popup   = document.getElementById('wazuh-course-popup');
          var closeBtn = document.getElementById('wazuh-popup-close');
          var cta      = document.getElementById('wazuh-popup-cta');
          if (!popup) return;

          function sendGA(action) {
            if (typeof gtag === 'function') {
              gtag('event', action, {
                event_category: 'wazuh_curso_popup',
                event_label: document.title,
                page_path: window.location.pathname,
              });
            }
          }

          function showPopup() {
            if (overlay) { overlay.style.opacity = '1'; overlay.style.pointerEvents = 'all'; }
            popup.style.opacity = '1';
            popup.style.transform = 'translate(-50%,-50%) scale(1)';
            popup.style.pointerEvents = 'all';
            popup.setAttribute('aria-hidden', 'false');
            sendGA('popup_shown');
          }

          function hidePopup() {
            if (overlay) { overlay.style.opacity = '0'; overlay.style.pointerEvents = 'none'; }
            popup.style.opacity = '0';
            popup.style.transform = 'translate(-50%,-50%) scale(0.92)';
            popup.style.pointerEvents = 'none';
            popup.setAttribute('aria-hidden', 'true');
            localStorage.setItem(STORAGE_KEY, '1');
          }

          // Mostrar tras 4 s
          setTimeout(showPopup, 4000);

          // Cerrar con X
          if (closeBtn) {
            closeBtn.addEventListener('click', function () {
              sendGA('popup_closed');
              hidePopup();
            });
          }

          // Cerrar overlay al hacer clic fuera
          if (overlay) {
            overlay.addEventListener('click', function () {
              sendGA('popup_closed_overlay');
              hidePopup();
            });
          }

          // Tracking del CTA
          if (cta) {
            cta.addEventListener('click', function () {
              sendGA('popup_cta_click');
              localStorage.setItem(STORAGE_KEY, '1');
            });
          }
        })();
      </script>
    )}

  </body>
</html>

<script is:inline>
(function() {
  const canvas = document.getElementById('blog-hero-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  function resize() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);
  const NODES = 60, MAX_DIST = 140;
  const nodes = Array.from({ length: NODES }, () => ({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    vx: (Math.random() - 0.5) * 0.4,
    vy: (Math.random() - 0.5) * 0.4,
    r: Math.random() * 1.5 + 1,
    phase: Math.random() * Math.PI * 2,
  }));
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    nodes.forEach(n => {
      n.x += n.vx; n.y += n.vy; n.phase += 0.02;
      if (n.x < 0 || n.x > canvas.width) n.vx *= -1;
      if (n.y < 0 || n.y > canvas.height) n.vy *= -1;
    });
    for (let i = 0; i < NODES; i++) {
      for (let j = i + 1; j < NODES; j++) {
        const dx = nodes[i].x - nodes[j].x, dy = nodes[i].y - nodes[j].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < MAX_DIST) {
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.strokeStyle = `rgba(96,165,250,${(1 - dist/MAX_DIST)*0.25})`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }
    }
    nodes.forEach(n => {
      const pulse = 0.5 + 0.5 * Math.sin(n.phase);
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r + pulse * 0.8, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(129,140,248,${0.4 + pulse * 0.4})`;
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

<script>
  // Añadir botón de copiar a cada bloque de código y aplicar color
  document.addEventListener('DOMContentLoaded', () => {
    const codeBlocks = document.querySelectorAll('article pre');

    codeBlocks.forEach((block) => {
      // Aplicar color al código
      const codeElement = block.querySelector('code');
      if (codeElement) {
        codeElement.style.color = '#64abd3';
      }

      // Crear botón de copiar
      const copyButton = document.createElement('button');
      copyButton.textContent = '📋 Copiar código';
      copyButton.className = 'copy-button';
      copyButton.setAttribute('aria-label', 'Copiar código');

      // Añadir evento de click
      copyButton.addEventListener('click', async () => {
        const code = block.querySelector('code');
        const text = code?.textContent || '';

        try {
          await navigator.clipboard.writeText(text);
          copyButton.textContent = '✓ ¡Código copiado!';
          copyButton.classList.add('copied');

          // Volver al estado original después de 2 segundos
          setTimeout(() => {
            copyButton.textContent = '📋 Copiar código';
            copyButton.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Error al copiar:', err);
        }
      });

      // Insertar el botón justo después del bloque de código
      block.parentNode?.insertBefore(copyButton, block.nextSibling);
    });

    // También aplicar color al código inline
    const inlineCodes = document.querySelectorAll('article :not(pre) > code');
    inlineCodes.forEach((code) => {
      code.style.color = '#64abd3';
    });
  });
</script>

<style>
  /* Mejoras adicionales para el contenido del artículo */
  article img {
    margin: 2rem auto;
  }

  article pre {
    overflow-x: auto;
    padding: 1.5rem; /* Padding uniforme */
  }

  /* Efecto de brillo sutil en los bloques de código */
  article pre::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.5), transparent);
  }

  .prose pre code {
    font-size: 0.9em !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    color: #64abd3 !important;
  }

  /* Código inline (fuera de pre) */
  .prose :not(pre) > code {
    color: #64abd3 !important;
  }

  article pre code {
    font-size: 0.9em !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    color: #64abd3 !important;
  }

  /* Código inline con mejor visibilidad */
  article :not(pre) > code {
    font-weight: 500;
    box-shadow: 0 0 0 1px rgba(16, 185, 129, 0.2);
  }

  /* Mejorar títulos H2 con gradiente sutil */
  article h2 {
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.1), transparent);
    padding-left: 0.75rem;
    margin-left: -0.75rem;
  }

  /* Listas con mejor espaciado */
  article ul li,
  article ol li {
    padding-left: 0.5rem;
