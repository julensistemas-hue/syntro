---
import BaseHead from "../components/BaseHead.astro";
import Navigation from "../components/global/Navigation.astro";
import Footer from "../components/global/Footer.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title: string;
  description: string;
  publishDate: string;
  author?: string;
  readTime?: string;
  tags?: string[];
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  publishDate,
  author = "AI Security",
  readTime = "5 min",
  tags = [],
  canonical,
  ogImage = "https://aisecurity.es/og-image.png"
} = Astro.props;

const fullTitle = `${title} | Blog AI Security`;
const isWazuh = tags.some((t: string) => t.toLowerCase() === 'wazuh');
---

<html
  lang="es"
  class="scroll-smooth selection:bg-accent-500 selection:text-white no-touchevents hydrated">
  <head>
    <BaseHead
      title={fullTitle}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
    />
    <!-- Article Schema.org for SEO -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "author": {
        "@type": "Organization",
        "name": author,
        "url": "https://aisecurity.es"
      },
      "publisher": {
        "@type": "Organization",
        "name": "AI Security",
        "logo": {
          "@type": "ImageObject",
          "url": "https://aisecurity.es/favicon.png"
        }
      },
      "datePublished": publishDate,
      "dateModified": publishDate,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonical
      },
      "image": ogImage,
      "keywords": tags.join(", ")
    })} />
  </head>
  <body class="flex flex-col min-h-svh">
    <Navigation />

    <main class="grow">
      <!-- Article Header -->
      <section class="py-16 relative overflow-hidden border-b border-base-700">
        <!-- Background Image -->
        <div class="absolute inset-0 opacity-30">
          <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
        </div>
        <!-- Overlay Gradient -->
        <div class="absolute inset-0 bg-gradient-to-bl from-accent-600/30 via-blue-600/40 to-accent-600/30"></div>

        <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
          <!-- Breadcrumb -->
          <nav class="mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-sm text-white/70">
              <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
              <li aria-hidden="true">→</li>
              <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
              <li aria-hidden="true">→</li>
              <li class="text-white font-medium" aria-current="page">Artículo</li>
            </ol>
          </nav>

          <!-- Tags -->
          {tags.length > 0 && (
            <div  class="flex flex-wrap gap-2 mb-4">
              {tags.map(tag => (
                <span class="px-3 py-1 bg-white/20 backdrop-blur-sm text-white text-xs font-semibold rounded-full border border-white/30">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
            {title}
          </h1>

          <!-- Description -->
          <p class="text-lg md:text-xl text-white/90 mb-6 leading-relaxed">
            {description}
          </p>

          <!-- Meta info -->
          <div  class="flex flex-wrap items-center gap-4 text-sm text-white/80">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              <span>{author}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>{readTime} lectura</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Article Content -->
      <article class="py-12 md:py-16 relative overflow-hidden" style="background-color: #010303;">
        <!-- Background Image -->
        <div class="absolute inset-0 opacity-15">
          <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
        </div>

        <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
          <div class="prose prose-lg prose-base max-w-none
            prose-headings:font-bold prose-headings:text-white
            prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4 prose-h2:border-b prose-h2:border-base-700 prose-h2:pb-3
            prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3
            prose-p:text-white/90 prose-p:leading-relaxed prose-p:mb-4
            prose-a:text-accent-400 prose-a:no-underline hover:prose-a:underline
            prose-strong:text-white prose-strong:font-semibold
            prose-code:bg-black prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:before:content-none prose-code:after:content-none prose-code:border prose-code:border-emerald-500/30
            prose-pre:bg-black prose-pre:rounded-xl prose-pre:border-2 prose-pre:border-blue-500/30 prose-pre:shadow-lg prose-pre:shadow-blue-500/10
            prose-ul:my-4 prose-li:text-white/90 prose-li:my-2
            prose-ol:my-4
            prose-img:rounded-xl prose-img:shadow-lg prose-img:border prose-img:border-base-700">
            <slot />
          </div>
        </div>
      </article>

      <!-- Back to Blog -->
      <section class="py-8 border-t border-base-700 relative overflow-hidden" style="background-color: #121416;">
        <!-- Background Image -->
        <div class="absolute inset-0 opacity-15">
          <img src="/images/3409297.jpg" alt="Background" class="w-full h-full object-cover" />
        </div>

        <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-300 font-medium transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al blog
          </a>
        </div>
      </section>
    </main>

    <Footer />
    <Analytics />
    <SpeedInsights />

    <!-- ══ POPUP CURSO WAZUH (solo en artículos Wazuh) ══ -->
    {isWazuh && (
      <div id="wazuh-course-popup" aria-hidden="true" style="
        position:fixed;bottom:1.5rem;right:1.5rem;
        z-index:9998;
        width:min(340px,calc(100vw - 2rem));
        background:linear-gradient(135deg,#0a1628 0%,#0f1e3a 60%,#0a1628 100%);
        border:1px solid rgba(59,130,246,0.35);
        border-radius:16px;
        box-shadow:0 0 0 1px rgba(59,130,246,0.08),0 20px 60px rgba(0,0,0,0.6),0 0 40px rgba(59,130,246,0.08);
        padding:0;
        overflow:hidden;
        opacity:0;
        transform:translateY(24px) scale(0.95);
        pointer-events:none;
        transition:opacity 0.4s ease,transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
      ">
        <!-- Barra superior de color -->
        <div style="height:3px;background:linear-gradient(90deg,#3b82f6,#818cf8,#a78bfa);"></div>

        <div style="padding:1.1rem 1.2rem 1.2rem;">
          <!-- Header -->
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:10px;">
            <div style="display:flex;align-items:center;gap:10px;">
              <!-- Icono escudo -->
              <div style="width:38px;height:38px;border-radius:10px;background:rgba(59,130,246,0.15);border:1px solid rgba(59,130,246,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="20" height="20" fill="none" stroke="#60a5fa" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <p style="font-size:0.65rem;font-weight:700;color:#60a5fa;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 2px;">Curso disponible</p>
                <p style="font-size:0.95rem;font-weight:800;color:white;margin:0;line-height:1.2;">Curso Wazuh en español</p>
              </div>
            </div>
            <!-- Botón cerrar -->
            <button id="wazuh-popup-close" aria-label="Cerrar" style="
              background:rgba(255,255,255,0.07);border:none;color:rgba(255,255,255,0.5);
              width:26px;height:26px;border-radius:50%;cursor:pointer;
              display:flex;align-items:center;justify-content:center;
              font-size:0.8rem;flex-shrink:0;transition:background 0.2s,color 0.2s;
            ">✕</button>
          </div>

          <!-- Descripción -->
          <p style="font-size:0.8rem;color:rgba(255,255,255,0.65);line-height:1.5;margin:0 0 10px;">
            Instalación completa, agentes Windows/Linux, reglas personalizadas y cumplimiento del <strong style="color:rgba(255,255,255,0.85);">ENS</strong>. Todo desde cero.
          </p>

          <!-- Pills de contenido -->
          <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px;">
            <span style="font-size:0.65rem;font-weight:600;padding:3px 8px;border-radius:20px;background:rgba(59,130,246,0.12);border:1px solid rgba(59,130,246,0.25);color:#93c5fd;">Instalación</span>
            <span style="font-size:0.65rem;font-weight:600;padding:3px 8px;border-radius:20px;background:rgba(167,139,250,0.12);border:1px solid rgba(167,139,250,0.25);color:#c4b5fd;">Reglas personalizadas</span>
            <span style="font-size:0.65rem;font-weight:600;padding:3px 8px;border-radius:20px;background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.2);color:#86efac;">ENS</span>
            <span style="font-size:0.65rem;font-weight:600;padding:3px 8px;border-radius:20px;background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);color:#fde68a;">Acceso permanente</span>
          </div>

          <!-- Precio + CTA -->
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="flex-shrink:0;">
              <span id="wazuh-popup-price" style="font-size:1.4rem;font-weight:900;color:white;">50€</span>
              <span style="font-size:0.7rem;color:rgba(255,255,255,0.4);margin-left:4px;">pago único</span>
            </div>
            <a href="/curso-wazuh" style="
              flex:1;display:flex;align-items:center;justify-content:center;gap:6px;
              padding:9px 14px;border-radius:10px;
              background:linear-gradient(135deg,#2563eb,#1d4ed8);
              color:white;font-size:0.8rem;font-weight:700;
              text-decoration:none;
              transition:opacity 0.2s,transform 0.15s;
              box-shadow:0 4px 16px rgba(37,99,235,0.4);
            " onmouseover="this.style.opacity='0.9';this.style.transform='scale(1.02)'" onmouseout="this.style.opacity='1';this.style.transform='scale(1)'">
              Ver el curso
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- JS popup Wazuh -->
    {isWazuh && (
      <script is:inline>
        (function () {
          var STORAGE_KEY = 'wazuh-popup-dismissed';
          if (localStorage.getItem(STORAGE_KEY)) return;

          var popup = document.getElementById('wazuh-course-popup');
          var closeBtn = document.getElementById('wazuh-popup-close');
          if (!popup) return;

          function showPopup() {
            popup.style.opacity = '1';
            popup.style.transform = 'translateY(0) scale(1)';
            popup.style.pointerEvents = 'all';
            popup.setAttribute('aria-hidden', 'false');
          }

          function hidePopup() {
            popup.style.opacity = '0';
            popup.style.transform = 'translateY(24px) scale(0.95)';
            popup.style.pointerEvents = 'none';
            popup.setAttribute('aria-hidden', 'true');
            localStorage.setItem(STORAGE_KEY, '1');
          }

          setTimeout(showPopup, 4000);

          if (closeBtn) {
            closeBtn.addEventListener('click', hidePopup);
          }

          // Cerrar también al hacer click en el CTA (ya van al curso, no molesta)
          var cta = popup.querySelector('a[href="/curso-wazuh"]');
          if (cta) {
            cta.addEventListener('click', function () {
              localStorage.setItem(STORAGE_KEY, '1');
            });
          }
        })();
      </script>
    )}

  </body>
</html>

<script>
  // Añadir botón de copiar a cada bloque de código y aplicar color
  document.addEventListener('DOMContentLoaded', () => {
    const codeBlocks = document.querySelectorAll('article pre');

    codeBlocks.forEach((block) => {
      // Aplicar color al código
      const codeElement = block.querySelector('code');
      if (codeElement) {
        codeElement.style.color = '#64abd3';
      }

      // Crear botón de copiar
      const copyButton = document.createElement('button');
      copyButton.textContent = '📋 Copiar código';
      copyButton.className = 'copy-button';
      copyButton.setAttribute('aria-label', 'Copiar código');

      // Añadir evento de click
      copyButton.addEventListener('click', async () => {
        const code = block.querySelector('code');
        const text = code?.textContent || '';

        try {
          await navigator.clipboard.writeText(text);
          copyButton.textContent = '✓ ¡Código copiado!';
          copyButton.classList.add('copied');

          // Volver al estado original después de 2 segundos
          setTimeout(() => {
            copyButton.textContent = '📋 Copiar código';
            copyButton.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Error al copiar:', err);
        }
      });

      // Insertar el botón justo después del bloque de código
      block.parentNode?.insertBefore(copyButton, block.nextSibling);
    });

    // También aplicar color al código inline
    const inlineCodes = document.querySelectorAll('article :not(pre) > code');
    inlineCodes.forEach((code) => {
      code.style.color = '#64abd3';
    });
  });
</script>

<style>
  /* Mejoras adicionales para el contenido del artículo */
  article img {
    margin: 2rem auto;
  }

  article pre {
    overflow-x: auto;
    padding: 1.5rem; /* Padding uniforme */
  }

  /* Efecto de brillo sutil en los bloques de código */
  article pre::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.5), transparent);
  }

  .prose pre code {
    font-size: 0.9em !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    color: #64abd3 !important;
  }

  /* Código inline (fuera de pre) */
  .prose :not(pre) > code {
    color: #64abd3 !important;
  }

  article pre code {
    font-size: 0.9em !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    color: #64abd3 !important;
  }

  /* Código inline con mejor visibilidad */
  article :not(pre) > code {
    font-weight: 500;
    box-shadow: 0 0 0 1px rgba(16, 185, 129, 0.2);
  }

  /* Mejorar títulos H2 con gradiente sutil */
  article h2 {
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.1), transparent);
    padding-left: 0.75rem;
    margin-left: -0.75rem;
  }

  /* Listas con mejor espaciado */
  article ul li,
  article ol li {
    padding-left: 0.5rem;
  }

  article ul li::marker {
    color: rgba(59, 130, 246, 0.7);
  }

  /* Botón de copiar código */
  .copy-button {
    padding: 0.625rem 1rem;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.5rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .copy-button:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.9);
    transform: translateX(4px);
  }

  .copy-button:active {
    transform: translateX(2px);
  }

  .copy-button.copied {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.3);
    color: rgba(16, 185, 129, 0.9);
  }

  .copy-button.copied:hover {
    background: rgba(16, 185, 129, 0.15);
    border-color: rgba(16, 185, 129, 0.4);
  }
</style>
