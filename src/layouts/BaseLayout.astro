---
import BaseHead from "../components/BaseHead.astro";
import Navigation from "../components/global/Navigation.astro";
import Footer from "../components/global/Footer.astro";
import Mascot from "../components/global/Mascot.astro";
import GoogleAnalytics from "../components/global/GoogleAnalytics.astro";
import LanguageBanner from "../components/global/LanguageBanner.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import {
  getLocaleFromPath,
  stripLocale,
  localizePath,
  hasTranslation,
} from "../i18n/config";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = "https://aisecurity.es/og-image.png"
} = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const canonicalPath = stripLocale(Astro.url.pathname);
const showAlternates = hasTranslation(canonicalPath);
const esUrl = new URL(canonicalPath, Astro.site).href;
const enUrl = new URL(localizePath(canonicalPath, "en"), Astro.site).href;
---

<html
  lang={locale}
  class="scroll-smooth selection:bg-accent-500 selection:text-white no-touchevents hydrated">
  <head>
    <GoogleAnalytics />
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
    />
    {showAlternates && (
      <>
        <link rel="alternate" hreflang="es" href={esUrl} />
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="x-default" href={esUrl} />
      </>
    )}
    <slot name="head" />
  </head>
  <body class="bg-base-50 flex flex-col min-h-svh">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KG5KMRL8"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <LanguageBanner />
    <Navigation />
    <main class="grow"><slot /></main>
    <Footer />
    <Mascot />
    <Analytics />
    <SpeedInsights />
    <!-- WebMCP: expone acciones del sitio a agentes IA via navigator.modelContext -->
    <script is:inline>
      (function () {
        if (typeof navigator === 'undefined' || !navigator.modelContext) return;
        try {
          navigator.modelContext.provideContext({
            tools: [
              {
                name: 'request-consultation',
                description: 'Solicitar una consulta gratuita con AI Security sobre servicios de IA o ciberseguridad para tu empresa',
                inputSchema: {
                  type: 'object',
                  properties: {
                    service: {
                      type: 'string',
                      description: 'Servicio de interés: chatbot, gestor-documental, gestor-citas, atencion-llamadas, automatizacion, wazuh, soporte-tecnico'
                    }
                  }
                },
                execute: function (params) {
                  var url = 'https://aisecurity.es/reunion';
                  if (params && params.service) url += '?servicio=' + encodeURIComponent(params.service);
                  window.location.href = url;
                  return { success: true, url: url };
                }
              },
              {
                name: 'view-services',
                description: 'Ver el catálogo completo de servicios de IA y ciberseguridad de AI Security',
                inputSchema: { type: 'object', properties: {} },
                execute: function () {
                  window.location.href = 'https://aisecurity.es/';
                  return { success: true, url: 'https://aisecurity.es/' };
                }
              }
            ]
          });
        } catch (e) {}
      })();
    </script>
  </body>
</html>
