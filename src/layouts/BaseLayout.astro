---
import BaseHead from "../components/BaseHead.astro";
import Navigation from "../components/global/Navigation.astro";
import Footer from "../components/global/Footer.astro";
import Mascot from "../components/global/Mascot.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = "https://aisecurity.es/og-image.png"
} = Astro.props;
---

<html
  lang="es"
  class="scroll-smooth selection:bg-accent-500 selection:text-white no-touchevents hydrated">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KG5KMRL8');</script>
    <!-- End Google Tag Manager -->
    <!-- Microsoft Clarity -->
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "w9l643hh32");
    </script>
    <!-- End Microsoft Clarity -->
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
    />
    <slot name="head" />
  </head>
  <body class="bg-base-50 flex flex-col min-h-svh">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KG5KMRL8"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Navigation />
    <main class="grow"><slot /></main>
    <Footer />
    <Mascot />
    <Analytics />
    <SpeedInsights />
    <!-- GA4 directo (sin depender de GTM para eventos custom) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-QZ1G3QDQCC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QZ1G3QDQCC', { send_page_view: false });
    </script>
    <!-- Tracking global de clics para GA4 -->
    <script is:inline>
    (function () {
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      function sendEvent(name, params) {
        gtag('event', name, params);
      }

      function getCategory(href) {
        if (!href) return 'ui';
        if (href.includes('/reunion'))         return 'lead';
        if (href.includes('/contacto'))        return 'lead';
        if (href.includes('/abrir-ticket'))    return 'lead';
        if (href.includes('mailto:'))          return 'email';
        if (href.includes('tel:'))             return 'phone';
        if (href.includes('/curso-wazuh'))     return 'curso';
        if (href.includes('/wazuh'))           return 'wazuh';
        if (href.includes('/soporte-tecnico')) return 'soporte';
        if (href.includes('/servicios/'))      return 'servicio';
        if (href.includes('/blog'))            return 'blog';
        if (href.includes('stripe.com') || href.includes('buy.stripe')) return 'pago';
        if (href.startsWith('http') && !href.includes('aisecurity.es')) return 'externo';
        return 'navegacion';
      }

      document.addEventListener('click', function (e) {
        var el = e.target.closest('a, button');
        if (!el) return;

        var tag      = el.tagName.toLowerCase();
        var href     = el.getAttribute('href') || '';
        var label    = (el.textContent || el.getAttribute('aria-label') || '').trim().replace(/\s+/g, ' ').slice(0, 100);
        var category = getCategory(href);
        var page     = window.location.pathname;

        if (tag === 'a' && href) {
          sendEvent('click_link', {
            event_category: category,
            event_label: label,
            link_url: href,
            page_path: page,
          });
          if (category === 'lead' || category === 'email' || category === 'phone') {
            sendEvent('conversion_click', {
              event_category: category,
              event_label: label,
              page_path: page,
            });
          }
        } else if (tag === 'button') {
          sendEvent('click_button', {
            event_category: category,
            event_label: label,
            page_path: page,
          });
        }
      }, true);

      document.addEventListener('submit', function (e) {
        var form = e.target;
        var id   = form.id || form.getAttribute('name') || form.action || 'form';
        sendEvent('form_submit', {
          event_category: 'lead',
          event_label: id,
          page_path: window.location.pathname,
        });
        sendEvent('conversion_form', {
          event_category: 'lead',
          event_label: id,
        });
      }, true);
    })();
    </script>
    <!-- WebMCP: expone acciones del sitio a agentes IA via navigator.modelContext -->
    <script is:inline>
      (function () {
        if (typeof navigator === 'undefined' || !navigator.modelContext) return;
        try {
          navigator.modelContext.provideContext({
            tools: [
              {
                name: 'request-consultation',
                description: 'Solicitar una consulta gratuita con AI Security sobre servicios de IA o ciberseguridad para tu empresa',
                inputSchema: {
                  type: 'object',
                  properties: {
                    service: {
                      type: 'string',
                      description: 'Servicio de interés: chatbot, gestor-documental, gestor-citas, atencion-llamadas, automatizacion, wazuh, soporte-tecnico'
                    }
                  }
                },
                execute: function (params) {
                  var url = 'https://aisecurity.es/reunion';
                  if (params && params.service) url += '?servicio=' + encodeURIComponent(params.service);
                  window.location.href = url;
                  return { success: true, url: url };
                }
              },
              {
                name: 'view-services',
                description: 'Ver el catálogo completo de servicios de IA y ciberseguridad de AI Security',
                inputSchema: { type: 'object', properties: {} },
                execute: function () {
                  window.location.href = 'https://aisecurity.es/';
                  return { success: true, url: 'https://aisecurity.es/' };
                }
              }
            ]
          });
        } catch (e) {}
      })();
    </script>
  </body>
</html>
