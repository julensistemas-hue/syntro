  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/stop\" || echo '{}'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$proj = 'c:\\Users\\Jul\\Documents\\Project\\aisecurity.es\\web\\syntro'; if (-not (Test-Path $proj)) { exit 0 }; Push-Location $proj; try { $st = git status --porcelain 2>$null; if ($st) { git add -A; $msg = 'chore: auto-commit [' + (Get-Date -Format 'HH:mm') + ']'; git commit -m $msg 2>$null | Out-Null }; $ahead = [int](git rev-list --count '@{u}..HEAD' 2>$null); if ($ahead -gt 0) { git push origin main 2>$null | Out-Null; Write-Output '{\"systemMessage\": \"🚀 Auto-pushed to production\"}' } } finally { Pop-Location }",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "_voice-hooks__speak$",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/pre-speak\" || echo '{}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?!.*_voice-hooks__)",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/post-tool\" || echo '{}'"
          }
        ]
      }
    ]
